; Nucleus self-hosted compiler
; Reads a .nuc source file and emits textual LLVM IR to stdout.

(include stdio)
(include string)
(include ctype)
(include unistd)
(import llvm)

; REPL shim FFI — declared up-front because reader.nuc and emit-* sites in
; this file call repl_throw on errors when running under the REPL. The
; implementations live in src/repl_shim.c; the rest of the REPL is in
; src/repl.nuc, source-imported below.
(declare repl_try:i32 ())
(declare repl_throw:void ())
(declare repl_print_f64:void (ptr))
(declare repl_print_f32:void (ptr))

(extern stderr:ptr)
(extern stdout:ptr)
(extern stdin:ptr)

; ============================================================
; Constants
; ============================================================

(defconst MAX-STRUCTS 64)
(defconst MAX-CAST-RULES 256)

; Token kinds
(defenum TokKind TOK-LPAREN TOK-RPAREN TOK-RMACRO TOK-INT TOK-STRING TOK-SYMBOL TOK-FLOAT TOK-EOF)

; Name kinds for the one-symbol-one-meaning shadowing check (see
; name-existing-kind / guard-name-kind). Ordered by lookup priority.
(defconst NK-NONE 0)
(defconst NK-SPECIAL 1)
(defconst NK-BUILTIN 2)   ; a primitive/built-in type name (i32, ptr, ...)
(defconst NK-TYPE 3)      ; a struct type
(defconst NK-PROTOCOL 4)
(defconst NK-MACRO 5)
(defconst NK-FUNCTION 6)
(defconst NK-VALUE 7)     ; defvar / defconst / defenum member / extern

; Node struct and NODE-* kinds come from lib/prelude.nuc (imported below).

; Type kinds. TY-TYVAR is an abstract type variable used only by the Stage 9
; rung-4 A2 def-time check of generic bodies; it never reaches codegen (generic
; templates emit only after monomorphization, where every type is concrete).
; TY-CSTR is a C-style (null-terminated) string — ABI-identical to a `char*`
; pointer (lowers to `ptr`), distinct only so `=`/`!=` dispatch to a `strcmp`
; content comparison (Eq) instead of pointer identity. Unicode is out of scope.
(defenum TypeKind TY-VOID TY-I1 TY-I8 TY-I16 TY-I32 TY-I64
                  TY-UI8 TY-UI16 TY-UI32 TY-UI64
                  TY-PTR TY-FN TY-STRUCT
                  TY-F32 TY-F64 TY-TYVAR TY-CSTR)

; Pointer kinds (Stage 10 nullability, design/stage10/nullability.md). A
; compile-time contract carried on TY-PTR types; all three lower to IR `ptr`
; and are ABI-identical. PTR-RAW is the default (today's unchecked pointer);
; PTR-REF is non-null; PTR-MAYBE is nullable-checked (deref forbidden until
; narrowed). The kind is deliberately ignored by type-eq / hash-type /
; type-mangle-token (like is-volatile), so dispatch, monomorphization, and
; emitted IR are unaffected — only the flow checks read it.
(defconst PTR-RAW 0)
(defconst PTR-REF 1)
(defconst PTR-MAYBE 2)

; ============================================================
; Struct definitions (ordered by dependency)
; ============================================================

(defstruct StructDef
  name:CStr
  field-names:ptr
  field-types:ptr
  num-fields:i32
  emitted:i32       ; type definition already written to IR (vs. name-only pre-registration)
  src-file:ptr      ; source file where defined (cheader/anon struct provenance)
  src-line:i32)

(defstruct Type
  kind:i32
  ret:ptr
  params:ptr
  num-params:i32
  variadic:i32
  has-rest:i32
  elem:ptr
  sdef:ptr
  ; --- Stage 8 additions ---
  nopt:i32          ; number of trailing &optional params (TY-FN)
  opt-defaults:ptr  ; array of ptr:Node default-value forms for the &optional params
  ; Parallel array to `params`: each entry is a `ptr` to the param's declared
  ; name (arena-owned C string), or null if unknown. Used by the REPL to render
  ; real parameter names instead of positional pN.
  param-names:ptr
  ; Volatile qualifier: when set, loads/stores at this type's storage site are
  ; emitted as `load volatile`/`store volatile`. Primitive singletons are shared,
  ; so volatility is represented by cloning the Type via type-with-volatile.
  is-volatile:i32
  ; Pointer kind (Stage 10): PTR-RAW / PTR-REF / PTR-MAYBE for TY-PTR.
  ; Shared Types are never mutated — clone via type-as-pkind.
  pkind:i32)

(defstruct Tok
  kind:i32
  line:i32
  i:i64
  s:ptr)

; Node struct comes from lib/prelude.nuc (imported below).

(defstruct Sym
  name:CStr
  type:ptr
  ir-name:ptr
  is-local:i32
  is-const:i32
  const-val:ptr
  tracker:ptr
  ; --- Stage 8 / REPL introspection additions ---
  src-file:ptr      ; source file where defined (null if unknown)
  src-line:i32      ; source line where defined (0 if unknown)
  trace-tracker:ptr ; resource tracker for a REPL-installed trace wrapper
  trace-saved:ptr   ; saved original ir-name while traced
  ; Docstring captured from a defn whose body's first form is a string literal
  ; (with at least one form following it). null otherwise. Used by REPL doc/apropos.
  docstring:ptr
  ; --- Stage 10 safety (lifecycle + nullability) ---
  home:ptr          ; defining Scope* (escape analysis compares scope nesting)
  taint:ptr         ; owning with-Scope* whose resource this value aliases (null = clean)
  owns:i32          ; 1 = this binding armed a `with` cleanup (owning binding)
  moved:i32         ; 1 = consumed by (move ...); any further use is an error
  cslot:ptr         ; cleanup slot IR name when owns=1 (move disarms by storing null)
  ntype:ptr         ; flow-narrowed type override (?T read as (ref T)); null = none
  ndepth:i32        ; g-loop-depth at which the current narrow was established
  kstamp:i32)       ; bumped on each kill (reassignment); stale undo entries skip

; One armed scope-exit cleanup (Stage 10 lifecycle, design/stage10/lifecycle.md).
; Exactly one shape is set: legacy libc free (only slot), a Drop-protocol call
; (slot + drop-*), or an ad-hoc (defer expr) re-emitted at each exit path.
(defstruct Cleanup
  slot:ptr        ; alloca slot holding the resource pointer (free/drop)
  drop-fn:ptr     ; IR name of the resolved drop method (Drop cleanups)
  drop-ty:ptr     ; declared binding Type* (Drop cleanups)
  drop-ret:ptr    ; drop method return Type* (Drop cleanups)
  defer-node:ptr  ; retained expression AST (defer cleanups)
  defer-scope:ref:Scope); scope in which defer-node is re-emitted

; A narrowing undo entry (Stage 10 nullability §4). Restores are skipped when
; the binding's kstamp moved past `stamp` — a kill (reassignment) is sticky.
(defstruct NarrowUndo
  name:ptr
  scope:ref:Scope
  old-ntype:ptr
  old-ndepth:i32
  stamp:i32)

(defstruct Scope
  parent:ptr
  syms:ptr
  len:i32
  cap:i32
  cleanup-slots:ptr
  ncleanups:i32
  ccleanups:i32)

(defstruct StrLit
  bytes:ptr
  len:i32
  id:i32)

(defstruct Val
  type:ptr
  val:ptr
  ; Stage 10 escape analysis: owning with-Scope* this value aliases (null =
  ; clean). Propagated through identity-preserving ops (cast, ptr+, .&, phi);
  ; dropped by value-copying ops (deref, field load, calls).
  taint:ptr)

; ---- Aggregate ABI lowering (Stage 8 Phase C, x86_64 System V) ----
; How a struct-by-value parameter or return is lowered to the platform C ABI.
; Only TY-STRUCT is ever non-DIRECT, so every scalar/pointer path is unchanged.
;   ABI-DIRECT  — passed/returned as-is (all scalars, pointers).
;   ABI-MEMORY  — >16 bytes: param is `ptr byval(%T)`, return is `sret` (hidden
;                 leading pointer param, function returns void).
;   ABI-COERCE1 — ≤8 bytes: one eightbyte, coerced to reg0 (e.g. i64/double).
;   ABI-COERCE2 — 9..16 bytes: two eightbytes reg0,reg1; return is {reg0,reg1}.
(defenum AbiKind ABI-DIRECT ABI-MEMORY ABI-COERCE1 ABI-COERCE2)

(defstruct AbiInfo
  kind:i32     ; AbiKind
  reg0:ptr     ; IR type string for eightbyte 0 (COERCE1/COERCE2), else null
  reg1:ptr     ; IR type string for eightbyte 1 (COERCE2), else null
  size:i32     ; struct ABI size in bytes (MEMORY/COERCE)
  align:i32)   ; struct ABI alignment in bytes (MEMORY/COERCE)

(defstruct BinOp
  name:ptr
  instr:ptr
  instr-u:ptr
  is-cmp:i32)

; ---- Polymorphism (Stage 9) ----
; A Generic is a named set of Methods sharing one source name. Operators are
; seeded as intrinsic generics (see init-generics); user defns add methods.
; Dispatch among concrete methods is on the whole argument tuple.
(defenum MethodKind METHOD-INTRINSIC METHOD-USER METHOD-GENERIC)

(defstruct Method
  param-types:ptr   ; ptr to array of ptr:Type (length num-params); null for intrinsic
  num-params:i32
  ret-type:ptr      ; ptr:Type; null for intrinsic
  has-rest:i32
  variadic:i32
  kind:i32          ; one of MethodKind
  ir-name:ptr       ; emitted symbol "@name..." (user methods); null otherwise
  fn-type:ptr       ; ptr:Type (TY-FN) for user methods; null otherwise
  binop:ptr         ; ptr:BinOp (intrinsic operators); null otherwise
  body:ptr          ; retained defn form (generic methods); null otherwise
  ; --- METHOD-GENERIC only (Stage 9 rung 4): a bounded generic defn template ---
  tyvars:ptr        ; array of ptr (distinct type-variable name strings)
  num-tyvars:i32
  con-protos:ptr    ; array of ptr (protocol name per &where constraint)
  con-vars:ptr      ; array of ptr (type-variable name per constraint; parallel)
  num-constraints:i32
  checked:i32)      ; A2 def-time check done (so it runs once per template)

(defstruct Generic
  name:CStr
  methods:ptr       ; ptr to array of ptr:Method
  num-methods:i32
  cap:i32
  finalized:i32     ; mangling decided + solitary scope binding established
  mangled:i32)      ; 0 = solitary, unmangled @name (C-callable); 1 = mangled set

; A Protocol names a capability: a set of required method signatures whose
; parameter/return types may mention `Self`. It is purely compile-time and
; emits no code. `extend Type Protocol` substitutes Self→Type in each signature
; and verifies a matching concrete method exists (see emit-extend).
(defstruct Protocol
  name:CStr
  sigs:ptr          ; ptr to array of ptr:Node, each a (name:ret (params...)) form
  num-sigs:i32)

; A recorded (Type, Protocol) conformance fact. No code; consulted by the
; resolver (protocol-bound tier, later) and exported in .nuch.
(defstruct Conformance
  type-name:CStr
  proto-name:CStr)

; A queued generic instantiation: the stamped concrete defn form awaiting body
; emission, plus a human-readable context ("while instantiating @name.toks…
; requested at file:line") attached to any compile error raised while emitting it.
(defstruct MonoJob
  form:ptr
  context:ptr)

(defstruct Vec
  data:ptr
  len:i32
  cap:i32)

(defstruct MacroDef
  name:CStr
  jit-name:ptr
  num-params:i32
  variadic:i32
  ; --- Stage 8 / REPL introspection additions ---
  src-file:ptr
  src-line:i32
  ; Docstring captured from a defmacro whose body's first form is a string
  ; literal (with at least one form following it). null otherwise.
  docstring:ptr
  ; Parameter names array (parallel to the user-declared param list, minus
  ; &rest/&optional keywords) for tooling. null if not captured.
  param-names:ptr)

(defstruct RMacro
  prefix:ptr
  prefix-len:i32
  wrap-sym:ptr)

; A label declaration within the current function (Stage 8 goto support).
; `total` is the number of (label NAME) occurrences seen in the pre-scan;
; `seen` counts how many have been emitted so the last one wins the live BB.
(defstruct LabelEntry
  name:ptr
  total:i32
  seen:i32)

; A user-asserted implicit conversion (defcast From To conv-fn). Applied at call
; sites by safe-coerce-val when an argument's type differs from the parameter's.
(defstruct CastRule
  from:ptr
  to:ptr
  ir-name:ptr)

; A resolved compilation target (Stage 8 cross-compilation). datalayout and
; ptr-size come from LLVM for `triple`, so emitted IR matches the target ABI.
(defstruct Target
  triple:ptr
  datalayout:ptr
  ptr-size:i32
  ptr-align:i32)


; ============================================================
; Global variables
; ============================================================

; g-arena, g-arena-used, g-arena-cap are defined by lib/arena.nuc.

(defvar g-source-path:ptr)

(defvar g-src:ptr)
(defvar g-pos:i64 0)
(defvar g-line:i32 1)

(defvar g-peek:ptr)
(defvar g-peek-valid:i32 0)

; Singleton types
(defvar ty-void:ref:Type)
(defvar ty-i1:ref:Type)
(defvar ty-i8:ref:Type)
(defvar ty-i16:ref:Type)
(defvar ty-i32:ref:Type)
(defvar ty-i64:ref:Type)
(defvar ty-ptr:ref:Type)
(defvar ty-ui8:ref:Type)
(defvar ty-ui16:ref:Type)
(defvar ty-ui32:ref:Type)
(defvar ty-ui64:ref:Type)
(defvar ty-f32:ref:Type)
(defvar ty-f64:ref:Type)
(defvar ty-cstr:ref:Type)
; Stage 10: the type of `none` — an elem-less (Maybe (ref ?)) that coerces
; into any concrete ?T slot exactly as `null` coerces into any (ptr T).
(defvar ty-maybe-ptr:ref:Type)

; Target descriptor. The compiler emits code for a single target, described
; here so the "a pointer is i64" assumption lives in one place instead of being
; scattered as literal 8s / i64s through codegen. Set in compiler-init; defaults
; describe x86_64 Linux. To target a 32-bit platform, set g-target-ptr-bytes to
; 4 (and g-target-triple accordingly) — type sizes, alignments, sizeof, and the
; size/pointer-sized integer type all follow. (The macro/CT JIT still runs on
; the host, so its target machine stays the host triple.)
(defvar g-target-triple:ptr)
(defvar g-target-ptr-bytes:i32 8)

; Stage 8 cross-compilation: g-target is the resolved Target (triple + datalayout
; + pointer size from LLVM). g-host-target is always the native platform — the
; macro/CT JIT runs in-process, so its modules use the host. g-target-triple and
; g-target-ptr-bytes (above) are derived from g-target so the rest of codegen,
; which predates the Target struct, keeps working unchanged. The override is set
; by --target=<triple>; null means "use the host".
(defvar g-target:ptr)
(defvar g-host-target:ptr)
(defvar g-target-triple-override:ptr)

; Host pointer size in bytes — the platform the compiler itself runs on, used to
; size its own arrays-of-pointers. Distinct from g-target-ptr-bytes (the
; platform being compiled *for*): when cross-compiling they differ. Initialised
; from (sizeof ptr) in compiler-init; the literal default covers allocations
; before init runs.
(defvar g-host-ptr-bytes:i32 8)

; Struct registry
(defvar g-structs:ptr)
(defvar g-structs-len:i32 0)

; Global scope
(defvar g-globals:ref:Scope)

; String literal table
(defvar g-strs:ptr)
(defvar g-strs-len:i32 0)
(defvar g-strs-cap:i32 0)

; Per-function codegen state
(defvar g-tmp:i32 0)
(defvar g-label:i32 0)
(defvar g-entry-stream:ptr)
(defvar g-entry-bufp:ptr)
(defvar g-entry-sizep:i64 0)
(defvar g-body-stream:ptr)
(defvar g-body-bufp:ptr)
(defvar g-body-sizep:i64 0)
(defvar g-block-term:i32 0)

; defcast registry (Stage 8). g-cast-rules is a pre-allocated array of CastRule
; (length MAX-CAST-RULES), filled by register-cast-rule from `defcast` forms.
(defvar g-cast-rules:ptr)
(defvar g-cast-rules-len:i32 0)

; Label/goto support (Stage 8 C-parity). g-lbl-tbl is a Vec of LabelEntry*
; (name, total occurrence count, seen-so-far) reset per function by
; reset-function-state. g-cur-fname is the @-less IR symbol of the function
; currently being emitted (for blockaddress in label-addr).
(defvar g-lbl-tbl:ptr)
(defvar g-cur-fname:ptr)

; Aggregate return ABI of the function currently being emitted (Stage 8 Phase C).
; g-fn-ret-abi is its AbiInfo* (ABI-DIRECT for scalar/pointer returns); when the
; return is ABI-MEMORY, g-fn-sret-name is the IR name of the hidden sret pointer
; param. Both reset by reset-function-state and set in emit-defn.
(defvar g-fn-ret-abi:ptr)
(defvar g-fn-sret-name:ptr)

; --- Stage 10 safety: per-function checking state ---
; Declared return Type* of the function being emitted (pointer-kind check on
; `return`); the loop-nesting depth and the narrowing undo stack (see the
; "flow narrowing" section); whether `declare void @llvm.trap()` has been
; written to the decl stream (lazy, used by `unwrap`).
(defvar g-fn-ret-type:ptr)
(defvar g-loop-depth:i32 0)
(defvar g-nundo:ptr)
(defvar g-trap-declared:i32 0)

; Current output stream for top-level emission
(defvar g-out:ptr)
(defvar g-decl-out:ptr)
(defvar g-qq-used:i32 0)

; Main module streams (global so emit-compile-time can access them mid-compilation)
(defvar g-type-stream:ptr)
(defvar g-decl-stream:ptr)
(defvar g-def-stream:ptr)
(defvar g-type-bufp:ptr)
(defvar g-decl-bufp:ptr)
(defvar g-def-bufp:ptr)
(defvar g-type-sizep:i64 0)
(defvar g-decl-sizep:i64 0)
(defvar g-def-sizep:i64 0)

; JIT state
(defvar g-jit:ptr)
(defvar g-jit-dylib:ptr)
(defvar g-ct-id:i32 0)

; BinOp table
(defvar g-binops:ptr)
(defvar g-num-binops:i32 0)

; Generic (polymorphism) registry
(defvar g-generics:ptr)
(defvar g-num-generics:i32 0)
(defvar g-cap-generics:i32 0)

; Monomorphization worklist (Stage 9 rung 4): stamped concrete defn forms
; awaiting emission. Generic calls resolve + register an instantiation eagerly
; (so the call site can name its symbol) but defer the body emission until the
; current function finishes; the worklist is drained at the end of the top-level
; loop. g-mono-drained is a persistent cursor so recursive drains never re-emit.
(defvar g-mono-worklist:ptr)
(defvar g-mono-drained:i32 0)
; Set to the current instantiation's context string while a stamped generic body
; is being emitted; die-at appends it as a note so a stamp-time error points back
; to the instantiation (and its requesting call site). Null otherwise.
(defvar g-mono-context:ptr)
; Nesting depth of emit-toplevel-forms (imports recurse). The A2 generic-body
; check runs only at the outermost level — after every import has registered its
; names and with g-source-path restored to the unit being compiled.
(defvar g-toplevel-depth:i32 0)

; Protocol / conformance registries (Stage 9 rung 2)
(defvar g-protocols:ptr)
(defvar g-num-protocols:i32 0)
(defvar g-cap-protocols:i32 0)
(defvar g-conformances:ptr)
(defvar g-num-conformances:i32 0)
(defvar g-cap-conformances:i32 0)
; Protocol inheritance edges (Stage 9 §10.3): `(extend Ord Eq)` records that
; conforming to Ord additionally requires conforming to Eq. Reuses the
; Conformance layout: type-name = sub-protocol, proto-name = required super.
(defvar g-proto-supers:ptr)
(defvar g-num-proto-supers:i32 0)
(defvar g-cap-proto-supers:i32 0)

; Blanket protocols (Stage 9 §10.1): built-in protocols with automatic
; conformance — `Any` (every type) and `Struct` (every struct type). Stored as a
; small set of names plus a per-name predicate baked into blanket-conforms.
(defvar g-blanket:ptr)
(defvar g-num-blanket:i32 0)

; Macro registry
(defvar g-macros:ptr)
(defvar g-num-macros:i32 0)
(defvar g-gensym-id:i32 0)

; Reader macro table
(defvar g-rmacros:ptr)
(defvar g-num-rmacros:i32 0)

; Set to 1 once @malloc has been declared via emit-include (e.g. from (include stdlib)).
; Guards against emitting a duplicate malloc declaration in macro JIT modules.
(defvar g-malloc-decl-done:i32 0)

; Compiler mode flags.
(defvar g-emit-nuch:i32 0)    ; when 1, output .nuch header instead of LLVM IR
(defvar g-emit-cheader:i32 0) ; when 1, output C header instead of LLVM IR
(defvar g-emit-llvm:i32 0)    ; when 1, output textual LLVM IR to stdout instead of a binary
(defvar g-emit-obj:i32 0)     ; when 1 (-c), emit a .o file instead of linking a binary
(defvar g-output-path:ptr)    ; -o <path>; null = default ("a.out")
(defvar g-link-args:ptr)      ; argv-style array of pass-through args appended to the link line
(defvar g-num-link-args:i32 0)
(defvar g-interactive:i32 0)  ; when 1, run in REPL mode (-i / --interactive)
(defvar g-repl-format:i32 0)  ; 0 = text (default), 1 = json (one JSON object per error)
(defvar g-opt-level:i32 0)    ; -O0..-O3; LLVMCodeGenOptLevel: None=0, Less=1, Default=2, Aggressive=3

; REPL eval counter (for unique __repl_eval_N symbols).
(defvar g-repl-id:i32 0)

; REPL defn impl counter (for unique <fname>.impl.N symbols when wrapping a
; user-defined function with a thunk so that callers see redefinitions).
(defvar g-defn-impl-counter:i64 0)

; REPL declarations preamble — accumulated declarations and type defs
; that get prepended to each JIT module.
(defvar g-repl-preamble:ptr)
(defvar g-repl-preamble-bufp:ptr)
(defvar g-repl-preamble-sizep:i64 0)

; Import tracking — duplicate guard and cycle detection.
; Each is a linked list of (path-string . next) pairs using Node cells.
(defvar g-imported:ptr)     ; already-imported resolved paths (null = empty)
(defvar g-importing:ptr)   ; currently-importing stack for cycle detection (null = empty)

; Include path list for -I flag
(defvar g-include-paths:ptr)
(defvar g-num-include-paths:i32 0)

; stdlib (malloc/free/exit) is included here — after defmacro and defvar —
; so that g-decl-bufp is free of malloc when macro JIT modules are assembled.
(include stdlib)

; ============================================================
; Arena allocator — imported from lib/arena.nuc
; ============================================================

(import arena)

; ============================================================
; Formatting helpers — imported from lib/format.nuc
; ============================================================

(import format)

; ============================================================
; Node utilities — imported from lib/node.nuc
; ============================================================

(import node)

; ============================================================
; Allocation helpers
; ============================================================

; Arena-backed allocators: arena-alloc aborts on exhaustion, never null.
(defn alloc-tok:ref:Tok ()
  (return (cast ref:Tok (arena-alloc (sizeof Tok)))))

(defn nucleus_gensym:ptr ()
  (let (id:i32 g-gensym-id)
    (inc! g-gensym-id)
    (let (buf:ptr (malloc (cast i64 32))
          n:ptr:Node (cast ptr:Node (malloc (sizeof Node))))
      (snprintf buf (cast i64 32) "__gs_%d" id)
      (memset (cast ptr n) 0 (sizeof Node))
      (.set! n kind (cast i32 NODE-SYM))
      (.set! n s buf)
      (return (cast ptr n)))))

(defn alloc-type:ref:Type ()
  (return (cast ref:Type (arena-alloc (sizeof Type)))))

(defn alloc-val:ref:Val (ty:ptr v:ptr)
  (let (r:ref:Val (cast ref:Val (arena-alloc (sizeof Val))))
    (.set! r type ty)
    (.set! r val v)
    (return r)))

; ============================================================
; Growable pointer vector
; ============================================================

(defn make-vec:ref:Vec ()
  (return (cast ref:Vec (arena-alloc (sizeof Vec)))))

(defn vec-push:void (v:ptr item:ptr)
  (let (vv:ptr:Vec (cast ptr:Vec v))
    (when (= (vv len) (vv cap))
      (let (nc:i32 4)
        (when (!= (vv cap) 0) (set! nc (* (vv cap) 2)))
        (let (nd:ptr (arena-alloc (* (cast i64 nc) (ptr-bytes))))
          (when (!= (vv len) 0)
            (memcpy nd (vv data) (* (cast i64 (vv len)) (ptr-bytes))))
          (.set! vv data nd)
          (.set! vv cap nc))))
    (aset! (cast ptr:ptr (vv data)) (vv len) item)
    (.set! vv len (+ (vv len) 1))))

; ============================================================
; Reader — imported from lib/reader.nuc
; ============================================================

(import reader)

; ============================================================
; AST printer — inverse of the reader, serializes nodes to stdout
; ============================================================

(defn fprint-node:void (out:ptr n:ptr)
  (when (= n null) (fputs "()" out) (return))
  (let (nn:ptr:Node (cast ptr:Node n))
    (case (nn kind)
      NODE-INT
        (fprintf out "%ld" (nn i))
      NODE-FLOAT
        (fputs (nn s) out)
      NODE-SYM
        (fputs (nn s) out)
      NODE-STR
        (do
          (fputc 34 out)
          (let (s:ptr (nn s)
                      i:i64 (cast i64 0)
                      len:i64 (strlen s))
            (while (< i len)
              (let (c:i32 (char-at s i))
                (case c
                  10 (do (fputc 92 out) (fputc 110 out))
                  9  (do (fputc 92 out) (fputc 116 out))
                  13 (do (fputc 92 out) (fputc 114 out))
                  92 (do (fputc 92 out) (fputc 92 out))
                  34 (do (fputc 92 out) (fputc 34 out))
                  0  (do (fputc 92 out) (fputc 48 out))
                  (fputc c out)))
              (set! i (+ i (cast i64 1)))))
          (fputc 34 out))
      NODE-CELL
        (do
          (fputc 40 out)
          (let (cur:ptr n
                        first:i32 1)
            (while (and (!= cur null)
                        (= ((cast ptr:Node cur) kind) NODE-CELL))
              (when (= first 0) (fputc 32 out))
              (set! first 0)
              (fprint-node out ((cast ptr:Node cur) car))
              (set! cur ((cast ptr:Node cur) cdr))))
          (fputc 41 out))
      0)))

(defn print-node:void (n:ptr)
  (fprint-node (cast ptr stdout) n))

; ============================================================
; Types
; ============================================================

(defn make-type:ref:Type (k:i32)
  (let (t:ref:Type (alloc-type))
    (.set! t kind k)
    (return t)))

(defn types-init:void ()
  (set! ty-void (make-type TY-VOID))
  (set! ty-i1   (make-type TY-I1))
  (set! ty-i8   (make-type TY-I8))
  (set! ty-i16  (make-type TY-I16))
  (set! ty-i32  (make-type TY-I32))
  (set! ty-i64  (make-type TY-I64))
  (set! ty-ui8  (make-type TY-UI8))
  (set! ty-ui16 (make-type TY-UI16))
  (set! ty-ui32 (make-type TY-UI32))
  (set! ty-ui64 (make-type TY-UI64))
  (set! ty-f32  (make-type TY-F32))
  (set! ty-f64  (make-type TY-F64))
  (set! ty-cstr (make-type TY-CSTR))
  (set! ty-ptr  (make-type TY-PTR))
  (set! ty-maybe-ptr (make-type TY-PTR))
  (.set! ty-maybe-ptr pkind PTR-MAYBE))

(defn type-to-ir:ptr (t:ptr)
  (let (tt:ptr:Type (cast ptr:Type t))
    (when (= (tt kind) TY-VOID)   (return "void"))
    (when (= (tt kind) TY-I1)     (return "i1"))
    (when (= (tt kind) TY-I8)     (return "i8"))
    (when (= (tt kind) TY-I16)    (return "i16"))
    (when (= (tt kind) TY-I32)    (return "i32"))
    (when (= (tt kind) TY-I64)    (return "i64"))
    (when (= (tt kind) TY-UI8)    (return "i8"))
    (when (= (tt kind) TY-UI16)   (return "i16"))
    (when (= (tt kind) TY-UI32)   (return "i32"))
    (when (= (tt kind) TY-UI64)   (return "i64"))
    (when (= (tt kind) TY-PTR)    (return "ptr"))
    (when (= (tt kind) TY-FN)     (return "ptr"))
    (when (= (tt kind) TY-CSTR)   (return "ptr"))
    (when (= (tt kind) TY-F32)    (return "float"))
    (when (= (tt kind) TY-F64)    (return "double"))
    (when (= (tt kind) TY-STRUCT)
      (return (fmt-s "%%%s" ((cast ptr:StructDef (tt sdef)) name))))
    (return "?")))

; Map a Nucleus type to its C representation string.
; For function pointer types, returns a simplified "void*" — the full
; C function pointer syntax (with return type and params) is handled
; separately in emit-cheader-declare where we have the param names.
(defn type-to-c:ptr (t:ptr)
  (let (tt:ptr:Type (cast ptr:Type t))
    (when (= (tt kind) TY-VOID)   (return "void"))
    (when (= (tt kind) TY-I1)     (return "_Bool"))
    (when (= (tt kind) TY-I8)     (return "int8_t"))
    (when (= (tt kind) TY-I16)    (return "int16_t"))
    (when (= (tt kind) TY-I32)    (return "int32_t"))
    (when (= (tt kind) TY-I64)    (return "int64_t"))
    (when (= (tt kind) TY-UI8)    (return "uint8_t"))
    (when (= (tt kind) TY-UI16)   (return "uint16_t"))
    (when (= (tt kind) TY-UI32)   (return "uint32_t"))
    (when (= (tt kind) TY-UI64)   (return "uint64_t"))
    (when (= (tt kind) TY-PTR)    (return "void*"))
    (when (= (tt kind) TY-FN)     (return "void*"))
    (when (= (tt kind) TY-CSTR)   (return "char*"))
    (when (= (tt kind) TY-F32)    (return "float"))
    (when (= (tt kind) TY-F64)    (return "double"))
    (when (= (tt kind) TY-STRUCT)
      (return (fmt-s "struct %s" ((cast ptr:StructDef (tt sdef)) name))))
    (return "/* unknown */")))

; The IR type of a pointer-sized integer (size_t / intptr_t) for the target.
; All pointer-as-integer codegen routes through this rather than hardcoding i64.
(defn ptr-int-ir:ptr ()
  (if (= g-target-ptr-bytes 4) "i32" "i64"))

; The registered singleton type for a pointer-sized integer on the target.
(defn ptr-int-type:ptr ()
  (if (= g-target-ptr-bytes 4) ty-i32 ty-i64))

; Size in bytes of one host pointer, as an i64 — the element size for the
; compiler's own arrays of pointers. Use instead of a literal 8 so the compiler
; allocates correctly on hosts where a pointer is not 8 bytes.
(defn ptr-bytes:i64 ()
  (cast i64 g-host-ptr-bytes))

(defn type-size:i32 (t:ptr)
  (let (tt:ptr:Type (cast ptr:Type t))
    (when (= (tt kind) TY-I1)   (return 1))
    (when (= (tt kind) TY-I8)   (return 1))
    (when (= (tt kind) TY-I16)  (return 2))
    (when (= (tt kind) TY-I32)  (return 4))
    (when (= (tt kind) TY-I64)  (return 8))
    (when (= (tt kind) TY-UI8)  (return 1))
    (when (= (tt kind) TY-UI16) (return 2))
    (when (= (tt kind) TY-UI32) (return 4))
    (when (= (tt kind) TY-UI64) (return 8))
    (when (= (tt kind) TY-PTR)  (return g-target-ptr-bytes))
    (when (= (tt kind) TY-CSTR) (return g-target-ptr-bytes))
    (when (= (tt kind) TY-F32)  (return 4))
    (when (= (tt kind) TY-F64)  (return 8))
    ; A struct value is laid out by LLVM; we use the pointer alignment as a
    ; conservative slot size/alignment for it (structs are handled by-reference).
    (when (= (tt kind) TY-STRUCT) (return g-target-ptr-bytes))
    (return 1)))

(defn is-int-type:i32 (t:ptr)
  (let (k:i32 ((cast ptr:Type t) kind))
    (when (= k TY-I1) (return 1))
    (when (= k TY-I8) (return 1))
    (when (= k TY-I16) (return 1))
    (when (= k TY-I32) (return 1))
    (when (= k TY-I64) (return 1))
    (when (= k TY-UI8) (return 1))
    (when (= k TY-UI16) (return 1))
    (when (= k TY-UI32) (return 1))
    (when (= k TY-UI64) (return 1))
    (return 0)))

(defn is-float-type:i32 (t:ptr)
  (let (k:i32 ((cast ptr:Type t) kind))
    (when (= k TY-F32) (return 1))
    (when (= k TY-F64) (return 1))
    (return 0)))

; A type whose IR representation is `ptr` and whose ABI is a plain pointer:
; TY-PTR and TY-CSTR (a C-string is a `char*`). They are interconvertible with
; no IR and zero-initialise to `null`. (TY-FN is deliberately excluded — its
; existing call-position handling is unchanged by CStr.)
(defn is-ptr-like:i32 (t:ptr)
  (let (k:i32 ((cast ptr:Type t) kind))
    (when (= k TY-PTR) (return 1))
    (when (= k TY-CSTR) (return 1))
    (return 0)))

(defn int-width:i32 (t:ptr)
  (let (k:i32 ((cast ptr:Type t) kind))
    (when (= k TY-I1) (return 1))
    (when (= k TY-I8) (return 8))
    (when (= k TY-I16) (return 16))
    (when (= k TY-I32) (return 32))
    (when (= k TY-I64) (return 64))
    (when (= k TY-UI8) (return 8))
    (when (= k TY-UI16) (return 16))
    (when (= k TY-UI32) (return 32))
    (when (= k TY-UI64) (return 64))
    (return 0)))

(defn is-unsigned:i32 (t:ptr)
  (let (k:i32 ((cast ptr:Type t) kind))
    (when (= k TY-UI8) (return 1))
    (when (= k TY-UI16) (return 1))
    (when (= k TY-UI32) (return 1))
    (when (= k TY-UI64) (return 1))
    (return 0)))

; ============================================================
; Stage 10: pointer kinds (design/stage10/nullability.md)
; ============================================================

; The pointer kind of a type: the Stage 10 contract for TY-PTR, PTR-RAW for
; everything else (including non-pointers, so callers can probe freely).
(defn ptr-pkind:i32 (t:ptr)
  (when (= t null) (return PTR-RAW))
  (let (tt:ptr:Type (cast ptr:Type t))
    (when (!= (tt kind) TY-PTR) (return PTR-RAW))
    (return (tt pkind))))

; Clone `t` with pkind=k. Typed-pointer Types may be shared (and bare ptr is a
; singleton), so relabeling/narrowing never mutates. Identity when k matches.
(defn type-as-pkind:ptr (t:ptr k:i32)
  (let (src:ptr:Type (cast ptr:Type t))
    (when (= (src pkind) k) (return t))
    (let (dst:ptr:Type (cast ptr:Type (alloc-type)))
      (.set! dst kind        (src kind))
      (.set! dst ret         (src ret))
      (.set! dst params      (src params))
      (.set! dst num-params  (src num-params))
      (.set! dst variadic    (src variadic))
      (.set! dst has-rest    (src has-rest))
      (.set! dst nopt        (src nopt))
      (.set! dst opt-defaults (src opt-defaults))
      (.set! dst elem        (src elem))
      (.set! dst sdef        (src sdef))
      (.set! dst param-names (src param-names))
      (.set! dst is-volatile (src is-volatile))
      (.set! dst pkind       k)
      (return (cast ptr dst)))))

; The conservative meet of two pointer kinds for a control-flow join (cond /
; if-some phi): raw if either side waived the checks, else Maybe if either
; side may be null, else ref.
(defn pkind-meet:i32 (a:i32 b:i32)
  (when (or (= a PTR-RAW) (= b PTR-RAW)) (return PTR-RAW))
  (when (or (= a PTR-MAYBE) (= b PTR-MAYBE)) (return PTR-MAYBE))
  (return PTR-REF))

; Enforce pointer-kind flow into a declared slot (binding init, set!, field /
; element store, argument, return). Only a non-null (ref T) destination adds an
; obligation: the source must itself be ref. Widening (ref→raw, ref→Maybe,
; raw→Maybe, Maybe→raw) is always allowed; the existing kind/elem rules are
; unchanged. `cast` does not pass through here, so (cast (ref T) raw) remains
; the explicit, audited assertion.
(defn pkind-flow-check:void (src:ptr dst:ptr line:i32 ctx:ptr)
  (when (or (= src null) (= dst null)) (return))
  (when (!= (ptr-pkind dst) PTR-REF) (return))
  (when (= (ptr-pkind src) PTR-REF) (return))
  (let (sk:i32 ((cast ptr:Type src) kind))
    (when (= sk TY-PTR)
      (if (= (ptr-pkind src) PTR-MAYBE)
        (die-at line (fmt-s "%s: value may be null where non-null (ref ...) is required — narrow with if-some/when-some, unwrap, or a null guard" ctx))
        (die-at line (fmt-s "%s: raw pointer where non-null (ref ...) is required — launder with (as-ref ...) + narrowing, or assert with (cast (ref T) ...)" ctx))))
    (when (= sk TY-CSTR)
      (die-at line (fmt-s "%s: raw pointer where non-null (ref ...) is required — launder with (as-ref ...) + narrowing, or assert with (cast (ref T) ...)" ctx)))))

; Deref/field/index gate: a (Maybe (ref T)) value cannot be accessed until
; narrowed. Raw stays unchecked (the signed waiver); ref is always safe.
(defn require-derefable:void (t:ptr line:i32 op:ptr)
  (when (= (ptr-pkind t) PTR-MAYBE)
    (die-at line (fmt-s "%s: value may be null — narrow with if-some/when-some, unwrap, or a (when (= x null) ...) guard before use" op))))

; ============================================================
; Aggregate ABI lowering — x86_64 System V (Stage 8 Phase C)
; ============================================================
; Struct-by-value parameters and returns must follow the platform C ABI, not
; LLVM's default by-value aggregate passing (which is not ABI-correct). The
; classifier below ports clang's eightbyte model: a struct ≤16 bytes is split
; into one or two eightbytes, each classified INTEGER or SSE and coerced to a
; register type; >16 bytes goes through memory (byval param / sret return).
; Only TY-STRUCT is ever non-DIRECT, so every scalar/pointer path is unchanged.
; See design/stage8/platform.md for the reverse-engineered coercion table.

; Round x up to a multiple of a (a is a power of two in practice, but the
; arithmetic form works for any positive a).
(defn abi-align-up:i32 (x:i32 a:i32)
  (when (<= a 1) (return x))
  (return (* (/ (+ x (- a 1)) a) a)))

; ABI alignment of a type in bytes. Scalars use their natural alignment
; (== size); pointers/functions use the target pointer alignment; structs use
; the max alignment of any field.
(defn abi-alignof:i32 (t:ptr)
  (let (k:i32 ((cast ptr:Type t) kind))
    (when (= k TY-STRUCT)
      (return (abi-struct-align (cast ptr:StructDef ((cast ptr:Type t) sdef)))))
    (when (= k TY-PTR)  (return g-target-ptr-bytes))
    (when (= k TY-CSTR) (return g-target-ptr-bytes))
    (when (= k TY-FN)   (return g-target-ptr-bytes))
    (return (type-size t))))

; ABI size of a type in bytes. Unlike type-size (which returns the pointer size
; for any struct, sufficient for its by-reference slots), this walks struct
; fields so the classifier sees the real aggregate size.
(defn abi-sizeof:i32 (t:ptr)
  (let (k:i32 ((cast ptr:Type t) kind))
    (when (= k TY-STRUCT)
      (return (abi-struct-size (cast ptr:StructDef ((cast ptr:Type t) sdef)))))
    (when (= k TY-FN) (return g-target-ptr-bytes))
    (return (type-size t))))

; Max field alignment of a struct (its own ABI alignment).
(defn abi-struct-align:i32 (sd:ptr)
  (let (sdd:ptr:StructDef (cast ptr:StructDef sd)
        n:i32 (sdd num-fields)
        a:i32 1
        i:i32 0)
    (while (< i n)
      (let (fa:i32 (abi-alignof (aref (cast ptr:ptr (sdd field-types)) i)))
        (when (> fa a) (set! a fa)))
      (inc! i))
    (return a)))

; ABI size of a struct: fields laid out with natural padding, total rounded up
; to the struct's own alignment (tail padding included).
(defn abi-struct-size:i32 (sd:ptr)
  (let (sdd:ptr:StructDef (cast ptr:StructDef sd)
        n:i32 (sdd num-fields)
        off:i32 0
        i:i32 0)
    (while (< i n)
      (let (ft:ptr (aref (cast ptr:ptr (sdd field-types)) i)
            fa:i32 (abi-alignof ft))
        (set! off (abi-align-up off fa))
        (set! off (+ off (abi-sizeof ft))))
      (inc! i))
    (return (abi-align-up off (abi-struct-align sd)))))

; Classify the eightbyte covering absolute bytes [lo, lo+8) against the fields
; of struct sd placed at absolute base offset `base`. Recurses into nested
; struct fields by absolute offset. Returns a class code: 0 none, 1 SSE/float,
; 2 SSE/double, 3 INTEGER. Higher wins (INTEGER beats SSE; double beats float).
(defn abi-class-eightbyte:i32 (sd:ptr base:i32 lo:i32)
  (let (sdd:ptr:StructDef (cast ptr:StructDef sd)
        n:i32 (sdd num-fields)
        hi:i32 (+ lo 8)
        off:i32 0
        cls:i32 0
        i:i32 0)
    (while (< i n)
      (let (ft:ptr (aref (cast ptr:ptr (sdd field-types)) i)
            fa:i32 (abi-alignof ft)
            fsz:i32 (abi-sizeof ft))
        (set! off (abi-align-up off fa))
        (let (fabs:i32 (+ base off)
              fk:i32 ((cast ptr:Type ft) kind))
          ; Does this field overlap [lo, hi)?
          (when (and (< fabs hi) (> (+ fabs fsz) lo))
            (if (= fk TY-STRUCT)
              (let (sub:i32 (abi-class-eightbyte
                              (cast ptr:StructDef ((cast ptr:Type ft) sdef)) fabs lo))
                (when (> sub cls) (set! cls sub)))
              (if (!= (is-float-type ft) 0)
                (let (fc:i32 (if (= fk TY-F64) 2 1))
                  (when (> fc cls) (set! cls fc)))
                (set! cls 3)))))     ; integer / pointer → INTEGER
        (set! off (+ off fsz)))
      (inc! i))
    (return cls)))

; Coercion IR type for one eightbyte: class `cls` holding `n` bytes (1..8).
; INTEGER → i(8·n) for n ≤ 4 (i8/i16/i24/i32), else i64. SSE/double → double.
; SSE/float → <2 x float> when the eightbyte is full, else float.
(defn abi-eightbyte-ir:ptr (cls:i32 n:i32)
  (when (= cls 2) (return "double"))
  (when (= cls 1)
    (if (= n 8) (return "<2 x float>") (return "float")))
  (if (<= n 4)
    (return (fmt-i32 "i%d" (* n 8)))
    (return "i64")))

; Classify a type for the SysV aggregate ABI. Returns an AbiInfo*. Non-struct
; types are ABI-DIRECT (byte-identical to pre-ABI codegen).
(defn abi-classify:ptr (t:ptr)
  (let (info:ptr:AbiInfo (cast ptr:AbiInfo (arena-alloc (sizeof AbiInfo))))
    (.set! info kind ABI-DIRECT)
    (.set! info reg0 null)
    (.set! info reg1 null)
    (.set! info size 0)
    (.set! info align 0)
    (when (!= ((cast ptr:Type t) kind) TY-STRUCT) (return (cast ptr info)))
    (let (sd:ptr (cast ptr ((cast ptr:Type t) sdef))
          sz:i32 (abi-struct-size (cast ptr:StructDef ((cast ptr:Type t) sdef)))
          al:i32 (abi-struct-align (cast ptr:StructDef ((cast ptr:Type t) sdef))))
      (.set! info size sz)
      (.set! info align al)
      (when (> sz 16)
        (.set! info kind ABI-MEMORY)
        (return (cast ptr info)))
      (let (n0:i32 (if (< sz 8) sz 8)
            c0:i32 (abi-class-eightbyte (cast ptr:StructDef sd) 0 0))
        (.set! info reg0 (abi-eightbyte-ir c0 n0)))
      (when (<= sz 8)
        (.set! info kind ABI-COERCE1)
        (return (cast ptr info)))
      (let (n1:i32 (- sz 8)
            c1:i32 (abi-class-eightbyte (cast ptr:StructDef sd) 0 8))
        (.set! info reg1 (abi-eightbyte-ir c1 n1)))
      (.set! info kind ABI-COERCE2)
      (return (cast ptr info)))))

; Return type string for a function signature given its return AbiInfo: void for
; MEMORY (the value goes through the sret pointer), the coercion reg(s) for
; COERCE, or the plain type for DIRECT.
(defn abi-ret-ir:ptr (info:ptr ret:ptr)
  (let (k:i32 ((cast ptr:AbiInfo info) kind))
    (when (= k ABI-MEMORY)  (return "void"))
    (when (= k ABI-COERCE1) (return ((cast ptr:AbiInfo info) reg0)))
    (when (= k ABI-COERCE2)
      (return (fmt-2s "{ %s, %s }"
                ((cast ptr:AbiInfo info) reg0) ((cast ptr:AbiInfo info) reg1))))
    (return (type-to-ir ret))))

; Print one lowered parameter to g-out. `name` is the param name for a `define`
; (emits the `%name.arg` operand) or null for a `declare` (types only). COERCE2
; expands to two comma-separated entries; the caller supplies the leading comma.
(defn abi-print-param:void (info:ptr ptype:ptr name:ptr)
  (let (ii:ptr:AbiInfo (cast ptr:AbiInfo info)
        k:i32 ((cast ptr:AbiInfo info) kind))
    (when (= k ABI-DIRECT)
      (if (= name null)
        (fprintf g-out "%s" (type-to-ir ptype))
        (fprintf g-out "%s %%%s.arg" (type-to-ir ptype) name))
      (return))
    (when (= k ABI-MEMORY)
      (if (= name null)
        (fprintf g-out "ptr byval(%s) align %d" (type-to-ir ptype) (ii align))
        (fprintf g-out "ptr byval(%s) align %d %%%s.arg" (type-to-ir ptype) (ii align) name))
      (return))
    (when (= k ABI-COERCE1)
      (if (= name null)
        (fprintf g-out "%s" (ii reg0))
        (fprintf g-out "%s %%%s.arg" (ii reg0) name))
      (return))
    ; COERCE2
    (if (= name null)
      (fprintf g-out "%s, %s" (ii reg0) (ii reg1))
      (fprintf g-out "%s %%%s.arg.0, %s %%%s.arg.1" (ii reg0) name (ii reg1) name))))

; Emit the entry-block reconstruction for one parameter into its `.addr` slot,
; and bind it in fn-scope. DIRECT keeps the prior alloca+store (byte-identical).
; MEMORY binds the byval pointer directly (it already points at the copy).
; COERCE allocas the struct and stores the register arg(s) at their offsets.
(defn abi-emit-param-prologue:void (fn-scope:ref:Scope pname:ptr ptype:ptr)
  (let (info:ptr:AbiInfo (cast ptr:AbiInfo (abi-classify ptype))
        k:i32 ((cast ptr:AbiInfo (abi-classify ptype)) kind)
        slot:ptr (fmt-s "%%%s.addr" pname)
        arg:ptr (fmt-s "%%%s.arg" pname))
    (when (= k ABI-DIRECT)
      (let (palign:i32 (type-size ptype))
        (fprintf g-entry-stream "  %s = alloca %s, align %d\n" slot (type-to-ir ptype) palign)
        (fprintf g-entry-stream "  store %s %s, ptr %s, align %d\n"
          (type-to-ir ptype) arg slot palign)
        (scope-define fn-scope pname ptype slot 1))
      (return))
    (when (= k ABI-MEMORY)
      (scope-define fn-scope pname ptype arg 1)
      (return))
    ; COERCE1 / COERCE2: materialize the register arg(s) back into a struct slot.
    (fprintf g-entry-stream "  %s = alloca %s\n" slot (type-to-ir ptype))
    (if (= k ABI-COERCE1)
      (fprintf g-entry-stream "  store %s %s, ptr %s\n" ((cast ptr:AbiInfo info) reg0) arg slot)
      (let (gp:ptr null)
        (fprintf g-entry-stream "  store %s %%%s.arg.0, ptr %s\n"
          ((cast ptr:AbiInfo info) reg0) pname slot)
        (set! gp (new-tmp))
        (fprintf g-entry-stream "  %s = getelementptr i8, ptr %s, i64 8\n" gp slot)
        (fprintf g-entry-stream "  store %s %%%s.arg.1, ptr %s\n"
          ((cast ptr:AbiInfo info) reg1) pname gp)))
    (scope-define fn-scope pname ptype slot 1)))

; Emit a struct return for the current function per g-fn-ret-abi. `v` is the
; first-class struct value to return. MEMORY stores it through the sret pointer
; and returns void; COERCE rounds it through memory and returns the reg(s).
(defn emit-struct-ret:void (v:ptr)
  (let (vv:ptr:Val (cast ptr:Val v)
        info:ptr:AbiInfo (cast ptr:AbiInfo g-fn-ret-abi)
        k:i32 ((cast ptr:AbiInfo g-fn-ret-abi) kind)
        ty:ptr (type-to-ir ((cast ptr:Val v) type)))
    (when (= k ABI-MEMORY)
      (fprintf g-body-stream "  store %s %s, ptr %s\n" ty (vv val) g-fn-sret-name)
      (fprintf g-body-stream "  ret void\n")
      (return))
    (let (tmp:ptr (new-tmp))
      (fprintf g-entry-stream "  %s = alloca %s\n" tmp ty)
      (fprintf g-body-stream "  store %s %s, ptr %s\n" ty (vv val) tmp)
      (if (= k ABI-COERCE1)
        (let (r:ptr (new-tmp))
          (fprintf g-body-stream "  %s = load %s, ptr %s\n" r (info reg0) tmp)
          (fprintf g-body-stream "  ret %s %s\n" (info reg0) r))
        ; COERCE2: load both eightbytes, build the {reg0,reg1} return aggregate.
        (let (r0:ptr (new-tmp)
              gp:ptr null
              r1:ptr null
              a0:ptr null
              a1:ptr null)
          (fprintf g-body-stream "  %s = load %s, ptr %s\n" r0 (info reg0) tmp)
          (set! gp (new-tmp))
          (fprintf g-body-stream "  %s = getelementptr i8, ptr %s, i64 8\n" gp tmp)
          (set! r1 (new-tmp))
          (fprintf g-body-stream "  %s = load %s, ptr %s\n" r1 (info reg1) gp)
          (set! a0 (new-tmp))
          (fprintf g-body-stream "  %s = insertvalue { %s, %s } undef, %s %s, 0\n"
            a0 (info reg0) (info reg1) (info reg0) r0)
          (set! a1 (new-tmp))
          (fprintf g-body-stream "  %s = insertvalue { %s, %s } %s, %s %s, 1\n"
            a1 (info reg0) (info reg1) a0 (info reg1) r1)
          (fprintf g-body-stream "  ret { %s, %s } %s\n" (info reg0) (info reg1) a1))))))

; Build the LLVM call-argument fragment for one already-emitted argument Val,
; emitting any materialization/coercion instructions as a side effect. Scalars
; and pointers return "<ty> <val>" unchanged; a struct is materialized to memory
; and lowered to byval / register load(s) per its AbiInfo.
(defn abi-arg-frag:ptr (av:ptr)
  (let (a:ptr:Val (cast ptr:Val av)
        info:ptr:AbiInfo (cast ptr:AbiInfo (abi-classify ((cast ptr:Val av) type)))
        k:i32 ((cast ptr:AbiInfo (abi-classify ((cast ptr:Val av) type))) kind))
    (when (= k ABI-DIRECT)
      (return (fmt-2s "%s %s" (type-to-ir (a type)) (a val))))
    (let (ty:ptr (type-to-ir (a type))
          addr:ptr (new-tmp))
      (fprintf g-entry-stream "  %s = alloca %s\n" addr ty)
      (fprintf g-body-stream "  store %s %s, ptr %s\n" ty (a val) addr)
      (when (= k ABI-MEMORY)
        (return (fmt-2s "%s %s" (fmt-sd "ptr byval(%s) align %d" ty (info align)) addr)))
      (when (= k ABI-COERCE1)
        (let (r:ptr (new-tmp))
          (fprintf g-body-stream "  %s = load %s, ptr %s\n" r (info reg0) addr)
          (return (fmt-2s "%s %s" (info reg0) r))))
      ; COERCE2
      (let (r0:ptr (new-tmp)
            gp:ptr null
            r1:ptr null)
        (fprintf g-body-stream "  %s = load %s, ptr %s\n" r0 (info reg0) addr)
        (set! gp (new-tmp))
        (fprintf g-body-stream "  %s = getelementptr i8, ptr %s, i64 8\n" gp addr)
        (set! r1 (new-tmp))
        (fprintf g-body-stream "  %s = load %s, ptr %s\n" r1 (info reg1) gp)
        (return (fmt-2s "%s, %s"
                  (fmt-2s "%s %s" (info reg0) r0)
                  (fmt-2s "%s %s" (info reg1) r1)))))))

; Emit a direct call whose return is a struct lowered per `info`, reconstruct
; the first-class struct value, and return its Val. `arglist` is the already
; built scalar/coerced argument string; `nargs` is the count it holds (so a
; MEMORY sret prefix knows whether it needs a separating comma).
(defn abi-emit-struct-call:ref:Val (info:ptr ret:ptr ir-name:ptr arglist:ptr nargs:i32)
  (let (ii:ptr:AbiInfo (cast ptr:AbiInfo info)
        k:i32 ((cast ptr:AbiInfo info) kind)
        ty:ptr (type-to-ir ret))
    (when (= k ABI-MEMORY)
      (let (slot:ptr (new-tmp)
            sep:ptr "")
        (fprintf g-entry-stream "  %s = alloca %s\n" slot ty)
        (when (> nargs 0) (set! sep ", "))
        (fprintf g-body-stream "  call void %s(ptr sret(%s) align %d %s%s%s)\n"
          ir-name ty (ii align) slot sep arglist)
        (let (v:ptr (new-tmp))
          (fprintf g-body-stream "  %s = load %s, ptr %s\n" v ty slot)
          (return (alloc-val ret v)))))
    (when (= k ABI-COERCE1)
      (let (tmp:ptr (new-tmp))
        (fprintf g-body-stream "  %s = call %s %s(%s)\n" tmp (ii reg0) ir-name arglist)
        (let (slot:ptr (new-tmp))
          (fprintf g-entry-stream "  %s = alloca %s\n" slot ty)
          (fprintf g-body-stream "  store %s %s, ptr %s\n" (ii reg0) tmp slot)
          (let (v:ptr (new-tmp))
            (fprintf g-body-stream "  %s = load %s, ptr %s\n" v ty slot)
            (return (alloc-val ret v))))))
    ; COERCE2: call returns {reg0,reg1}; split it back into the struct slot.
    (let (rty:ptr (fmt-2s "{ %s, %s }" (ii reg0) (ii reg1))
          tmp:ptr (new-tmp))
      (fprintf g-body-stream "  %s = call %s %s(%s)\n" tmp rty ir-name arglist)
      (let (slot:ptr (new-tmp)
            e0:ptr null
            gp:ptr null
            e1:ptr null
            v:ptr null)
        (fprintf g-entry-stream "  %s = alloca %s\n" slot ty)
        (set! e0 (new-tmp))
        (fprintf g-body-stream "  %s = extractvalue %s %s, 0\n" e0 rty tmp)
        (fprintf g-body-stream "  store %s %s, ptr %s\n" (ii reg0) e0 slot)
        (set! gp (new-tmp))
        (fprintf g-body-stream "  %s = getelementptr i8, ptr %s, i64 8\n" gp slot)
        (set! e1 (new-tmp))
        (fprintf g-body-stream "  %s = extractvalue %s %s, 1\n" e1 rty tmp)
        (fprintf g-body-stream "  store %s %s, ptr %s\n" (ii reg1) e1 gp)
        (set! v (new-tmp))
        (fprintf g-body-stream "  %s = load %s, ptr %s\n" v ty slot)
        (return (alloc-val ret v))))))

; Try to coerce a value to a target type. Returns a Val* or null on failure.
; Handles: same kind (identity), int-to-int (trunc/sext/zext), same-width sign change.
(defn coerce-int-val:?Val (v:ptr target:ptr line:i32)
  (let (vv:ptr:Val (cast ptr:Val v)
        src:ptr (vv type)
        sk:i32 (-> src (cast ptr:Type _) (_ kind))
        dk:i32 (-> target (cast ptr:Type _) (_ kind)))
    ; Stage 10: pointer-kind flow gate — raw/Maybe may not flow into a
    ; non-null (ref T) slot. Engages only when the destination is ref, so
    ; every pre-Stage-10 path is untouched.
    (when (= dk TY-PTR)
      (pkind-flow-check src target line "assignment"))
    ; Same kind — identity
    (when (= sk dk) (return v))
    ; CStr is an opaque char* — freely interconvertible with a plain pointer,
    ; no IR (both lower to `ptr`). Keeps string literals (CStr) usable wherever a
    ; ptr is expected, and a ptr usable where a CStr slot is declared.
    (when (or (and (= sk TY-CSTR) (= dk TY-PTR))
              (and (= sk TY-PTR) (= dk TY-CSTR)))
      (let (rv:ptr:Val (cast ptr:Val (alloc-val target (vv val))))
        (.set! rv taint (vv taint))
        (return (cast ptr rv))))
    ; Both integers — emit cast if needed
    (when (and (!= (is-int-type src) 0) (!= (is-int-type target) 0))
      (let (sw:i32 (int-width src) dw:i32 (int-width target))
        (when (= sw dw)
          ; Same width, different signedness — reinterpret (no IR needed)
          (return (alloc-val target (vv val))))
        (let (tmp:ptr (new-tmp)
              instr:ptr null)
          (if (< dw sw)
            (set! instr "trunc")
            (if (!= (is-unsigned src) 0)
              (set! instr "zext")
              (set! instr "sext")))
          (fprintf g-body-stream "  %s = %s %s %s to %s\n"
            tmp instr (type-to-ir src) (vv val) (type-to-ir target))
          (return (alloc-val target tmp)))))
    ; Not compatible
    (return null)))

(defn register-struct:ref:StructDef (name:ptr)
  (when (>= g-structs-len MAX-STRUCTS)
    (fprintf stderr "nucleusc: too many structs\n") (exit 1))
  (let (sd:ptr:StructDef (cast ptr:StructDef (ptr+ (cast ptr:StructDef g-structs) g-structs-len)))
    (.set! sd name name)
    (.set! sd num-fields 0)
    (.set! sd emitted 0)
    (inc! g-structs-len)
    (return (cast ref:StructDef sd))))

; ============================================================
; Stage 8: anonymous structs — (struct field:type ...) types, memoized by
; content hash so two textually-identical shapes share one StructDef.
; ============================================================

(defn fnv-byte:i64 (h:i64 b:i64)
  (set! h (bit-xor h b))
  (set! h (* h (cast i64 1099511628211)))
  (return h))

(defn fnv-str:i64 (h:i64 s:ptr)
  (let (i:i64 0
        c:i32 (bit-and (cast i32 (aref (cast ptr:i8 s) 0)) 255))
    (while (!= c 0)
      (set! h (fnv-byte h (cast i64 c)))
      (set! i (+ i (cast i64 1)))
      (set! c (bit-and (cast i32 (aref (cast ptr:i8 s) i)) 255)))
    (return h)))

(defn hash-type:i64 (h:i64 t:ptr)
  (when (= t null) (return (fnv-byte h (cast i64 255))))
  (let (tt:ptr:Type (cast ptr:Type t)
        k:i32 (tt kind))
    (set! h (fnv-byte h (cast i64 k)))
    (set! h (fnv-byte h (cast i64 (tt is-volatile))))
    (when (= k TY-PTR)
      (set! h (hash-type h (tt elem))))
    (when (= k TY-STRUCT)
      (set! h (fnv-str h ((cast ptr:StructDef (tt sdef)) name))))
    (when (= k TY-FN)
      (set! h (hash-type h (tt ret)))
      (set! h (fnv-byte h (cast i64 (tt num-params))))
      (let (i:i32 0)
        (while (< i (tt num-params))
          (set! h (hash-type h (aref (cast ptr:ptr (tt params)) i)))
          (inc! i))))
    (return h)))

(defn hash-struct-shape:i64 (field-names:ptr field-types:ptr nfields:i32)
  (let (h:i64 -3750763034362895579
        i:i32 0)
    (while (< i nfields)
      (set! h (fnv-str h (aref (cast ptr:ptr field-names) i)))
      (set! h (fnv-byte h (cast i64 0)))
      (set! h (hash-type h (aref (cast ptr:ptr field-types) i)))
      (inc! i))
    (return h)))

(defn lookup-or-make-anon-struct:ref:StructDef (field-names:ptr field-types:ptr nfields:i32)
  (let (hash:i64 (hash-struct-shape field-names field-types nfields)
        synth:ptr (fmt-i64 "__anon_struct_h%016lx" hash)
        sd:ptr (lookup-struct synth))
    (when (= sd null)
      (set! sd (register-struct synth))
      (let (sd2:ptr:StructDef (cast ptr:StructDef sd))
        (.set! sd2 field-names field-names)
        (.set! sd2 field-types field-types)
        (.set! sd2 num-fields nfields)
        (.set! sd2 emitted 1)
        (.set! sd2 src-file g-source-path)
        (.set! sd2 src-line 0))
      (fprintf g-type-stream "%%%s = type { " synth)
      (let (i:i32 0)
        (while (< i nfields)
          (when (!= i 0) (fprintf g-type-stream ", "))
          (fprintf g-type-stream "%s" (type-to-ir (aref (cast ptr:ptr field-types) i)))
          (inc! i)))
      (fprintf g-type-stream " }\n\n"))
    ; Both arms leave sd non-null, but the set!-kill is sticky across the join
    ; (nullability.md §4) — assert rather than re-test.
    (return (cast ref:StructDef sd))))

(defn lookup-struct:?StructDef (name:ptr)
  (let (i:i32 0)
    (while (< i g-structs-len)
      (let (sd:ptr:StructDef (cast ptr:StructDef (ptr+ (cast ptr:StructDef g-structs) i)))
        (when (= (sd name) name)
          (return (cast ptr sd))))
      (inc! i)))
  (return null))

(defn parse-type-name:ref:Type (name:ptr line:i32)
  ; Stage 10 sugar: ?T is (Maybe (ref T)) — an explicitly nullable non-null
  ; pointer, niche-encoded as the bare pointer (null = none).
  (when (= (char-at name (cast i64 0)) 63)
    (let (inner:ptr (parse-type-name (ptr+ (cast ptr:i8 name) (cast i64 1)) line)
          mt:ref:Type (make-type TY-PTR))
      (.set! mt elem inner)
      (.set! mt pkind PTR-MAYBE)
      (return mt)))
  (when (= name "int") (return ty-i32))
  (when (= name "i1") (return ty-i1))
  (when (= name "i8") (return ty-i8))
  (when (= name "i16") (return ty-i16))
  (when (= name "i32") (return ty-i32))
  (when (= name "i64") (return ty-i64))
  (when (= name "bool") (return ty-i1))
  (when (= name "ptr") (return ty-ptr))
  (when (= name "CStr") (return ty-cstr))
  (when (= name "void") (return ty-void))
  (when (= name "ui8") (return ty-ui8))
  (when (= name "ui16") (return ty-ui16))
  (when (= name "ui32") (return ty-ui32))
  (when (= name "ui64") (return ty-ui64))
  (when (= name "f32") (return ty-f32))
  (when (= name "f64") (return ty-f64))
  (when (= name "float") (return ty-f32))
  (when (= name "double") (return ty-f64))
  (let (sd:ptr (lookup-struct name))
    (when (!= sd null)
      (let (t:ref:Type (make-type TY-STRUCT))
        (.set! t sdef sd)
        (return t))))
  (die-at line (fmt-s "unknown type: %s" name)))

; Parse a type from an AST node. Handles:
;   - symbol node: delegates to parse-type-name
;   - list node (ptr T) or (ptr ptr ... T): builds TY-PTR
;   - list node ((fn ret-type) (param-types...)) or (fn ret-type): builds TY-FN
(defn parse-type-from-node:ref:Type (node:ptr line:i32)
  (let (n:ptr:Node (cast ptr:Node node))
    (when (= (n kind) NODE-SYM)
      ; Colon-sugar in inline type position: "ptr:Node" → (ptr Node).
      (when (!= (strchr (n s) 58) null)
        (return (parse-type-from-node (split-colon-segments (n s) line) line)))
      (return (parse-type-name (n s) line)))
    (when (= (n kind) NODE-CELL)
      ; Postfix volatile: (T volatile) or (T1 T2 ... volatile). Strip the trailing
      ; 'volatile and recurse on the head, then mark volatile. Placed before ptr/fn
      ; so (ptr i32 volatile) ≡ volatile (ptr i32).
      (let (nlen:i32 (node-len n))
        (when (>= nlen 2)
          (let (last:ptr:Node (cast ptr:Node (node-at n (- nlen 1))))
            (when (and (!= (cast ptr last) null)
                       (and (= (last kind) NODE-SYM)
                            (= (strcmp (last s) "volatile") 0)))
              (let (head-len:i32 (- nlen 1)
                    inner:ptr null)
                (if (= head-len 1)
                  (set! inner (n car))
                  (let (cur:ptr (cast ptr n)
                        new-head:ptr null
                        new-tail:ptr null
                        i:i32 0)
                    (while (< i head-len)
                      (let (cell:ptr (make-cell ((cast ptr:Node cur) car) null line))
                        (when (= new-head null) (set! new-head cell))
                        (when (!= new-tail null) (.set! (cast ptr:Node new-tail) cdr cell))
                        (set! new-tail cell))
                      (set! cur ((cast ptr:Node cur) cdr))
                      (inc! i))
                    (set! inner new-head)))
                (return (type-with-volatile (parse-type-from-node inner line))))))))
      ; Anonymous struct: (struct field:type ...) — memoized by content hash so
      ; two textually-identical shapes share one synthesized StructDef.
      (let (head:ptr (n car))
        (when (= head 'struct)
          (let (rest:ptr (n cdr)
                nfields:i32 0
                cur:ptr null)
            (set! cur rest)
            (while (!= cur null)
              (inc! nfields)
              (set! cur ((cast ptr:Node cur) cdr)))
            (let (fnames:ptr (arena-alloc (* (cast i64 nfields) (cast i64 8)))
                  ftypes:ptr (arena-alloc (* (cast i64 nfields) (cast i64 8)))
                  i:i32 0)
              (set! cur rest)
              (while (!= cur null)
                (let (field:ptr ((cast ptr:Node cur) car)
                      fname:ptr null
                      fty:ptr (extract-name-and-type field (cast ptr:ptr (addr-of fname)) line))
                  (when (= fty null)
                    (die-at line (fmt-s "struct: field '%s' missing :type" fname)))
                  ; Intern so field-name pointer-equality works at access sites.
                  (aset! (cast ptr:ptr fnames) i (intern-str fname))
                  (aset! (cast ptr:ptr ftypes) i fty))
                (inc! i)
                (set! cur ((cast ptr:Node cur) cdr)))
              (let (sd:ptr (lookup-or-make-anon-struct fnames ftypes nfields)
                    t:ref:Type (make-type TY-STRUCT))
                (.set! t sdef sd)
                (return t))))))
      ; Check for pointer constructor: (ptr T) or (ptr ptr T) ...
      (let (head:ptr (n car))
        (when (= head 'ptr)
          (let (rest:ptr (n cdr))
            (when (= rest null) (return ty-ptr))
            (let (elem:ptr null)
              (if (= ((cast ptr:Node rest) cdr) null)
                (set! elem (parse-type-from-node ((cast ptr:Node rest) car) line))
                (set! elem (parse-type-from-node rest line)))
              (let (pt:ref:Type (make-type TY-PTR))
                (.set! pt elem elem)
                (return pt))))))
      ; Stage 10: (ref T) — a non-null pointer to T. Same shape as (ptr T)
      ; (colon sugar ref:T arrives here too), but the element is required.
      (let (head:ptr (n car))
        (when (= head 'ref)
          (let (rest:ptr (n cdr))
            (when (= rest null)
              (die-at line "ref: element type required — (ref T)"))
            (let (elem:ptr null)
              (if (= ((cast ptr:Node rest) cdr) null)
                (set! elem (parse-type-from-node ((cast ptr:Node rest) car) line))
                (set! elem (parse-type-from-node rest line)))
              (let (pt:ref:Type (make-type TY-PTR))
                (.set! pt elem elem)
                (.set! pt pkind PTR-REF)
                (return pt))))))
      ; Stage 10: (Maybe (ref T)) — explicit nullability over a non-null
      ; pointer, niche-encoded (null = none). Pointer payloads only; a
      ; non-pointer Maybe needs a discriminant and is left to sum types.
      (let (head:ptr (n car))
        (when (= head 'Maybe)
          (let (rest:ptr (n cdr))
            (when (= rest null)
              (die-at line "Maybe: payload type required — (Maybe (ref T))"))
            (let (inner:ptr null)
              (if (= ((cast ptr:Node rest) cdr) null)
                (set! inner (parse-type-from-node ((cast ptr:Node rest) car) line))
                (set! inner (parse-type-from-node rest line)))
              (when (or (-> inner (cast ptr:Type _) (_ kind) (!= _ TY-PTR))
                        (!= (ptr-pkind inner) PTR-REF))
                (die-at line "Maybe: payload must be (ref T) — (Maybe T) over non-pointers needs sum types (future)"))
              (return (cast ref:Type (type-as-pkind inner PTR-MAYBE)))))))
      ; Check for function pointer type: ((fn ret) (param-types...))
      (let (head:ptr (n car))
        (when (!= head null)
          ; Head is a list (fn ret-type) — function pointer with params
         (when (= ((cast ptr:Node head) kind) NODE-CELL)
           (let (fn-head:ptr ((cast ptr:Node head) car))
             (when (= fn-head 'fn)
                ; Parse return type from (fn ret-type)
                (let (ret-node:ptr ((cast ptr:Node head) cdr)
                      ret-type:ptr ty-void)
                  (when (and (!= ret-node null)
                             (!= ((cast ptr:Node ret-node) car) null))
                    (set! ret-type (parse-type-from-node ((cast ptr:Node ret-node) car) line)))
                  ; Parse parameter types from the second element (param-types...)
                  (let (params-node:ptr (n cdr)
                        num-p:i32 0
                        param-arr:ptr null
                        is-va:i32 0)
                    (when (!= params-node null)
                      (let (plist:ptr ((cast ptr:Node params-node) car))
                        (when (!= plist null)
                          ; Count params
                          (let (cur:ptr plist
                                count:i32 0)
                            (while (!= cur null)
                              (inc! count)
                              (set! cur ((cast ptr:Node cur) cdr)))
                            (set! num-p count)
                            (set! param-arr (arena-alloc (* (cast i64 count) (ptr-bytes))))
                            ; Parse each param type
                            (set! cur plist)
                            (let (pi:i32 0)
                              (while (!= cur null)
                                (aset! (cast ptr:ptr param-arr) pi
                                       (parse-type-from-node ((cast ptr:Node cur) car) line))
                                (inc! pi)
                                (set! cur ((cast ptr:Node cur) cdr))))))))
                    (let (ft:ref:Type (make-type TY-FN))
                      (.set! ft ret ret-type)
                      (.set! ft params param-arr)
                      (.set! ft num-params num-p)
                      (.set! ft variadic is-va)
                      (return ft)))))))
          ; Head is a symbol "fn" — function pointer with no params: (fn ret-type)
         (when (= head 'fn)
             (let (ret-node:ptr (n cdr)
                                ret-type:ptr ty-void)
               (when (and (!= ret-node null)
                          (!= ((cast ptr:Node ret-node) car) null))
                 (set! ret-type (parse-type-from-node ((cast ptr:Node ret-node) car) line)))
               (let (ft:ref:Type (make-type TY-FN))
                 (.set! ft ret ret-type)
                 (.set! ft params null)
                 (.set! ft num-params 0)
                 (.set! ft variadic 0)
                 (return ft)))))))
    (die-at line "unable to parse type expression")))

(defn split-typed:void (sym:ptr out-name:ptr:ptr out-type-name:ptr:ptr)
  (let (colon:ptr (strchr sym 58))
    (if (= colon null)
      (do
        (ptr-set! out-name (arena-strdup sym))
        (ptr-set! out-type-name null))
      (let (name-len:i64 (- (cast i64 colon) (cast i64 sym)))
        (ptr-set! out-name (arena-strndup sym name-len))
        (ptr-set! out-type-name (arena-strdup (ptr+ (cast ptr:i8 colon) (cast i64 1))))))))

; Extract name and type-name from a node that is either:
;   - a symbol node (possibly containing :) — uses split-typed
;   - a list node (name type ...) from desugar — extracts car/cadr strings
; Sets out-name and out-type-name.  out-type-name is null if untyped.
(defn extract-name-type:void (node:ptr out-name:ptr:ptr out-type-name:ptr:ptr)
  (let (n:ptr:Node (cast ptr:Node node))
    (when (= (n kind) NODE-SYM)
      (split-typed (n s) out-name out-type-name)
      (return))
    (when (= (n kind) NODE-CELL)
      (let (car-node:ptr:Node (cast ptr:Node (n car)))
        (when (and (!= (cast ptr car-node) null) (= (car-node kind) NODE-SYM))
          (ptr-set! out-name (car-node s))
          (let (rest:ptr (n cdr))
            (if (!= rest null)
                (let (type-node:ptr:Node (cast ptr:Node ((cast ptr:Node rest) car)))
                  (when (and (!= (cast ptr type-node) null) (= (type-node kind) NODE-SYM))
                    (ptr-set! out-type-name (type-node s)))
                  (return))
              (do (ptr-set! out-type-name null)
                  (return)))))))
    ; Fallback: treat as untyped
    (ptr-set! out-name null)
    (ptr-set! out-type-name null)))

; Extract name and parsed Type* from a node. Handles function pointer types.
; Returns the Type* or null if untyped. Sets out-name.
; For simple types: (name type-sym) → parse-type-name
; For function pointer types: (name (fn ret) (param-types)) → parse-type-from-node on rest
(defn extract-name-and-type:ptr (node:ptr out-name:ptr:ptr line:i32)
  (let (n:ptr:Node (cast ptr:Node node))
    ; Simple symbol: name:type[:more] — desugar first if multi-colon,
    ; else use split-typed and parse-type-name on the single tail token.
    (when (= (n kind) NODE-SYM)
      (let (s:ptr (n s))
        (when (!= (strchr s 58) null)
          (let (sec-colon:ptr (strchr (ptr+ (cast ptr:i8 (strchr s 58)) (cast i64 1)) 58))
            (when (!= sec-colon null)
              ; Multi-colon: desugar to a list and re-dispatch
              (return (extract-name-and-type (desugar-symbol node line)
                                              out-name line)))))
        (let (tname:ptr null)
          (split-typed s out-name (cast ptr:ptr (addr-of tname)))
          (when (!= tname null)
            (return (parse-type-name tname line)))
          (return null))))
    ; List node from desugar: (name type-info...)
    (when (= (n kind) NODE-CELL)
      (let (car-node:ptr:Node (cast ptr:Node (n car)))
        (when (and (!= (cast ptr car-node) null) (= (car-node kind) NODE-SYM))
         (ptr-set! out-name (car-node s))
         (let (rest:ptr (n cdr))
           (when (= rest null) (return null))
           (let (type-node:ptr ((cast ptr:Node rest) car))
             (when (= type-node null) (return null))
              ; If type is a symbol, parse it — parse-type-from-node also handles
              ; colon-sugar (`ptr:M7`), which arises when a generic instantiation
              ; substitutes a pointer type's spelling into a desugared (name T) head.
              (when (= ((cast ptr:Node type-node) kind) NODE-SYM)
                (return (parse-type-from-node type-node line)))
              ; If type is a list — (ptr T) or function-pointer type.
              ; Legacy fn-pointer form ((fn ret) (params)) was spread across
              ; the rest; for that case we still pass the whole rest.
              (when (= ((cast ptr:Node type-node) kind) NODE-CELL)
                (let (inner-head:ptr ((cast ptr:Node type-node) car)
                      is-fn:i32 0)
                  (when (and (!= inner-head null)
                             (and (= ((cast ptr:Node inner-head) kind) NODE-SYM)
                                  (= ((cast ptr:Node inner-head) s) "fn")))
                    (set! is-fn 1))
                  (if (!= is-fn 0)
                    (return (parse-type-from-node rest line))
                    (return (parse-type-from-node type-node line)))))
              (return null))))))
    (ptr-set! out-name null)
    (return null)))

; ============================================================
; Symbol table
; ============================================================

(defn scope-new:ref:Scope (parent:ptr)
  (let (s:ref:Scope (new Scope))
    (.set! s parent parent)
    (return s)))

(defn scope-define:ref:Sym (s:ptr name:ptr type:ptr ir-name:ptr is-local:i32)
  (let (sc:ptr:Scope (cast ptr:Scope s))
    (when (= (sc len) (sc cap))
      (let (nc:i32 8)
        (when (!= (sc cap) 0) (set! nc (* (sc cap) 2)))
        (let (ns:ptr (arena-alloc (* (cast i64 nc) (sizeof Sym))))
          (when (!= (sc len) 0)
            (memcpy ns (sc syms) (* (cast i64 (sc len)) (sizeof Sym))))
          (.set! sc syms ns)
          (.set! sc cap nc))))
    (let (sym:ptr:Sym (cast ptr:Sym (ptr+ (cast ptr:Sym (sc syms)) (sc len))))
      (.set! sym name name)
      (.set! sym type type)
      (.set! sym ir-name ir-name)
      (.set! sym is-local is-local)
      (.set! sym home s)
      (.set! sc len (+ (sc len) 1))
      (return (cast ref:Sym sym)))))

(defn scope-lookup:?Sym (s:ptr name:ptr)
  (let (cur:ptr s)
    (while (!= cur null)
      (let (sc:ptr:Scope (cast ptr:Scope cur)
            i:i32 (- (sc len) 1))
        (while (>= i 0)
          (let (sym:ptr:Sym (cast ptr:Sym (ptr+ (cast ptr:Sym (sc syms)) i)))
            (when (= (sym name) name)
              (return (cast ptr sym))))
          (set! i (- i 1)))
        (set! cur (sc parent)))))
  (return null))

; Record an armed Cleanup* on a scope, fired at scope exit (and on each early
; return that unwinds past it) by emit-scope-cleanups, in reverse order.
(defn scope-push-cleanup:void (s:ptr slot:ptr)
  (let (sc:ptr:Scope (cast ptr:Scope s))
    (when (= (sc ncleanups) (sc ccleanups))
      (let (nc:i32 4)
        (when (!= (sc ccleanups) 0) (set! nc (* (sc ccleanups) 2)))
        (let (ns:ptr (arena-alloc (* (cast i64 nc) (ptr-bytes))))
          (when (!= (sc ncleanups) 0)
            (memcpy ns (sc cleanup-slots) (* (cast i64 (sc ncleanups)) (ptr-bytes))))
          (.set! sc cleanup-slots ns)
          (.set! sc ccleanups nc))))
    (let (slots:ptr:ptr (cast ptr:ptr (sc cleanup-slots)))
      (aset! slots (sc ncleanups) slot)
      (.set! sc ncleanups (+ (sc ncleanups) 1)))))

; ============================================================
; String literal table
; ============================================================

(defn intern-string:i32 (bytes:ptr len:i32)
  (let (id:i32 g-strs-len)
    (when (= g-strs-len g-strs-cap)
      (let (nc:i32 8)
        (when (!= g-strs-cap 0) (set! nc (* g-strs-cap 2)))
        (let (ns:ptr (malloc (* (cast i64 nc) (sizeof StrLit))))
          (when (= ns null) (perror "malloc") (exit 1))
          (when (!= g-strs null)
            (memcpy ns g-strs (* (cast i64 g-strs-len) (sizeof StrLit)))
            (free g-strs))
          (set! g-strs ns)
          (set! g-strs-cap nc))))
    (let (sl:ptr:StrLit (cast ptr:StrLit (ptr+ (cast ptr:StrLit g-strs) g-strs-len)))
      (.set! sl bytes (arena-strndup bytes (cast i64 len)))
      (.set! sl len len)
      (.set! sl id id)
      (inc! g-strs-len)
      (return id))))

; ============================================================
; Codegen helpers
; ============================================================

(defn new-tmp:ptr ()
  (let (r:ptr (fmt-i32 "%%t%d" g-tmp))
    (inc! g-tmp)
    (return r)))

(defn new-label-id:i32 ()
  (let (r:i32 g-label)
    (inc! g-label)
    (return r)))

(defn reset-function-state:void ()
  (set! g-tmp 0)
  (set! g-label 0)
  (set! g-block-term 0)
  (set! g-lbl-tbl (make-vec))
  (set! g-cur-fname null)
  (set! g-fn-ret-abi null)
  (set! g-fn-sret-name null)
  (set! g-fn-ret-type null)
  (set! g-loop-depth 0)
  (set! g-nundo (make-vec))
  (set! g-entry-stream (open_memstream (addr-of g-entry-bufp)
                                       (cast ptr (addr-of g-entry-sizep))))
  (set! g-body-stream (open_memstream (addr-of g-body-bufp)
                                      (cast ptr (addr-of g-body-sizep)))))

; ============================================================
; node-type: non-emitting expression typing (Stage 9 rung 3)
; ============================================================
; node-type(n, scope) computes the Type an expression contributes to its parent
; WITHOUT emitting IR. emit-node sets the type it propagates from this function,
; so the type pass and codegen share one rule per node kind and cannot drift —
; any divergence corrupts the self-hosting bootstrap and is caught immediately.
;
; It is total over the language's value forms. The few forms whose emit-time
; type depends on control-flow/expansion that can't be reproduced purely (`cond`
; phi typing, `quasiquote` of a bare unquote, macro calls) return null, meaning
; "not modeled — keep the emit-computed type"; callers treat null as unknown.
; node-type never emits and never aborts: ambiguous lookups yield null.

(defn node-type-sym:?Type (n:ptr scope:ref:Scope)
  (when (= n 'null)  (return ty-ptr))
  (when (= n 'true)  (return ty-i1))
  (when (= n 'false) (return ty-i1))
  (when (= n 'none)  (return ty-maybe-ptr))
  (let (lookup-name:ptr null
        ignored:ptr null)
    (split-typed ((cast ptr:Node n) s)
                 (cast ptr:ptr (addr-of lookup-name)) (cast ptr:ptr (addr-of ignored)))
    (let (sym:ptr:Sym (cast ptr:Sym (scope-lookup scope lookup-name)))
      (when (= (cast ptr sym) null) (return null))
      (return (sym-effective-type (cast ptr sym))))))

; let / with: the type of the last body expression, evaluated in a child scope
; carrying the binding types (values are irrelevant to typing).
(defn node-type-block:?Type (n:ptr scope:ref:Scope)
  (let (binds:ptr:Node (cast ptr:Node (node-at n 1)))
    (when (or (= (cast ptr binds) null) (!= (binds kind) NODE-CELL)) (return null))
    (let (inner:ref:Scope (scope-new scope)
          i:i32 0
          bl:i32 (node-len (cast ptr binds)))
      (while (< i bl)
        (let (bname:ptr (node-at (cast ptr binds) i)
              name:ptr null
              ty:ptr (extract-name-and-type bname (cast ptr:ptr (addr-of name))
                                            ((cast ptr:Node bname) line)))
          (when (!= ty null) (scope-define inner name ty name 1)))
        (set! i (+ i 2)))
      (let (last:ptr null
            j:i32 2
            cl:i32 (node-len n))
        (while (< j cl)
          (set! last (node-at n j))
          (inc! j))
        (when (= last null) (return ty-void))
        (return (node-type last inner))))))

(defn node-type-cast:ref:Type (n:ptr)
  (let (tn:ptr:Node (cast ptr:Node (node-at n 1)))
    (return (parse-type-from-node (cast ptr tn) (tn line)))))

(defn node-type-alloca:ref:Type (n:ptr)
  (let (tn:ptr:Node (cast ptr:Node (node-at n 1)))
    (let (ty:ptr (parse-type-from-node (cast ptr tn) (tn line))
          pt:ref:Type (make-type TY-PTR))
      (.set! pt elem ty)
      (return pt))))

(defn node-type-addr-of:?Type (n:ptr scope:ref:Scope)
  (let (target:ptr:Node (cast ptr:Node (node-at n 1)))
    (when (!= (target kind) NODE-SYM) (return null))
    (let (sym:ptr:Sym (cast ptr:Sym (scope-lookup scope (target s))))
      (when (= (cast ptr sym) null) (return null))
      (let (pt:ptr:Type (cast ptr:Type (make-type TY-PTR)))
        (.set! pt elem (sym type))
        (return (cast ptr pt))))))

(defn node-type-funcall:?Type (n:ptr scope:ref:Scope)
  (let (t:ptr (node-type (node-at n 1) scope))
    (when (= t null) (return null))
    (let (tt:ptr:Type (cast ptr:Type t))
      (when (!= (tt kind) TY-FN) (return null))
      (return (tt ret)))))

; deref / aref: the pointee type of the first operand's pointer.
(defn node-type-deref-elem:?Type (n:ptr scope:ref:Scope)
  (let (t:ptr (node-type (node-at n 1) scope))
    (when (= t null) (return null))
    (let (tt:ptr:Type (cast ptr:Type t))
      (when (or (!= (tt kind) TY-PTR) (= (tt elem) null)) (return null))
      (return (tt elem)))))

(defn node-type-field:?Type (n:ptr scope:ref:Scope)
  (let (t:ptr (node-type (node-at n 1) scope))
    (when (= t null) (return null))
    (let (tt:ptr:Type (cast ptr:Type t))
      (when (or (or (!= (tt kind) TY-PTR) (= (tt elem) null))
                (-> tt (_ elem) (cast ptr:Type _) (_ kind) (!= _ TY-STRUCT)))
        (return null))
      (let (fn-node:ptr:Node (cast ptr:Node (node-at n 2)))
        (when (!= (fn-node kind) NODE-SYM) (return null))
        (let (sd:ptr:StructDef (cast ptr:StructDef (-> tt (_ elem) (cast ptr:Type _) (_ sdef)))
              idx:i32 (struct-field-index (cast ptr sd) (fn-node s)))
          (when (< idx 0) (return null))
          (return (aref (cast ptr:ptr (sd field-types)) idx)))))))

; Result type of `(get callee selector)` for callee type `ct` — mirrors
; emit-get-with-callee / emit-get-intrinsic so the type pass cannot drift from
; codegen. A tier-0 user `get` method → its return; a literal selector → the
; named field's type; a computed selector → null (emit keeps its own type).
(defn callable-get-type:?Type (ct:ptr sel-node:ptr scope:ref:Scope)
  (let (ctt:ptr:Type (cast ptr:Type ct)
        g:?Generic (generic-lookup "get"))
    (when (!= g null)
      (let (argtypes:ptr (arena-alloc (* (cast i64 2) (ptr-bytes))))
        (aset! (cast ptr:ptr argtypes) 0 ct)
        (aset! (cast ptr:ptr argtypes) 1 ty-ptr)
        (let (m:?Method (generic-find-method-exact g argtypes 2))
          (when (!= m null) (return (m ret-type))))))
    (when (or (or (!= (ctt kind) TY-PTR) (= (ctt elem) null))
              (-> ctt (_ elem) (cast ptr:Type _) (_ kind) (!= _ TY-STRUCT)))
      (return null))
    (let (lit:ptr (selector-literal-sym sel-node))
      (when (= lit null) (return null))
      (let (sd:ptr:StructDef (cast ptr:StructDef (-> ctt (_ elem) (cast ptr:Type _) (_ sdef)))
            idx:i32 (struct-field-index (-> ctt (_ elem) (cast ptr:Type _) (_ sdef))
                                        (-> lit (cast ptr:Node _) (_ s))))
        (when (< idx 0) (return null))
        (return (aref (cast ptr:ptr (sd field-types)) idx))))))

; Result type of `(invoke callee arg…)` for callee type `ct` — the tier-0 `invoke`
; method's return, else null (mirrors emit-invoke-with-callee at the exact tier).
(defn callable-invoke-type:?Type (ct:ptr n:ptr arg-start:i32 nargs:i32 scope:ref:Scope)
  (let (g:?Generic (generic-lookup "invoke"))
    (when (= g null) (return null))
    (let (total:i32 (+ nargs 1)
          argtypes:ptr (arena-alloc (* (cast i64 (+ total 1)) (ptr-bytes)))
          ok:i32 1)
      (aset! (cast ptr:ptr argtypes) 0 ct)
      (let (i:i32 0)
        (while (< i nargs)
          (let (at:ptr (node-type (node-at n (+ arg-start i)) scope))
            (when (= at null) (set! ok 0))
            (aset! (cast ptr:ptr argtypes) (+ i 1) at))
          (inc! i)))
      (when (= ok 0) (return null))
      (let (m:?Method (generic-find-method-exact g argtypes total))
        (when (= m null) (return null))
        (return (m ret-type))))))

; Type of a non-function head value `ct` applied in `(callee arg…)` — mirrors
; emit-callable-value: single literal-symbol arg → get, else → invoke.
(defn callable-value-type:?Type (ct:ptr n:ptr scope:ref:Scope)
  (let (nargs:i32 (- (node-len n) 1))
    (if (and (= nargs 1) (!= (selector-literal-sym (node-at n 1)) null))
      (return (callable-get-type ct (node-at n 1) scope))
      (return (callable-invoke-type ct n 1 nargs scope)))))

(defn node-type-get:?Type (n:ptr scope:ref:Scope)
  (when (!= (node-len n) 3) (return null))
  (let (ct:ptr (node-type (node-at n 1) scope))
    (when (= ct null) (return null))
    (return (callable-get-type ct (node-at n 2) scope))))

(defn node-type-invoke:?Type (n:ptr scope:ref:Scope)
  (when (< (node-len n) 2) (return null))
  (let (ct:ptr (node-type (node-at n 1) scope))
    (when (= ct null) (return null))
    (return (callable-invoke-type ct n 2 (- (node-len n) 2) scope))))

; A call head (not a special form): mirror emit-dispatch. Operator → a matching
; user overload's return type, else i1 for comparisons / the first operand's type
; (the intrinsic peephole result); overloaded set → the exactly matched method's
; return type; solitary/extern → the bound function's return.
(defn node-type-call:?Type (n:ptr scope:ref:Scope h:ptr)
  (let (g:?Generic (generic-lookup h))
    (when (!= g null)
      (let (m0:ptr:Method (cast ptr:Method (aref (cast ptr:ptr (g methods)) 0)))
        (when (= (m0 kind) METHOD-INTRINSIC)
          ; A user overload of this operator, if any, wins (mirror emit).
          (when (!= (g mangled) 0)
            (let (nargs:i32 (- (node-len n) 1)
                  argtypes:ptr (arena-alloc (* (cast i64 (+ nargs 1)) (ptr-bytes)))
                  arg-nodes:ptr (arena-alloc (* (cast i64 (+ nargs 1)) (ptr-bytes)))
                  i:i32 0
                  ok:i32 1)
              (while (< i nargs)
                (let (anode:ptr (node-at n (+ i 1))
                      at:ptr (node-type anode scope))
                  (when (= at null) (set! ok 0))
                  (aset! (cast ptr:ptr argtypes) i at)
                  (aset! (cast ptr:ptr arg-nodes) i anode))
                (inc! i))
              (when (!= ok 0)
                (let (um:?Method (operator-user-resolve g argtypes arg-nodes nargs))
                  (when (!= um null) (return (um ret-type)))))))
          (let (bop:ptr:BinOp (cast ptr:BinOp (m0 binop)))
            (when (!= (bop is-cmp) 0) (return ty-i1))
            (return (node-type (node-at n 1) scope))))
        (when (!= (g mangled) 0)
          (let (nargs:i32 (- (node-len n) 1)
                argtypes:ptr (arena-alloc (* (cast i64 (+ nargs 1)) (ptr-bytes)))
                i:i32 0
                ok:i32 1)
            (while (< i nargs)
              (let (at:ptr (node-type (node-at n (+ i 1)) scope))
                (when (= at null) (set! ok 0))
                (aset! (cast ptr:ptr argtypes) i at))
              (inc! i))
            (when (= ok 0) (return null))
            (let (m:?Method (generic-find-method-exact g argtypes nargs))
              (when (= m null) (return null))
              (return (m ret-type)))))))
    (if-some (sym (scope-lookup scope h))
      (let (ft:ptr:Type (cast ptr:Type (sym type)))
        ; A non-function value head is a callable value: mirror the get/invoke desugar.
        (when (!= (ft kind) TY-FN) (return (callable-value-type (cast ptr ft) n scope)))
        (return (ft ret)))
      (return null))))

(defn node-type:?Type (n:ptr scope:ref:Scope)
  (when (= n null) (return ty-void))
  (let (nn:ptr:Node (cast ptr:Node n))
    (when (= (nn kind) NODE-INT)   (return ty-i32))
    (when (= (nn kind) NODE-FLOAT) (return ty-f64))
    (when (= (nn kind) NODE-STR)   (return ty-cstr))
    (when (= (nn kind) NODE-SYM)   (return (node-type-sym n scope)))
    (when (!= (nn kind) NODE-CELL) (return ty-void))
    (when (= (node-len n) 0) (return null))
    (let (head:ptr:Node (cast ptr:Node (node-at n 0)))
      (when (!= (head kind) NODE-SYM) (return null))
      (let (h:ptr (head s)
            hp:ptr (cast ptr head))
        (when (!= (find-macro h) null) (return null))
        (when (= hp 'gensym) (return ty-ptr))
        (when (= hp 'funcall-ptr-1) (return ty-ptr))
        (when (= hp 'funcall-ptr-i32) (return ty-i32))
        (when (= hp 'funcall-ptr-i64) (return ty-i64))
        (when (= hp 'funcall-ptr-ptr) (return ty-ptr))
        (when (= hp 'return) (return ty-void))
        (when (= hp 'do)
          (if (> (node-len n) 1)
            (return (node-type (node-at n (- (node-len n) 1)) scope))
            (return ty-void)))
        (when (= hp 'let) (return (node-type-block n scope)))
        (when (= hp 'with) (return (node-type-block n scope)))
        (when (= hp 'cond) (return null))
        (when (= hp 'quote) (return ty-ptr))
        (when (= hp 'quasiquote) (return null))
        (when (= hp 'while) (return ty-void))
        (when (= hp 'set!)
          (let (tgt:ptr:Node (cast ptr:Node (node-at n 1))
                nm:ptr null  ti:ptr null)
            (split-typed (tgt s) (cast ptr:ptr (addr-of nm)) (cast ptr:ptr (addr-of ti)))
            (let (sym:ptr:Sym (cast ptr:Sym (scope-lookup scope nm)))
              (when (= (cast ptr sym) null) (return ty-void))
              (return (sym type)))))
        (when (= hp 'inc!) (return ty-void))
        (when (= hp 'not) (return ty-i1))
        (when (= hp 'and) (return ty-i1))
        (when (= hp 'or) (return ty-i1))
        (when (= hp 'cast) (return (node-type-cast n)))
        (when (= hp 'addr-of) (return (node-type-addr-of n scope)))
        (when (= hp 'funcall-void) (return ty-void))
        (when (= hp 'funcall) (return (node-type-funcall n scope)))
        (when (= hp 'deref) (return (node-type-deref-elem n scope)))
        (when (= hp 'ptr-set!) (return ty-void))
        (when (= hp 'ptr+) (return (node-type (node-at n 1) scope)))
        (when (= hp '_get) (return (node-type-field n scope)))
        (when (= hp '.set!) (return ty-void))
        (when (= hp 'get) (return (node-type-get n scope)))
        (when (= hp 'invoke) (return (node-type-invoke n scope)))
        (when (= hp 'sizeof) (return ty-i64))
        (when (= hp 'alloca) (return (node-type-alloca n)))
        (when (= hp 'char) (return ty-i8))
        (when (= hp 'aref) (return (node-type-deref-elem n scope)))
        (when (= hp 'aset!) (return ty-void))
        ; Stage 10: Maybe transition forms — relabelings mirror their emitters
        ; exactly; if-some/when-some are phi-shaped like cond (null = unmodeled).
        (when (or (= hp 'some) (= hp 'as-ref))
          (let (t:ptr (node-type (node-at n 1) scope))
            (when (= t null) (return null))
            (when (!= ((cast ptr:Type t) kind) TY-PTR) (return null))
            (return (type-as-pkind t PTR-MAYBE))))
        (when (or (= hp 'unwrap) (= hp 'unwrap-or))
          (let (t:ptr (node-type (node-at n 1) scope))
            (when (= t null) (return null))
            (when (!= (ptr-pkind t) PTR-MAYBE) (return null))
            (return (type-as-pkind t PTR-REF))))
        (when (or (= hp 'if-some) (= hp 'when-some)) (return null))
        (when (= hp 'defer) (return ty-void))
        (when (= hp 'move) (return (node-type (node-at n 1) scope)))
        (return (node-type-call n scope h))))))

; ============================================================
; Expression codegen
; ============================================================

(defn emit-node:ref:Val (n:ptr scope:ref:Scope)
  (let (nn:ptr:Node (cast ptr:Node n)
        v:ref:Val (alloc-val ty-void null))
    (when (= (nn kind) NODE-INT)   (set! v (emit-int n)))
    (when (= (nn kind) NODE-FLOAT) (set! v (emit-float n)))
    (when (= (nn kind) NODE-STR)   (set! v (emit-string n)))
    (when (= (nn kind) NODE-SYM)   (set! v (emit-symbol-ref n scope)))
    (when (= (nn kind) NODE-CELL)  (set! v (emit-list n scope)))
    ; Rung 3: the type a node contributes to its parent is the shared node-type
    ; rule's answer, so codegen and the (non-emitting) type pass cannot drift —
    ; a mismatch corrupts the next bootstrap and is caught at once. node-type
    ; returns null for the forms it does not model; those keep emit's own type.
    (let (t:ptr (node-type n scope))
      (when (!= t null) (.set! v type t)))
    (return v)))

(defn emit-int:ref:Val (n:ptr)
  (return (alloc-val ty-i32 (fmt-i64 "%ld" ((cast ptr:Node n) i)))))

; Translate a float literal lexeme to an LLVM IR floating-point
; constant. Hex bit-patterns for the Scheme-style special tokens
; `+inf.0`, `-inf.0`, `+nan.0`. Otherwise normalize to LLVM's
; required form: a leading digit, an explicit `.` with at least
; one fractional digit, and optional exponent. So `1e3` -> `1.0e3`,
; `.5` -> `0.5`, `2.` -> `2.0`.
(defn float-literal-ir:ptr (lex:ptr)
  (when (= lex "+inf.0") (return "0x7FF0000000000000"))
  (when (= lex "-inf.0") (return "0xFFF0000000000000"))
  (when (= lex "+nan.0") (return "0x7FF8000000000000"))
  (let (len:i64 (cast i64 (strlen lex))
        buf:ptr (malloc (cast i64 96))
        out:i64 (cast i64 0)
        in:i64 (cast i64 0))
    ; Optional sign.
    (when (and (> len (cast i64 0))
               (or (= (char-at lex (cast i64 0)) 43)
                   (= (char-at lex (cast i64 0)) 45)))
      (aset! (cast ptr:i8 buf) out (cast i8 (char-at lex (cast i64 0))))
      (set! out (+ out (cast i64 1)))
      (set! in (cast i64 1)))
    ; Integer part: insert leading 0 if absent.
    (let (had-int-digit:i32 0)
      (while (and (< in len)
                  (!= (isdigit (char-at lex in)) 0))
        (aset! (cast ptr:i8 buf) out (cast i8 (char-at lex in)))
        (set! out (+ out (cast i64 1)))
        (set! in (+ in (cast i64 1)))
        (set! had-int-digit 1))
      (when (= had-int-digit 0)
        (aset! (cast ptr:i8 buf) out (cast i8 48))
        (set! out (+ out (cast i64 1)))))
    ; Decimal point + fraction. Synthesize a `.0` if missing.
    (cond (and (< in len) (= (char-at lex in) 46))
            (do (aset! (cast ptr:i8 buf) out (cast i8 46))
                (set! out (+ out (cast i64 1)))
                (set! in (+ in (cast i64 1)))
                (let (had-frac-digit:i32 0)
                  (while (and (< in len)
                              (!= (isdigit (char-at lex in)) 0))
                    (aset! (cast ptr:i8 buf) out (cast i8 (char-at lex in)))
                    (set! out (+ out (cast i64 1)))
                    (set! in (+ in (cast i64 1)))
                    (set! had-frac-digit 1))
                  (when (= had-frac-digit 0)
                    (aset! (cast ptr:i8 buf) out (cast i8 48))
                    (set! out (+ out (cast i64 1))))))
          true
            (do (aset! (cast ptr:i8 buf) out (cast i8 46))
                (aset! (cast ptr:i8 buf) (+ out (cast i64 1)) (cast i8 48))
                (set! out (+ out (cast i64 2)))))
    ; Exponent (verbatim).
    (while (< in len)
      (aset! (cast ptr:i8 buf) out (cast i8 (char-at lex in)))
      (set! out (+ out (cast i64 1)))
      (set! in (+ in (cast i64 1))))
    (aset! (cast ptr:i8 buf) out (cast i8 0))
    (return buf)))

(defn emit-float:ref:Val (n:ptr)
  (let (nn:ptr:Node (cast ptr:Node n))
    (return (alloc-val ty-f64 (float-literal-ir (nn s))))))

(defn emit-string:ref:Val (n:ptr)
  (let (nn:ptr:Node (cast ptr:Node n)
        id:i32 (intern-string (nn s) (cast i32 (strlen (nn s))))
        ir-len:i32 (+ ((cast ptr:StrLit (ptr+ (cast ptr:StrLit g-strs) id)) len) 1)
        tmp:ptr (new-tmp))
    (fprintf g-body-stream
      "  %s = getelementptr inbounds [%d x i8], ptr @.str.%d, i64 0, i64 0\n"
      tmp ir-len id)
    (return (alloc-val ty-cstr tmp))))

; Build a quoted Node tree at runtime so that quoted symbols share Node
; identity with reader-produced ones. Returns a body-stream tmp ref.
;
; - NODE-SYM:   call ptr @intern-symbol(spelling)
; - NODE-CELL:  recurse on car/cdr, then call ptr @make-cell(car, cdr, line)
; - NODE-INT/STR/FLOAT: alloc-node, then store the relevant fields
(defn emit-quote-tree:ptr (n:ptr)
  (when (= n null) (return "null"))
  (let (nn:ptr:Node (cast ptr:Node n))
    (when (= (nn kind) NODE-SYM)
      (let (sid:i32 (intern-string (nn s) (cast i32 (strlen (nn s))))
            ir-len:i32 (+ ((cast ptr:StrLit (ptr+ (cast ptr:StrLit g-strs) sid)) len) 1)
            tmp:ptr (new-tmp))
        (fprintf g-body-stream
          "  %s = call ptr @intern-symbol(ptr getelementptr inbounds ([%d x i8], ptr @.str.%d, i64 0, i64 0))\n"
          tmp ir-len sid)
        (return tmp)))
    (when (= (nn kind) NODE-CELL)
      (let (car-ref:ptr (emit-quote-tree (nn car))
            cdr-ref:ptr (emit-quote-tree (nn cdr))
            tmp:ptr (new-tmp))
        (fprintf g-body-stream "  %s = call ptr @make-cell(ptr %s, ptr %s, i32 %d)\n"
                 tmp car-ref cdr-ref (nn line))
        (return tmp)))
    ; NODE-INT / NODE-STR / NODE-FLOAT — runtime alloc + fill.
    (let (tmp:ptr (new-tmp))
      (fprintf g-body-stream "  %s = call ptr @alloc-node()\n" tmp)
      (when (or (= (nn kind) NODE-STR) (= (nn kind) NODE-FLOAT))
        (let (k:i32 1
              kp:ptr (new-tmp))
          (when (= (nn kind) NODE-FLOAT) (set! k 4))
          (fprintf g-body-stream
            "  %s = getelementptr inbounds { i32, i32, i64, ptr, ptr, ptr }, ptr %s, i32 0, i32 0\n"
            kp tmp)
          (fprintf g-body-stream "  store i32 %d, ptr %s, align 4\n" k kp)))
      (let (lp:ptr (new-tmp))
        (fprintf g-body-stream
          "  %s = getelementptr inbounds { i32, i32, i64, ptr, ptr, ptr }, ptr %s, i32 0, i32 1\n"
          lp tmp)
        (fprintf g-body-stream "  store i32 %d, ptr %s, align 4\n" (nn line) lp))
      (when (= (nn kind) NODE-INT)
        (let (ip:ptr (new-tmp))
          (fprintf g-body-stream
            "  %s = getelementptr inbounds { i32, i32, i64, ptr, ptr, ptr }, ptr %s, i32 0, i32 2\n"
            ip tmp)
          (fprintf g-body-stream "  store i64 %ld, ptr %s, align 8\n" (nn i) ip)))
      (when (or (= (nn kind) NODE-STR) (= (nn kind) NODE-FLOAT))
        (let (sid:i32 (intern-string (nn s) (cast i32 (strlen (nn s))))
              ir-len:i32 (+ ((cast ptr:StrLit (ptr+ (cast ptr:StrLit g-strs) sid)) len) 1)
              sp:ptr (new-tmp))
          (fprintf g-body-stream
            "  %s = getelementptr inbounds { i32, i32, i64, ptr, ptr, ptr }, ptr %s, i32 0, i32 3\n"
            sp tmp)
          (fprintf g-body-stream
            "  store ptr getelementptr inbounds ([%d x i8], ptr @.str.%d, i64 0, i64 0), ptr %s, align 8\n"
            ir-len sid sp)))
      (return tmp))))

(defn emit-quote:ref:Val (call:ptr)
  (let (cc:ptr:Node (cast ptr:Node call))
    (when (!= (node-len call) 2) (die-at (cc line) "quote: expects 1 arg"))
    (let (ref:ptr (emit-quote-tree (node-at call 1)))
      (return (alloc-val ty-ptr ref)))))

(defn qq-is-tagged:i32 (n:ptr tag:ptr)
  (when (= n null) (return 0))
  (let (nn:ptr:Node (cast ptr:Node n))
    (when (!= (nn kind) NODE-CELL) (return 0))
    (when (!= (node-len n) 2) (return 0))
    (let (h:ptr (nn car))
      (when (= h null) (return 0))
      (when (!= ((cast ptr:Node h) kind) NODE-SYM) (return 0))
      (when (= h tag) (return 1))
      (return 0))))

(defn emit-qq-list:ref:Val (list:ptr scope:ref:Scope)
  (when (= list null) (return (alloc-val ty-ptr "null")))
  (set! g-qq-used 1)
  (let (lc:ptr:Node (cast ptr:Node list)
        elem:ptr (lc car))
    (when (!= (qq-is-tagged elem 'unquote-splice) 0)
      (let (inner:ptr (node-at elem 1)
            a:ref:Val (emit-node inner scope)
            rest:ref:Val (emit-qq-list (lc cdr) scope)
            tmp:ptr (new-tmp))
        (fprintf g-body-stream "  %s = call ptr @__append(ptr %s, ptr %s)\n"
                 tmp (a val) (rest val))
        (return (alloc-val ty-ptr tmp))))
    (let (head:ref:Val (emit-qq-form elem scope)
          tail:ref:Val (emit-qq-list (lc cdr) scope)
          tmp:ptr (new-tmp))
      (fprintf g-body-stream "  %s = call ptr @__cons(ptr %s, ptr %s)\n"
               tmp (head val) (tail val))
      (return (alloc-val ty-ptr tmp)))))

(defn emit-qq-form:ref:Val (form:ptr scope:ref:Scope)
  (when (= form null) (return (alloc-val ty-ptr "null")))
  (let (fn:ptr:Node (cast ptr:Node form))
    (when (!= (fn kind) NODE-CELL)
      (let (ref:ptr (emit-quote-tree form))
        (return (alloc-val ty-ptr ref))))
    (when (!= (qq-is-tagged form 'unquote) 0)
      (return (emit-node (node-at form 1) scope)))
    (when (!= (qq-is-tagged form 'unquote-splice) 0)
      (die-at (fn line) "unquote-splice outside list"))
    (return (emit-qq-list form scope))))

(defn emit-quasiquote:ref:Val (call:ptr scope:ref:Scope)
  (let (cc:ptr:Node (cast ptr:Node call))
    (when (!= (node-len call) 2) (die-at (cc line) "quasiquote: expects 1 arg"))
    (return (emit-qq-form (node-at call 1) scope))))

; ============================================================
; Stage 10: flow narrowing (nullability.md §4) + escape analysis (lifecycle.md)
; ============================================================
; Narrowing: inside a region dominated by a successful non-null test, a local
; ?T binding reads as (ref T). State lives on Sym (ntype/ndepth/kstamp) with a
; global undo stack, and is maintained where control flow is emitted (cond,
; and/or, while, label, set!) — macro-expanded guards like `when`/`if` have
; already lowered to cond by then, so the compiler's own null-guard idioms are
; the narrowing points. Reads (emit-symbol-ref and node-type-sym) share
; sym-effective-type, so the type pass cannot drift from codegen.
;
; Soundness notes:
;  - A kill (assignment) bumps the binding's kstamp; undo entries record the
;    stamp at push and a restore is skipped if it changed, so a branch join can
;    never resurrect a narrow past a reassignment (kills are sticky).
;  - Loop bodies are pre-scanned for textual (set! x ...) so a narrow from
;    outside the loop is dropped before the body emits; a macro-synthesized
;    assignment is caught by the emit-set backstop (ndepth < g-loop-depth).
;  - (label ...) is a potential backward-goto target: all narrows are killed.

(defn sym-effective-type:ptr (sym:ptr)
  (let (ss:ptr:Sym (cast ptr:Sym sym))
    (when (!= (ss ntype) null) (return (ss ntype)))
    (return (ss type))))

(defn narrow-mark:i32 ()
  (when (= g-nundo null) (set! g-nundo (make-vec)))
  (return ((cast ptr:Vec g-nundo) len)))

; Narrow binding `name` (resolved in `scope`) to the non-null view of its
; current effective type, pushing an undo entry. No-op unless the binding
; currently reads as a local (Maybe (ref T)).
(defn narrow-apply:void (scope:ref:Scope name:ptr)
  (when (= g-nundo null) (set! g-nundo (make-vec)))
  (let (sym:ptr:Sym (cast ptr:Sym (scope-lookup scope name)))
    (when (= (cast ptr sym) null) (return))
    (when (= (sym is-local) 0) (return))
    (let (eff:ptr (sym-effective-type (cast ptr sym)))
      (when (!= (ptr-pkind eff) PTR-MAYBE) (return))
      (let (u:ptr:NarrowUndo (new NarrowUndo))
        (.set! u name name)
        (.set! u scope scope)
        (.set! u old-ntype (sym ntype))
        (.set! u old-ndepth (sym ndepth))
        (.set! u stamp (sym kstamp))
        (vec-push g-nundo (cast ptr u)))
      (.set! sym ntype (type-as-pkind eff PTR-REF))
      (.set! sym ndepth g-loop-depth))))

; Undo narrows back to `mark` (a branch/region boundary). Entries whose
; binding was killed after the push are skipped.
(defn narrow-restore:void (mark:i32)
  (when (= g-nundo null) (return))
  (let (v:ptr:Vec (cast ptr:Vec g-nundo))
    (while (> (v len) mark)
      (let (u:ptr:NarrowUndo (cast ptr:NarrowUndo
                               (aref (cast ptr:ptr (v data)) (- (v len) 1))))
        (let (sym:ptr:Sym (cast ptr:Sym (scope-lookup (u scope) (u name))))
          (when (!= (cast ptr sym) null)
            (when (= (u stamp) (sym kstamp))
              (.set! sym ntype (u old-ntype))
              (.set! sym ndepth (u old-ndepth)))))
        (.set! v len (- (v len) 1))))))

; Kill a binding's narrow: reassignment invalidates the dominating test.
(defn narrow-kill:void (sym:ptr)
  (let (ss:ptr:Sym (cast ptr:Sym sym))
    (.set! ss ntype null)
    (.set! ss kstamp (+ (ss kstamp) 1))))

; Kill every live narrow (label join points — a backward goto re-enters).
(defn narrow-kill-all:void ()
  (when (= g-nundo null) (return))
  (let (v:ptr:Vec (cast ptr:Vec g-nundo)
        i:i32 0)
    (while (< i (v len))
      (let (u:ptr:NarrowUndo (cast ptr:NarrowUndo (aref (cast ptr:ptr (v data)) i)))
        (let (sym:ptr:Sym (cast ptr:Sym (scope-lookup (u scope) (u name))))
          (when (and (!= (cast ptr sym) null) (!= (sym ntype) null))
            (narrow-kill (cast ptr sym)))))
      (inc! i))))

; Is `node` the symbol `null`? (content compare — macro-built nodes may not be
; interned).
(defn node-is-null-sym:i32 (node:ptr)
  (when (= node null) (return 0))
  (let (nn:ptr:Node (cast ptr:Node node))
    (when (!= (nn kind) NODE-SYM) (return 0))
    (when (= (strcmp (nn s) "null") 0) (return 1))
    (return 0)))

; If `node` is a plain binding reference, its lookup name (annotation
; stripped); else null.
(defn node-binding-name:ptr (node:ptr)
  (when (= node null) (return null))
  (let (nn:ptr:Node (cast ptr:Node node))
    (when (!= (nn kind) NODE-SYM) (return null))
    (when (= (strcmp (nn s) "null") 0) (return null))
    (let (name:ptr null
          ti:ptr null)
      (split-typed (nn s) (cast ptr:ptr (addr-of name)) (cast ptr:ptr (addr-of ti)))
      (return name))))

; Collect binding names proven non-null when `test` is TRUE into `out`:
;   (!= m null) — m;  (and A B) — both arms;  (not X) — X's false-facts.
(defn test-true-nonnull:void (test:ptr out:ptr)
  (when (= test null) (return))
  (let (nn:ptr:Node (cast ptr:Node test))
    (when (!= (nn kind) NODE-CELL) (return))
    (let (head:ptr:Node (cast ptr:Node (node-at test 0)))
      (when (or (= (cast ptr head) null) (!= (head kind) NODE-SYM)) (return))
      (let (h:ptr (head s))
        (when (= (strcmp h "and") 0)
          (let (i:i32 1)
            (while (< i (node-len test))
              (test-true-nonnull (node-at test i) out)
              (inc! i)))
          (return))
        (when (= (strcmp h "not") 0)
          (when (= (node-len test) 2)
            (test-false-nonnull (node-at test 1) out))
          (return))
        (when (= (strcmp h "!=") 0)
          (when (= (node-len test) 3)
            (let (a:ptr (node-at test 1)
                  b:ptr (node-at test 2))
              (when (and (!= (node-is-null-sym b) 0) (!= (node-binding-name a) null))
                (vec-push out (node-binding-name a)))
              (when (and (!= (node-is-null-sym a) 0) (!= (node-binding-name b) null))
                (vec-push out (node-binding-name b)))))
          (return))))))

; Collect binding names proven non-null when `test` is FALSE into `out`:
;   (= m null) — m;  (or A B) — both arms;  (not X) — X's true-facts.
(defn test-false-nonnull:void (test:ptr out:ptr)
  (when (= test null) (return))
  (let (nn:ptr:Node (cast ptr:Node test))
    (when (!= (nn kind) NODE-CELL) (return))
    (let (head:ptr:Node (cast ptr:Node (node-at test 0)))
      (when (or (= (cast ptr head) null) (!= (head kind) NODE-SYM)) (return))
      (let (h:ptr (head s))
        (when (= (strcmp h "or") 0)
          (let (i:i32 1)
            (while (< i (node-len test))
              (test-false-nonnull (node-at test i) out)
              (inc! i)))
          (return))
        (when (= (strcmp h "not") 0)
          (when (= (node-len test) 2)
            (test-true-nonnull (node-at test 1) out))
          (return))
        (when (= (strcmp h "=") 0)
          (when (= (node-len test) 3)
            (let (a:ptr (node-at test 1)
                  b:ptr (node-at test 2))
              (when (and (!= (node-is-null-sym b) 0) (!= (node-binding-name a) null))
                (vec-push out (node-binding-name a)))
              (when (and (!= (node-is-null-sym a) 0) (!= (node-binding-name b) null))
                (vec-push out (node-binding-name b)))))
          (return))))))

; Narrow every name in `names` (a Vec) resolved against `scope`.
(defn narrow-names:void (scope:ref:Scope names:ptr)
  (let (v:ptr:Vec (cast ptr:Vec names)
        i:i32 0)
    (while (< i (v len))
      (narrow-apply scope (aref (cast ptr:ptr (v data)) i))
      (inc! i))))

; Conservatively kill narrows for any textual (set! x ...) target inside `n` —
; run before a loop body emits, so a narrow established outside the loop can't
; license a use that a later iteration's assignment would invalidate.
(defn prescan-kill-sets:void (n:ptr scope:ref:Scope)
  (when (= n null) (return))
  (let (nn:ptr:Node (cast ptr:Node n))
    (when (!= (nn kind) NODE-CELL) (return))
    (let (head:ptr:Node (cast ptr:Node (node-at n 0)))
      (when (and (!= (cast ptr head) null)
                 (and (= (head kind) NODE-SYM) (= (strcmp (head s) "set!") 0)))
        (when (>= (node-len n) 2)
          (let (tname:ptr (node-binding-name (node-at n 1)))
            (when (!= tname null)
              (let (sym:ptr:Sym (cast ptr:Sym (scope-lookup scope tname)))
                (when (and (!= (cast ptr sym) null) (!= (sym ntype) null))
                  (narrow-kill (cast ptr sym)))))))))
    (let (cur:ptr n)
      (while (!= cur null)
        (prescan-kill-sets ((cast ptr:Node cur) car) scope)
        (set! cur ((cast ptr:Node cur) cdr))))))

; --- escape analysis helpers (lifecycle.md §2–3) ---

; Is scope `a` the same as, or lexically inside, scope `b`?
(defn scope-descends:i32 (a:ptr b:ptr)
  (when (= b null) (return 1))
  (let (cur:ptr a)
    (while (!= cur null)
      (when (= cur b) (return 1))
      (set! cur ((cast ptr:Scope cur) parent))))
  (return 0))

; The deeper (shorter-lived) of two taint scopes. At any program point all
; live owning scopes enclose it, so two non-null taints are always nested.
(defn taint-merge:ptr (a:ptr b:ptr)
  (when (= a null) (return b))
  (when (= b null) (return a))
  (when (!= (scope-descends a b) 0) (return a))
  (return b))

; Escape sink for a store through a pointer (aset! / .set!, lifecycle.md §2.3):
; a tainted value may only be stored into memory that provably dies no later
; than the resource — memory owned by the same or an inner with-scope (its
; taint scope descends from the value's). Untainted targets (outer locals,
; globals, arena memory) outlive the with and are rejected.
(defn taint-store-check:void (tval:ptr vval:ptr line:i32 op:ptr)
  (let (vtaint:ptr ((cast ptr:Val vval) taint))
    (when (= vtaint null) (return))
    (when (= (scope-descends ((cast ptr:Val tval) taint) vtaint) 0)
      (die-at line
        (fmt-s "%s: resource bound by `with` escapes via store into longer-lived memory — use (move ...) to transfer ownership" op)))))

(defn emit-symbol-ref:ref:Val (n:ptr scope:ref:Scope)
  (let (nn:ptr:Node (cast ptr:Node n))
    (when (= n 'null)  (return (alloc-val ty-ptr "null")))
    (when (= n 'true)  (return (alloc-val ty-i1 "1")))
    (when (= n 'false) (return (alloc-val ty-i1 "0")))
    (when (= n 'none)  (return (alloc-val ty-maybe-ptr "null")))
    ; Strip any trailing :type annotation so typed names (e.g. i:i32 from macro
    ; expansion) resolve correctly in value position.
    (let (lookup-name:ptr null
          ignored-type:ptr null)
      (split-typed (nn s) (cast ptr:ptr (addr-of lookup-name)) (cast ptr:ptr (addr-of ignored-type)))
      (if-some (sym (scope-lookup scope lookup-name))
        (do
          (when (!= (sym moved) 0)
            (die-at (nn line) (fmt-s "use after move: '%s'" (nn s))))
          (when (!= (sym is-const) 0)
            (return (alloc-val (sym type) (sym const-val))))
          (when (= (sym is-local) 0)
            (when (-> sym (_ type) (cast ptr:Type _) (_ kind) (= _ TY-FN))
              (return (alloc-val (sym type) (sym ir-name))))
            (die-at (nn line) (fmt-s "cannot use '%s' as value" (nn s))))
          (let (tmp:ptr (new-tmp))
            (emit-load tmp (type-to-ir (sym type)) (sym ir-name) (sym type))
            ; Stage 10: the read uses the flow-narrowed view of the binding's
            ; type and carries the binding's escape taint.
            (let (rv:ref:Val (alloc-val (sym-effective-type sym) tmp))
              (.set! rv taint (sym taint))
              (return rv))))
        (die-at (nn line) (fmt-s "undefined: %s" (nn s)))))))

; ============================================================
; Binary operations
; ============================================================

(defn add-binop:void (name:ptr instr:ptr instr-u:ptr is-cmp:i32)
  (let (op:ptr:BinOp (cast ptr:BinOp (ptr+ (cast ptr:BinOp g-binops) g-num-binops)))
    (.set! op name name)
    (.set! op instr instr)
    (.set! op instr-u instr-u)
    (.set! op is-cmp is-cmp)
    (inc! g-num-binops)))

(defn init-binops:void ()
  (set! g-binops (arena-alloc (* (cast i64 24) (sizeof BinOp))))
  (add-binop "_+"     "add nsw"  "add"      0)
  (add-binop "_-"     "sub nsw"  "sub"      0)
  (add-binop "_*"     "mul nsw"  "mul"      0)
  (add-binop "_/"     "sdiv"     "udiv"     0)
  (add-binop "%"       "srem"     "urem"     0)
  (add-binop "bit-and" "and"      "and"      0)
  (add-binop "bit-or"  "or"       "or"       0)
  (add-binop "bit-xor" "xor"      "xor"      0)
  (add-binop "bit-shl" "shl"      "shl"      0)
  (add-binop "bit-shr" "ashr"     "lshr"     0)
  (add-binop "="       "icmp eq"  "icmp eq"  1)
  (add-binop "!="      "icmp ne"  "icmp ne"  1)
  (add-binop "<"       "icmp slt" "icmp ult" 1)
  (add-binop "<="      "icmp sle" "icmp ule" 1)
  (add-binop ">"       "icmp sgt" "icmp ugt" 1)
  (add-binop ">="      "icmp sge" "icmp uge" 1))

; True if a node denotes an untyped integer literal, so it may adapt to the type
; of the other operand in a binary operation (Stage 9 §10.1). Sees through the
; variadic operator macros' single-arg wrappers (`(+ 7)` → `7`) by expanding a
; cell head; cheap for the symbol/field/call operands that dominate (no macro).
(defn node-is-int-literal:i32 (n:ptr)
  (when (= n null) (return 0))
  (let (nn:ptr:Node (cast ptr:Node n))
    (when (= (nn kind) NODE-INT) (return 1))
    (when (= (nn kind) NODE-CELL)
      (let (e:ptr (macroexpand-form n (cast i32 -1)))
        (when (and (!= e null) (= ((cast ptr:Node e) kind) NODE-INT)) (return 1))))
    (return 0)))

(defn float-width:i32 (t:ptr)
  (let (k:i32 ((cast ptr:Type t) kind))
    (when (= k TY-F32) (return 32))
    (when (= k TY-F64) (return 64))
    (return 0)))

; Coerce a numeric Val to a target numeric type: int→int (trunc/sext/zext),
; int→float (sitofp/uitofp), float→float (fpext/fptrunc). Identity when already
; the target; null when the source is not numeric.
(defn coerce-num-val:?Val (v:ptr target:ptr line:i32)
  (let (vv:ptr:Val (cast ptr:Val v)
        src:ptr (vv type))
    (when (!= (type-eq src target) 0) (return v))
    (when (and (!= (is-int-type src) 0) (!= (is-int-type target) 0))
      (return (coerce-int-val v target line)))
    (when (and (!= (is-int-type src) 0) (!= (is-float-type target) 0))
      (let (tmp:ptr (new-tmp)
            instr:ptr "sitofp")
        (when (!= (is-unsigned src) 0) (set! instr "uitofp"))
        (fprintf g-body-stream "  %s = %s %s %s to %s\n"
          tmp instr (type-to-ir src) (vv val) (type-to-ir target))
        (return (alloc-val target tmp))))
    (when (and (!= (is-float-type src) 0) (!= (is-float-type target) 0))
      (let (tmp:ptr (new-tmp)
            instr:ptr "fpext")
        (when (< (float-width target) (float-width src)) (set! instr "fptrunc"))
        (fprintf g-body-stream "  %s = %s %s %s to %s\n"
          tmp instr (type-to-ir src) (vv val) (type-to-ir target))
        (return (alloc-val target tmp))))
    (return null)))

; ============================================================
; Stage 8: defcast registry + implicit safe coercion at call sites
; ============================================================

(defn register-cast-rule:void (from:ptr to:ptr ir-name:ptr)
  (when (>= g-cast-rules-len MAX-CAST-RULES)
    (fprintf stderr "nucleusc: too many defcast rules\n") (exit 1))
  (let (cr:ptr:CastRule (cast ptr:CastRule
                          (ptr+ (cast ptr:CastRule g-cast-rules) g-cast-rules-len)))
    (.set! cr from from)
    (.set! cr to to)
    (.set! cr ir-name ir-name)
    (inc! g-cast-rules-len)))

(defn lookup-cast-rule:?CastRule (from:ptr to:ptr)
  (let (i:i32 0)
    (while (< i g-cast-rules-len)
      (let (cr:ptr:CastRule (cast ptr:CastRule
                              (ptr+ (cast ptr:CastRule g-cast-rules) i)))
        (when (and (!= (type-eq (cr from) from) 0)
                   (!= (type-eq (cr to) to) 0))
          (return (cast ptr cr))))
      (inc! i)))
  (return null))

; Coerce a Val to a target type at a call site (or any implicit context):
; same-kind identity, int↔int via coerce-int-val, f32→f64 fpext, and any
; user-registered defcast rule. Returns null when no safe conversion applies.
(defn safe-coerce-val:?Val (v:ptr target:ptr line:i32)
  (let (vv:ptr:Val (cast ptr:Val v)
        src:ptr (vv type)
        sk:i32 ((cast ptr:Type src) kind)
        dk:i32 ((cast ptr:Type target) kind))
    (when (= sk dk) (return v))
    (when (and (!= (is-int-type src) 0) (!= (is-int-type target) 0))
      (return (coerce-int-val v target line)))
    (when (and (= sk TY-F32) (= dk TY-F64))
      (let (tmp:ptr (new-tmp))
        (fprintf g-body-stream "  %s = fpext float %s to double\n" tmp (vv val))
        (return (alloc-val target tmp))))
    (let (rule:ptr (lookup-cast-rule src target))
      (when (!= rule null)
        (let (cr:ptr:CastRule (cast ptr:CastRule rule)
              tmp:ptr (new-tmp))
          (fprintf g-body-stream "  %s = call %s %s(%s %s)\n"
            tmp (type-to-ir target) (cr ir-name) (type-to-ir src) (vv val))
          (return (alloc-val target tmp)))))
    (return null)))

(defn emit-defcast:void (call:ptr)
  (let (cc:ptr:Node (cast ptr:Node call))
    (when (!= (node-len cc) 4)
      (die-at (cc line) "defcast: expects (defcast From To conv-fn)"))
    (let (from-node:ptr (node-at cc 1)
          to-node:ptr   (node-at cc 2)
          fn-node:ptr:Node (cast ptr:Node (node-at cc 3))
          from:ptr (parse-type-from-node from-node (cc line))
          to:ptr   (parse-type-from-node to-node   (cc line)))
      (when (!= (fn-node kind) NODE-SYM)
        (die-at (fn-node line) "defcast: conv-fn must be a symbol"))
      ; Reject pairs already covered by built-in safe-coerce rules.
      (let (fk:i32 ((cast ptr:Type from) kind)
            tk:i32 ((cast ptr:Type to) kind))
        (when (= fk tk)
          (die-at (cc line) "defcast: identity cast is implicit; rule rejected"))
        (when (and (!= (is-int-type from) 0) (!= (is-int-type to) 0))
          (die-at (cc line)
            "defcast: integer↔integer pairs are handled by built-in coercion; rule rejected"))
        (when (and (= fk TY-F32) (= tk TY-F64))
          (die-at (cc line)
            "defcast: f32→f64 is handled by built-in coercion; rule rejected")))
      (when (!= (lookup-cast-rule from to) null)
        (die-at (cc line) "defcast: a rule for this pair is already registered"))
      (let (sym:ptr (scope-lookup g-globals (fn-node s)))
        (when (= sym null)
          (die-at (fn-node line) (fmt-s "defcast: unknown function '%s'" (fn-node s))))
        (let (ss:ptr:Sym (cast ptr:Sym sym)
              ft:ptr:Type (cast ptr:Type (ss type)))
          (when (!= (ft kind) TY-FN)
            (die-at (fn-node line) (fmt-s "defcast: '%s' is not a function" (fn-node s))))
          (when (!= (ft num-params) 1)
            (die-at (fn-node line) (fmt-s "defcast: '%s' must take exactly one argument" (fn-node s))))
          (when (!= (ft variadic) 0)
            (die-at (fn-node line) (fmt-s "defcast: '%s' must not be variadic" (fn-node s))))
          (when (!= (ft has-rest) 0)
            (die-at (fn-node line) (fmt-s "defcast: '%s' must not use &rest" (fn-node s))))
          (let (param0:ptr (aref (cast ptr:ptr (ft params)) 0))
            (when (= (type-eq param0 from) 0)
              (die-at (fn-node line)
                (fmt-2s "defcast: '%s' parameter type does not match From; expected %s"
                  (fn-node s) (type-to-ir from)))))
          (when (= (type-eq (ft ret) to) 0)
            (die-at (fn-node line)
              (fmt-2s "defcast: '%s' return type does not match To; expected %s"
                (fn-node s) (type-to-ir to))))
          (register-cast-rule from to (ss ir-name)))))))

; The widen / untyped-int-literal resolution tier for a binary operator
; (Stage 9 §10.3). Untyped int literals (a-node/b-node denoting an int literal)
; adopt the other operand's numeric type; otherwise the narrower int/float widens
; to the wider. Returns a 2-element Val* array [a' b'] sharing a type, or null
; when no adaptation applies (operands already match, or can't be reconciled
; here — the caller's checks then fire). Literalness is probed only after the
; types are known to differ, so the same-type hot path costs nothing.
(defn binop-coerce:ptr (a:ptr b:ptr a-node:ptr b-node:ptr line:i32)
  (let (at:ptr ((cast ptr:Val a) type)
        bt:ptr ((cast ptr:Val b) type))
    (when (!= (type-eq at bt) 0) (return null))
    (let (a-num:i32 (or (!= (is-int-type at) 0) (!= (is-float-type at) 0))
          b-num:i32 (or (!= (is-int-type bt) 0) (!= (is-float-type bt) 0)))
      (when (or (= a-num 0) (= b-num 0)) (return null)))
    (let (a-lit:i32 (node-is-int-literal a-node)
          b-lit:i32 (node-is-int-literal b-node))
    (let (target:ptr null)
      (cond (and (!= a-lit 0) (= b-lit 0)) (set! target bt)
            (and (!= b-lit 0) (= a-lit 0)) (set! target at)
            true
              (do
                ; Both typed: int+float (non-literal) needs an explicit cast.
                (when (and (!= (is-float-type at) 0) (!= (is-int-type bt) 0)) (return null))
                (when (and (!= (is-int-type at) 0) (!= (is-float-type bt) 0)) (return null))
                (if (!= (is-float-type at) 0)
                  (if (>= (float-width at) (float-width bt)) (set! target at) (set! target bt))
                  (do
                    (when (!= (is-unsigned at) (is-unsigned bt)) (return null))
                    (if (>= (int-width at) (int-width bt)) (set! target at) (set! target bt))))))
      (when (= target null) (return null))
      (let (na:ptr (coerce-num-val a target line)
            nb:ptr (coerce-num-val b target line))
        (when (or (= na null) (= nb null)) (return null))
        (let (pair:ptr (arena-alloc (* (cast i64 2) (ptr-bytes))))
          (aset! (cast ptr:ptr pair) 0 na)
          (aset! (cast ptr:ptr pair) 1 nb)
          (return pair)))))))

; Emit an operator's inline instruction given already-emitted operand Vals. This
; is the front-end inline peephole (§10.3): a built-in numeric/pointer operator
; lowers to a single `add nsw`/`icmp slt`/`fadd`/… instruction, never a call.
; a-node/b-node are the operand source nodes (or null), consulted only to flag
; untyped int literals for the widen/adapt tier when the operand types differ. For
; operands that already share a type, the IR is byte-identical to the pre-Stage-9
; emit-binop (binop-coerce returns null and nothing is inserted).
(defn emit-binop-vals:ref:Val (a:ptr b:ptr a-node:ptr b-node:ptr op:ptr line:i32)
  (let (bop:ptr:BinOp (cast ptr:BinOp op)
        av:ptr:Val (cast ptr:Val a)
        bv:ptr:Val (cast ptr:Val b))
    ; C-string equality (Eq): =/!= where *either* operand is CStr lower to a
    ; strcmp content comparison, not pointer identity (the other operand must be
    ; a pointer/CStr — a string literal is CStr, so `(= some-ptr "lit")` does a
    ; content test). strcmp is declared by the prelude's (include string); CStr
    ; only supports = and != for now (no ordering). Two plain `ptr` operands fall
    ; through to the identity comparison below.
    (when (or (-> av (_ type) (cast ptr:Type _) (_ kind) (= _ TY-CSTR))
              (-> bv (_ type) (cast ptr:Type _) (_ kind) (= _ TY-CSTR)))
      (when (or (= (is-ptr-like (av type)) 0) (= (is-ptr-like (bv type)) 0))
        (die-at line (fmt-s "%s: a CStr compares only with a CStr or pointer" (bop name))))
      (let (op-name:ptr (bop name))
        (when (and (!= op-name "=") (!= op-name "!="))
          (die-at line (fmt-s "%s: CStr supports only = and != (Eq)" op-name)))
        (let (c:ptr (new-tmp))
          (fprintf g-body-stream "  %s = call i32 @strcmp(ptr %s, ptr %s)\n"
            c (av val) (bv val))
          (let (r:ptr (new-tmp)
                icmp-op:ptr "eq")
            (when (= op-name "!=") (set! icmp-op "ne"))
            (fprintf g-body-stream "  %s = icmp %s i32 %s, 0\n" r icmp-op c)
            (return (alloc-val ty-i1 r))))))
    ; Pointer comparison
    (when (and (-> av (_ type) (cast ptr:Type _) (_ kind) (= _ TY-PTR))
             (-> bv (_ type) (cast ptr:Type _) (_ kind) (= _ TY-PTR)))
      (when (!= (bop is-cmp) 0)
        (let (tmp:ptr (new-tmp))
          (fprintf g-body-stream "  %s = %s ptr %s, %s\n"
            tmp (bop instr) (av val) (bv val))
          (return (alloc-val ty-i1 tmp)))))
    ; Widen / adapt mixed numeric operands (untyped int literals + int/float widening).
    (let (adapted:ptr (binop-coerce a b a-node b-node line))
      (when (!= adapted null)
        (set! av (cast ptr:Val (aref (cast ptr:ptr adapted) 0)))
        (set! bv (cast ptr:Val (aref (cast ptr:ptr adapted) 1)))))
    ; Float arithmetic / comparison
    (when (or (!= (is-float-type (av type)) 0) (!= (is-float-type (bv type)) 0))
      (when (or (= (is-float-type (av type)) 0) (= (is-float-type (bv type)) 0))
        (die-at line (fmt-s "%s: mixed float and non-float operands — use explicit cast" (bop name))))
      (when (!= (-> av (_ type) (cast ptr:Type _) (_ kind))
               (-> bv (_ type) (cast ptr:Type _) (_ kind)))
        (die-at line (fmt-s "%s float operand width mismatch — use explicit cast" (bop name))))
      (let (finstr:ptr null
            op-name:ptr (bop name))
        (cond (or (or (= op-name "+") (= op-name "_+"))
                      (= op-name "_+"))
                (set! finstr "fadd")
              (or (or (= op-name "-") (= op-name "_-"))
                      (= op-name "_-"))
                (set! finstr "fsub")
              (or (or (= op-name "*") (= op-name "_*"))
                      (= op-name "_*"))
                (set! finstr "fmul")
              (or (or (= op-name "/") (= op-name "_/"))
                      (= op-name "_/"))
                (set! finstr "fdiv")
              (= op-name "%")  (set! finstr "frem")
              (= op-name "=")  (set! finstr "fcmp oeq")
              (= op-name "!=") (set! finstr "fcmp one")
              (= op-name "<")  (set! finstr "fcmp olt")
              (= op-name "<=") (set! finstr "fcmp ole")
              (= op-name ">")  (set! finstr "fcmp ogt")
              (= op-name ">=") (set! finstr "fcmp oge")
              true (do))
        (when (= finstr null)
          (die-at line (fmt-s "%s does not apply to floats" op-name)))
        (let (tmp:ptr (new-tmp))
          (fprintf g-body-stream "  %s = %s %s %s, %s\n"
            tmp finstr (type-to-ir (av type)) (av val) (bv val))
          (let (rtype:ptr (av type))
            (when (!= (bop is-cmp) 0) (set! rtype ty-i1))
            (return (alloc-val rtype tmp))))))
    (when (or (= (is-int-type (av type)) 0) (= (is-int-type (bv type)) 0))
      (die-at line (fmt-s "%s expects integer operands" (bop name))))
    (when (!= (is-unsigned (av type)) (is-unsigned (bv type)))
      (die-at line (fmt-s "%s: mixed signed/unsigned operands — use explicit cast" (bop name))))
    (when (!= (-> av (_ type) (cast ptr:Type _) (_ kind))
             (-> bv (_ type) (cast ptr:Type _) (_ kind)))
      (die-at line (fmt-s "%s operand type mismatch" (bop name))))
    (let (tmp:ptr (new-tmp)
          instr:ptr (bop instr))
      (when (!= (is-unsigned (av type)) 0) (set! instr (bop instr-u)))
      (fprintf g-body-stream "  %s = %s %s %s, %s\n"
        tmp instr (type-to-ir (av type)) (av val) (bv val))
      (let (rtype:ptr (av type))
        (when (!= (bop is-cmp) 0) (set! rtype ty-i1))
        (return (alloc-val rtype tmp))))))

(defn emit-binop:ref:Val (call:ptr scope:ref:Scope op:ptr)
  (let (cc:ptr:Node (cast ptr:Node call)
        bop:ptr:BinOp (cast ptr:BinOp op))
    (when (!= (node-len cc) 3)
      (die-at (cc line) (fmt-s "%s expects 2 args" (bop name))))
    (let (a:ref:Val (emit-node (node-at cc 1) scope)
          b:ref:Val (emit-node (node-at cc 2) scope))
      (return (emit-binop-vals a b (node-at cc 1) (node-at cc 2) op (cc line))))))

; ============================================================
; Generic (polymorphism) registry
; ============================================================

(defn generic-lookup:?Generic (name:ptr)
  (let (i:i32 0)
    (while (< i g-num-generics)
      (let (g:ptr:Generic (cast ptr:Generic (ptr+ (cast ptr:Generic g-generics) i)))
        (when (= (g name) name)
          (return (cast ptr g))))
      (inc! i)))
  (return null))

(defn generic-new:ref:Generic (name:ptr)
  (when (= g-num-generics g-cap-generics)
    (let (nc:i32 64)
      (when (!= g-cap-generics 0) (set! nc (* g-cap-generics 2)))
      (let (ng:ptr (arena-alloc (* (cast i64 nc) (sizeof Generic))))
        (when (!= g-num-generics 0)
          (memcpy ng g-generics (* (cast i64 g-num-generics) (sizeof Generic))))
        (set! g-generics ng)
        (set! g-cap-generics nc))))
  (let (g:ptr:Generic (cast ptr:Generic (ptr+ (cast ptr:Generic g-generics) g-num-generics)))
    (.set! g name name)
    (.set! g methods (arena-alloc (* (cast i64 4) (ptr-bytes))))
    (.set! g num-methods 0)
    (.set! g cap 4)
    (.set! g finalized 0)
    (.set! g mangled 0)
    (inc! g-num-generics)
    (return (cast ref:Generic g))))

(defn generic-add-method:void (g:ptr m:ptr)
  (let (gg:ptr:Generic (cast ptr:Generic g))
    (when (= (gg num-methods) (gg cap))
      (let (nc:i32 (* (gg cap) 2)
            nm:ptr (arena-alloc (* (cast i64 nc) (ptr-bytes))))
        (memcpy nm (gg methods) (* (cast i64 (gg num-methods)) (ptr-bytes)))
        (.set! gg methods nm)
        (.set! gg cap nc)))
    (aset! (cast ptr:ptr (gg methods)) (gg num-methods) m)
    (.set! gg num-methods (+ (gg num-methods) 1))))

; Seed the operator family as intrinsic generics. Each intrinsic method defers
; to emit-binop (which performs the numeric type selection), so operator IR is
; byte-identical to the pre-dispatch compiler.
(defn init-generics:void ()
  (let (i:i32 0)
    (while (< i g-num-binops)
      (let (bop:ptr:BinOp (cast ptr:BinOp (ptr+ (cast ptr:BinOp g-binops) i))
            g:ptr (generic-new (bop name))
            m:ptr:Method (new Method))
        (.set! m param-types null)
        (.set! m num-params 2)
        (.set! m ret-type null)
        (.set! m has-rest 0)
        (.set! m variadic 0)
        (.set! m kind METHOD-INTRINSIC)
        (.set! m ir-name null)
        (.set! m fn-type null)
        (.set! m binop (cast ptr bop))
        (.set! m body null)
        (generic-add-method g (cast ptr m)))
      (inc! i))))

; Structural type equality. Primitive types are singletons, so pointer equality
; handles them; structs are equal iff they share a StructDef; pointers compare
; their pointee (untyped ptr has elem=null, distinct from typed ptr).
(defn type-eq:i32 (a:ptr b:ptr)
  (when (= a b) (return 1))
  (when (or (= a null) (= b null)) (return 0))
  (let (aa:ptr:Type (cast ptr:Type a)
        bb:ptr:Type (cast ptr:Type b))
    (when (!= (aa kind) (bb kind)) (return 0))
    (when (= (aa kind) TY-STRUCT)
      (if (= (aa sdef) (bb sdef)) (return 1) (return 0)))
    (when (= (aa kind) TY-PTR)
      (return (type-eq (aa elem) (bb elem))))
    ; Abstract type variables (A2 check only): equal iff the same variable of the
    ; same template (sdef = owning Method*, num-params = tyvar index).
    (when (= (aa kind) TY-TYVAR)
      (if (and (= (aa sdef) (bb sdef)) (= (aa num-params) (bb num-params)))
        (return 1) (return 0)))
    (return 1)))

(defn params-type-eq:i32 (pa:ptr pb:ptr n:i32)
  (let (i:i32 0)
    (while (< i n)
      (when (= (type-eq (aref (cast ptr:ptr pa) i) (aref (cast ptr:ptr pb) i)) 0)
        (return 0))
      (inc! i)))
  (return 1))

; A short, dot-free token naming a type for use in mangled symbols. Pointers
; get a "p" prefix on their pointee so ptr:Circle and Circle stay distinct.
(defn type-mangle-token:ptr (t:ptr)
  (let (tt:ptr:Type (cast ptr:Type t)
        k:i32 (tt kind))
    (when (= k TY-VOID) (return "void"))
    (when (= k TY-I1)   (return "i1"))
    (when (= k TY-I8)   (return "i8"))
    (when (= k TY-I16)  (return "i16"))
    (when (= k TY-I32)  (return "i32"))
    (when (= k TY-I64)  (return "i64"))
    (when (= k TY-UI8)  (return "u8"))
    (when (= k TY-UI16) (return "u16"))
    (when (= k TY-UI32) (return "u32"))
    (when (= k TY-UI64) (return "u64"))
    (when (= k TY-F32)  (return "f32"))
    (when (= k TY-F64)  (return "f64"))
    (when (= k TY-PTR)
      (if (= (tt elem) null)
        (return "ptr")
        (return (fmt-s "p%s" (type-mangle-token (tt elem))))))
    (when (= k TY-STRUCT)
      (return (-> tt (_ sdef) (cast ptr:StructDef _) (_ name))))
    (when (= k TY-FN) (return "fn"))
    (when (= k TY-CSTR) (return "cstr"))
    (return "x")))

; A safe, distinct IR token for a generic name. Operators (whose source symbols
; — `=`, `<`, `_+`, … — are not valid LLVM identifier characters and would
; collide under blanket underscore-sanitizing) map to readable mnemonics; other
; names pass through sanitize-for-ir unchanged. Used when a name carrying an
; operator method is overloaded and its methods must take mangled symbols (§10.3).
(defn op-name-token:ptr (name:ptr)
  (when (= name "_+") (return "add"))
  (when (= name "_-") (return "sub"))
  (when (= name "_*") (return "mul"))
  (when (= name "_/") (return "div"))
  (when (= name "%")  (return "rem"))
  (when (= name "=")  (return "eq"))
  (when (= name "!=") (return "ne"))
  (when (= name "<")  (return "lt"))
  (when (= name "<=") (return "le"))
  (when (= name ">")  (return "gt"))
  (when (= name ">=") (return "ge"))
  (when (= name "bit-and") (return "band"))
  (when (= name "bit-or")  (return "bor"))
  (when (= name "bit-xor") (return "bxor"))
  (when (= name "bit-shl") (return "bshl"))
  (when (= name "bit-shr") (return "bshr"))
  (return (sanitize-for-ir name)))

; "@name.tok1.tok2..." for an overloaded method.
(defn mangle-fn-name:ptr (fname:ptr param-types:ptr nparams:i32)
  (let (acc:ptr (fmt-s "@%s" (op-name-token fname))
        i:i32 0)
    (while (< i nparams)
      (set! acc (fmt-2s "%s.%s" acc (type-mangle-token (aref (cast ptr:ptr param-types) i))))
      (inc! i))
    (return acc)))

; A type's source spelling as a colon-joined string: the inverse of the type
; parser. Serves two roles — the key into the conformance registry (matching the
; subject spelling of `extend`), and the replacement text when substituting a
; concrete type for a type variable's occurrences in a retained generic body.
; Pointers nest as ptr:elem; structs/primitives are their bare names.
(defn type-spelling:ptr (t:ptr)
  (let (tt:ptr:Type (cast ptr:Type t)
        k:i32 (tt kind))
    (when (= k TY-VOID) (return "void"))
    (when (= k TY-I1)   (return "i1"))
    (when (= k TY-I8)   (return "i8"))
    (when (= k TY-I16)  (return "i16"))
    (when (= k TY-I32)  (return "i32"))
    (when (= k TY-I64)  (return "i64"))
    (when (= k TY-UI8)  (return "ui8"))
    (when (= k TY-UI16) (return "ui16"))
    (when (= k TY-UI32) (return "ui32"))
    (when (= k TY-UI64) (return "ui64"))
    (when (= k TY-F32)  (return "f32"))
    (when (= k TY-F64)  (return "f64"))
    (when (= k TY-STRUCT) (return (-> tt (_ sdef) (cast ptr:StructDef _) (_ name))))
    (when (= k TY-CSTR) (return "CStr"))
    (when (= k TY-PTR)
      (if (= (tt elem) null)
        (return "ptr")
        (return (fmt-s "ptr:%s" (type-spelling (tt elem))))))
    (return "ptr")))

(defn generic-find-method-exact:?Method (g:ptr param-types:ptr nparams:i32)
  (let (gg:ptr:Generic (cast ptr:Generic g)
        i:i32 0)
    (while (< i (gg num-methods))
      (let (m:ptr:Method (cast ptr:Method (aref (cast ptr:ptr (gg methods)) i)))
        (when (and (= (m kind) METHOD-USER)
                   (and (= (m num-params) nparams)
                        (!= (params-type-eq (m param-types) param-types nparams) 0)))
          (return (cast ptr m))))
      (inc! i))
    (return null)))

; Fixed parameter count of a defn param list: the raw count, minus one if a
; &rest marker is present (the marker itself is not a parameter).
(defn defn-params-count:i32 (params-node:ptr)
  (let (raw:i32 (node-len params-node)
        n:i32 (node-len params-node)
        i:i32 0)
    (while (< i raw)
      (let (sp:ptr:Node (cast ptr:Node (node-at params-node i)))
        (when (= (sp kind) NODE-SYM)
          (when (= (sp s) "&rest") (set! n (- n 1)))
          (when (= (sp s) "&optional") (set! n (- n 1)))))
      (inc! i))
    (return n)))

; The fixed parameter types of a defn param list as a ptr-array (&rest-aware:
; the &rest marker is skipped and the rest parameter is typed ptr). Shared by
; prescan, .nuch export, and method lookup so the three stay consistent.
(defn defn-params-to-types:ptr (params-node:ptr)
  (let (raw:i32 (node-len params-node)
        has-rest:i32 0
        rest-idx:i32 -1
        opt-idx:i32 -1)
    (let (si:i32 0)
      (while (< si raw)
        (let (sp:ptr:Node (cast ptr:Node (node-at params-node si)))
          (when (= (sp kind) NODE-SYM)
            (when (= (sp s) "&rest") (set! has-rest 1) (set! rest-idx si))
            (when (= (sp s) "&optional") (set! opt-idx si))))
        (inc! si)))
    (let (nparams:i32 raw)
      (when (!= has-rest 0) (set! nparams (- nparams 1)))
      (when (!= opt-idx -1) (set! nparams (- nparams 1)))
      (let (ptypes:ptr null)
        (when (> nparams 0)
          (set! ptypes (arena-alloc (* (cast i64 nparams) (ptr-bytes)))))
        (let (i:i32 0
              di:i32 0)
          (while (< i raw)
            (let (skip:i32 0)
              (when (and (!= has-rest 0) (= i rest-idx)) (set! skip 1))
              (when (= i opt-idx) (set! skip 1))
              (when (= skip 0)
                (let (p:ptr (node-at params-node i)
                      pn:ptr null
                      spec:ptr (node-at params-node i))
                  ; Optional params are (name:type default) lists — type is on the head.
                  (when (and (!= opt-idx -1) (> i opt-idx))
                    (set! spec (node-at p 0)))
                  (let (pty:ptr (extract-name-and-type spec (cast ptr:ptr (addr-of pn))
                                                       ((cast ptr:Node spec) line)))
                    (when (= pty null) (set! pty ty-i32))
                    (when (and (!= has-rest 0) (= di (- nparams 1)))
                      (set! pty ty-ptr))
                    (aset! (cast ptr:ptr ptypes) di pty)
                    (inc! di)))))
            (inc! i)))
        (return ptypes)))))

; Register one defn signature as a USER method of its name's generic. Called
; from prescan-defn-signatures; mangling/scope binding is decided later by
; finalize-generics once the full method set per name is known.
(defn generic-register-method:ref:Method (fname:ptr ret:ptr param-types:ptr nparams:i32
                                   has-rest:i32 variadic:i32 body:ptr)
  (let (g:ptr (generic-lookup fname))
    (when (= g null) (set! g (generic-new fname)))
    (let (ft:ptr:Type (cast ptr:Type (make-type TY-FN)))
      (.set! ft ret ret)
      (.set! ft num-params nparams)
      (.set! ft params param-types)
      (.set! ft variadic variadic)
      (.set! ft has-rest has-rest)
      (let (m:ref:Method (new Method))
        (.set! m param-types param-types)
        (.set! m num-params nparams)
        (.set! m ret-type ret)
        (.set! m has-rest has-rest)
        (.set! m variadic variadic)
        (.set! m kind METHOD-USER)
        (.set! m ir-name null)
        (.set! m fn-type (cast ptr ft))
        (.set! m binop null)
        (.set! m body body)
        (generic-add-method g (cast ptr m))
        (return m)))))

; Decide mangling for every not-yet-finalized user generic. A solitary concrete
; name keeps its unmangled @name and is bound in g-globals (so forward references
; and the byte-identical single-function path keep working). An overloaded set —
; or any name carrying a bounded-generic template — gets mangled per-method names
; and dispatches through the registry (templates are stamped on demand).
(defn finalize-generics:void ()
  (let (gi:i32 0)
    (while (< gi g-num-generics)
      (let (gg:ptr:Generic (cast ptr:Generic (ptr+ (cast ptr:Generic g-generics) gi)))
        (when (and (= (gg finalized) 0) (> (gg num-methods) 0))
          ; Tally the method kinds. An operator name carries an intrinsic seed
          ; method (§9.2); a user overload of that operator adds METHOD-USER
          ; methods alongside it (§10.3 operators-as-functions).
          (let (has-generic:i32 0
                has-intrinsic:i32 0
                n-user:i32 0
                gk:i32 0)
            (while (< gk (gg num-methods))
              (let (mk:ptr:Method (cast ptr:Method (aref (cast ptr:ptr (gg methods)) gk)))
                (cond (= (mk kind) METHOD-GENERIC)   (set! has-generic 1)
                      (= (mk kind) METHOD-INTRINSIC) (set! has-intrinsic 1)
                      true                              (inc! n-user)))
              (inc! gk))
            ; A pure operator (only intrinsic seeds, no user/generic methods) needs
            ; no mangling and dispatches via the emit-binop peephole. Leave it
            ; unfinalized so a later user overload (possibly from an import) is
            ; picked up; everything else finalizes now.
            (when (or (> n-user 0) (!= has-generic 0))
              (if (and (= has-intrinsic 0) (and (= has-generic 0) (= n-user 1)))
                (let (m0:ptr:Method (cast ptr:Method (aref (cast ptr:ptr (gg methods)) 0)))
                  (.set! gg mangled 0)
                  (.set! m0 ir-name (fmt-s "@%s" (gg name)))
                  (scope-define g-globals (gg name) (m0 fn-type) (m0 ir-name) 0))
                (do
                  (.set! gg mangled 1)
                  (let (i:i32 0)
                    (while (< i (gg num-methods))
                      (let (mi:ptr:Method (cast ptr:Method (aref (cast ptr:ptr (gg methods)) i)))
                        (when (= (mi kind) METHOD-USER)
                          (let (j:i32 0)
                            (while (< j i)
                              (let (mj:ptr:Method (cast ptr:Method (aref (cast ptr:ptr (gg methods)) j)))
                                (when (and (= (mj kind) METHOD-USER)
                                           (and (= (mi num-params) (mj num-params))
                                                (!= (params-type-eq (mi param-types) (mj param-types)
                                                                    (mi num-params)) 0)))
                                  (die-at (-> mi (_ body) (cast ptr:Node _) (_ line))
                                    (fmt-s "duplicate method signature for overloaded '%s'" (gg name)))))
                              (inc! j)))
                          (.set! mi ir-name
                            (mangle-fn-name (gg name) (mi param-types) (mi num-params)))))
                      (inc! i)))))
              (.set! gg finalized 1)))))
      (inc! gi))))

; Can an argument of type `at` (an untyped int literal when is-lit≠0) be passed
; to a parameter of type `pt` by exact match or a safe widen / literal adaptation
; (§10.3 resolution tiers)? Widening never narrows a typed value; an untyped int
; literal adapts to any integer (and to a float) since its value is known.
(defn arg-adapts:i32 (at:ptr pt:ptr is-lit:i32)
  (when (= at null) (return 0))
  (when (!= (type-eq at pt) 0) (return 1))
  (let (a-int:i32 (is-int-type at)   a-flt:i32 (is-float-type at)
        p-int:i32 (is-int-type pt)   p-flt:i32 (is-float-type pt))
    (when (and (!= a-int 0) (!= p-int 0))
      (when (!= is-lit 0) (return 1))
      (when (and (>= (int-width pt) (int-width at)) (= (is-unsigned at) (is-unsigned pt)))
        (return 1))
      (return 0))
    (when (and (!= a-flt 0) (!= p-flt 0))
      (if (>= (float-width pt) (float-width at)) (return 1) (return 0)))
    (when (and (!= a-int 0) (!= p-flt 0))
      (if (!= is-lit 0) (return 1) (return 0))))
  (return 0))

; Select the method of a generic for a concrete argument-type tuple.
; Tier 0: an exact concrete method (type-eq on every param) — concrete beats
; generic (§8.6). Tier 1: a bounded-generic template whose type variables bind
; consistently and whose bound types satisfy the &where protocol constraints;
; on a unique tier-1 match the template is monomorphized (stamped + cached) and
; the resulting concrete method returned. Tier 2: a concrete method reachable by
; a safe widen / untyped-int-literal adaptation on every argument (§10.3); the
; caller (emit-generic-call) coerces the args to the chosen params. arg-nodes is
; the parallel array of argument source nodes (or null) used to spot literals.
(defn generic-resolve:ref:Method (g:ptr argtypes:ptr arg-nodes:ptr nargs:i32 line:i32)
  (let (gg:ptr:Generic (cast ptr:Generic g)
        found:?Method null
        i:i32 0)
    (while (< i (gg num-methods))
      (let (m:ptr:Method (cast ptr:Method (aref (cast ptr:ptr (gg methods)) i)))
        (when (and (= (m kind) METHOD-USER)
                   (and (= (m num-params) nargs)
                        (!= (params-type-eq (m param-types) argtypes nargs) 0)))
          (set! found (cast ptr m))))
      (inc! i))
    (when (!= found null) (return found))
    ; tier 1: bounded-generic templates.
    (let (cand:ptr null
          cand-bound:ptr null
          ncand:i32 0
          constraint-fail:i32 0
          j:i32 0)
      (while (< j (gg num-methods))
        (let (m:ptr:Method (cast ptr:Method (aref (cast ptr:ptr (gg methods)) j)))
          (when (= (m kind) METHOD-GENERIC)
            (let (bound:ptr (arena-alloc (* (cast i64 (+ (m num-tyvars) 1)) (ptr-bytes))))
              (when (!= (generic-method-bind (cast ptr m) argtypes nargs bound) 0)
                (if (!= (generic-constraints-ok (cast ptr m) bound line) 0)
                  (do (set! cand (cast ptr m)) (set! cand-bound bound) (inc! ncand))
                  (set! constraint-fail 1))))))
        (inc! j))
      (when (> ncand 1)
        (die-at line (fmt-s "ambiguous generic match for '%s'" (gg name))))
      (when (= ncand 1)
        (return (generic-instantiate g cand cand-bound argtypes nargs line)))
      ; tier 2: widen / untyped-int-literal adaptation on a concrete method.
      (let (wcand:?Method null
            wn:i32 0
            k:i32 0)
        (while (< k (gg num-methods))
          (let (m:ptr:Method (cast ptr:Method (aref (cast ptr:ptr (gg methods)) k)))
            (when (and (= (m kind) METHOD-USER)
                       (and (= (m has-rest) 0) (= (m num-params) nargs)))
              (let (ok:i32 1
                    a:i32 0)
                (while (< a nargs)
                  (let (is-lit:i32 0)
                    (when (!= arg-nodes null)
                      (set! is-lit (node-is-int-literal (aref (cast ptr:ptr arg-nodes) a))))
                    (when (= (arg-adapts (aref (cast ptr:ptr argtypes) a)
                                         (aref (cast ptr:ptr (m param-types)) a) is-lit) 0)
                      (set! ok 0)))
                  (inc! a))
                (when (!= ok 0) (set! wcand (cast ptr m)) (inc! wn)))))
          (inc! k))
        (when (> wn 1)
          (die-at line (fmt-s "ambiguous overload for '%s' under argument widening" (gg name))))
        (when (!= wcand null) (return wcand)))
      (when (!= constraint-fail 0)
        (die-at line
          (fmt-s "no matching method for '%s': arguments do not satisfy the required protocol constraint"
                 (gg name))))
      (die-at line (fmt-s "no matching method for overloaded '%s' with given argument types"
                          (gg name))))))

; Resolve an operator call to a USER overload (exact, then a unique widen/literal
; match), or null to fall back to the built-in numeric/pointer peephole. Unlike
; generic-resolve this never dies — an unmatched operator is the common case and
; simply uses its intrinsic seed. Shared by emit (call vs inline) and node-type
; (the overload's return type vs the intrinsic's) so the two cannot drift.
(defn operator-user-resolve:?Method (g:ptr argtypes:ptr arg-nodes:ptr nargs:i32)
  (let (gg:ptr:Generic (cast ptr:Generic g)
        i:i32 0)
    (while (< i (gg num-methods))
      (let (m:ptr:Method (cast ptr:Method (aref (cast ptr:ptr (gg methods)) i)))
        (when (and (= (m kind) METHOD-USER)
                   (and (= (m num-params) nargs)
                        (!= (params-type-eq (m param-types) argtypes nargs) 0)))
          (return (cast ptr m))))
      (inc! i))
    (let (wcand:ptr null
          wn:i32 0
          k:i32 0)
      (while (< k (gg num-methods))
        (let (m:ptr:Method (cast ptr:Method (aref (cast ptr:ptr (gg methods)) k)))
          (when (and (= (m kind) METHOD-USER)
                     (and (= (m has-rest) 0) (= (m num-params) nargs)))
            (let (ok:i32 1
                  a:i32 0)
              (while (< a nargs)
                (let (is-lit:i32 0)
                  (when (!= arg-nodes null)
                    (set! is-lit (node-is-int-literal (aref (cast ptr:ptr arg-nodes) a))))
                  (when (= (arg-adapts (aref (cast ptr:ptr argtypes) a)
                                       (aref (cast ptr:ptr (m param-types)) a) is-lit) 0)
                    (set! ok 0)))
                (inc! a))
              (when (!= ok 0) (set! wcand (cast ptr m)) (inc! wn)))))
        (inc! k))
      (when (= wn 1) (return wcand)))
    (return null)))

; The emitted symbol for a defn being codegen'd: the mangled name for an
; overloaded method, else the unmangled @name (also the fallback when no
; generic was registered, e.g. compile-time/REPL defns).
(defn defn-ir-name:ptr (fname:ptr param-types:ptr nparams:i32)
  (let (g:ptr (generic-lookup fname))
    (when (!= g null)
      (let (m:ptr (generic-find-method-exact g param-types nparams))
        (when (and (!= m null) (!= (-> m (cast ptr:Method _) (_ ir-name)) null))
          (return (-> m (cast ptr:Method _) (_ ir-name)))))))
  (return (fmt-s "@%s" fname)))

(defn defn-is-mangled:i32 (fname:ptr)
  (let (g:ptr (generic-lookup fname))
    (when (!= g null)
      (return (-> g (cast ptr:Generic _) (_ mangled)))))
  (return 0))

; If a defn form's name is overloaded, return that method's mangled @-symbol;
; else null. Used by .nuch export to declare overloads under their real symbols.
(defn defn-form-mangled-name:ptr (form:ptr)
  (let (fname:ptr null
        ret:ptr (extract-name-and-type (node-at form 1) (cast ptr:ptr (addr-of fname))
                                        ((cast ptr:Node (node-at form 1)) line)))
    (when (= ret null) (return null))
    (let (g:ptr (generic-lookup fname))
      (when (= g null) (return null))
      (when (= (-> g (cast ptr:Generic _) (_ mangled)) 0) (return null))
      (let (params-node:ptr (node-at form 2)
            m:ptr (generic-find-method-exact g (defn-params-to-types params-node)
                                             (defn-params-count params-node)))
        (when (= m null) (return null))
        (return (-> m (cast ptr:Method _) (_ ir-name)))))))

; ============================================================
; Bounded generic defn (Stage 9 rung 4)
; ============================================================
; A generic defn carries a `&where` clause in its parameter list:
;   (defn max:T (a:T b:T &where (Ord T)) ...)
; Type variables are declared-only (named in a constraint). The template body is
; retained and monomorphized — substitute concrete types, stamp, cache — at each
; call site whose argument types bind the variables and satisfy the constraints.

; Index of the `&where` marker in a (desugared) parameter list, or -1.
(defn params-where-index:i32 (params-node:ptr)
  (let (raw:i32 (node-len params-node) i:i32 0)
    (while (< i raw)
      (let (e:ptr:Node (cast ptr:Node (node-at params-node i)))
        (when (and (= (e kind) NODE-SYM) (= (e s) "&where"))
          (return i)))
      (inc! i)))
  (return -1))

; The bare function name from a defn name node, without parsing its return type
; (which may mention a type variable). Handles both `name:T` and desugared
; `(name T)` forms.
(defn defn-name-only:ptr (name-node:ptr)
  (let (n:ptr:Node (cast ptr:Node name-node))
    (when (= (n kind) NODE-SYM)
      (let (nm:ptr null tn:ptr null)
        (split-typed (n s) (cast ptr:ptr (addr-of nm)) (cast ptr:ptr (addr-of tn)))
        (return nm)))
    (when (= (n kind) NODE-CELL)
      (let (c:ptr:Node (cast ptr:Node (n car)))
        (when (= (c kind) NODE-SYM) (return (c s)))))
    (return null)))

; The type node of a desugared binding `(name type)`, or null if untyped.
(defn binding-type-node:ptr (bind-node:ptr)
  (let (n:ptr:Node (cast ptr:Node bind-node))
    (when (= (n kind) NODE-CELL) (return (node-at bind-node 1)))
    (return null)))

(defn tyvar-index-of:i32 (name:CStr tyvars:ptr ntv:i32)
  (let (i:i32 0)
    (while (< i ntv)
      (when (= (aref (cast ptr:ptr tyvars) i) name) (return i))
      (inc! i)))
  (return -1))

; Does any symbol anywhere in this node name a declared type variable?
(defn node-mentions-tyvar:i32 (node:ptr tyvars:ptr ntv:i32)
  (when (= node null) (return 0))
  (let (n:ptr:Node (cast ptr:Node node))
    (when (= (n kind) NODE-SYM)
      (if (>= (tyvar-index-of (n s) tyvars ntv) 0) (return 1) (return 0)))
    (when (= (n kind) NODE-CELL)
      (when (!= (node-mentions-tyvar (n car) tyvars ntv) 0) (return 1))
      (return (node-mentions-tyvar (n cdr) tyvars ntv)))
    (return 0)))

; Substitute type variables inside one symbol's colon spelling: split on ':',
; replace any segment that names a tyvar with that tyvar's concrete spelling,
; rejoin. Handles both desugared standalone type symbols ("T" → "i32") and the
; colon-typed symbols left in un-desugared bodies ("r:T" → "r:i32",
; "x:ptr:T" → "x:ptr:Circle").
(defn subst-tyvars-sym:ptr (s:ptr tyvars:ptr spellings:ptr ntv:i32 line:i32)
  (when (= (strchr s 58) null)
    (let (idx:i32 (tyvar-index-of s tyvars ntv))
      (when (>= idx 0) (return (aref (cast ptr:ptr spellings) idx)))
      (return s)))
  (let (segs:ptr (split-colon-segments s line)
        acc:ptr null
        cur:ptr segs)
    (while (!= cur null)
      (let (seg:ptr (-> cur (cast ptr:Node _) (_ car) (cast ptr:Node _) (_ s))
            piece:ptr null
            idx:i32 0)
        (set! piece seg)
        (set! idx (tyvar-index-of seg tyvars ntv))
        (when (>= idx 0) (set! piece (aref (cast ptr:ptr spellings) idx)))
        (if (= acc null) (set! acc piece) (set! acc (fmt-2s "%s:%s" acc piece))))
      (set! cur ((cast ptr:Node cur) cdr)))
    (when (= acc null) (return s))
    (return acc)))

; Deep-copy a node, substituting type variables (by colon-spelling) in every
; symbol. Used to stamp a concrete instance from a generic template.
(defn subst-tyvars-node:ptr (node:ptr tyvars:ptr spellings:ptr ntv:i32)
  (when (= node null) (return null))
  (let (n:ptr:Node (cast ptr:Node node))
    (when (= (n kind) NODE-SYM)
      (let (ns:ptr (subst-tyvars-sym (n s) tyvars spellings ntv (n line)))
        (when (= ns (n s)) (return node))
        (let (new:ptr:Node (cast ptr:Node (alloc-node)))
          (.set! new kind NODE-SYM)
          (.set! new line (n line))
          (.set! new s ns)
          (return (cast ptr new)))))
    (when (= (n kind) NODE-CELL)
      (return (make-cell (subst-tyvars-node (n car) tyvars spellings ntv)
                         (subst-tyvars-node (n cdr) tyvars spellings ntv)
                         (n line))))
    (return node)))

; The first n cells of a list as a freshly-consed list (drops the tail).
(defn take-first-n:ptr (list:ptr n:i32 line:i32)
  (when (<= n 0) (return null))
  (when (= list null) (return null))
  (let (l:ptr:Node (cast ptr:Node list))
    (return (make-cell (l car) (take-first-n (l cdr) (- n 1) line) line))))

; Register a bounded-generic defn as a METHOD-GENERIC template. Validates the
; &where constraints, that every type variable is bound by a bare parameter
; (no return-only / B2), and that no tyvar appears in a nested position.
(defn register-generic-defn:void (form:ptr trusted:i32)
  (let (ff:ptr:Node (cast ptr:Node form)
        name-node:ptr (node-at form 1)
        params-node:ptr (node-at form 2)
        fname:ptr (defn-name-only name-node)
        wi:i32 (params-where-index params-node))
    (when (= fname null) (die-at (ff line) "defn: malformed generic name"))
    (let (nparams:i32 wi
          i:i32 0)
      (while (< i nparams)
        (let (p:ptr:Node (cast ptr:Node (node-at params-node i)))
          (when (and (= (p kind) NODE-SYM) (= (p s) "&rest"))
            (die-at (p line) "defn: &rest combined with &where is not supported yet")))
        (inc! i))
      (let (raw:i32 (node-len params-node)
            nc:i32 (- raw (+ wi 1)))
        (when (< nc 1)
          (die-at (ff line) "defn: &where requires at least one (Protocol Var) constraint"))
        (let (con-protos:ptr (arena-alloc (* (cast i64 nc) (ptr-bytes)))
              con-vars:ptr   (arena-alloc (* (cast i64 nc) (ptr-bytes)))
              tyvars:ptr     (arena-alloc (* (cast i64 nc) (ptr-bytes)))
              ntv:i32 0
              ci:i32 0)
          (while (< ci nc)
            (let (cnode:ptr (node-at params-node (+ (+ wi 1) ci)))
              (when (or (= (node-is-list cnode) 0) (!= (node-len cnode) 2))
                (die-at (ff line) "defn: each &where constraint must be (Protocol Var)"))
              (let (pn:ptr:Node (cast ptr:Node (node-at cnode 0))
                    vn:ptr:Node (cast ptr:Node (node-at cnode 1)))
                (when (or (!= (pn kind) NODE-SYM) (!= (vn kind) NODE-SYM))
                  (die-at (ff line) "defn: &where constraint must name a protocol and a variable"))
                (aset! (cast ptr:ptr con-protos) ci (pn s))
                (aset! (cast ptr:ptr con-vars) ci (vn s))
                (when (< (tyvar-index-of (vn s) tyvars ntv) 0)
                  (aset! (cast ptr:ptr tyvars) ntv (vn s))
                  (inc! ntv))))
            (inc! ci))
          ; Reject nested tyvar positions in params and return (deferred to Option 3).
          (let (j:i32 0)
            (while (< j nparams)
              (let (ptn:ptr (binding-type-node (node-at params-node j)))
                (when (and (!= ptn null)
                           (and (!= ((cast ptr:Node ptn) kind) NODE-SYM)
                                (!= (node-mentions-tyvar ptn tyvars ntv) 0)))
                  (die-at (ff line)
                    "defn: nested type variable in a parameter type is not supported (deferred to Option 3)")))
              (inc! j)))
          (let (rtn:ptr (binding-type-node name-node))
            (when (and (!= rtn null)
                       (and (!= ((cast ptr:Node rtn) kind) NODE-SYM)
                            (!= (node-mentions-tyvar rtn tyvars ntv) 0)))
              (die-at (ff line)
                "defn: nested type variable in the return type is not supported (deferred to Option 3)")))
          ; Every declared tyvar must be determined by a bare parameter type.
          (let (ti:i32 0)
            (while (< ti ntv)
              (let (tvname:CStr (aref (cast ptr:ptr tyvars) ti)
                    bnd:i32 0
                    j:i32 0)
                (while (< j nparams)
                  (let (ptn:ptr (binding-type-node (node-at params-node j)))
                    (when (and (!= ptn null)
                               (and (= ((cast ptr:Node ptn) kind) NODE-SYM)
                                    (= ((cast ptr:Node ptn) s) tvname)))
                      (set! bnd 1)))
                  (inc! j))
                (when (= bnd 0)
                  (die-at (ff line)
                    (fmt-s "defn: type variable '%s' is not determined by any parameter (return-only generics need dyn, deferred)" tvname))))
              (inc! ti)))
          ; Constraint protocols are validated in the A2 pass (check-generic-
          ; template), which runs after all imports — so a &where may name a
          ; protocol that an `import` provides, while a genuine typo is still
          ; caught (just at the outermost top-level rather than at the prescan).
          ; Register the template.
          (let (g:ptr (generic-lookup fname))
            (when (= g null) (set! g (generic-new fname)))
            (let (m:ptr:Method (new Method))
              (.set! m param-types null)
              (.set! m num-params nparams)
              (.set! m ret-type null)
              (.set! m has-rest 0)
              (.set! m variadic 0)
              (.set! m kind METHOD-GENERIC)
              (.set! m ir-name null)
              (.set! m fn-type null)
              (.set! m binop null)
              (.set! m body form)
              (.set! m tyvars tyvars)
              (.set! m num-tyvars ntv)
              (.set! m con-protos con-protos)
              (.set! m con-vars con-vars)
              (.set! m num-constraints nc)
              ; Imported templates were checked by the exporting unit; skip A2.
              (.set! m checked trusted)
              (generic-add-method g (cast ptr m)))))))))

; Try to bind a generic template's type variables from a concrete argument
; tuple. Bare-tyvar params bind (and must agree on repeats); concrete params
; must match exactly. On success fills out-bound[tyvar-index] = Type* and
; returns 1; on any mismatch returns 0.
(defn generic-method-bind:i32 (m:ptr argtypes:ptr nargs:i32 out-bound:ptr)
  (let (mm:ptr:Method (cast ptr:Method m))
    (when (!= (mm num-params) nargs) (return 0))
    (let (params-node:ptr (node-at (mm body) 2)
          ntv:i32 (mm num-tyvars)
          k:i32 0)
      (while (< k ntv) (aset! (cast ptr:ptr out-bound) k null) (inc! k))
      (let (i:i32 0)
        (while (< i nargs)
          (let (ptn:ptr (binding-type-node (node-at params-node i))
                at:ptr (aref (cast ptr:ptr argtypes) i))
            (when (or (= ptn null) (= at null)) (return 0))
            (let (pn:ptr:Node (cast ptr:Node ptn)
                  idx:i32 -1)
              (when (= (pn kind) NODE-SYM)
                (set! idx (tyvar-index-of (pn s) (mm tyvars) ntv)))
              (if (>= idx 0)
                (let (cur:ptr (aref (cast ptr:ptr out-bound) idx))
                  (if (= cur null)
                    (aset! (cast ptr:ptr out-bound) idx at)
                    (when (= (type-eq cur at) 0) (return 0))))
                (let (cty:ptr (parse-type-from-node ptn (pn line)))
                  (when (= (type-eq cty at) 0) (return 0))))))
          (inc! i)))
      (let (k:i32 0)
        (while (< k ntv)
          (when (= (aref (cast ptr:ptr out-bound) k) null) (return 0))
          (inc! k)))
      (return 1))))

; Check that each &where constraint is satisfied: the type bound to its variable
; must conform (nominally, via `extend`) to the named protocol.
(defn generic-constraints-ok:i32 (m:ptr bound:ptr line:i32)
  (let (mm:ptr:Method (cast ptr:Method m)
        nc:i32 (mm num-constraints)
        i:i32 0)
    (while (< i nc)
      (let (proto:ptr (aref (cast ptr:ptr (mm con-protos)) i)
            var:ptr   (aref (cast ptr:ptr (mm con-vars)) i)
            idx:i32 (tyvar-index-of var (mm tyvars) (mm num-tyvars))
            bt:ptr (aref (cast ptr:ptr bound) idx))
        ; Blanket protocols (§10.1) conform automatically; Valid (§10.2) matches
        ; here and is checked structurally at the call site; otherwise require a
        ; nominal conformance recorded by `extend`.
        (when (and (= (blanket-conforms bt proto) 0)
                   (and (!= proto "Valid")
                        (= (conformance-lookup (type-spelling bt) proto) 0)))
          (return 0)))
      (inc! i))
    (return 1)))

; Build a concrete defn form from a generic template + a type-variable binding:
; substitute the variables throughout, then drop the &where clause.
(defn monomorphize-form:ptr (form:ptr tyvars:ptr spellings:ptr ntv:i32 nparams:i32)
  (let (ff:ptr:Node (cast ptr:Node form)
        line:i32 (ff line)
        defn-sym:ptr (node-at form 0)
        name-node:ptr (subst-tyvars-node (node-at form 1) tyvars spellings ntv)
        params-src:ptr (subst-tyvars-node (node-at form 2) tyvars spellings ntv)
        new-params:ptr null
        body-src:ptr (subst-tyvars-node
                       ((cast ptr:Node ((cast ptr:Node (ff cdr)) cdr)) cdr)
                       tyvars spellings ntv))
    (set! new-params (take-first-n params-src nparams line))
    (return (make-cell defn-sym
              (make-cell name-node
                (make-cell new-params body-src line)
                line)
              line))))

; Monomorphize a generic template for a concrete argument tuple: reuse a cached
; instantiation if present, else stamp a concrete method (registered now so the
; call site can name its symbol; its body is queued for later emission).
(defn generic-instantiate:ref:Method (g:ptr m:ptr bound:ptr argtypes:ptr nargs:i32 line:i32)
  (let (gg:ptr:Generic (cast ptr:Generic g)
        mm:ptr:Method (cast ptr:Method m))
    (let (existing:?Method (generic-find-method-exact g argtypes nargs))
      (when (!= existing null) (return existing)))
    ; Concrete spelling for each bound type variable, used to stamp the body.
    (let (ntv:i32 (mm num-tyvars)
          spellings:ptr (arena-alloc (* (cast i64 (+ ntv 1)) (ptr-bytes)))
          si:i32 0)
      (while (< si ntv)
        (aset! (cast ptr:ptr spellings) si (type-spelling (aref (cast ptr:ptr bound) si)))
        (inc! si))
    (let (stamped:ptr (monomorphize-form (mm body) (mm tyvars) spellings
                                         (mm num-tyvars) (mm num-params))
          sname:ptr null
          sret:ptr (extract-name-and-type (node-at stamped 1) (cast ptr:ptr (addr-of sname))
                                          ((cast ptr:Node (node-at stamped 1)) line)))
      (when (= sret null)
        (die-at line (fmt-s "generic '%s': cannot resolve instantiated return type" (gg name))))
      ; Valid bound (§10.2): dry-run the concrete body before committing it, so an
      ; operation C can't support is reported at this call site, not at stamp time.
      (when (!= (method-has-valid m) 0)
        (valid-check-instance m stamped bound line))
      (let (ptypes:ptr null)
        (when (> nargs 0)
          (set! ptypes (arena-alloc (* (cast i64 nargs) (ptr-bytes))))
          (let (i:i32 0)
            (while (< i nargs)
              (aset! (cast ptr:ptr ptypes) i (aref (cast ptr:ptr argtypes) i))
              (inc! i))))
        (let (newm:ref:Method (generic-register-method (gg name) sret ptypes nargs 0 0 stamped)
              mangled:ptr (mangle-fn-name (gg name) ptypes nargs)
              job:ptr:MonoJob (new MonoJob))
          (.set! newm ir-name mangled)
          ; Record where this instantiation was requested, so a stamp-time emit
          ; error in the body points back here (g-source-path is the call site's).
          (.set! job form stamped)
          (.set! job context
                 (fmt-2s-i "while instantiating %s (requested at %s:%d)"
                           mangled g-source-path line))
          (vec-push g-mono-worklist (cast ptr job))
          (return newm)))))))

; ============================================================
; A2: def-time checking of bounded-generic bodies
; ============================================================
; Type-check a generic template body ONCE at its definition against the abstract
; protocol interface: a value of type variable T (an abstract `TY-TYVAR`) admits
; only the operations its `&where` protocols declare (with Self → T) — plus calls
; to other generics whose own constraints T's constraints satisfy. A use the
; constraints don't provide errors at the `defn`, not at the first instantiation.
; This never emits and only ever manufactures TY-TYVAR types, which codegen never
; sees (templates emit only after monomorphization).

(defn make-tyvar-type:ref:Type (m:ptr idx:i32)
  (let (t:ref:Type (make-type TY-TYVAR))
    (.set! t sdef m)         ; owning template Method*
    (.set! t num-params idx) ; tyvar index within that template
    (return t)))

(defn tyvar-type-name:ptr (t:ptr)
  (let (m:ptr:Method (cast ptr:Method (-> t (cast ptr:Type _) (_ sdef)))
        idx:i32 (-> t (cast ptr:Type _) (_ num-params)))
    (return (aref (cast ptr:ptr (m tyvars)) idx))))

(defn is-tyvar-type:i32 (t:ptr)
  (when (= t null) (return 0))
  (if (= (-> t (cast ptr:Type _) (_ kind)) TY-TYVAR) (return 1) (return 0)))

; The type-spelling tail of a colon symbol ("a:Self" → "Self"), or null.
(defn colon-tail:ptr (s:ptr)
  (let (nm:ptr null tail:ptr null)
    (split-typed s (cast ptr:ptr (addr-of nm)) (cast ptr:ptr (addr-of tail)))
    (return tail)))

; Parse a concrete type from a colon spelling string (no Self/tyvars).
(defn parse-type-spelling-str:ptr (s:ptr line:i32)
  (when (= (strchr s 58) null) (return (parse-type-name s line)))
  (return (parse-type-from-node (split-colon-segments s line) line)))

; Does a colon spelling mention "Self" as a segment other than being exactly Self?
(defn spelling-nests-self:i32 (s:ptr)
  (when (= s "Self") (return 0))
  (let (segs:ptr (split-colon-segments s 0)
        cur:ptr segs)
    (while (!= cur null)
      (when (= (-> cur (cast ptr:Node _) (_ car) (cast ptr:Node _) (_ s)) "Self")
        (return 1))
      (set! cur ((cast ptr:Node cur) cdr))))
  (return 0))

(defn caller-has-constraint:i32 (m:ptr tyvar-name:CStr proto:CStr)
  (let (mm:ptr:Method (cast ptr:Method m) i:i32 0)
    (while (< i (mm num-constraints))
      (when (and (= (aref (cast ptr:ptr (mm con-vars)) i) tyvar-name)
                 (= (aref (cast ptr:ptr (mm con-protos)) i) proto))
        (return 1))
      (inc! i)))
  (return 0))

; Does protocol signature `sig` provide the call `head(argtypes)` for tyvar `ti`
; of template `m` (Self → that tyvar)? Returns the call's result type or null.
(defn sig-provides-call:ptr (sig:ptr head:CStr ti:i32 m:ptr argtypes:ptr nargs:i32 line:i32)
  (let (name-node:ptr (node-at sig 0)
        params:ptr (node-at sig 1)
        nm:ptr null
        rettail:ptr null)
    (split-typed (-> name-node (cast ptr:Node _) (_ s))
                 (cast ptr:ptr (addr-of nm)) (cast ptr:ptr (addr-of rettail)))
    (when (= nm head)
      (when (= (node-len params) nargs)
        (let (i:i32 0 ok:i32 1)
          (while (< i nargs)
            (let (pn:ptr:Node (cast ptr:Node (node-at params i))
                  pspell:ptr (colon-tail (pn s))
                  at:ptr (aref (cast ptr:ptr argtypes) i))
              (if (and (!= pspell null) (= pspell "Self"))
                (when (or (= (is-tyvar-type at) 0)
                          (or (!= (-> at (cast ptr:Type _) (_ num-params)) ti)
                              (!= (-> at (cast ptr:Type _) (_ sdef)) m)))
                  (set! ok 0))
                (if (or (= pspell null) (!= (spelling-nests-self pspell) 0))
                  (set! ok 0)
                  (when (= (type-eq (parse-type-spelling-str pspell line) at) 0)
                    (set! ok 0)))))
            (inc! i))
          (when (!= ok 0)
            (when (and (!= rettail null) (= rettail "Self"))
              (return (make-tyvar-type m ti)))
            (when (= rettail null) (return ty-void))
            (return (parse-type-spelling-str rettail line))))))
    (return null)))

; Resolve a call with at least one abstract argument against the protocol methods
; provided by the constraints on the call's tyvar arguments. Result type or null.
(defn abstract-call-via-protocol:ptr (head:ptr argtypes:ptr nargs:i32 m:ptr line:i32)
  (let (mm:ptr:Method (cast ptr:Method m) ti:i32 0)
    (while (< ti (mm num-tyvars))
      (let (tvname:CStr (aref (cast ptr:ptr (mm tyvars)) ti) ci:i32 0)
        (while (< ci (mm num-constraints))
          (when (= (aref (cast ptr:ptr (mm con-vars)) ci) tvname)
            (let (proto:ptr (protocol-lookup (aref (cast ptr:ptr (mm con-protos)) ci)))
              (when (!= proto null)
                (let (pp:ptr:Protocol (cast ptr:Protocol proto) si:i32 0)
                  (while (< si (pp num-sigs))
                    (let (rt:ptr (sig-provides-call (aref (cast ptr:ptr (pp sigs)) si)
                                                    head ti m argtypes nargs line))
                      (when (!= rt null) (return rt)))
                    (inc! si))))))
          (inc! ci)))
      (inc! ti)))
  (return null))

; Resolve an abstract-argument call against another generic template whose own
; constraints are satisfied by the caller's tyvar constraints. Result type or null.
(defn abstract-call-via-generic:ptr (head:ptr argtypes:ptr nargs:i32 m:ptr line:i32)
  (let (g:ptr (generic-lookup head))
    (when (= g null) (return null))
    (let (gg:ptr:Generic (cast ptr:Generic g) gi:i32 0)
      (while (< gi (gg num-methods))
        (let (m2:ptr:Method (cast ptr:Method (aref (cast ptr:ptr (gg methods)) gi)))
          (when (= (m2 kind) METHOD-GENERIC)
            (let (bound:ptr (arena-alloc (* (cast i64 (+ (m2 num-tyvars) 1)) (ptr-bytes))))
              (when (!= (generic-method-bind (cast ptr m2) argtypes nargs bound) 0)
                (let (ok:i32 1 ci:i32 0)
                  (while (< ci (m2 num-constraints))
                    (let (uidx:i32 (tyvar-index-of (aref (cast ptr:ptr (m2 con-vars)) ci)
                                                   (m2 tyvars) (m2 num-tyvars))
                          proto:ptr (aref (cast ptr:ptr (m2 con-protos)) ci)
                          bt:ptr (aref (cast ptr:ptr bound) uidx))
                      (if (!= (is-tyvar-type bt) 0)
                        (when (= (caller-has-constraint m (tyvar-type-name bt) proto) 0)
                          (set! ok 0))
                        (when (= (conformance-lookup (type-spelling bt) proto) 0)
                          (set! ok 0))))
                    (inc! ci))
                  (when (!= ok 0)
                    ; result = m2's return spelling, its tyvars substituted by `bound`
                    (let (rnode:ptr (binding-type-node (node-at (m2 body) 1)))
                      (when (= rnode null) (return ty-void))
                      (when (= (-> rnode (cast ptr:Node _) (_ kind)) NODE-SYM)
                        (let (ridx:i32 (tyvar-index-of (-> rnode (cast ptr:Node _) (_ s))
                                                       (m2 tyvars) (m2 num-tyvars)))
                          (when (>= ridx 0) (return (aref (cast ptr:ptr bound) ridx)))))
                      (return (parse-type-from-node rnode line)))))))))
        (inc! gi)))
    (return null)))

; Is this head one of the core special forms (mirrors emit-list's dispatch)?
; Such forms are handled structurally by gcheck, never as function calls.
(defn gcheck-special-form:i32 (hp:ptr)
  (when (or (= hp 'let) (= hp 'with)) (return 1))
  (when (or (= hp 'do) (= hp 'cond)) (return 1))
  (when (or (= hp 'return) (= hp 'while)) (return 1))
  (when (or (= hp 'set!) (= hp 'inc!)) (return 1))
  (when (or (= hp 'quote) (= hp 'quasiquote)) (return 1))
  (when (or (= hp 'not) (or (= hp 'and) (= hp 'or))) (return 1))
  (when (or (= hp 'cast) (= hp 'addr-of)) (return 1))
  (when (or (= hp 'deref) (or (= hp 'ptr-set!) (= hp 'ptr+))) (return 1))
  (when (or (= hp '_get) (= hp '.set!)) (return 1))
  (when (or (= hp 'sizeof) (or (= hp 'alloca) (= hp 'char))) (return 1))
  (when (or (= hp 'aref) (or (= hp 'aset!) (= hp 'gensym))) (return 1))
  (when (or (= hp 'funcall) (= hp 'funcall-void)) (return 1))
  (when (or (= hp 'funcall-ptr-1) (= hp 'funcall-ptr-i32)) (return 1))
  (when (or (= hp 'funcall-ptr-i64) (= hp 'funcall-ptr-ptr)) (return 1))
  (when (or (= hp 'some) (or (= hp 'as-ref) (= hp 'unwrap))) (return 1))
  (when (or (= hp 'unwrap-or) (or (= hp 'if-some) (= hp 'when-some))) (return 1))
  (when (or (= hp 'move) (= hp 'defer)) (return 1))
  (return 0))

; Declared type of a let/with binding name in a generic body. Handles both the
; un-desugared colon symbol ("r:T") and the desugared (name type) cell. Returns
; null for an untyped binding (caller infers from the value).
(defn gbind-decl-type:ptr (bind-node:ptr m:ptr line:i32)
  (let (n:ptr:Node (cast ptr:Node bind-node))
    (when (= (n kind) NODE-SYM)
      (let (tail:ptr (colon-tail (n s)))
        (when (= tail null) (return null))
        (let (idx:i32 (tyvar-index-of tail ((cast ptr:Method m) tyvars)
                                      ((cast ptr:Method m) num-tyvars)))
          (when (>= idx 0) (return (make-tyvar-type m idx)))
          (return (parse-type-spelling-str tail line)))))
    (when (= (n kind) NODE-CELL)
      (let (tnode:ptr (node-at bind-node 1))
        (when (= tnode null) (return null))
        (when (= (-> tnode (cast ptr:Node _) (_ kind)) NODE-SYM)
          (let (idx:i32 (tyvar-index-of (-> tnode (cast ptr:Node _) (_ s))
                                        ((cast ptr:Method m) tyvars)
                                        ((cast ptr:Method m) num-tyvars)))
            (when (>= idx 0) (return (make-tyvar-type m idx)))))
        (return (parse-type-from-node tnode line))))
    (return null)))

(defn gbind-name:ptr (bind-node:ptr)
  (let (n:ptr:Node (cast ptr:Node bind-node))
    (when (= (n kind) NODE-SYM)
      (let (nm:ptr null tail:ptr null)
        (split-typed (n s) (cast ptr:ptr (addr-of nm)) (cast ptr:ptr (addr-of tail)))
        (return nm)))
    (when (= (n kind) NODE-CELL)
      (return (-> n (_ car) (cast ptr:Node _) (_ s))))
    (return null)))

; Type-check one node of a generic body in `scope`, against template `m`.
; Returns the node's (possibly abstract) type, or null when not modeled. Aborts
; with a def-time diagnostic on an operation the constraints do not provide.
(defn gcheck:ptr (n:ptr scope:ref:Scope m:ptr)
  (when (= n null) (return ty-void))
  (let (nn:ptr:Node (cast ptr:Node n))
    (when (= (nn kind) NODE-INT)   (return ty-i32))
    (when (= (nn kind) NODE-FLOAT) (return ty-f64))
    (when (= (nn kind) NODE-STR)   (return ty-cstr))
    (when (= (nn kind) NODE-SYM)   (return (node-type-sym n scope)))
    (when (!= (nn kind) NODE-CELL) (return ty-void))
    (when (= (node-len n) 0) (return null))
    (let (head:ptr:Node (cast ptr:Node (node-at n 0)))
      (when (!= (head kind) NODE-SYM)
        ; non-symbol head: just walk compound children for nested calls.
        (gcheck-walk-children n scope m)
        (return null))
      (let (h:ptr (head s)
            hp:ptr (cast ptr head))
        ; Expand macros (if/when/-> …) so the body is core forms.
        (when (!= (find-macro h) null)
          (let (ex:ptr (macroexpand-form n 1))
            (when (!= ex n) (return (gcheck ex scope m)))))
        (when (or (= hp 'quote) (= hp 'quasiquote)) (return ty-ptr))
        ; let / with: bind names (possibly abstract), then check the body.
        (when (or (= hp 'let) (= hp 'with))
          (let (binds:ptr (node-at n 1)
                inner:ref:Scope (scope-new scope)
                bl:i32 (node-len binds)
                i:i32 0)
            (while (< i bl)
              (let (bname:ptr (node-at binds i)
                    bval:ptr (node-at binds (+ i 1))
                    vty:ptr (gcheck bval inner m)
                    dty:ptr (gbind-decl-type bname m (nn line))
                    nm:ptr (gbind-name bname))
                (when (= dty null) (set! dty vty))
                (when (and (!= nm null) (!= dty null))
                  (scope-define inner nm dty nm 1)))
              (set! i (+ i 2)))
            (let (last:ptr null j:i32 2 cl:i32 (node-len n))
              (while (< j cl) (set! last (gcheck (node-at n j) inner m)) (inc! j))
              (return last))))
        (when (= hp 'do)
          (let (last:ptr null j:i32 1 cl:i32 (node-len n))
            (while (< j cl) (set! last (gcheck (node-at n j) scope m)) (inc! j))
            (return last)))
        ; cond / and / or / not / set! / inc! / return / while and the structural
        ; special forms: walk compound children; result type is not modeled.
        (when (!= (gcheck-special-form hp) 0)
          (gcheck-walk-children n scope m)
          (return null))
        ; A genuine call: type the arguments (catching nested abstract calls),
        ; then resolve the head. Lenient model: resolve protocol-method and
        ; generic calls precisely (good types for nested checking); for anything
        ; else, only a genuinely unknown name is an error — a known operation
        ; (operator, foreign/concrete function) on an abstract value is deferred
        ; to stamp-time (A1), since it may well be valid for the concrete type.
        (let (nargs:i32 (- (node-len n) 1)
              argtypes:ptr (arena-alloc (* (cast i64 (+ nargs 1)) (ptr-bytes)))
              any-abstract:i32 0
              i:i32 0)
          (while (< i nargs)
            (let (at:ptr (gcheck (node-at n (+ i 1)) scope m))
              (aset! (cast ptr:ptr argtypes) i at)
              (when (!= (is-tyvar-type at) 0) (set! any-abstract 1)))
            (inc! i))
          ; Protocol-method resolution (Self → tyvar) takes priority — a required
          ; method need not have a concrete impl in this unit to be a valid call.
          (when (!= any-abstract 0)
            (let (rt:ptr (abstract-call-via-protocol h argtypes nargs m (nn line)))
              (when (!= rt null) (return rt))
              (set! rt (abstract-call-via-generic h argtypes nargs m (nn line)))
              (when (!= rt null) (return rt))))
          (let (g:ptr (generic-lookup h))
            ; Intrinsic operator: best-effort type (i1 for comparisons, else the
            ; first operand's type — possibly the abstract tyvar). Deferred, no error.
            (when (!= g null)
              (let (m0:ptr:Method (cast ptr:Method (aref (cast ptr:ptr (-> g (cast ptr:Generic _) (_ methods))) 0)))
                (when (= (m0 kind) METHOD-INTRINSIC)
                  (when (!= ((cast ptr:BinOp (m0 binop)) is-cmp) 0) (return ty-i1))
                  (return (gcheck (node-at n 1) scope m)))))
            ; A name that is neither a generic nor scope-bound is a typo — error
            ; whether or not an argument is abstract.
            (when (and (= g null) (= (scope-lookup scope h) null))
              (die-at (nn line) (fmt-s "in generic body: unknown function '%s'" h)))
            ; Known name, unresolved here: defer to stamp-time. Concrete calls get
            ; a best-effort type; abstract ones stay unknown (null).
            (when (!= any-abstract 0) (return null))
            (return (node-type-call n scope h))))))))

; Walk only the compound (list) children of a node, checking nested calls but
; ignoring bare symbols (which may be type names, field names, or places).
(defn gcheck-walk-children:void (n:ptr scope:ref:Scope m:ptr)
  (let (cl:i32 (node-len n) i:i32 1)
    (while (< i cl)
      (let (c:ptr (node-at n i))
        (when (and (!= c null) (= (-> c (cast ptr:Node _) (_ kind)) NODE-CELL))
          (gcheck c scope m)))
      (inc! i))))

; Run the A2 check on one generic template: bind its parameters to their abstract
; (or concrete) types, then check each body form.
(defn check-generic-template:void (m:ptr)
  (let (mm:ptr:Method (cast ptr:Method m)
        form:ptr (mm body)
        params-node:ptr (node-at form 2)
        scope:ref:Scope (scope-new g-globals)
        nparams:i32 (mm num-params)
        i:i32 0)
    ; Every &where constraint must name a known protocol/blanket/Valid — checked
    ; here (not at prescan) so an imported protocol is already registered.
    (let (ci:i32 0)
      (while (< ci (mm num-constraints))
        (let (pnm:ptr (aref (cast ptr:ptr (mm con-protos)) ci))
          (when (= (constraint-proto-known pnm) 0)
            (die-at ((cast ptr:Node form) line)
              (fmt-s "defn: &where names unknown protocol '%s'" pnm))))
        (inc! ci)))
    (while (< i nparams)
      (let (pnode:ptr (node-at params-node i)
            pty:ptr (gbind-decl-type pnode m ((cast ptr:Node form) line))
            pnm:ptr (gbind-name pnode))
        (when (and (!= pnm null) (!= pty null))
          (scope-define scope pnm pty pnm 1)))
      (inc! i))
    (let (cl:i32 (node-len form) j:i32 3)
      (while (< j cl)
        (gcheck (node-at form j) scope m)
        (inc! j)))))

; Check every not-yet-checked bounded-generic template. Runs after the top-level
; loop (so includes/imports/protocols/conformances are all registered) and before
; the worklist drain (so a body error surfaces at the defn, before any A1
; stamp-time error from instantiation).
(defn check-generic-templates:void ()
  (let (gi:i32 0)
    (while (< gi g-num-generics)
      (let (gg:ptr:Generic (cast ptr:Generic (ptr+ (cast ptr:Generic g-generics) gi))
            mi:i32 0)
        (while (< mi (gg num-methods))
          (let (m:ptr:Method (cast ptr:Method (aref (cast ptr:ptr (gg methods)) mi)))
            (when (and (= (m kind) METHOD-GENERIC) (= (m checked) 0))
              (.set! m checked 1)
              (check-generic-template (cast ptr m))))
          (inc! mi)))
      (inc! gi))))

; ============================================================
; Valid: inferred structural bounds (Stage 9 §10.2)
; ============================================================
; `&where (Valid T)` bounds T structurally: instead of naming a protocol, the
; required interface is whatever the body does to T-typed values. Per the
; designer (open Q3), this is realized as a per-call-site non-emitting stamp —
; at each instantiation (T := C known) the body is substituted and the rung-3
; type pass is run over it WITHOUT emitting, so any operation the concrete type C
; cannot support is reported at the call site (ahead of, and clearer than, the
; A1 stamp-time emit error), and derived-value chains are handled by the same
; concrete walk (no associated-type solver).

; Does this template carry a Valid constraint?
(defn method-has-valid:i32 (m:ptr)
  (let (mm:ptr:Method (cast ptr:Method m) i:i32 0)
    (while (< i (mm num-constraints))
      (when (= (aref (cast ptr:ptr (mm con-protos)) i) "Valid") (return 1))
      (inc! i)))
  (return 0))

; The concrete declared type of a binding in a stamped (substituted) body, or
; null when untyped (the caller infers it from the value).
(defn valid-decl-type:ptr (bind-node:ptr line:i32)
  (let (n:ptr:Node (cast ptr:Node bind-node))
    (when (= (n kind) NODE-SYM)
      (let (nm:ptr null tail:ptr null)
        (split-typed (n s) (cast ptr:ptr (addr-of nm)) (cast ptr:ptr (addr-of tail)))
        (when (= tail null) (return null))
        (return (parse-type-spelling-str tail line))))
    (when (= (n kind) NODE-CELL)
      (let (tnode:ptr (node-at bind-node 1))
        (when (= tnode null) (return null))
        (return (parse-type-from-node tnode line))))
    (return null)))

; The result type of a generic template `m2` for a concrete binding, or null:
; a bare-tyvar return is the bound type; anything else is parsed concretely.
(defn template-result-type:ptr (m2:ptr bound:ptr line:i32)
  (let (mm:ptr:Method (cast ptr:Method m2)
        rnode:ptr (binding-type-node (node-at (mm body) 1)))
    (when (= rnode null) (return ty-void))
    (when (= (-> rnode (cast ptr:Node _) (_ kind)) NODE-SYM)
      (let (ridx:i32 (tyvar-index-of (-> rnode (cast ptr:Node _) (_ s))
                                     (mm tyvars) (mm num-tyvars)))
        (when (>= ridx 0) (return (aref (cast ptr:ptr bound) ridx)))))
    (return (parse-type-from-node rnode line))))

; Non-dying resolution of a concrete call against generic `g`: returns the call's
; result type if it resolves (exact method, built-in operator, user-operator or
; user-method widen, or a bounded-generic template), else null. The Valid walk
; turns a null here into a localized call-site error.
(defn valid-resolve-type:ptr (g:ptr argtypes:ptr arg-nodes:ptr nargs:i32 line:i32)
  (let (gg:ptr:Generic (cast ptr:Generic g))
    (let (m:ptr (generic-find-method-exact g argtypes nargs))
      (when (!= m null) (return (-> m (cast ptr:Method _) (_ ret-type)))))
    (let (rt:ptr (builtin-op-result-type g argtypes nargs))
      (when (!= rt null) (return rt)))
    (let (m:ptr (operator-user-resolve g argtypes arg-nodes nargs))
      (when (!= m null) (return (-> m (cast ptr:Method _) (_ ret-type)))))
    ; widen on a concrete user method
    (let (i:i32 0 wcand:ptr null wn:i32 0)
      (while (< i (gg num-methods))
        (let (m:ptr:Method (cast ptr:Method (aref (cast ptr:ptr (gg methods)) i)))
          (when (and (= (m kind) METHOD-USER)
                     (and (= (m has-rest) 0) (= (m num-params) nargs)))
            (let (ok:i32 1 a:i32 0)
              (while (< a nargs)
                (let (is-lit:i32 0)
                  (when (!= arg-nodes null)
                    (set! is-lit (node-is-int-literal (aref (cast ptr:ptr arg-nodes) a))))
                  (when (= (arg-adapts (aref (cast ptr:ptr argtypes) a)
                                       (aref (cast ptr:ptr (m param-types)) a) is-lit) 0)
                    (set! ok 0)))
                (inc! a))
              (when (!= ok 0) (set! wcand (cast ptr m)) (inc! wn)))))
        (inc! i))
      (when (= wn 1) (return (-> wcand (cast ptr:Method _) (_ ret-type)))))
    ; bounded-generic template
    (let (j:i32 0)
      (while (< j (gg num-methods))
        (let (m:ptr:Method (cast ptr:Method (aref (cast ptr:ptr (gg methods)) j)))
          (when (= (m kind) METHOD-GENERIC)
            (let (bound:ptr (arena-alloc (* (cast i64 (+ (m num-tyvars) 1)) (ptr-bytes))))
              (when (and (!= (generic-method-bind (cast ptr m) argtypes nargs bound) 0)
                         (!= (generic-constraints-ok (cast ptr m) bound line) 0))
                (return (template-result-type (cast ptr m) bound line))))))
        (inc! j)))
    (return null)))

(defn valid-walk-children:void (n:ptr scope:ref:Scope gname:ptr cty:ptr line:i32)
  (let (cl:i32 (node-len n) i:i32 1)
    (while (< i cl)
      (let (c:ptr (node-at n i))
        (when (and (!= c null) (= (-> c (cast ptr:Node _) (_ kind)) NODE-CELL))
          (valid-walk c scope gname cty line)))
      (inc! i))))

; Walk one node of a stamped (concrete) Valid body, returning its type and
; aborting at any direct generic/operator call the concrete type can't satisfy.
; gname is the generic being instantiated and cty its concrete spelling, used
; only in the diagnostic. line is the requesting call site.
(defn valid-walk:ptr (n:ptr scope:ref:Scope gname:ptr cty:ptr line:i32)
  (when (= n null) (return ty-void))
  (let (nn:ptr:Node (cast ptr:Node n))
    (when (= (nn kind) NODE-INT)   (return ty-i32))
    (when (= (nn kind) NODE-FLOAT) (return ty-f64))
    (when (= (nn kind) NODE-STR)   (return ty-cstr))
    (when (= (nn kind) NODE-SYM)   (return (node-type-sym n scope)))
    (when (!= (nn kind) NODE-CELL) (return ty-void))
    (when (= (node-len n) 0) (return null))
    (let (head:ptr:Node (cast ptr:Node (node-at n 0)))
      (when (!= (head kind) NODE-SYM)
        (valid-walk-children n scope gname cty line)
        (return null))
      (let (h:ptr (head s)
            hp:ptr (cast ptr head))
        (when (!= (find-macro h) null)
          (let (ex:ptr (macroexpand-form n 1))
            (when (!= ex n) (return (valid-walk ex scope gname cty line)))))
        (when (or (= hp 'quote) (= hp 'quasiquote)) (return ty-ptr))
        (when (or (= hp 'let) (= hp 'with))
          (let (binds:ptr (node-at n 1)
                inner:ref:Scope (scope-new scope)
                bl:i32 (node-len binds)
                i:i32 0)
            (while (< i bl)
              (let (bname:ptr (node-at binds i)
                    bval:ptr (node-at binds (+ i 1))
                    vty:ptr (valid-walk bval inner gname cty line)
                    dty:ptr (valid-decl-type bname (nn line))
                    nm:ptr (gbind-name bname))
                (when (= dty null) (set! dty vty))
                (when (and (!= nm null) (!= dty null))
                  (scope-define inner nm dty nm 1)))
              (set! i (+ i 2)))
            (let (last:ptr null j:i32 2 cl:i32 (node-len n))
              (while (< j cl) (set! last (valid-walk (node-at n j) inner gname cty line)) (inc! j))
              (return last))))
        (when (= hp 'do)
          (let (last:ptr null j:i32 1 cl:i32 (node-len n))
            (while (< j cl) (set! last (valid-walk (node-at n j) scope gname cty line)) (inc! j))
            (return last)))
        (when (!= (gcheck-special-form hp) 0)
          (valid-walk-children n scope gname cty line)
          (return (node-type n scope)))
        ; A genuine call: type the arguments, then require it to resolve.
        (let (nargs:i32 (- (node-len n) 1)
              argtypes:ptr (arena-alloc (* (cast i64 (+ nargs 1)) (ptr-bytes)))
              arg-nodes:ptr (arena-alloc (* (cast i64 (+ nargs 1)) (ptr-bytes)))
              all-known:i32 1
              i:i32 0)
          (while (< i nargs)
            (let (anode:ptr (node-at n (+ i 1))
                  at:ptr (valid-walk anode scope gname cty line))
              (aset! (cast ptr:ptr argtypes) i at)
              (aset! (cast ptr:ptr arg-nodes) i anode)
              (when (= at null) (set! all-known 0)))
            (inc! i))
          (let (g:ptr (generic-lookup h))
            (when (!= g null)
              ; Only verify when every argument type is known; an unknown
              ; (e.g. a macro/cond result) defers, matching node-type's frontier.
              (when (!= all-known 0)
                (let (rt:ptr (valid-resolve-type g argtypes arg-nodes nargs line))
                  (when (!= rt null) (return rt))
                  (die-at line
                    (fmt-2s "type '%s' does not satisfy the Valid bound of '%s'"
                            cty gname))))
              (return null))
            ; A non-generic name: it must at least be in scope (catches a typo);
            ; its own arg typing is deferred to that function's own emission.
            (when (= (scope-lookup scope h) null)
              (die-at line
                (fmt-2s "type '%s' does not satisfy the Valid bound of '%s'" cty gname)))
            (return (node-type-call n scope h))))))))

; Run the per-call-site Valid check on a stamped instantiation `stamped` whose
; type variables were bound to the concrete types in `bound`. Builds a scope from
; the (now concrete) parameters and walks the body.
(defn valid-check-instance:void (m:ptr stamped:ptr bound:ptr line:i32)
  (let (mm:ptr:Method (cast ptr:Method m)
        params-node:ptr (node-at stamped 2)
        scope:ref:Scope (scope-new g-globals)
        gname:ptr (defn-name-only (node-at stamped 1))
        cty:ptr "?"
        nparams:i32 (mm num-params)
        i:i32 0)
    (when (> (mm num-tyvars) 0)
      (set! cty (type-spelling (aref (cast ptr:ptr bound) 0))))
    (while (< i nparams)
      (let (pnode:ptr (node-at params-node i)
            pty:ptr (valid-decl-type pnode line)
            pnm:ptr (gbind-name pnode))
        (when (and (!= pnm null) (!= pty null))
          (scope-define scope pnm pty pnm 1)))
      (inc! i))
    (let (cl:i32 (node-len stamped) j:i32 3)
      (while (< j cl)
        (valid-walk (node-at stamped j) scope gname cty line)
        (inc! j)))))

; Emit the bodies of every stamped generic instantiation queued so far. Runs at
; the end of the top-level loop, when no function emission is in progress. The
; persistent cursor makes recursive drains (during imports) never re-emit, and
; stamping inside a drained body simply extends the worklist this loop consumes.
(defn drain-mono-worklist:void ()
  (let (vv:ptr:Vec (cast ptr:Vec g-mono-worklist))
    (while (< g-mono-drained (vv len))
      (let (job:ptr:MonoJob (cast ptr:MonoJob (aref (cast ptr:ptr (vv data)) g-mono-drained)))
        (set! g-mono-drained (+ g-mono-drained 1))
        (set! g-out g-def-stream)
        ; Attach the instantiation context to any error raised while emitting.
        (set! g-mono-context (job context))
        (emit-defn (job form))
        (set! g-mono-context null)))))

; ============================================================
; Protocols & conformances (Stage 9 rung 2)
; ============================================================
; defprotocol/extend are entirely compile-time and emit no code. A protocol is
; a named set of required signatures (types may mention Self); `extend Type P`
; verifies, after the whole-file prescan, that each required signature resolves
; to a concrete method with Self→Type substituted, and records the conformance.

(defn protocol-lookup:?Protocol (name:ptr)
  (let (i:i32 0)
    (while (< i g-num-protocols)
      (let (p:ptr:Protocol (cast ptr:Protocol (ptr+ (cast ptr:Protocol g-protocols) i)))
        (when (= (p name) name) (return (cast ptr p))))
      (inc! i)))
  (return null))

(defn protocol-new:ref:Protocol (name:ptr sigs:ptr num-sigs:i32)
  (when (= g-num-protocols g-cap-protocols)
    (let (nc:i32 16)
      (when (!= g-cap-protocols 0) (set! nc (* g-cap-protocols 2)))
      (let (np:ptr (arena-alloc (* (cast i64 nc) (sizeof Protocol))))
        (when (!= g-num-protocols 0)
          (memcpy np g-protocols (* (cast i64 g-num-protocols) (sizeof Protocol))))
        (set! g-protocols np)
        (set! g-cap-protocols nc))))
  (let (p:ptr:Protocol (cast ptr:Protocol (ptr+ (cast ptr:Protocol g-protocols) g-num-protocols)))
    (.set! p name name)
    (.set! p sigs sigs)
    (.set! p num-sigs num-sigs)
    (inc! g-num-protocols)
    (return (cast ref:Protocol p))))

; Is `name` one of the built-in blanket protocols (§10.1)? Blanket protocols have
; automatic conformance — no `extend` is written — so they are consulted before
; the nominal conformance registry.
(defn blanket-lookup:i32 (name:CStr)
  (let (i:i32 0)
    (while (< i g-num-blanket)
      (when (= (aref (cast ptr:ptr g-blanket) i) name) (return 1))
      (inc! i)))
  (return 0))

; A name usable as a `&where` constraint: a declared protocol, a blanket protocol
; (Any/Struct, §10.1), or the structural bound Valid (§10.2). Used to reject typos
; once all imports have registered their protocols (the A2 pass).
(defn constraint-proto-known:i32 (name:ptr)
  (when (!= (protocol-lookup name) null) (return 1))
  (when (!= (blanket-lookup name) 0) (return 1))
  (when (= name "Valid") (return 1))
  (return 0))

; Automatic conformance for a blanket protocol (§10.1). `Any` holds for every
; type (the no-constraint constraint); `Struct` holds for any struct type or
; pointer-to-struct (its required `get` member-access method is supplied by a
; built-in once callable-values lands). Blanket conformance is structural and
; consulted directly, so it is never recorded in g-conformances.
(defn blanket-conforms:i32 (ty:ptr proto-name:ptr)
  (when (= proto-name "Any") (return 1))
  (when (= proto-name "Struct")
    (let (k:i32 (-> ty (cast ptr:Type _) (_ kind)))
      (when (= k TY-STRUCT) (return 1))
      (when (and (= k TY-PTR)
                 (and (!= (-> ty (cast ptr:Type _) (_ elem)) null)
                      (= (-> ty (cast ptr:Type _) (_ elem) (cast ptr:Type _) (_ kind)) TY-STRUCT)))
        (return 1))
      (return 0)))
  (return 0))

(defn conformance-lookup:i32 (type-name:ptr proto-name:ptr)
  (let (i:i32 0)
    (while (< i g-num-conformances)
      (let (c:ptr:Conformance (cast ptr:Conformance (ptr+ (cast ptr:Conformance g-conformances) i)))
        (when (and (= (c type-name) type-name)
                   (= (c proto-name) proto-name))
          (return 1)))
      (inc! i)))
  (return 0))

(defn conformance-add:void (type-name:ptr proto-name:ptr)
  (when (!= (conformance-lookup type-name proto-name) 0) (return))
  (when (= g-num-conformances g-cap-conformances)
    (let (nc:i32 16)
      (when (!= g-cap-conformances 0) (set! nc (* g-cap-conformances 2)))
      (let (ncf:ptr (arena-alloc (* (cast i64 nc) (sizeof Conformance))))
        (when (!= g-num-conformances 0)
          (memcpy ncf g-conformances (* (cast i64 g-num-conformances) (sizeof Conformance))))
        (set! g-conformances ncf)
        (set! g-cap-conformances nc))))
  (let (c:ptr:Conformance (cast ptr:Conformance (ptr+ (cast ptr:Conformance g-conformances) g-num-conformances)))
    (.set! c type-name type-name)
    (.set! c proto-name proto-name)
    (inc! g-num-conformances)))

; Record a protocol-inheritance edge: conforming to `sub` requires `super`.
(defn proto-super-add:void (sub:ptr super:ptr)
  (let (i:i32 0)
    (while (< i g-num-proto-supers)
      (let (e:ptr:Conformance (cast ptr:Conformance (ptr+ (cast ptr:Conformance g-proto-supers) i)))
        (when (and (= (e type-name) sub) (= (e proto-name) super))
          (return)))
      (inc! i)))
  (when (= g-num-proto-supers g-cap-proto-supers)
    (let (nc:i32 16)
      (when (!= g-cap-proto-supers 0) (set! nc (* g-cap-proto-supers 2)))
      (let (ne:ptr (arena-alloc (* (cast i64 nc) (sizeof Conformance))))
        (when (!= g-num-proto-supers 0)
          (memcpy ne g-proto-supers (* (cast i64 g-num-proto-supers) (sizeof Conformance))))
        (set! g-proto-supers ne)
        (set! g-cap-proto-supers nc))))
  (let (e:ptr:Conformance (cast ptr:Conformance (ptr+ (cast ptr:Conformance g-proto-supers) g-num-proto-supers)))
    (.set! e type-name sub)
    (.set! e proto-name super)
    (inc! g-num-proto-supers)))

; Substitute the type variable `Self` in a colon-typed symbol spelling: split
; on ':' and replace any segment that is exactly "Self" with the concrete type
; name, rejoining with ':'. "self:ptr:Self" with Circle → "self:ptr:Circle".
(defn subst-self-sym:ptr (s:ptr typename:ptr line:i32)
  (let (segs:ptr (split-colon-segments s line)
        acc:ptr null
        cur:ptr segs)
    (while (!= cur null)
      (let (seg-node:ptr ((cast ptr:Node cur) car)
            seg:ptr ((cast ptr:Node seg-node) s)
            piece:ptr seg)
        (when (= seg "Self") (set! piece typename))
        (if (= acc null)
          (set! acc piece)
          (set! acc (fmt-2s "%s:%s" acc piece))))
      (set! cur ((cast ptr:Node cur) cdr)))
    (when (= acc null) (return s))
    (return acc)))

; Deep-copy a signature AST with Self→typename in every symbol, yielding a
; concrete signature parseable by the ordinary defn helpers.
(defn subst-self-node:ptr (node:ptr typename:ptr)
  (when (= node null) (return null))
  (let (n:ptr:Node (cast ptr:Node node))
    (when (= (n kind) NODE-SYM)
      (let (ns:ptr:Node (cast ptr:Node (alloc-node)))
        (.set! ns kind NODE-SYM)
        (.set! ns line (n line))
        (.set! ns s (subst-self-sym (n s) typename (n line)))
        (return (cast ptr ns))))
    (when (= (n kind) NODE-CELL)
      (return (make-cell (subst-self-node (n car) typename)
                         (subst-self-node (n cdr) typename)
                         (n line))))
    (return node)))

; Register a (defprotocol Name (sig...) ...) form. Idempotent on name.
(defn protocol-register-form:void (form:ptr)
  (let (ff:ptr:Node (cast ptr:Node form))
    (when (< (node-len form) 2)
      (die-at (ff line) "defprotocol: expected (defprotocol Name (sig...) ...)"))
    (let (name-node:ptr:Node (cast ptr:Node (node-at form 1)))
      (when (!= (name-node kind) NODE-SYM)
        (die-at (name-node line) "defprotocol: name must be a symbol"))
      (let (pname:ptr (name-node s))
        (when (!= (protocol-lookup pname) null) (return))
        (guard-name-kind pname (ff line) NK-PROTOCOL)
        (let (nsigs:i32 (- (node-len form) 2)
              sigs:ptr null)
          (when (> nsigs 0)
            (set! sigs (arena-alloc (* (cast i64 nsigs) (ptr-bytes))))
            (let (i:i32 0)
              (while (< i nsigs)
                (aset! (cast ptr:ptr sigs) i (node-at form (+ i 2)))
                (inc! i))))
          (protocol-new pname sigs nsigs))))))

(defn prescan-protocols:void (forms:ptr)
  (let (fc:ptr forms)
    (while (!= fc null)
      (let (f:ptr:Node (cast ptr:Node ((cast ptr:Node fc) car)))
        (when (and (and (!= (cast ptr f) null) (= (f kind) NODE-CELL))
                   (and (>= (node-len (cast ptr f)) 2)
                        (and (-> f (node-at _ 0) (cast ptr:Node _) (_ kind) (= _ NODE-SYM))
                             (-> f (node-at _ 0) (cast ptr:Node _) (_ s)
                                 (= _ "defprotocol")))))
          (protocol-register-form (cast ptr f))))
      (set! fc ((cast ptr:Node fc) cdr)))))

; Built-in result type of an operator generic `g` applied to a same-typed pair
; of operands, or null if the operator does not apply. Comparisons yield i1;
; arithmetic yields the operand type. This is what lets numeric/pointer built-ins
; satisfy operator protocol requirements (Num/Eq/Ord) with no user method (§10.3).
(defn builtin-op-result-type:ptr (g:ptr ptypes:ptr nparams:i32)
  (let (gg:ptr:Generic (cast ptr:Generic g))
    (when (= (gg num-methods) 0) (return null))
    (let (m0:ptr:Method (cast ptr:Method (aref (cast ptr:ptr (gg methods)) 0)))
      (when (!= (m0 kind) METHOD-INTRINSIC) (return null))
      (when (!= nparams 2) (return null))
      (let (at:ptr (aref (cast ptr:ptr ptypes) 0)
            bt:ptr (aref (cast ptr:ptr ptypes) 1)
            bop:ptr:BinOp (cast ptr:BinOp (m0 binop)))
        (when (= (type-eq at bt) 0) (return null))
        (if (!= (bop is-cmp) 0)
          (do
            (when (or (or (!= (is-int-type at) 0) (!= (is-float-type at) 0))
                      (= (-> at (cast ptr:Type _) (_ kind)) TY-PTR))
              (return ty-i1))
            ; CStr satisfies Eq (= / !=) only — content comparison via strcmp.
            (when (and (= (-> at (cast ptr:Type _) (_ kind)) TY-CSTR)
                       (or (= (bop name) "=")
                           (= (bop name) "!=")))
              (return ty-i1))
            (return null))
          (do
            (when (or (!= (is-int-type at) 0) (!= (is-float-type at) 0))
              (return at))
            (return null)))))))

; Does a method named `mname` satisfy a required signature (param types `ptypes`,
; return `ret`; ret=null means "any")? Either a user/concrete method at the exact
; tier, or a built-in operator whose result type matches. Shared by `extend`
; conformance and the `Valid` call-site check (§10.2).
(defn method-satisfies-sig:i32 (mname:ptr ptypes:ptr nparams:i32 ret:ptr)
  (let (g:ptr (generic-lookup mname))
    (when (= g null) (return 0))
    (when (!= (generic-find-method-exact g ptypes nparams) null) (return 1))
    (let (rt:ptr (builtin-op-result-type g ptypes nparams))
      (when (and (!= rt null) (or (= ret null) (!= (type-eq rt ret) 0))) (return 1)))
    (return 0)))

; Verify (when check≠0) and record that `typename` conforms to protocol
; `proto-name`, then recurse into the protocol's super-protocols (§10.3). In
; check mode every required signature (Self→typename) must resolve to a concrete
; method or a satisfying built-in operator; missing methods are reported and the
; compile aborts. The conformance-lookup guard makes this idempotent and safe
; against cyclic inheritance. Import side passes check=0 (trust the exporter).
(defn verify-conformance:void (typename:ptr proto-name:ptr line:i32 check:i32)
  (when (!= (conformance-lookup typename proto-name) 0) (return))
  (let (proto:ptr (protocol-lookup proto-name))
    (when (= proto null)
      (when (!= check 0)
        (die-at line (fmt-s "extend: unknown protocol '%s'" proto-name)))
      (return))
    (when (!= check 0)
      (let (pp:ptr:Protocol (cast ptr:Protocol proto)
            i:i32 0
            missing:i32 0)
        (while (< i (pp num-sigs))
          (let (sig:ptr (aref (cast ptr:ptr (pp sigs)) i)
                csig:ptr (subst-self-node sig typename)
                name-node:ptr (node-at csig 0)
                params-node:ptr (node-at csig 1)
                mname:ptr null
                ret:ptr (extract-name-and-type name-node (cast ptr:ptr (addr-of mname))
                                               ((cast ptr:Node name-node) line)))
            (let (nparams:i32 (defn-params-count params-node)
                  ptypes:ptr (defn-params-to-types params-node))
              (when (= (method-satisfies-sig mname ptypes nparams ret) 0)
                (set! missing 1)
                (fprintf (cast ptr stderr)
                  "  %s does not implement %s.%s\n" typename proto-name mname))))
          (inc! i))
        (when (!= missing 0)
          (die-at line
            (fmt-2s "type '%s' does not conform to protocol '%s'" typename proto-name)))))
    (conformance-add typename proto-name)
    ; Conforming to `proto-name` requires conforming to each declared super.
    (let (si:i32 0)
      (while (< si g-num-proto-supers)
        (let (e:ptr:Conformance (cast ptr:Conformance (ptr+ (cast ptr:Conformance g-proto-supers) si)))
          (when (= (e type-name) proto-name)
            (verify-conformance typename (e proto-name) line check)))
        (inc! si)))))

; (extend Subject Protocol): post-prescan conformance check (§9.2/§10.3). When
; Subject is a *protocol*, this declares protocol inheritance (Subject requires
; Protocol). Otherwise Subject is a type whose conformance is verified and
; recorded, recursing into the protocol's supers.
(defn emit-extend:void (form:ptr)
  (let (ff:ptr:Node (cast ptr:Node form))
    (when (< (node-len form) 3)
      (die-at (ff line) "extend: expected (extend Subject Protocol)"))
    (let (type-node:ptr:Node (cast ptr:Node (node-at form 1))
          proto-node:ptr:Node (cast ptr:Node (node-at form 2)))
      (when (!= (type-node kind) NODE-SYM)
        (die-at (type-node line) "extend: subject must be a symbol"))
      (when (!= (proto-node kind) NODE-SYM)
        (die-at (proto-node line) "extend: protocol must be a symbol"))
      (let (typename:ptr (type-node s)
            proto-name:ptr (proto-node s))
        ; Protocol-on-protocol: declare inheritance, no per-type check.
        (when (!= (protocol-lookup typename) null)
          (when (= (protocol-lookup proto-name) null)
            (die-at (proto-node line)
              (fmt-s "extend: '%s' is a protocol, so its supertype '%s' must be a protocol too"
                     typename proto-name)))
          (proto-super-add typename proto-name)
          (return))
        ; Extending to a blanket protocol (Any/Struct) is redundant — conformance
        ; is automatic and structural — so accept it as a no-op.
        (when (!= (blanket-lookup proto-name) 0) (return))
        (when (= (protocol-lookup proto-name) null)
          (die-at (proto-node line) (fmt-s "extend: unknown protocol '%s'" proto-name)))
        ; Validate single-token subject types eagerly for a clean diagnostic.
        (when (= (strchr typename 58) null)
          (parse-type-name typename (type-node line)))
        (verify-conformance typename proto-name (ff line) 1)))))

; Import side: trust the exporting unit's check; record the fact (and recurse
; supers), or re-register a protocol-inheritance edge.
(defn register-imported-conformance:void (form:ptr)
  (when (>= (node-len form) 3)
    (let (type-node:ptr:Node (cast ptr:Node (node-at form 1))
          proto-node:ptr:Node (cast ptr:Node (node-at form 2)))
      (when (and (= (type-node kind) NODE-SYM) (= (proto-node kind) NODE-SYM))
        (if (!= (protocol-lookup (type-node s)) null)
          (proto-super-add (type-node s) (proto-node s))
          (verify-conformance (type-node s) (proto-node s)
                              ((cast ptr:Node form) line) 0))))))

; ============================================================
; Cast
; ============================================================

(defn emit-cast:ref:Val (call:ptr scope:ref:Scope)
  (let (cc:ptr:Node (cast ptr:Node call))
    (when (!= (node-len cc) 3)
      (die-at (cc line) "cast expects 2 args"))
    (let (type-node:ptr:Node (cast ptr:Node (node-at cc 1)))
      (let (dst:ptr (parse-type-from-node (cast ptr type-node) (type-node line))
            v:ref:Val (emit-node (node-at cc 2) scope)
            src:ptr (v type))
        ; Reinterpreting casts preserve pointer identity, so the result keeps
        ; the operand's escape taint (lifecycle.md §2.2).
        (when (= (-> src (cast ptr:Type _) (_ kind)) (-> dst (cast ptr:Type _) (_ kind)))
          (let (rv:ref:Val (alloc-val dst (v val)))
            (.set! rv taint (v taint))
            (return rv)))
        ; CStr <-> ptr: both lower to `ptr`, reinterpret with no IR.
        (when (and (!= (is-ptr-like src) 0) (!= (is-ptr-like dst) 0))
          (let (rv:ref:Val (alloc-val dst (v val)))
            (.set! rv taint (v taint))
            (return rv)))
        (let (instr:ptr null)
          (when (and (!= (is-int-type src) 0) (!= (is-int-type dst) 0))
            (let (sw:i32 (int-width src) dw:i32 (int-width dst))
              (when (= sw dw)
                ; Same width, different signedness — reinterpret (no IR needed)
                (return (alloc-val dst (v val))))
              (if (< dw sw)
                (set! instr "trunc")
                (if (!= (is-unsigned src) 0)
                  (set! instr "zext")
                  (set! instr "sext")))))
          (when (and (!= (is-int-type src) 0) (!= (is-ptr-like dst) 0))
            (set! instr "inttoptr"))
          (when (and (!= (is-ptr-like src) 0) (!= (is-int-type dst) 0))
            (set! instr "ptrtoint"))
          ; Float-to-float (different widths): fpext or fptrunc.
          (when (and (!= (is-float-type src) 0) (!= (is-float-type dst) 0))
            (let (sk:i32 (-> src (cast ptr:Type _) (_ kind))
                  dk:i32 (-> dst (cast ptr:Type _) (_ kind)))
              (cond (and (= sk TY-F32) (= dk TY-F64)) (set! instr "fpext")
                    (and (= sk TY-F64) (= dk TY-F32)) (set! instr "fptrunc")
                    true (do))))
          ; Int-to-float: sitofp or uitofp depending on src signedness.
          (when (and (!= (is-int-type src) 0) (!= (is-float-type dst) 0))
            (if (!= (is-unsigned src) 0)
              (set! instr "uitofp")
              (set! instr "sitofp")))
          ; Float-to-int: fptosi or fptoui depending on dst signedness.
          (when (and (!= (is-float-type src) 0) (!= (is-int-type dst) 0))
            (if (!= (is-unsigned dst) 0)
              (set! instr "fptoui")
              (set! instr "fptosi")))
          (when (= instr null)
            (die-at (cc line) "cast: unsupported conversion"))
          (let (tmp:ptr (new-tmp))
            (fprintf g-body-stream "  %s = %s %s %s to %s\n"
              tmp instr (type-to-ir src) (v val) (type-to-ir dst))
            (return (alloc-val dst tmp))))))))

; ============================================================
; Struct field access
; ============================================================

; Intern `s` and return its canonical string pointer. Two equal spellings yield
; the same pointer, so interned strings compare by pointer identity (`=`) rather
; than `strcmp`. Field names are stored interned (emit-defstruct,
; repl-register-node) and selectors arrive interned (the reader/`quote` intern at
; lex time), so struct-field-index matches by identity.
(defn intern-str:ptr (s:ptr)
  (return ((cast ptr:Node (intern-symbol s)) s)))

; Index of field `fname` in struct `sd`, or -1. Shared by `.`, the `get`
; intrinsic, and the non-emitting type pass so the three cannot drift. `fname`
; and the stored field names are interned, so this is a pointer-identity scan.
(defn struct-field-index:i32 (sd:ptr fname:ptr)
  (let (sdd:ptr:StructDef (cast ptr:StructDef sd)
        i:i32 0)
    (while (< i (sdd num-fields))
      (when (= (aref (cast ptr:ptr (sdd field-names)) i) fname)
        (return i))
      (inc! i))
    (return -1)))

; Emit `getelementptr + load` of field `idx` from the pointer-to-struct value
; `p`. This is the zero-overhead member-access core shared by the `.` special
; form (emit-field-get) and the `get` blanket intrinsic (emit-get-intrinsic);
; a literal-symbol `(s 'field)` const-folds straight to this, byte-identical.
(defn emit-field-load:ref:Val (p:ptr sd:ptr idx:i32)
  (let (pv:ptr:Val (cast ptr:Val p)
        sdd:ptr:StructDef (cast ptr:StructDef sd)
        ftype:ptr (aref (cast ptr:ptr (sdd field-types)) idx)
        gep:ptr (new-tmp))
    (fprintf g-body-stream
      "  %s = getelementptr inbounds %%%s, ptr %s, i32 0, i32 %d\n"
      gep (sdd name) (pv val) idx)
    (let (val:ptr (new-tmp))
      (emit-load val (type-to-ir ftype) gep ftype)
      (return (alloc-val ftype val)))))

(defn emit-field-get:ref:Val (call:ptr scope:ref:Scope)
  (let (cc:ptr:Node (cast ptr:Node call))
    (when (!= (node-len cc) 3)
      (die-at (cc line) "_get expects 2 args"))
    (let (p:ref:Val (emit-node (node-at cc 1) scope)
          pt:ptr:Type (cast ptr:Type (p type)))
      (when (or (or (!= (pt kind) TY-PTR) (= (pt elem) null))
              (-> pt (_ elem) (cast ptr:Type _) (_ kind) (!= _ TY-STRUCT)))
        (die-at (cc line) "_get: operand must be pointer to struct"))
      (require-derefable (cast ptr pt) (cc line) "field access")
      (let (fn-node:ptr:Node (cast ptr:Node (node-at cc 2)))
        (when (!= (fn-node kind) NODE-SYM)
          (die-at (fn-node line) "_get: field name must be symbol"))
        (let (sd:ptr:StructDef (cast ptr:StructDef (-> pt (_ elem) (cast ptr:Type _) (_ sdef)))
              idx:i32 (struct-field-index (cast ptr sd) (fn-node s)))
          (when (< idx 0)
            (die-at (fn-node line)
              (fmt-2s "_get: no field '%s' on struct '%s'" (fn-node s) (sd name))))
          (return (emit-field-load (cast ptr p) (cast ptr sd) idx)))))))

(defn emit-field-set:ref:Val (call:ptr scope:ref:Scope)
  (let (cc:ptr:Node (cast ptr:Node call))
    (when (!= (node-len cc) 4)
      (die-at (cc line) ".set! expects 3 args"))
    (let (p:ref:Val (emit-node (node-at cc 1) scope)
          pt:ptr:Type (cast ptr:Type (p type)))
      (when (or (or (!= (pt kind) TY-PTR) (= (pt elem) null))
              (-> pt (_ elem) (cast ptr:Type _) (_ kind) (!= _ TY-STRUCT)))
        (die-at (cc line) ".set!: operand must be pointer to struct"))
      (require-derefable (cast ptr pt) (cc line) ".set!")
      (let (fn-node:ptr:Node (cast ptr:Node (node-at cc 2)))
        (when (!= (fn-node kind) NODE-SYM)
          (die-at (fn-node line) ".set!: field name must be symbol"))
        (let (sd:ptr:StructDef (cast ptr:StructDef (-> pt (_ elem) (cast ptr:Type _) (_ sdef)))
              idx:i32 (struct-field-index (cast ptr sd) (fn-node s)))
          (when (< idx 0)
            (die-at (fn-node line)
              (fmt-2s ".set!: no field '%s' on struct '%s'" (fn-node s) (sd name))))
          (let (ftype:ptr (aref (cast ptr:ptr (sd field-types)) idx)
                v:ref:Val (emit-node (node-at cc 3) scope)
                coerced:ptr (coerce-int-val v ftype (cc line)))
            (when (= coerced null)
              (die-at (cc line) (fmt-s ".set!: type mismatch for field '%s'" (fn-node s))))
            (taint-store-check (cast ptr p) v (cc line) ".set!")
            (let (cv:ptr:Val (cast ptr:Val coerced)
                  gep:ptr (new-tmp))
              (fprintf g-body-stream
                "  %s = getelementptr inbounds %%%s, ptr %s, i32 0, i32 %d\n"
                gep (sd name) (p val) idx)
              (emit-store (type-to-ir ftype) (cv val) gep ftype)
              (return (alloc-val ty-void null)))))))))

; ============================================================
; Callable values (non-function call position) — callable-values.md
;
; A non-function value `s` in head position, `(s arg…)`, desugars by the sole
; argument into one of two reserved generics:
;   (s 'field) / (s field)  [a literal symbol]  → (get s 'field)   member access
;   (s 3)      / (s a b …)  [anything else]      → (invoke s 3 …)   general call
; `get` carries a built-in Struct intrinsic (GEP+load, zero overhead, overridable
; by a user `get` method); `invoke` is purely user-supplied (indexing, Seq/Call).
; ============================================================

; If `node` is a literal field selector — a bare symbol `field` or an explicit
; `(quote field)` — return the symbol Node; else null (a computed selector). A
; bare symbol is always a field, never a variable: field interpretation wins so
; it never depends on what is in scope (callable-values.md §3.5).
(defn selector-literal-sym:ptr (node:ptr)
  (when (= node null) (return null))
  (let (nn:ptr:Node (cast ptr:Node node))
    (when (= (nn kind) NODE-SYM) (return node))
    (when (and (= (nn kind) NODE-CELL) (= (node-len node) 2))
      (when (= (node-at node 0) 'quote)
        (let (inner:ptr (node-at node 1))
          (when (= (-> inner (cast ptr:Node _) (_ kind)) NODE-SYM) (return inner)))))
    (return null)))

; Emit the selector argument as a value for a user `get` method: a literal
; selector becomes its interned symbol Node* (the same pointer the reader / a
; `'sym` quote produce); a computed selector is evaluated normally.
(defn emit-selector-value:ref:Val (sel-node:ptr scope:ref:Scope)
  (let (lit:ptr (selector-literal-sym sel-node))
    (if (!= lit null)
      (return (alloc-val ty-ptr (emit-quote-tree lit)))
      (return (emit-node sel-node scope)))))

; Computed-symbol field access (callable-values.md §3.2/§3.3, step 3): the
; selector is dynamic but the struct type is static. Restricted to a homogeneous
; struct (all fields one type) so the result type is well-defined. Emits a
; bounded branch comparing the selector against each interned field symbol
; (pointer identity), then an array-style GEP+load at the matched index.
(defn emit-computed-field:ref:Val (n:ptr scope:ref:Scope callee-val:ptr sd:ptr sel-node:ptr line:i32)
  (let (sdd:ptr:StructDef (cast ptr:StructDef sd)
        nf:i32 (sdd num-fields))
    (when (= nf 0) (die-at line "get: cannot index an empty struct with a computed selector"))
    (let (ftype:ptr (aref (cast ptr:ptr (sdd field-types)) 0)
          fi:i32 1)
      ; Homogeneity gate — a heterogeneous struct has no single result type.
      (while (< fi nf)
        (when (= (type-eq (aref (cast ptr:ptr (sdd field-types)) fi) ftype) 0)
          (die-at line
            (fmt-s "get: computed field access requires a homogeneous struct, but '%s' has fields of differing types"
                   (sdd name))))
        (inc! fi))
      (let (cv:ptr:Val (cast ptr:Val callee-val)
            sel:ref:Val (emit-node sel-node scope))
        (when (-> sel (_ type) (cast ptr:Type _) (_ kind) (!= _ TY-PTR))
          (die-at line "get: computed selector must evaluate to a symbol (ptr)"))
        ; Build the field index by a chain of select instructions, innermost
        ; default 0: idx = (sel==f0)?0 : (sel==f1)?1 : … : 0.
        (let (idx:ptr "0"
              k:i32 (- nf 1))
          (while (>= k 0)
            (let (fsym-node:ptr:Node (cast ptr:Node (alloc-node)))
              (.set! fsym-node kind NODE-SYM)
              (.set! fsym-node line line)
              (.set! fsym-node s (aref (cast ptr:ptr (sdd field-names)) k))
              (let (fsym:ptr (emit-quote-tree (cast ptr fsym-node))
                    cmp:ptr (new-tmp))
                (fprintf g-body-stream "  %s = icmp eq ptr %s, %s\n" cmp (sel val) fsym)
                (let (nidx:ptr (new-tmp))
                  (fprintf g-body-stream "  %s = select i1 %s, i64 %d, i64 %s\n"
                    nidx cmp k idx)
                  (set! idx nidx))))
            (set! k (- k 1)))
          ; Homogeneous layout is contiguous, so index it as an array of ftype.
          (let (gep:ptr (new-tmp))
            (fprintf g-body-stream
              "  %s = getelementptr inbounds %s, ptr %s, i64 %s\n"
              gep (type-to-ir ftype) (cv val) idx)
            (let (val:ptr (new-tmp))
              (fprintf g-body-stream "  %s = load %s, ptr %s, align %d\n"
                val (type-to-ir ftype) gep (type-size ftype))
              (return (alloc-val ftype val)))))))))

; The `get` blanket intrinsic: member access on a pointer-to-struct callee. A
; literal selector const-folds to a static GEP+load (byte-identical to `.`); a
; computed selector takes the homogeneous runtime branch above.
(defn emit-get-intrinsic:ref:Val (n:ptr scope:ref:Scope callee-val:ptr sel-node:ptr line:i32)
  (let (cv:ptr:Val (cast ptr:Val callee-val)
        ct:ptr:Type (cast ptr:Type (cv type)))
    (when (or (or (!= (ct kind) TY-PTR) (= (ct elem) null))
              (-> ct (_ elem) (cast ptr:Type _) (_ kind) (!= _ TY-STRUCT)))
      (die-at line "callable value: not callable — no matching get/invoke method and not a pointer-to-struct"))
    (require-derefable (cast ptr ct) line "field access")
    (let (sd:ptr:StructDef (cast ptr:StructDef (-> ct (_ elem) (cast ptr:Type _) (_ sdef)))
          lit:ptr (selector-literal-sym sel-node))
      (when (= lit null)
        (return (emit-computed-field n scope callee-val (cast ptr sd) sel-node line)))
      (let (idx:i32 (struct-field-index (cast ptr sd) (-> lit (cast ptr:Node _) (_ s))))
        (when (< idx 0)
          (die-at line
            (fmt-2s "get: no field '%s' on struct '%s'" (-> lit (cast ptr:Node _) (_ s)) (sd name))))
        (return (emit-field-load callee-val (cast ptr sd) idx))))))

; Resolve `(get callee selector)` for an already-emitted callee value. A user
; `get` method for (callee-type, symbol) sits at tier 0 and out-ranks the
; intrinsic (concrete beats blanket); otherwise the Struct intrinsic handles it.
(defn emit-get-with-callee:ref:Val (n:ptr scope:ref:Scope callee-val:ptr sel-node:ptr)
  (let (cv:ptr:Val (cast ptr:Val callee-val)
        ct:ptr (cv type)
        line:i32 (-> n (cast ptr:Node _) (_ line))
        g:ptr (generic-lookup "get"))
    (when (!= g null)
      (let (argtypes:ptr (arena-alloc (* (cast i64 2) (ptr-bytes))))
        (aset! (cast ptr:ptr argtypes) 0 ct)
        (aset! (cast ptr:ptr argtypes) 1 ty-ptr)
        (let (m:?Method (generic-find-method-exact g argtypes 2))
          (when (!= m null)
            (let (sel-val:ref:Val (emit-selector-value sel-node scope)
                  args:ptr (arena-alloc (* (cast i64 2) (sizeof Val))))
              (memcpy (ptr+ (cast ptr:Val args) 0) cv (sizeof Val))
              (memcpy (ptr+ (cast ptr:Val args) 1) sel-val (sizeof Val))
              (return (emit-resolved-call n scope "get" m args 2 line)))))))
    (return (emit-get-intrinsic n scope callee-val sel-node line))))

; Resolve `(invoke callee arg…)` for an already-emitted callee value. The callee
; is the first dispatch argument; the rest are emitted here. Dispatch is ordinary
; multimethod resolution over the `invoke` generic — a type "becomes callable" by
; defining `invoke` methods (indexing, Seq/Call). No built-in default.
(defn emit-invoke-with-callee:ref:Val (n:ptr scope:ref:Scope callee-val:ptr arg-start:i32 nargs:i32)
  (let (cv:ptr:Val (cast ptr:Val callee-val)
        line:i32 (-> n (cast ptr:Node _) (_ line))
        total:i32 (+ nargs 1)
        args:ptr (arena-alloc (* (cast i64 (+ total 1)) (sizeof Val)))
        argtypes:ptr (arena-alloc (* (cast i64 (+ total 1)) (ptr-bytes)))
        arg-nodes:ptr (arena-alloc (* (cast i64 (+ total 1)) (ptr-bytes))))
    (memcpy (ptr+ (cast ptr:Val args) 0) cv (sizeof Val))
    (aset! (cast ptr:ptr argtypes) 0 (cv type))
    (aset! (cast ptr:ptr arg-nodes) 0 null)
    (let (i:i32 0)
      (while (< i nargs)
        (let (anode:ptr (node-at n (+ arg-start i))
              v:ref:Val (emit-node anode scope))
          (memcpy (ptr+ (cast ptr:Val args) (+ i 1)) v (sizeof Val))
          (aset! (cast ptr:ptr argtypes) (+ i 1) (-> v (cast ptr:Val _) (_ type)))
          (aset! (cast ptr:ptr arg-nodes) (+ i 1) anode))
        (inc! i)))
    (let (g:ptr (generic-lookup "invoke"))
      (when (= g null)
        (die-at line "value is not callable: no `invoke` method is defined for this type"))
      (let (m:ref:Method (generic-resolve g argtypes arg-nodes total line))
        (return (emit-resolved-call n scope "invoke" m args total line))))))

; The desugar entry point: an already-emitted non-function head value `callee-val`
; in `(callee arg…)`. A single literal-symbol argument routes to `get` (member
; access); everything else routes to `invoke`.
(defn emit-callable-value:ref:Val (n:ptr scope:ref:Scope callee-val:ptr)
  (let (nargs:i32 (- (node-len n) 1)
        ct:ptr:Type (cast ptr:Type ((cast ptr:Val callee-val) type)))
    ; A function-pointer value folds to an indirect call (callable-values.md §4.2).
    (when (= (ct kind) TY-FN)
      (return (emit-funcall-value n scope callee-val 1)))
    (when (and (= nargs 1) (!= (selector-literal-sym (node-at n 1)) null))
      (return (emit-get-with-callee n scope callee-val (node-at n 1))))
    (return (emit-invoke-with-callee n scope callee-val 1 nargs))))

; Explicit `(get value selector)` and `(invoke value arg…)` surface forms. They
; share the resolution above so `(get s 'f)` ≡ `(s f)` and `(invoke v 3)` ≡ `(v 3)`.
(defn emit-get:ref:Val (call:ptr scope:ref:Scope)
  (let (cc:ptr:Node (cast ptr:Node call))
    (when (!= (node-len cc) 3) (die-at (cc line) "get expects (get value selector)"))
    (let (callee-val:ref:Val (emit-node (node-at cc 1) scope))
      (return (emit-get-with-callee call scope callee-val (node-at cc 2))))))

(defn emit-invoke:ref:Val (call:ptr scope:ref:Scope)
  (let (cc:ptr:Node (cast ptr:Node call))
    (when (< (node-len cc) 2) (die-at (cc line) "invoke expects (invoke value arg...)"))
    (let (callee-val:ref:Val (emit-node (node-at cc 1) scope))
      (return (emit-invoke-with-callee call scope callee-val 2 (- (node-len cc) 2))))))

; ============================================================
; sizeof, alloca, array ops, char, pointer ops
; ============================================================

(defn emit-sizeof:ref:Val (call:ptr scope:ref:Scope)
  (let (cc:ptr:Node (cast ptr:Node call))
    (when (!= (node-len cc) 2) (die-at (cc line) "sizeof expects 1 arg"))
    (let (tn:ptr:Node (cast ptr:Node (node-at cc 1)))
      (let (ty:ptr (parse-type-from-node (cast ptr tn) (tn line))
            gep:ptr (new-tmp))
        (fprintf g-body-stream "  %s = getelementptr %s, ptr null, i32 1\n"
          gep (type-to-ir ty))
        (let (sz:ptr (new-tmp))
          ; sizeof yields a pointer-sized integer (size_t), not a hardcoded i64.
          (fprintf g-body-stream "  %s = ptrtoint ptr %s to %s\n"
            sz gep (ptr-int-ir))
          (return (alloc-val (ptr-int-type) sz)))))))

(defn emit-alloca-form:ref:Val (call:ptr scope:ref:Scope)
  (let (cc:ptr:Node (cast ptr:Node call))
    (when (and (!= (node-len cc) 2) (!= (node-len cc) 3))
      (die-at (cc line) "alloca expects 1 or 2 args"))
    (let (tn:ptr:Node (cast ptr:Node (node-at cc 1)))
      (let (ty:ptr (parse-type-from-node (cast ptr tn) (tn line))
            slot:ptr (new-tmp)
            pt:ptr:Type (cast ptr:Type (make-type TY-PTR)))
        (.set! pt elem ty)
        (if (= (node-len cc) 3)
          (let (nv:ref:Val (emit-node (node-at cc 2) scope))
            (fprintf g-body-stream "  %s = alloca %s, i32 %s, align %d\n"
              slot (type-to-ir ty) (nv val) (type-size ty)))
          (fprintf g-entry-stream "  %s = alloca %s, align %d\n"
            slot (type-to-ir ty) (type-size ty)))
        (return (alloc-val (cast ptr pt) slot))))))

(defn emit-aref:ref:Val (call:ptr scope:ref:Scope)
  (let (cc:ptr:Node (cast ptr:Node call))
    (when (!= (node-len cc) 3) (die-at (cc line) "aref expects 2 args"))
    (let (p:ref:Val (emit-node (node-at cc 1) scope))
      (when (or (-> p (_ type) (cast ptr:Type _) (_ kind) (!= _ TY-PTR))
              (-> p (_ type) (cast ptr:Type _) (_ elem) (= _ null)))
        (die-at (cc line) "aref: operand must be typed pointer"))
      (require-derefable (p type) (cc line) "aref")
      (let (idx:ref:Val (emit-node (node-at cc 2) scope))
        (when (= (is-int-type (idx type)) 0)
          (die-at (cc line) "aref: index must be integer"))
        (let (idx64:ptr (idx val))
          (when (-> idx (_ type) (cast ptr:Type _) (_ kind) (!= _ TY-I64))
            (let (t:ptr (new-tmp))
              (fprintf g-body-stream "  %s = sext %s %s to i64\n"
                t (type-to-ir (idx type)) (idx val))
              (set! idx64 t)))
          (let (elem:ptr (-> p (_ type) (cast ptr:Type _) (_ elem))
                gep:ptr (new-tmp))
            (fprintf g-body-stream
              "  %s = getelementptr inbounds %s, ptr %s, i64 %s\n"
              gep (type-to-ir elem) (p val) idx64)
            (let (val:ptr (new-tmp))
              (fprintf g-body-stream "  %s = load %s, ptr %s, align %d\n"
                val (type-to-ir elem) gep (type-size elem))
              (return (alloc-val elem val)))))))))

(defn emit-aset:ref:Val (call:ptr scope:ref:Scope)
  (let (cc:ptr:Node (cast ptr:Node call))
    (when (!= (node-len cc) 4) (die-at (cc line) "aset! expects 3 args"))
    (let (p:ref:Val (emit-node (node-at cc 1) scope))
      (when (or (-> p (_ type) (cast ptr:Type _) (_ kind) (!= _ TY-PTR))
              (-> p (_ type) (cast ptr:Type _) (_ elem) (= _ null)))
        (die-at (cc line) "aset!: operand must be typed pointer"))
      (require-derefable (p type) (cc line) "aset!")
      (let (idx:ref:Val (emit-node (node-at cc 2) scope))
        (when (= (is-int-type (idx type)) 0)
          (die-at (cc line) "aset!: index must be integer"))
        (let (idx64:ptr (idx val))
          (when (-> idx (_ type) (cast ptr:Type _) (_ kind) (!= _ TY-I64))
            (let (t:ptr (new-tmp))
              (fprintf g-body-stream "  %s = sext %s %s to i64\n"
                t (type-to-ir (idx type)) (idx val))
              (set! idx64 t)))
          (let (elem:ptr (-> p (_ type) (cast ptr:Type _) (_ elem))
                v:ref:Val (emit-node (node-at cc 3) scope)
                coerced:ptr (coerce-int-val v elem (cc line)))
            (when (= coerced null)
              (die-at (cc line) "aset!: value type mismatch"))
            (taint-store-check (cast ptr p) v (cc line) "aset!")
            (let (cv:ptr:Val (cast ptr:Val coerced)
                  gep:ptr (new-tmp))
              (fprintf g-body-stream
                "  %s = getelementptr inbounds %s, ptr %s, i64 %s\n"
                gep (type-to-ir elem) (p val) idx64)
              (fprintf g-body-stream "  store %s %s, ptr %s, align %d\n"
                (type-to-ir elem) (cv val) gep (type-size elem))
              (return (alloc-val ty-void null)))))))))

(defn emit-char:ref:Val (call:ptr scope:ref:Scope)
  (let (cc:ptr:Node (cast ptr:Node call))
    (when (!= (node-len cc) 2) (die-at (cc line) "char expects 1 arg"))
    (let (arg:ptr:Node (cast ptr:Node (node-at cc 1)))
      (when (or (!= (arg kind) NODE-STR) (!= (cast i64 (strlen (arg s))) (cast i64 1)))
        (die-at (arg line) "char: arg must be single-char string"))
      (return (alloc-val ty-i8 (fmt-i32 "%d" (char-at (arg s) (cast i64 0))))))))

(defn emit-addr-of:ref:Val (call:ptr scope:ref:Scope)
  (let (cc:ptr:Node (cast ptr:Node call))
    (when (!= (node-len cc) 2) (die-at (cc line) "addr-of expects 1 arg"))
    (let (target:ptr:Node (cast ptr:Node (node-at cc 1)))
      (when (!= (target kind) NODE-SYM)
        (die-at (target line) "addr-of: target must be symbol"))
      (let (sym:ptr:Sym (cast ptr:Sym (scope-lookup scope (target s))))
        (when (= (cast ptr sym) null)
          (die-at (target line) (fmt-s "addr-of: undefined '%s'" (target s))))
        (when (-> sym (_ type) (cast ptr:Type _) (_ kind) (= _ TY-FN))
          (die-at (target line) (fmt-s "addr-of: cannot take address of function '%s'" (target s))))
        (let (pt:ptr:Type (cast ptr:Type (make-type TY-PTR)))
          (.set! pt elem (sym type))
          ; The slot address reaches the same resource the binding does, so it
          ; carries the binding's escape taint (lifecycle.md §2.2).
          (let (rv:ref:Val (alloc-val (cast ptr pt) (sym ir-name)))
            (.set! rv taint (sym taint))
            (return rv)))))))

(defn emit-funcall-void:ref:Val (call:ptr scope:ref:Scope)
  (let (cc:ptr:Node (cast ptr:Node call))
    (when (!= (node-len cc) 2) (die-at (cc line) "funcall-void expects 1 arg"))
    (let (fn:ref:Val (emit-node (node-at cc 1) scope))
      (when (-> fn (_ type) (cast ptr:Type _) (_ kind) (!= _ TY-PTR))
        (die-at (cc line) "funcall-void: arg must be ptr"))
      (fprintf g-body-stream "  call void %s()\n" (fn val))
      (return (alloc-val ty-void null)))))

; (funcall-ptr-1 fn arg) — call fn(arg) as ptr(ptr) via pointer, return ptr
(defn emit-funcall-ptr-1:ref:Val (call:ptr scope:ref:Scope)
  (let (cc:ptr:Node (cast ptr:Node call))
    (when (!= (node-len cc) 3) (die-at (cc line) "funcall-ptr-1 expects 2 args"))
    (let (fn:ptr:Val  (cast ptr:Val (emit-node (node-at cc 1) scope))
          arg:ref:Val (emit-node (node-at cc 2) scope))
      (when (-> fn (_ type) (cast ptr:Type _) (_ kind) (!= _ TY-PTR))
        (die-at (cc line) "funcall-ptr-1: fn must be ptr"))
      (when (-> arg (_ type) (cast ptr:Type _) (_ kind) (!= _ TY-PTR))
        (die-at (cc line) "funcall-ptr-1: arg must be ptr"))
      (let (tmp:ptr (new-tmp))
        (fprintf g-body-stream "  %s = call ptr %s(ptr %s)\n"
          tmp (fn val) (arg val))
        (return (alloc-val ty-ptr tmp))))))

; (funcall-ptr-i32 fn) — call fn() as i32() via pointer, return i32
(defn emit-funcall-ptr-i32:ref:Val (call:ptr scope:ref:Scope)
  (let (cc:ptr:Node (cast ptr:Node call))
    (when (!= (node-len cc) 2) (die-at (cc line) "funcall-ptr-i32 expects 1 arg"))
    (let (fn:ref:Val (emit-node (node-at cc 1) scope))
      (when (-> fn (_ type) (cast ptr:Type _) (_ kind) (!= _ TY-PTR))
        (die-at (cc line) "funcall-ptr-i32: arg must be ptr"))
      (let (tmp:ptr (new-tmp))
        (fprintf g-body-stream "  %s = call i32 %s()\n" tmp (fn val))
        (return (alloc-val ty-i32 tmp))))))

; (funcall-ptr-i64 fn) — call fn() as i64() via pointer, return i64
(defn emit-funcall-ptr-i64:ref:Val (call:ptr scope:ref:Scope)
  (let (cc:ptr:Node (cast ptr:Node call))
    (when (!= (node-len cc) 2) (die-at (cc line) "funcall-ptr-i64 expects 1 arg"))
    (let (fn:ref:Val (emit-node (node-at cc 1) scope))
      (when (-> fn (_ type) (cast ptr:Type _) (_ kind) (!= _ TY-PTR))
        (die-at (cc line) "funcall-ptr-i64: arg must be ptr"))
      (let (tmp:ptr (new-tmp))
        (fprintf g-body-stream "  %s = call i64 %s()\n" tmp (fn val))
        (return (alloc-val ty-i64 tmp))))))

; (funcall-ptr-ptr fn) — call fn() as ptr() via pointer, return ptr
(defn emit-funcall-ptr-ptr:ref:Val (call:ptr scope:ref:Scope)
  (let (cc:ptr:Node (cast ptr:Node call))
    (when (!= (node-len cc) 2) (die-at (cc line) "funcall-ptr-ptr expects 1 arg"))
    (let (fn:ref:Val (emit-node (node-at cc 1) scope))
      (when (-> fn (_ type) (cast ptr:Type _) (_ kind) (!= _ TY-PTR))
        (die-at (cc line) "funcall-ptr-ptr: arg must be ptr"))
      (let (tmp:ptr (new-tmp))
        (fprintf g-body-stream "  %s = call ptr %s()\n" tmp (fn val))
        (return (alloc-val ty-ptr tmp))))))

; Indirect call of an already-emitted function-pointer value `fn-val`; arguments
; are node-at(arg-start)..end. Shared by the explicit `funcall` surface and the
; call position — a TY-FN value in head position folds to this, so `funcall` is
; effectively compiler-internal (callable-values.md §4.2).
(defn emit-funcall-value:ref:Val (n:ptr scope:ref:Scope fn-val:ptr arg-start:i32)
  (let (cc:ptr:Node (cast ptr:Node n)
        fv:ptr:Val (cast ptr:Val fn-val)
        fn-type:ptr:Type (cast ptr:Type (fv type))
        ret-type:ptr (fn-type ret)
        np:i32 (fn-type num-params)
        nargs:i32 (- (node-len cc) arg-start))
    (when (!= nargs np)
      (die-at (cc line)
        (fmt-s "call: expected %d args, got %d" (cast i64 np) (cast i64 nargs))))
    (let (arg-vals:ptr (arena-alloc (* (cast i64 (+ nargs 1)) (ptr-bytes)))
          i:i32 0)
      (while (< i nargs)
        (aset! (cast ptr:ptr arg-vals) i (emit-node (node-at cc (+ i arg-start)) scope))
        (inc! i))
      (let (ret-ir:ptr (type-to-ir ret-type))
        (if (= (-> ret-type (cast ptr:Type _) (_ kind)) TY-VOID)
          (do
            (fprintf g-body-stream "  call void %s(" (fv val))
            (set! i 0)
            (while (< i nargs)
              (when (!= i 0) (fprintf g-body-stream ", "))
              (let (av:ptr:Val (cast ptr:Val (aref (cast ptr:ptr arg-vals) i)))
                (fprintf g-body-stream "%s %s" (type-to-ir (av type)) (av val)))
              (inc! i))
            (fprintf g-body-stream ")\n")
            (return (alloc-val ty-void null)))
          (let (tmp:ptr (new-tmp))
            (fprintf g-body-stream "  %s = call %s %s(" tmp ret-ir (fv val))
            (set! i 0)
            (while (< i nargs)
              (when (!= i 0) (fprintf g-body-stream ", "))
              (let (av:ptr:Val (cast ptr:Val (aref (cast ptr:ptr arg-vals) i)))
                (fprintf g-body-stream "%s %s" (type-to-ir (av type)) (av val)))
              (inc! i))
            (fprintf g-body-stream ")\n")
            (return (alloc-val ret-type tmp))))))))

; (funcall fn-ptr args...) — general typed function pointer call.
; fn-ptr must have TY-FN type. Emits call with proper LLVM IR signature.
(defn emit-funcall:ref:Val (call:ptr scope:ref:Scope)
  (let (cc:ptr:Node (cast ptr:Node call))
    (when (< (node-len cc) 2)
      (die-at (cc line) "funcall expects at least 1 arg"))
    (let (fn-val:ref:Val (emit-node (node-at cc 1) scope))
      (when (-> fn-val (_ type) (cast ptr:Type _) (_ kind) (!= _ TY-FN))
        (die-at (cc line) "funcall: first arg must be a function pointer"))
      (return (emit-funcall-value call scope (cast ptr fn-val) 2)))))

(defn emit-deref:ref:Val (call:ptr scope:ref:Scope)
  (let (cc:ptr:Node (cast ptr:Node call))
    (when (!= (node-len cc) 2) (die-at (cc line) "deref expects 1 arg"))
    (let (p:ref:Val (emit-node (node-at cc 1) scope))
      (when (or (-> p (_ type) (cast ptr:Type _) (_ kind) (!= _ TY-PTR))
              (-> p (_ type) (cast ptr:Type _) (_ elem) (= _ null)))
        (die-at (cc line) "deref: operand must be typed pointer"))
      (require-derefable (p type) (cc line) "deref")
      (let (elem:ptr (-> p (_ type) (cast ptr:Type _) (_ elem))
            tmp:ptr (new-tmp))
        (emit-load tmp (type-to-ir elem) (p val) elem)
        (return (alloc-val elem tmp))))))

(defn emit-ptr-set:ref:Val (call:ptr scope:ref:Scope)
  (let (cc:ptr:Node (cast ptr:Node call))
    (when (!= (node-len cc) 3) (die-at (cc line) "ptr-set! expects 2 args"))
    (let (p:ref:Val (emit-node (node-at cc 1) scope))
      (when (or (-> p (_ type) (cast ptr:Type _) (_ kind) (!= _ TY-PTR))
              (-> p (_ type) (cast ptr:Type _) (_ elem) (= _ null)))
        (die-at (cc line) "ptr-set!: operand must be typed pointer"))
      (require-derefable (p type) (cc line) "ptr-set!")
      (let (elem:ptr (-> p (_ type) (cast ptr:Type _) (_ elem))
            v:ref:Val (emit-node (node-at cc 2) scope)
            coerced:ptr (coerce-int-val v elem (cc line)))
        (when (= coerced null)
          (die-at (cc line) "ptr-set!: value type mismatch"))
        (taint-store-check (cast ptr p) v (cc line) "ptr-set!")
        (let (cv:ptr:Val (cast ptr:Val coerced))
          (emit-store (type-to-ir elem) (cv val) (p val) elem)
          (return (alloc-val ty-void null)))))))

; ============================================================
; Stage 10: Maybe transition forms (design/stage10/nullability.md §3)
; ============================================================

; (some r) — wrap a non-null (ref T) as (Maybe (ref T)). Pure relabel, no IR.
(defn emit-some:ref:Val (call:ptr scope:ref:Scope)
  (let (cc:ptr:Node (cast ptr:Node call))
    (when (!= (node-len cc) 2) (die-at (cc line) "some expects 1 arg"))
    (let (v:ref:Val (emit-node (node-at cc 1) scope))
      (when (!= (ptr-pkind (v type)) PTR-REF)
        (die-at (cc line) "some: value must be non-null (ref ...) — launder a raw pointer with (as-ref ...)"))
      (let (rv:ref:Val (alloc-val (type-as-pkind (v type) PTR-MAYBE) (v val)))
        (.set! rv taint (v taint))
        (return rv)))))

; (as-ref p) — launder a raw pointer into (Maybe (ref T)): null stays none.
; Pure relabel, no IR; the value still has to be narrowed before use.
(defn emit-as-ref:ref:Val (call:ptr scope:ref:Scope)
  (let (cc:ptr:Node (cast ptr:Node call))
    (when (!= (node-len cc) 2) (die-at (cc line) "as-ref expects 1 arg"))
    (let (v:ref:Val (emit-node (node-at cc 1) scope))
      (when (-> v (_ type) (cast ptr:Type _) (_ kind) (!= _ TY-PTR))
        (die-at (cc line) "as-ref: value must be a pointer"))
      (let (rv:ref:Val (alloc-val (type-as-pkind (v type) PTR-MAYBE) (v val)))
        (.set! rv taint (v taint))
        (return rv)))))

; (unwrap m) — the (ref T) inside, or trap. The one runtime branch nullability
; costs, paid only where it is written.
(defn emit-unwrap:ref:Val (call:ptr scope:ref:Scope)
  (let (cc:ptr:Node (cast ptr:Node call))
    (when (!= (node-len cc) 2) (die-at (cc line) "unwrap expects 1 arg"))
    (let (v:ref:Val (emit-node (node-at cc 1) scope))
      (when (!= (ptr-pkind (v type)) PTR-MAYBE)
        (die-at (cc line) "unwrap: value must be (Maybe (ref ...)) — launder a raw pointer with (as-ref ...)"))
      (when (= g-trap-declared 0)
        (fprintf g-decl-stream "declare void @llvm.trap()\n")
        (set! g-trap-declared 1))
      (let (isn:ptr (new-tmp)
            id:i32 (new-label-id)
            trap-lbl:ptr (fmt-i32 "unwrap.none%d" id)
            ok-lbl:ptr (fmt-i32 "unwrap.some%d" id))
        (fprintf g-body-stream "  %s = icmp eq ptr %s, null\n" isn (v val))
        (fprintf g-body-stream "  br i1 %s, label %%%s, label %%%s\n" isn trap-lbl ok-lbl)
        (fprintf g-body-stream "%s:\n" trap-lbl)
        (fprintf g-body-stream "  call void @llvm.trap()\n")
        (fprintf g-body-stream "  unreachable\n")
        (fprintf g-body-stream "%s:\n" ok-lbl)
        (set! g-block-term 0)
        (let (rv:ref:Val (alloc-val (type-as-pkind (v type) PTR-REF) (v val)))
          (.set! rv taint (v taint))
          (return rv))))))

; (unwrap-or m default) — the narrowed value, or `default` (evaluated only on
; the none path; it must satisfy the non-null (ref ...) result type).
(defn emit-unwrap-or:ref:Val (call:ptr scope:ref:Scope)
  (let (cc:ptr:Node (cast ptr:Node call))
    (when (!= (node-len cc) 3) (die-at (cc line) "unwrap-or expects 2 args"))
    (let (v:ref:Val (emit-node (node-at cc 1) scope))
      (when (!= (ptr-pkind (v type)) PTR-MAYBE)
        (die-at (cc line) "unwrap-or: value must be (Maybe (ref ...)) — launder a raw pointer with (as-ref ...)"))
      (let (ref-ty:ptr (type-as-pkind (v type) PTR-REF)
            isn:ptr (new-tmp)
            id:i32 (new-label-id)
            some-lbl:ptr (fmt-i32 "unwrapor.some%d" id)
            none-lbl:ptr (fmt-i32 "unwrapor.none%d" id)
            join-lbl:ptr (fmt-i32 "unwrapor.join%d" id)
            end-lbl:ptr (fmt-i32 "unwrapor.end%d" id))
        (fprintf g-body-stream "  %s = icmp eq ptr %s, null\n" isn (v val))
        (fprintf g-body-stream "  br i1 %s, label %%%s, label %%%s\n" isn none-lbl some-lbl)
        (fprintf g-body-stream "%s:\n" some-lbl)
        (fprintf g-body-stream "  br label %%%s\n" end-lbl)
        (fprintf g-body-stream "%s:\n" none-lbl)
        (set! g-block-term 0)
        (let (dv:ref:Val (emit-node (node-at cc 2) scope)
              dval:ptr null
              dtaint:ptr null)
          (let (dterm:i32 g-block-term)
            (when (= dterm 0)
              (let (coerced:ptr (coerce-int-val (cast ptr dv) ref-ty (cc line)))
                (when (= coerced null)
                  (die-at (cc line) "unwrap-or: default type mismatch"))
                (set! dval ((cast ptr:Val coerced) val))
                (set! dtaint (dv taint)))
              (fprintf g-body-stream "  br label %%%s\n" join-lbl)
              (fprintf g-body-stream "%s:\n" join-lbl)
              (fprintf g-body-stream "  br label %%%s\n" end-lbl))
            (fprintf g-body-stream "%s:\n" end-lbl)
            (set! g-block-term 0)
            (let (tmp:ptr (new-tmp))
              (if (= dterm 0)
                (fprintf g-body-stream "  %s = phi ptr [ %s, %%%s ], [ %s, %%%s ]\n"
                  tmp (v val) some-lbl dval join-lbl)
                (fprintf g-body-stream "  %s = phi ptr [ %s, %%%s ]\n"
                  tmp (v val) some-lbl))
              (let (rv:ref:Val (alloc-val ref-ty tmp))
                (.set! rv taint (taint-merge (v taint) dtaint))
                (return rv)))))))))

; (if-some (x m) then [else]) / (when-some (x m) body…) — bind x to the Maybe
; value and desugar to cond: the synthesized (!= x null) test is the standard
; narrowing point, so x reads as (ref T) exactly inside the then arm (and stays
; Maybe in the else arm). Reuses cond's phi typing, fall-through, and
; after-the-form narrowing rules wholesale.
(defn emit-if-some:ref:Val (call:ptr scope:ref:Scope is-when:i32)
  (let (cc:ptr:Node (cast ptr:Node call)
        tag:ptr "if-some")
    (when (!= is-when 0) (set! tag "when-some"))
    (when (< (node-len cc) 3)
      (die-at (cc line) (fmt-s "%s: expects (name maybe-expr) and a body" tag)))
    (when (and (= is-when 0) (> (node-len cc) 4))
      (die-at (cc line) "if-some: expects (name maybe-expr) then [else]"))
    (let (binder:ptr:Node (cast ptr:Node (node-at cc 1)))
      (when (or (!= (binder kind) NODE-CELL) (!= (node-len (cast ptr binder)) 2))
        (die-at (cc line) (fmt-s "%s: binding must be (name maybe-expr)" tag)))
      (let (xnode:ptr:Node (cast ptr:Node (node-at (cast ptr binder) 0)))
        (when (!= (xnode kind) NODE-SYM)
          (die-at (binder line) (fmt-s "%s: name must be a symbol" tag)))
        (let (mv:ref:Val (emit-node (node-at (cast ptr binder) 1) scope))
          (when (!= (ptr-pkind (mv type)) PTR-MAYBE)
            (die-at (cc line) (fmt-s "%s: value must be (Maybe (ref ...)) — launder a raw pointer with (as-ref ...)" tag)))
          (let (slot:ptr (fmt-sd "%%%s.addr.%d" (xnode s) g-tmp))
            (inc! g-tmp)
            (fprintf g-entry-stream "  %s = alloca ptr, align 8\n" slot)
            (fprintf g-body-stream "  store ptr %s, ptr %s, align 8\n" (mv val) slot)
            (let (inner:ref:Scope (scope-new scope)
                  sym:ptr:Sym (cast ptr:Sym (scope-define inner (xnode s) (mv type) slot 1))
                  ln:i32 (cc line))
              (.set! sym taint (mv taint))
              (let (test:ptr (make-cell (cast ptr '!=)
                               (make-cell (cast ptr xnode)
                                 (make-cell (cast ptr 'null) null ln) ln) ln)
                    tail:ptr null)
                (if (!= is-when 0)
                  (let (body-chain:ptr (-> cc (_ cdr) (cast ptr:Node _) (_ cdr)))
                    (set! tail (make-cell (make-cell (cast ptr 'do) body-chain ln) null ln)))
                  (if (= (node-len cc) 4)
                    (set! tail (make-cell (node-at cc 2)
                                 (make-cell (cast ptr 'true)
                                   (make-cell (node-at cc 3) null ln) ln) ln))
                    (set! tail (make-cell (node-at cc 2) null ln))))
                (let (synth:ptr (make-cell (cast ptr 'cond)
                                  (make-cell test tail ln) ln))
                  (return (emit-cond synth inner)))))))))))

(defn emit-ptr-add:ref:Val (call:ptr scope:ref:Scope)
  (let (cc:ptr:Node (cast ptr:Node call))
    (when (!= (node-len cc) 3) (die-at (cc line) "ptr+ expects 2 args"))
    (let (p:ref:Val (emit-node (node-at cc 1) scope))
      (when (or (-> p (_ type) (cast ptr:Type _) (_ kind) (!= _ TY-PTR))
              (-> p (_ type) (cast ptr:Type _) (_ elem) (= _ null)))
        (die-at (cc line) "ptr+: operand must be typed pointer"))
      (let (nv:ref:Val (emit-node (node-at cc 2) scope))
        (when (= (is-int-type (nv type)) 0)
          (die-at (cc line) "ptr+: offset must be integer"))
        (let (idx:ptr (nv val))
          (when (-> nv (_ type) (cast ptr:Type _) (_ kind) (!= _ TY-I64))
            (let (t:ptr (new-tmp))
              (fprintf g-body-stream "  %s = sext %s %s to i64\n"
                t (type-to-ir (nv type)) (nv val))
              (set! idx t)))
          (let (elem:ptr (-> p (_ type) (cast ptr:Type _) (_ elem))
                tmp:ptr (new-tmp))
            (fprintf g-body-stream
              "  %s = getelementptr inbounds %s, ptr %s, i64 %s\n"
              tmp (type-to-ir elem) (p val) idx)
            ; An interior pointer aliases the resource: keep the taint
            ; (lifecycle.md §2.2).
            (let (rv:ref:Val (alloc-val (p type) tmp))
              (.set! rv taint (p taint))
              (return rv))))))))

(defn emit-not:ref:Val (call:ptr scope:ref:Scope)
  (let (cc:ptr:Node (cast ptr:Node call))
    (when (!= (node-len cc) 2) (die-at (cc line) "not expects 1 arg"))
    (let (a:ref:Val (emit-node (node-at cc 1) scope))
      (when (-> a (_ type) (cast ptr:Type _) (_ kind) (!= _ TY-I1))
        (die-at (cc line) "not expects i1 operand"))
      (let (tmp:ptr (new-tmp))
        (fprintf g-body-stream "  %s = xor i1 %s, 1\n" tmp (a val))
        (return (alloc-val ty-i1 tmp))))))

(defn emit-short-circuit:ref:Val (call:ptr scope:ref:Scope is-and:i32)
  (let (cc:ptr:Node (cast ptr:Node call)
        tag:ptr "or")
    (when (!= is-and 0) (set! tag "and"))
    (when (!= (node-len cc) 3)
      (die-at (cc line) (fmt-s "%s expects 2 args" tag)))
    (let (id:i32 (new-label-id)
          rhs-lbl:ptr (fmt-sd "%s.rhs%d" tag id)
          end-lbl:ptr (fmt-sd "%s.end%d" tag id)
          slot:ptr (fmt-sd "%%%s.val%d" tag id))
      (fprintf g-entry-stream "  %s = alloca i1, align 1\n" slot)
      (let (lhs:ref:Val (emit-node (node-at cc 1) scope))
        (when (-> lhs (_ type) (cast ptr:Type _) (_ kind) (!= _ TY-I1))
          (die-at ((cast ptr:Node (node-at cc 1)) line)
            (fmt-s "%s expects i1 operands" tag)))
        (fprintf g-body-stream "  store i1 %s, ptr %s, align 1\n"
          (lhs val) slot)
        (if (!= is-and 0)
          (fprintf g-body-stream "  br i1 %s, label %%%s, label %%%s\n"
            (lhs val) rhs-lbl end-lbl)
          (fprintf g-body-stream "  br i1 %s, label %%%s, label %%%s\n"
            (lhs val) end-lbl rhs-lbl))
        (fprintf g-body-stream "%s:\n" rhs-lbl)
        (set! g-block-term 0)
        ; Stage 10 narrowing: the rhs only runs when the lhs was true (and)
        ; or false (or) — so the lhs's facts hold while it is emitted. This
        ; is what makes (and (!= m null) (m kind)) check.
        (let (scmark:i32 (narrow-mark)
              scfacts:ptr (make-vec))
          (if (!= is-and 0)
            (test-true-nonnull (node-at cc 1) scfacts)
            (test-false-nonnull (node-at cc 1) scfacts))
          (narrow-names scope scfacts)
        (let (rhs:ref:Val (emit-node (node-at cc 2) scope))
          (narrow-restore scmark)
          (when (-> rhs (_ type) (cast ptr:Type _) (_ kind) (!= _ TY-I1))
            (die-at ((cast ptr:Node (node-at cc 2)) line)
              (fmt-s "%s expects i1 operands" tag)))
          (fprintf g-body-stream "  store i1 %s, ptr %s, align 1\n"
            (rhs val) slot)
          (fprintf g-body-stream "  br label %%%s\n" end-lbl)
          (fprintf g-body-stream "%s:\n" end-lbl)
          (set! g-block-term 0)
          (let (tmp:ptr (new-tmp))
            (fprintf g-body-stream "  %s = load i1, ptr %s, align 1\n" tmp slot)
            (return (alloc-val ty-i1 tmp)))))))))

; ============================================================
; Function calls
; ============================================================

(defn emit-call:ref:Val (call:ptr scope:ref:Scope sym:ref:Sym)
  (let (cc:ptr:Node (cast ptr:Node call)
        ss:ptr:Sym (cast ptr:Sym sym)
        ft0:ptr:Type (cast ptr:Type (ss type))
        nargs:i32 (- (node-len cc) 1)
        max-args:i32 (- (node-len cc) 1))
    ; &optional callee: the arg buffer may need to grow up to num-params.
    (when (and (!= (cast ptr ft0) null) (= (ft0 kind) TY-FN))
      (when (> (ft0 num-params) max-args) (set! max-args (ft0 num-params))))
    ; Stage 10 escape analysis (lifecycle.md §2.3): manually freeing a
    ; with-owned binding double-frees — the armed cleanup also fires at scope
    ; exit. (free (move p)) is the sanctioned spelling: move disarms first.
    (when (and (= (strcmp (ss name) "free") 0) (= nargs 1))
      (let (tname:ptr (node-binding-name (node-at cc 1)))
        (when (!= tname null)
          (let (tsym:ptr:Sym (cast ptr:Sym (scope-lookup scope tname)))
            (when (and (!= (cast ptr tsym) null) (!= (tsym owns) 0))
              (die-at (cc line)
                (fmt-2s "double free: '%s' is freed at `with` scope exit — use (move %s) to take ownership first" tname tname)))))))
    (let (args:ptr (arena-alloc (* (cast i64 (+ max-args 1)) (sizeof Val)))
          i:i32 0)
      (while (< i nargs)
        (let (v:ref:Val (emit-node (node-at cc (+ i 1)) scope))
          (memcpy (ptr+ (cast ptr:Val args) i) v (sizeof Val)))
        (inc! i))
      ; Fill defaults for missing trailing &optional args, emitting each default
      ; expression in the caller's scope.
      (when (and (= (ft0 kind) TY-FN) (!= (ft0 nopt) 0))
        (let (np:i32 (ft0 num-params)
              required:i32 (- (ft0 num-params) (ft0 nopt)))
          (when (< nargs required) (die-at (cc line) (fmt-s "%s: too few args" (ss name))))
          (when (> nargs np) (die-at (cc line) (fmt-s "%s: too many args" (ss name))))
          (let (oi:i32 nargs)
            (while (< oi np)
              (let (default-node:ptr (aref (cast ptr:ptr (ft0 opt-defaults)) (- oi required))
                    v:ref:Val (emit-node default-node scope))
                (memcpy (ptr+ (cast ptr:Val args) oi) v (sizeof Val)))
              (inc! oi))
            (set! nargs np))))
      (return (emit-call-with-args call scope sym args nargs)))))

; Emit a call given already-emitted argument Vals. Shared by the ordinary call
; path and the multimethod dispatch path (which must resolve the method from
; argument types before the call can be emitted). Handles &rest folding, the
; variadic signature, and void/non-void returns.
(defn emit-call-with-args:ref:Val (call:ptr scope:ref:Scope sym:ref:Sym args:ptr nargs:i32)
  (let (cc:ptr:Node (cast ptr:Node call)
        ss:ptr:Sym (cast ptr:Sym sym)
        i:i32 0)
    ; If the callee has &rest, fold trailing args into a runtime Node cons
    ; list and replace them with a single ptr arg pointing at the list.
    (let (eff-nargs:i32 nargs
          ft0:ptr:Type (cast ptr:Type (ss type)))
      (when (and (= (ft0 kind) TY-FN) (!= (ft0 has-rest) 0))
        (let (fixed:i32 (- (ft0 num-params) 1))
          (when (< nargs fixed)
            (die-at (cc line)
              (fmt-s "%s: too few args for &rest function" (ss name))))
          ; Build list right-to-left: prev = null; for i = nargs-1..fixed:
          ;   cell = make-cell(arg-as-ptr, prev, 0); prev = cell.
          (let (prev-name:ptr "null"
                ri:i32 nargs)
            (while (> ri fixed)
              (set! ri (- ri 1))
              (let (av:ptr:Val (cast ptr:Val (ptr+ (cast ptr:Val args) ri))
                    av-val:ptr (av val)
                    aty:ptr:Type (cast ptr:Type (av type)))
                ; Coerce non-pointer values to ptr so they fit in Node.car
                ; (a CStr is already a pointer — no inttoptr).
                (when (= (is-ptr-like (cast ptr aty)) 0)
                  (let (tmp:ptr (new-tmp))
                    (fprintf g-body-stream "  %s = inttoptr %s %s to ptr\n"
                      tmp (type-to-ir (cast ptr aty)) av-val)
                    (set! av-val tmp)))
                (let (cell:ptr (new-tmp))
                  (fprintf g-body-stream
                    "  %s = call ptr @make-cell(ptr %s, ptr %s, i32 0)\n"
                    cell av-val prev-name)
                  (set! prev-name cell))))
            ; Place list ptr as the trailing arg slot at index `fixed`.
            (let (slot:ptr:Val (cast ptr:Val (ptr+ (cast ptr:Val args) fixed)))
              (.set! slot type ty-ptr)
              (.set! slot val prev-name))
            (set! eff-nargs (+ fixed 1)))))
      ; Stage 8 implicit casts: coerce each fixed argument whose IR type differs
      ; from its parameter's via safe-coerce-val (int widen, f32→f64, defcast).
      ; When the IR types already match, or no safe conversion exists, the
      ; argument is left untouched — preserving the prior pass-through behavior.
      (let (ncoerce:i32 (ft0 num-params))
        (when (!= (ft0 has-rest) 0) (set! ncoerce (- (ft0 num-params) 1)))
        (when (> ncoerce eff-nargs) (set! ncoerce eff-nargs))
        (let (ci:i32 0)
          (while (< ci ncoerce)
            (let (slot:ptr:Val (cast ptr:Val (ptr+ (cast ptr:Val args) ci))
                  ptype:ptr (aref (cast ptr:ptr (ft0 params)) ci))
              ; Stage 10: pointer-kind contract on arguments — raw/Maybe may
              ; not flow into a (ref T) parameter. Checked independently of IR
              ; coercion (all pointer flavors share the IR type `ptr`).
              (pkind-flow-check (slot type) ptype (cc line) "argument")
              (when (!= (strcmp (type-to-ir (slot type)) (type-to-ir ptype)) 0)
                (let (nc:ptr (safe-coerce-val (cast ptr slot) ptype (cc line)))
                  (when (and (!= nc null) (!= nc (cast ptr slot)))
                    (memcpy slot nc (sizeof Val))))))
            (inc! ci))))
      (let (arglist:ptr (alloca i8 2048)
            apos:i64 (cast i64 0))
        (aset! (cast ptr:i8 arglist) (cast i64 0) (cast i8 0))
        (set! i 0)
        (while (< i eff-nargs)
        (let (av:ptr:Val (cast ptr:Val (ptr+ (cast ptr:Val args) i))
              sep:ptr "")
          (when (!= i 0) (set! sep ", "))
          ; abi-arg-frag returns "<ty> <val>" for scalars/pointers (unchanged),
          ; or the byval / register-coerced fragment for a struct-by-value arg
          ; (emitting the materialization instructions as a side effect).
          (let (w:i32 (snprintf (ptr+ (cast ptr:i8 arglist) apos)
                                (- (cast i64 2048) apos)
                                "%s%s" sep
                                (abi-arg-frag (cast ptr av))))
            (set! apos (+ apos (cast i64 w)))))
        (inc! i))
      (let (ft:ptr:Type (cast ptr:Type (ss type)))
        (when (!= (ft kind) TY-FN)
          (die-at (cc line) (fmt-s "not a function: %s" (ss name))))
        (if (!= (ft variadic) 0)
          (do
            (let (sig:ptr (alloca i8 512)
                  sp:i64 (cast i64 0)
                  w:i32 (snprintf sig (cast i64 512) "%s (" (type-to-ir (ft ret))))
              (set! sp (cast i64 w))
              (set! i 0)
              (while (< i (ft num-params))
                (let (pt:ptr (aref (cast ptr:ptr (ft params)) i)
                      sep:ptr "")
                  (when (!= i 0) (set! sep ", "))
                  (set! w (snprintf (ptr+ (cast ptr:i8 sig) sp) (- (cast i64 512) sp)
                                    "%s%s" sep (type-to-ir pt)))
                  (set! sp (+ sp (cast i64 w))))
                (inc! i))
              (let (va-sep:ptr "")
                (when (!= (ft num-params) 0) (set! va-sep ", "))
                (snprintf (ptr+ (cast ptr:i8 sig) sp) (- (cast i64 512) sp)
                          "%s...)" va-sep))
              (if (-> ft (_ ret) (cast ptr:Type _) (_ kind) (= _ TY-VOID))
                (fprintf g-body-stream "  call %s %s(%s)\n"
                  sig (ss ir-name) arglist)
                (let (tmp:ptr (new-tmp))
                  (fprintf g-body-stream "  %s = call %s %s(%s)\n"
                    tmp sig (ss ir-name) arglist)
                  (return (alloc-val (ft ret) tmp))))))
          (do
            (let (ret-info:ptr:AbiInfo (cast ptr:AbiInfo (abi-classify (ft ret))))
              (if (!= ((cast ptr:AbiInfo ret-info) kind) ABI-DIRECT)
                ; Struct return: emit the lowered call + reconstruction.
                (return (abi-emit-struct-call ret-info (ft ret) (ss ir-name)
                                              (cast ptr arglist) eff-nargs))
                (if (-> ft (_ ret) (cast ptr:Type _) (_ kind) (= _ TY-VOID))
                  (fprintf g-body-stream "  call %s %s(%s)\n"
                    (type-to-ir (ft ret)) (ss ir-name) arglist)
                  (let (tmp:ptr (new-tmp))
                    (fprintf g-body-stream "  %s = call %s %s(%s)\n"
                      tmp (type-to-ir (ft ret)) (ss ir-name) arglist)
                    (return (alloc-val (ft ret) tmp))))))))
        (return (alloc-val ty-void null)))))))

; ============================================================
; Special forms
; ============================================================

; Recognize a libc allocator call as a binding init for `with`. Walks past
; (cast T <inner>) so that the typical (cast ptr:Node (malloc N)) idiom is
; detected. Purely syntactic — no type inference.
(defn is-libc-alloc:i32 (node:ptr)
  (when (= node null) (return 0))
  (let (n:ptr:Node (cast ptr:Node node))
    (when (!= (n kind) NODE-CELL) (return 0))
    (when (< (node-len node) 1) (return 0))
    (let (head:ptr:Node (cast ptr:Node (node-at node 0)))
      (when (!= (head kind) NODE-SYM) (return 0))
      (let (hp:ptr (cast ptr head))
        (when (= hp 'cast)
          (when (>= (node-len node) 3)
            (return (is-libc-alloc (node-at node 2))))
          (return 0))
        (when (or (= hp 'malloc) (= hp 'calloc)) (return 1))
        (when (or (= hp 'realloc) (= hp 'strdup)) (return 1))
        (return 0)))))

; The drop method to arm for a with-binding of declared type `ty` (lifecycle.md
; §5): ty must be a pointer to a struct that conforms to the Drop protocol
; (recorded by `extend <S> Drop`), and the `drop` generic must resolve exactly
; on [ty]. Returns the Method*, or null when the binding is not Drop-managed.
; type-eq ignores pointer kinds, so (ref S) resolves the same method as (ptr S).
(defn with-drop-method:?Method (ty:ptr)
  (let (tt:ptr:Type (cast ptr:Type ty))
    (when (!= (tt kind) TY-PTR) (return null))
    (when (= (tt elem) null) (return null))
    (let (et:ptr:Type (cast ptr:Type (tt elem)))
      (when (!= (et kind) TY-STRUCT) (return null))
      (let (sd:ptr:StructDef (cast ptr:StructDef (et sdef)))
        (when (= (cast ptr sd) null) (return null))
        (when (= (conformance-lookup (sd name) "Drop") 0) (return null))
        (let (g:ptr (generic-lookup "drop"))
          (when (= g null) (return null))
          (let (argtypes:ptr (arena-alloc (ptr-bytes)))
            (aset! (cast ptr:ptr argtypes) 0 ty)
            (return (generic-find-method-exact g argtypes 1))))))))

; (defer expr) — register expr as an ad-hoc cleanup on the enclosing binding
; scope (nearest let/with/function body), re-emitted at every exit path in
; reverse registration order. Lexical, not dynamic: the cleanup runs at scope
; exit whether or not control reached the defer site at runtime.
(defn emit-defer:ref:Val (call:ptr scope:ref:Scope)
  (let (cc:ptr:Node (cast ptr:Node call))
    (when (!= (node-len cc) 2) (die-at (cc line) "defer expects 1 expression"))
    (let (cl:ptr:Cleanup (new Cleanup))
      (.set! cl defer-node (node-at cc 1))
      (.set! cl defer-scope scope)
      (scope-push-cleanup scope (cast ptr cl))
      (return (alloc-val ty-void null)))))

; (move p) — affine ownership transfer out of a with (lifecycle.md §4):
; disarm p's cleanup slot (store null; free(NULL) / the drop null-guard make
; the armed cleanup a no-op), yield p's value with its escape taint cleared so
; it may legitimately return or store out, and mark p consumed — any later use
; is "use after move" (a reassignment revives the binding).
(defn emit-move:ref:Val (call:ptr scope:ref:Scope)
  (let (cc:ptr:Node (cast ptr:Node call))
    (when (!= (node-len cc) 2) (die-at (cc line) "move expects 1 binding name"))
    (let (tname:ptr (node-binding-name (node-at cc 1)))
      (when (= tname null) (die-at (cc line) "move: operand must be a binding name"))
      (if-some (sym (scope-lookup scope tname))
        (do
          (when (!= (sym moved) 0)
            (die-at (cc line) (fmt-s "use after move: '%s'" tname)))
          (when (= (sym owns) 0)
            (die-at (cc line) (fmt-s "move: '%s' does not own a with-bound resource" tname)))
          (let (tmp:ptr (new-tmp))
            (emit-load tmp (type-to-ir (sym type)) (sym ir-name) (sym type))
            (fprintf g-body-stream "  store ptr null, ptr %s, align 8\n" (sym cslot))
            (.set! sym moved 1)
            (return (alloc-val (sym-effective-type sym) tmp))))
        (die-at (cc line) (fmt-s "move: undefined '%s'" tname))))))

; Emit a Drop-protocol cleanup: load the resource pointer from its slot and,
; when non-null, statically dispatch to the resolved drop method. The null
; guard mirrors free(NULL)-is-a-no-op so `move` / (set! name null) disarm
; Drop resources exactly like libc ones.
(defn emit-drop-cleanup:void (cl:ptr)
  (let (c:ptr:Cleanup (cast ptr:Cleanup cl)
        tmp:ptr (new-tmp)
        isn:ptr (new-tmp)
        id:i32 (new-label-id)
        do-lbl:ptr (fmt-i32 "drop.do%d" id)
        skip-lbl:ptr (fmt-i32 "drop.skip%d" id))
    (fprintf g-body-stream "  %s = load ptr, ptr %s, align 8\n" tmp (c slot))
    (fprintf g-body-stream "  %s = icmp eq ptr %s, null\n" isn tmp)
    (fprintf g-body-stream "  br i1 %s, label %%%s, label %%%s\n" isn skip-lbl do-lbl)
    (fprintf g-body-stream "%s:\n" do-lbl)
    (if (or (= (c drop-ret) null)
            (= ((cast ptr:Type (c drop-ret)) kind) TY-VOID))
      (fprintf g-body-stream "  call void %s(ptr %s)\n" (c drop-fn) tmp)
      (let (r:ptr (new-tmp))
        (fprintf g-body-stream "  %s = call %s %s(ptr %s)\n"
          r (type-to-ir (c drop-ret)) (c drop-fn) tmp)))
    (fprintf g-body-stream "  br label %%%s\n" skip-lbl)
    (fprintf g-body-stream "%s:\n" skip-lbl)))

; Emit every armed cleanup in this scope, in reverse order of registration
; (innermost binding releases first, matching C++/RAII intuition). Three
; shapes: legacy libc free (free(NULL) is a no-op, so a slot disarmed via
; (set! name null) or `move` is safe), a Drop-protocol call (null-guarded for
; the same reason), and a (defer expr) re-emitted in its registration scope.
(defn emit-scope-cleanups:void (scope:ref:Scope)
  (when (= g-block-term 1) (return))
  (let (sc:ptr:Scope (cast ptr:Scope scope))
    (when (= (sc ncleanups) 0) (return))
    (let (slots:ptr:ptr (cast ptr:ptr (sc cleanup-slots))
          i:i32 (- (sc ncleanups) 1))
      (while (>= i 0)
        (let (cl:ptr:Cleanup (cast ptr:Cleanup (aref slots i)))
          (cond (!= (cl defer-node) null)
                  ; defer-scope is set whenever defer-node is (emit-defer) —
                  ; a correlated-fields invariant the pointer kinds can't carry.
                  (emit-node (cl defer-node) (cast ref:Scope (cl defer-scope)))
                (!= (cl drop-fn) null)
                  (emit-drop-cleanup (cast ptr cl))
                true
                  (let (tmp:ptr (new-tmp))
                    (fprintf g-body-stream "  %s = load ptr, ptr %s, align 8\n" tmp (cl slot))
                    (fprintf g-body-stream "  call void @free(ptr %s)\n" tmp))))
        (set! i (- i 1))))))

; Walk the lexical scope chain emitting cleanups at every level. Used by
; emit-return so an early return inside nested `with` bodies still frees
; bound resources before terminating the basic block.
(defn emit-walk-cleanups:void (scope:ref:Scope)
  (let (cur:?Scope (some scope))
    (while (!= cur null)
      (emit-scope-cleanups cur)
      (set! cur ((cast ptr:Scope cur) parent)))))

(defn emit-return:ref:Val (call:ptr scope:ref:Scope)
  (let (cc:ptr:Node (cast ptr:Node call))
    (when (= (node-len cc) 1)
      (emit-walk-cleanups scope)
      (fprintf g-body-stream "  ret void\n")
      (set! g-block-term 1)
      (return (alloc-val ty-void null)))
    (when (!= (node-len cc) 2)
      (die-at (cc line) "return expects 0 or 1 args"))
    (let (v:ref:Val (emit-node (node-at cc 1) scope))
      ; Stage 10 escape analysis: returning unwinds every with-scope, so a
      ; tainted value always dangles past its cleanup (lifecycle.md §2.3).
      (when (!= (v taint) null)
        (die-at (cc line)
          "resource bound by `with` escapes via return — use (move ...) to transfer ownership"))
      ; Stage 10 nullability: a declared (ref T) return requires a ref value.
      (when (!= g-fn-ret-type null)
        (pkind-flow-check (v type) g-fn-ret-type (cc line) "return"))
      (emit-walk-cleanups scope)
      (if (and (!= g-fn-ret-abi null)
               (!= ((cast ptr:AbiInfo g-fn-ret-abi) kind) ABI-DIRECT))
        (emit-struct-ret (cast ptr v))
        (fprintf g-body-stream "  ret %s %s\n" (type-to-ir (v type)) (v val)))
      (set! g-block-term 1)
      (return (alloc-val ty-void null)))))

(defn emit-do:ref:Val (call:ptr scope:ref:Scope)
  (let (cc:ptr:Node (cast ptr:Node call)
        last:ref:Val (alloc-val ty-void null)
        i:i32 1)
    (while (< i (node-len cc))
      (set! last (emit-node (node-at cc i) scope))
      (inc! i))
    (return last)))

(defn emit-let:ref:Val (call:ptr scope:ref:Scope)
  (let (cc:ptr:Node (cast ptr:Node call))
    (when (or (< (node-len cc) 2) (-> cc (node-at _ 1) (cast ptr:Node _) (_ kind) (!= _ NODE-CELL)))
      (die-at (cc line) "let: bad form"))
    (let (binds:ptr:Node (cast ptr:Node (node-at cc 1)))
      (when (!= (% (node-len binds) 2) 0)
        (die-at (binds line) "let: binding list must be even"))
      (let (inner:ref:Scope (scope-new scope)
            i:i32 0)
        (while (< i (node-len binds))
          (let (bname:ptr (node-at binds i)
                bval-node:ptr (node-at binds (+ i 1)))
            (let (name:ptr null
                  ty:ptr (extract-name-and-type bname (cast ptr:ptr (addr-of name))
                                                ((cast ptr:Node bname) line)))
              (when (= ty null)
                (die-at ((cast ptr:Node bname) line) (fmt-s "let: missing :type on '%s'" name)))
              (let (slot:ptr (fmt-sd "%%%s.addr.%d" name g-tmp)
                    align:i32 (type-size ty))
                (inc! g-tmp)
                (fprintf g-entry-stream "  %s = alloca %s, align %d\n"
                  slot (type-to-ir ty) align)
                (let (v:ref:Val (emit-node bval-node inner)
                      coerced:ptr (coerce-int-val v ty ((cast ptr:Node bval-node) line)))
                  (when (= coerced null)
                    (die-at ((cast ptr:Node bval-node) line)
                      (fmt-s "let: init type mismatch for '%s'" name)))
                  (let (cv:ptr:Val (cast ptr:Val coerced))
                    (fprintf g-body-stream "  store %s %s, ptr %s, align %d\n"
                      (type-to-ir ty) (cv val) slot align)
                    (let (sym:ptr:Sym (cast ptr:Sym (scope-define inner name ty slot 1)))
                      ; Stage 10 escape analysis: a binding initialized from a
                      ; tainted value aliases the same resource (§2.2).
                      (.set! sym taint ((cast ptr:Val v) taint))
                      ; Narrowing: a ?T binding initialized with a known
                      ; non-null value starts narrowed (parity with set!).
                      (when (and (= (ptr-pkind ty) PTR-MAYBE)
                                 (= (ptr-pkind ((cast ptr:Val v) type)) PTR-REF))
                        (narrow-apply inner name))))))))
          (set! i (+ i 2)))
        (let (last:ref:Val (alloc-val ty-void null)
              j:i32 2)
          (while (< j (node-len cc))
            (set! last (emit-node (node-at cc j) inner))
            (inc! j))
          ; Fire (defer …) cleanups registered on this scope (no-op otherwise:
          ; let itself never arms one).
          (emit-scope-cleanups inner)
          (return last))))))

; `with` is `let` plus auto-free for any binding whose init expression is a
; libc allocator call (malloc/calloc/realloc/strdup, optionally wrapped in
; cast). Frees fire on fall-through (after the body) and on early `return`
; via emit-walk-cleanups in emit-return.
(defn emit-with:ref:Val (call:ptr scope:ref:Scope)
  (let (cc:ptr:Node (cast ptr:Node call))
    (when (or (< (node-len cc) 2) (-> cc (node-at _ 1) (cast ptr:Node _) (_ kind) (!= _ NODE-CELL)))
      (die-at (cc line) "with: bad form"))
    (let (binds:ptr:Node (cast ptr:Node (node-at cc 1)))
      (when (!= (% (node-len binds) 2) 0)
        (die-at (binds line) "with: binding list must be even"))
      (let (inner:ref:Scope (scope-new scope)
            i:i32 0)
        (while (< i (node-len binds))
          (let (bname:ptr (node-at binds i)
                bval-node:ptr (node-at binds (+ i 1)))
            (let (name:ptr null
                  ty:ptr (extract-name-and-type bname (cast ptr:ptr (addr-of name))
                                                ((cast ptr:Node bname) line)))
              (when (= ty null)
                (die-at ((cast ptr:Node bname) line) (fmt-s "with: missing :type on '%s'" name)))
              (let (slot:ptr (fmt-sd "%%%s.addr.%d" name g-tmp)
                    align:i32 (type-size ty)
                    autofree:i32 (is-libc-alloc bval-node))
                (inc! g-tmp)
                (fprintf g-entry-stream "  %s = alloca %s, align %d\n"
                  slot (type-to-ir ty) align)
                (let (v:ref:Val (emit-node bval-node inner)
                      coerced:ptr (coerce-int-val v ty ((cast ptr:Node bval-node) line)))
                  (when (= coerced null)
                    (die-at ((cast ptr:Node bval-node) line)
                      (fmt-s "with: init type mismatch for '%s'" name)))
                  (let (cv:ptr:Val (cast ptr:Val coerced))
                    (fprintf g-body-stream "  store %s %s, ptr %s, align %d\n"
                      (type-to-ir ty) (cv val) slot align)
                    (let (sym:ptr:Sym (cast ptr:Sym (scope-define inner name ty slot 1)))
                      (let (dm:ptr:Method (cast ptr:Method (with-drop-method ty)))
                        (cond
                          ; Owning binding, libc shape: arm the legacy free
                          ; cleanup and seed the escape analysis — the value
                          ; aliases a resource freed when this with-scope
                          ; exits (lifecycle.md §2.1).
                          (= autofree 1)
                            (let (cl:ptr:Cleanup (new Cleanup))
                              (.set! cl slot slot)
                              (scope-push-cleanup inner (cast ptr cl))
                              (.set! sym owns 1)
                              (.set! sym cslot slot)
                              (.set! sym taint inner))
                          ; Owning binding, Drop shape: statically dispatched
                          ; (drop binding) at scope exit (lifecycle.md §5).
                          (!= (cast ptr dm) null)
                            (let (cl:ptr:Cleanup (new Cleanup))
                              (.set! cl slot slot)
                              (.set! cl drop-fn (dm ir-name))
                              (.set! cl drop-ty ty)
                              (.set! cl drop-ret (dm ret-type))
                              (scope-push-cleanup inner (cast ptr cl))
                              (.set! sym owns 1)
                              (.set! sym cslot slot)
                              (.set! sym taint inner))
                          ; Non-owning with-binding: behaves like let (adopts
                          ; the init value's taint).
                          true
                            (.set! sym taint ((cast ptr:Val v) taint))))
                      (when (and (= (ptr-pkind ty) PTR-MAYBE)
                                 (= (ptr-pkind ((cast ptr:Val v) type)) PTR-REF))
                        (narrow-apply inner name))))))))
          (set! i (+ i 2)))
        (let (last:ref:Val (alloc-val ty-void null)
              j:i32 2)
          (while (< j (node-len cc))
            (set! last (emit-node (node-at cc j) inner))
            (inc! j))
          (emit-scope-cleanups inner)
          (return last))))))

; cond is an expression: each branch's last value contributes to a phi at
; cond.end. If all live branches agree on a non-void type, that's the cond's
; type. On any disagreement (or any void branch), fall back to void — the
; cond is then statement-shaped and any caller that uses it in value position
; will fail its own type-check downstream. If no clause has `true` as its
; test, the implicit fallthrough contributes `undef` of the result type.
(defn emit-cond:ref:Val (call:ptr scope:ref:Scope)
  (let (cc:ptr:Node (cast ptr:Node call)
        nargs:i32 (- (node-len cc) 1))
    (when (or (< nargs 2) (!= (% nargs 2) 0))
      (die-at (cc line) "cond: expects pairs of (test body)"))
    (let (npairs:i32 (/ nargs 2)
          id:i32 (new-label-id)
          end-lbl:ptr (fmt-i32 "cond.end%d" id)
          fall-lbl:ptr (fmt-i32 "cond.fall%d" id)
          vals:ptr (make-vec)
          preds:ptr (make-vec)
          result-type:ptr null
          result-taint:ptr null
          has-fallthrough:i32 0
          ; Stage 10 narrowing: `acc` holds names proven non-null for every
          ; subsequent pair (a failed null-test); `after` holds names to
          ; narrow past the cond (a terminated guard body whose predecessors
          ; all terminated too); all-term tracks the latter condition.
          acc:ptr (make-vec)
          after:ptr (make-vec)
          all-term:i32 1
          i:i32 0)
      (while (< i npairs)
        (let (test-node:ptr:Node (cast ptr:Node (node-at cc (+ 1 (* i 2))))
              body-node:ptr (node-at cc (+ 2 (* i 2)))
              is-last:i32 0
              is-final-true:i32 0
              then-lbl:ptr (fmt-i32-i32 "cond.then%d.%d" id i)
              next-lbl:ptr null
              tmark:i32 (narrow-mark))
          (narrow-names scope acc)
          (when (= i (- npairs 1)) (set! is-last 1))
          (when (and (= is-last 1) (= (test-node kind) NODE-SYM))
            (when (= (test-node s) "true")
              (set! is-final-true 1)))
          (if (= is-final-true 1)
            (do
              (fprintf g-body-stream "  br label %%%s\n" then-lbl)
              (fprintf g-body-stream "%s:\n" then-lbl)
              (set! g-block-term 0))
            (do
              (if (= is-last 1)
                (do
                  (set! next-lbl fall-lbl)
                  (set! has-fallthrough 1))
                (set! next-lbl (fmt-i32-i32 "cond.test%d.%d" id (+ i 1))))
              (let (test:ref:Val (emit-node (cast ptr test-node) scope))
                (when (!= ((cast ptr:Type (test type)) kind) TY-I1)
                  (die-at (test-node line) "cond: test must be i1"))
                (fprintf g-body-stream "  br i1 %s, label %%%s, label %%%s\n"
                  (test val) then-lbl next-lbl))
              (fprintf g-body-stream "%s:\n" then-lbl)
              (set! g-block-term 0)
              ; Inside the taken branch the test's non-null facts hold.
              (let (tfacts:ptr (make-vec))
                (test-true-nonnull (cast ptr test-node) tfacts)
                (narrow-names scope tfacts))))
          (let (bv:ref:Val (emit-node body-node scope)
                bterm:i32 g-block-term)
            (when (= bterm 0)
              (let (join-lbl:ptr (fmt-i32-i32 "cond.join%d.%d" id i)
                    bty:ptr (bv type))
                (if (= result-type null)
                  (set! result-type bty)
                  (if (= (type-eq bty result-type) 0)
                    (when (!= ((cast ptr:Type result-type) kind) TY-VOID)
                      (set! result-type ty-void))
                    ; Same type, possibly differing pointer kinds: meet them
                    ; (identity when the kinds already agree).
                    (when (= ((cast ptr:Type result-type) kind) TY-PTR)
                      (set! result-type
                        (type-as-pkind result-type
                          (pkind-meet (ptr-pkind result-type) (ptr-pkind bty)))))))
                (when (= ((cast ptr:Type bty) kind) TY-VOID)
                  (set! result-type ty-void))
                (set! result-taint (taint-merge result-taint (bv taint)))
                (fprintf g-body-stream "  br label %%%s\n" join-lbl)
                (fprintf g-body-stream "%s:\n" join-lbl)
                (fprintf g-body-stream "  br label %%%s\n" end-lbl)
                (vec-push vals (bv val))
                (vec-push preds join-lbl)))
            (narrow-restore tmark)
            (when (= is-final-true 0)
              ; Failed tests hold for every later pair...
              (test-false-nonnull (cast ptr test-node) acc)
              ; ...and past the cond, iff every body so far has terminated
              ; (so the only ways to reach the code after the cond evaluated
              ; this test as false).
              (when (and (= bterm 1) (= all-term 1))
                (test-false-nonnull (cast ptr test-node) after)))
            (when (= bterm 0) (set! all-term 0)))
          (when (and (= is-last 0) (= is-final-true 0))
            (fprintf g-body-stream "%s:\n" next-lbl)
            (set! g-block-term 0)))
        (inc! i))
      ; Guard-narrows that dominate the rest of the enclosing region.
      (narrow-names scope after)
      (when (= has-fallthrough 1)
        (fprintf g-body-stream "%s:\n" fall-lbl)
        (fprintf g-body-stream "  br label %%%s\n" end-lbl))
      (fprintf g-body-stream "%s:\n" end-lbl)
      (set! g-block-term 0)
      ; If every branch terminated (no live phi incomings) and there is no
      ; fallthrough, end-lbl is unreachable — terminate it so callers know
      ; control does not flow past the cond.
      (when (and (= ((cast ptr:Vec vals) len) 0) (= has-fallthrough 0))
        (fprintf g-body-stream "  unreachable\n")
        (set! g-block-term 1))
      (if (or (= result-type null)
              (= ((cast ptr:Type result-type) kind) TY-VOID))
        (return (alloc-val ty-void null))
        (let (tmp:ptr (new-tmp)
              ty-ir:ptr (type-to-ir result-type)
              vv:ptr:Vec (cast ptr:Vec vals)
              pv:ptr:Vec (cast ptr:Vec preds)
              k:i32 0)
          (fprintf g-body-stream "  %s = phi %s " tmp ty-ir)
          (while (< k (vv len))
            (when (> k 0) (fprintf g-body-stream ", "))
            (fprintf g-body-stream "[ %s, %%%s ]"
              (aref (cast ptr:ptr (vv data)) k)
              (aref (cast ptr:ptr (pv data)) k))
            (inc! k))
          (when (= has-fallthrough 1)
            (fprintf g-body-stream ", [ undef, %%%s ]" fall-lbl))
          (fprintf g-body-stream "\n")
          (let (rv:ref:Val (alloc-val result-type tmp))
            (.set! rv taint result-taint)
            (return rv)))))))

(defn emit-while:ref:Val (call:ptr scope:ref:Scope)
  (let (cc:ptr:Node (cast ptr:Node call))
    (when (< (node-len cc) 2) (die-at (cc line) "while: missing condition"))
    (let (id:i32 (new-label-id)
          cond-lbl:ptr (fmt-i32 "while.cond%d" id)
          body-lbl:ptr (fmt-i32 "while.body%d" id)
          end-lbl:ptr (fmt-i32 "while.end%d" id))
      ; Stage 10 narrowing: the loop re-executes, so any binding the loop
      ; assigns loses a narrowing established outside it — kill those before
      ; anything inside the loop is emitted (the emit-set backstop catches
      ; macro-synthesized assignments the prescan cannot see).
      (inc! g-loop-depth)
      (let (psi:i32 1)
        (while (< psi (node-len cc))
          (prescan-kill-sets (node-at cc psi) scope)
          (inc! psi)))
      (fprintf g-body-stream "  br label %%%s\n" cond-lbl)
      (fprintf g-body-stream "%s:\n" cond-lbl)
      (set! g-block-term 0)
      (let (cnd:ref:Val (emit-node (node-at cc 1) scope))
        (when (-> cnd (_ type) (cast ptr:Type _) (_ kind) (!= _ TY-I1))
          (die-at ((cast ptr:Node (node-at cc 1)) line)
            "while condition must be i1"))
        (fprintf g-body-stream "  br i1 %s, label %%%s, label %%%s\n"
          (cnd val) body-lbl end-lbl))
      (fprintf g-body-stream "%s:\n" body-lbl)
      (set! g-block-term 0)
      ; The condition's non-null facts hold inside the body (re-established
      ; by the back-edge re-test); they are undone at loop exit.
      (let (wmark:i32 (narrow-mark)
            wfacts:ptr (make-vec))
        (test-true-nonnull (node-at cc 1) wfacts)
        (narrow-names scope wfacts)
        (let (i:i32 2)
          (while (< i (node-len cc))
            (emit-node (node-at cc i) scope)
            (inc! i)))
        (narrow-restore wmark))
      (dec! g-loop-depth)
      (when (= g-block-term 0)
        (fprintf g-body-stream "  br label %%%s\n" cond-lbl))
      (fprintf g-body-stream "%s:\n" end-lbl)
      (set! g-block-term 0)
      (return (alloc-val ty-void null)))))

(defn emit-set:ref:Val (call:ptr scope:ref:Scope)
  (let (cc:ptr:Node (cast ptr:Node call))
    (when (!= (node-len cc) 3) (die-at (cc line) "set! expects 2 args"))
    (let (target:ptr:Node (cast ptr:Node (node-at cc 1)))
      (when (!= (target kind) NODE-SYM)
        (die-at (target line) "set!: target must be symbol"))
      ; Strip any :type annotation so typed names from macro expansions resolve.
      (let (set-name:ptr null
            set-type-ignored:ptr null)
        (split-typed (target s)
                     (cast ptr:ptr (addr-of set-name))
                     (cast ptr:ptr (addr-of set-type-ignored)))
        (if-some (sym (scope-lookup scope set-name))
          (do
          (when (= (sym is-local) 0)
            (die-at (target line) (fmt-s "set!: undefined local '%s'" (target s))))
          (let (v:ref:Val (emit-node (node-at cc 2) scope)
                coerced:?Val (coerce-int-val v (sym type) (cc line)))
            (when (= coerced null)
              (die-at (cc line) (fmt-s "set!: type mismatch for '%s'" (target s))))
            ; Stage 10 escape analysis: a with-owned resource may only be
            ; stored into a binding that lives no longer than the resource
            ; (same-or-inner scope relative to the owning with).
            (let (vtaint:ptr (v taint))
              (when (!= vtaint null)
                (when (= (scope-descends (sym home) vtaint) 0)
                  (die-at (cc line)
                    (fmt-s "resource bound by `with` escapes via assignment to longer-lived '%s' — use (move ...) to transfer ownership" (target s)))))
              (let (cv:ptr:Val (cast ptr:Val coerced))
                (emit-store (type-to-ir (sym type)) (cv val) (sym ir-name) (sym type))
                ; An owning binding's slot stays armed whatever is stored, so
                ; it keeps its taint; an ordinary binding adopts the value's.
                ; Either way a reassignment revives a moved-out binding.
                (when (= (sym owns) 0)
                  (.set! sym taint vtaint))
                (.set! sym moved 0)
                ; Narrowing: reassignment kills the dominating test's fact.
                ; Inside a loop, a narrow established outside the loop has
                ; already licensed earlier uses in this body — reject the
                ; assignment the prescan could not see (macro-expanded set!).
                (when (= (ptr-pkind (sym type)) PTR-MAYBE)
                  (when (and (!= (sym ntype) null) (< (sym ndepth) g-loop-depth))
                    (die-at (cc line)
                      (fmt-s "assignment to '%s' invalidates a null-narrowing established outside this loop — re-guard inside the loop" (target s))))
                  (narrow-kill (cast ptr sym))
                  ; Assigning a known non-null value re-narrows going forward.
                  (when (= (ptr-pkind (v type)) PTR-REF)
                    (narrow-apply scope set-name)))
                ; set! yields the assigned value (so the REPL echoes it).
                (let (rv:ref:Val (alloc-val (sym type) (cv val)))
                  (.set! rv taint vtaint)
                  (return rv))))))
          (die-at (target line) (fmt-s "set!: undefined local '%s'" (target s))))))))

; ============================================================
; Stage 8: scalar load/store helpers (volatile-aware)
; ============================================================

; Emit a scalar load into dst-tmp. When `ty` is volatile, emits `load volatile`.
(defn emit-load:void (dst-tmp:ptr ir-type:ptr ptr-name:ptr ty:ptr)
  (let (vol:ptr ""
        align:i32 (type-size ty))
    (when (and (!= ty null) (!= ((cast ptr:Type ty) is-volatile) 0))
      (set! vol "volatile "))
    (fprintf g-body-stream "  %s = load %s%s, ptr %s, align %d\n"
      dst-tmp vol ir-type ptr-name align)))

; Emit a scalar store of `val`. When `ty` is volatile, emits `store volatile`.
(defn emit-store:void (ir-type:ptr val:ptr ptr-name:ptr ty:ptr)
  (let (vol:ptr ""
        align:i32 (type-size ty))
    (when (and (!= ty null) (!= ((cast ptr:Type ty) is-volatile) 0))
      (set! vol "volatile "))
    (fprintf g-body-stream "  store %s%s %s, ptr %s, align %d\n"
      vol ir-type val ptr-name align)))

; Store a zero/null of `field-type` into the slot at `gep` (struct/array fill).
(defn emit-zero-store:void (field-type:ptr gep:ptr)
  (let (ft:ptr:Type (cast ptr:Type field-type)
        ir:ptr (type-to-ir field-type)
        zero:ptr "0")
    (when (= (ft kind) TY-PTR) (set! zero "null"))
    (when (= (ft kind) TY-F32) (set! zero "0.000000e+00"))
    (when (= (ft kind) TY-F64) (set! zero "0.000000e+00"))
    (fprintf g-body-stream "  store %s %s, ptr %s\n" ir zero gep)))

; Return a copy of `t` with is-volatile=1. Primitive type singletons are shared,
; so we clone rather than mutate. If `t` is already volatile, returns it as-is.
(defn type-with-volatile:ref:Type (t:ref:Type)
  (let (src:ptr:Type (cast ptr:Type t))
    (when (!= (src is-volatile) 0) (return t))
    (let (dst:ref:Type (alloc-type))
      (.set! dst kind        (src kind))
      (.set! dst ret         (src ret))
      (.set! dst params      (src params))
      (.set! dst num-params  (src num-params))
      (.set! dst variadic    (src variadic))
      (.set! dst has-rest    (src has-rest))
      (.set! dst nopt        (src nopt))
      (.set! dst opt-defaults (src opt-defaults))
      (.set! dst elem        (src elem))
      (.set! dst sdef        (src sdef))
      (.set! dst param-names (src param-names))
      (.set! dst is-volatile 1)
      (.set! dst pkind       (src pkind))
      (return dst))))

; ============================================================
; Stage 8: inc! / dec!
; ============================================================

(defn emit-inc-dec:ref:Val (call:ptr scope:ref:Scope op-instr:ptr op-name:ptr)
  (let (cc:ptr:Node (cast ptr:Node call))
    (when (!= (node-len cc) 2) (die-at (cc line) (fmt-s "%s expects 1 arg" op-name)))
    (let (target:ptr:Node (cast ptr:Node (node-at cc 1)))
      (when (!= (target kind) NODE-SYM)
        (die-at (target line) (fmt-s "%s: target must be symbol" op-name)))
      ; Strip any :type annotation so typed names from macro expansions resolve.
      (let (nm:ptr null
            type-ignored:ptr null)
        (split-typed (target s)
                     (cast ptr:ptr (addr-of nm))
                     (cast ptr:ptr (addr-of type-ignored)))
        (let (sym:ptr:Sym (cast ptr:Sym (scope-lookup scope nm)))
          (when (or (= (cast ptr sym) null) (= (sym is-local) 0))
            (die-at (target line) (fmt-s "%s: undefined local" op-name)))
          (when (= (is-int-type (sym type)) 0)
            (die-at (cc line) (fmt-s "%s: must be integer" op-name)))
          (let (ir:ptr (type-to-ir (sym type))
                t1:ptr (new-tmp))
            (emit-load t1 ir (sym ir-name) (sym type))
            (let (t2:ptr (new-tmp))
              (fprintf g-body-stream "  %s = %s nsw %s %s, 1\n" t2 op-instr ir t1)
              (emit-store ir t2 (sym ir-name) (sym type))
              (return (alloc-val ty-void null)))))))))

(defn emit-inc:ref:Val (call:ptr scope:ref:Scope)
  (return (emit-inc-dec call scope "add" "inc!")))

(defn emit-dec:ref:Val (call:ptr scope:ref:Scope)
  (return (emit-inc-dec call scope "sub" "dec!")))

; ============================================================
; Stage 8: labels and goto (incl. computed goto via blockaddress)
; ============================================================

(defn lbl-find:?LabelEntry (name:ptr)
  (let (v:ptr:Vec (cast ptr:Vec g-lbl-tbl)
        i:i32 0)
    (while (< i (v len))
      (let (e:ptr:LabelEntry (cast ptr:LabelEntry (aref (cast ptr:ptr (v data)) i)))
        (when (= (strcmp (e name) name) 0)
          (return (cast ptr e))))
      (inc! i))
    (return null)))

(defn lbl-add-occurrence:void (name:ptr)
  (let (e:ptr:LabelEntry (cast ptr:LabelEntry (lbl-find name)))
    (when (= (cast ptr e) null)
      (let (ne:ptr:LabelEntry (cast ptr:LabelEntry (arena-alloc (sizeof LabelEntry))))
        (.set! ne name name)
        (.set! ne total 0)
        (.set! ne seen 0)
        (vec-push g-lbl-tbl (cast ptr ne))
        (set! e ne)))
    (.set! e total (+ (e total) 1))))

; Pre-scan a function body form for (label NAME) declarations so forward gotos
; and last-decl-wins resolution work. Skips inside quote/quasiquote.
(defn prescan-labels:void (form:ptr)
  (when (= form null) (return))
  (let (n:ptr:Node (cast ptr:Node form))
    (when (!= (n kind) NODE-CELL) (return))
    (when (= (node-len n) 0) (return))
    (let (head:ptr:Node (cast ptr:Node (node-at n 0)))
      (when (= (head kind) NODE-SYM)
        (when (or (= (strcmp (head s) "quote") 0)
                  (= (strcmp (head s) "quasiquote") 0))
          (return))
        (when (and (= (strcmp (head s) "label") 0)
                   (= (node-len n) 2))
          (let (nm:ptr:Node (cast ptr:Node (node-at n 1)))
            (when (= (nm kind) NODE-SYM)
              (lbl-add-occurrence (nm s)))))))
    (let (it:ptr:Node n)
      (while (and (!= (cast ptr it) null) (= (it kind) NODE-CELL))
        (prescan-labels (it car))
        (set! it (cast ptr:Node (it cdr)))))))

(defn emit-label:ref:Val (call:ptr scope:ref:Scope)
  (let (cc:ptr:Node (cast ptr:Node call))
    (when (!= (node-len cc) 2) (die-at (cc line) "label: expects 1 name"))
    ; Stage 10 narrowing: a label is a potential backward-goto target — a
    ; join with unknown predecessors — so no narrow survives it.
    (narrow-kill-all)
    (let (nm:ptr:Node (cast ptr:Node (node-at cc 1)))
      (when (!= (nm kind) NODE-SYM)
        (die-at (nm line) "label: name must be symbol"))
      (let (e:ptr:LabelEntry (cast ptr:LabelEntry (lbl-find (nm s))))
        (when (= (cast ptr e) null)
          ; Pre-scan missed this label (e.g. from a macro expansion). Treat as a
          ; single decl; computed gotos may miss it in the indirectbr dest list.
          (lbl-add-occurrence (nm s))
          (set! e (cast ptr:LabelEntry (lbl-find (nm s)))))
        (.set! e seen (+ (e seen) 1))
        (let (bb-name:ptr null)
          (if (= (e seen) (e total))
            (set! bb-name (fmt-s "lbl.%s" (nm s)))
            (set! bb-name (fmt-sd "lbl.%s.dead%d" (nm s) (e seen))))
          (when (= g-block-term 0)
            (fprintf g-body-stream "  br label %%%s\n" bb-name))
          (fprintf g-body-stream "%s:\n" bb-name)
          (set! g-block-term 0)
          (return (alloc-val ty-void null)))))))

(defn emit-goto:ref:Val (call:ptr scope:ref:Scope)
  (let (cc:ptr:Node (cast ptr:Node call))
    (when (!= (node-len cc) 2) (die-at (cc line) "goto: expects 1 label name"))
    (let (nm:ptr:Node (cast ptr:Node (node-at cc 1)))
      (when (!= (nm kind) NODE-SYM)
        (die-at (nm line) "goto: name must be symbol"))
      (let (e:ptr:LabelEntry (cast ptr:LabelEntry (lbl-find (nm s))))
        (when (= (cast ptr e) null)
          (die-at (nm line) (fmt-s "goto: no such label '%s' in function" (nm s))))
        (fprintf g-body-stream "  br label %%lbl.%s\n" (nm s))
        ; Start a fresh dead BB so subsequent forms in a do/let body have a valid
        ; insertion point. LLVM eliminates it (no predecessors).
        (let (dead:ptr (fmt-i32 "goto.dead%d" (new-label-id)))
          (fprintf g-body-stream "%s:\n" dead))
        (set! g-block-term 0)
        (return (alloc-val ty-void null))))))

(defn emit-label-addr:ref:Val (call:ptr scope:ref:Scope)
  (let (cc:ptr:Node (cast ptr:Node call))
    (when (!= (node-len cc) 2) (die-at (cc line) "label-addr: expects 1 label name"))
    (let (nm:ptr:Node (cast ptr:Node (node-at cc 1)))
      (when (!= (nm kind) NODE-SYM)
        (die-at (nm line) "label-addr: name must be symbol"))
      (let (e:ptr:LabelEntry (cast ptr:LabelEntry (lbl-find (nm s))))
        (when (= (cast ptr e) null)
          (die-at (nm line) (fmt-s "label-addr: no such label '%s' in function" (nm s)))))
      (when (= g-cur-fname null)
        (die-at (cc line) "label-addr: not inside a function"))
      (let (tmp:ptr (new-tmp))
        ; getelementptr offset 0 is a no-op binding the blockaddress to an SSA name.
        (fprintf g-body-stream
          "  %s = getelementptr i8, ptr blockaddress(@%s, %%lbl.%s), i64 0\n"
          tmp g-cur-fname (nm s))
        (return (alloc-val ty-ptr tmp))))))

(defn emit-goto-ptr:ref:Val (call:ptr scope:ref:Scope)
  (let (cc:ptr:Node (cast ptr:Node call))
    (when (!= (node-len cc) 2) (die-at (cc line) "goto-ptr: expects 1 ptr arg"))
    (let (v:ref:Val (emit-node (node-at cc 1) scope))
      (when (!= ((cast ptr:Type (v type)) kind) TY-PTR)
        (die-at (cc line) "goto-ptr: arg must be ptr"))
      (let (tbl:ptr:Vec (cast ptr:Vec g-lbl-tbl))
        (when (= (tbl len) 0)
          (die-at (cc line) "goto-ptr: no labels declared in function"))
        (fprintf g-body-stream "  indirectbr ptr %s, [" (v val))
        (let (i:i32 0
              first:i32 1)
          (while (< i (tbl len))
            (let (e:ptr:LabelEntry (cast ptr:LabelEntry (aref (cast ptr:ptr (tbl data)) i)))
              (when (= first 0) (fprintf g-body-stream ","))
              (set! first 0)
              (fprintf g-body-stream " label %%lbl.%s" (e name)))
            (inc! i)))
        (fprintf g-body-stream " ]\n"))
      (let (dead:ptr (fmt-i32 "goto-ptr.dead%d" (new-label-id)))
        (fprintf g-body-stream "%s:\n" dead))
      (set! g-block-term 0)
      (return (alloc-val ty-void null)))))

; ============================================================
; Stage 8: struct/array compound literals and field-address
; ============================================================

(defn struct-field-idx:i32 (sd:ptr name:ptr)
  (let (sdef:ptr:StructDef (cast ptr:StructDef sd)
        i:i32 0)
    (while (< i (sdef num-fields))
      (when (= (strcmp (aref (cast ptr:ptr (sdef field-names)) i) name) 0)
        (return i))
      (inc! i))
    (return -1)))

; (.& p field) -> pointer to the field within struct *p.
(defn emit-field-addr:ref:Val (call:ptr scope:ref:Scope)
  (let (cc:ptr:Node (cast ptr:Node call))
    (when (!= (node-len cc) 3) (die-at (cc line) ".& expects 2 args"))
    (let (p:ref:Val (emit-node (node-at cc 1) scope)
          pt:ptr:Type (cast ptr:Type (p type)))
      (when (or (or (!= (pt kind) TY-PTR) (= (pt elem) null))
              (!= ((cast ptr:Type (pt elem)) kind) TY-STRUCT))
        (die-at (cc line) ".&: operand must be pointer to struct"))
      (require-derefable (cast ptr pt) (cc line) ".&")
      (let (fn-node:ptr:Node (cast ptr:Node (node-at cc 2)))
        (when (!= (fn-node kind) NODE-SYM)
          (die-at (fn-node line) ".&: field name must be symbol"))
        (let (sd:ptr:StructDef (cast ptr:StructDef ((cast ptr:Type (pt elem)) sdef))
              idx:i32 (struct-field-idx (cast ptr sd) (fn-node s)))
          (when (< idx 0)
            (die-at (fn-node line)
              (fmt-2s ".&: no field '%s' on struct '%s'" (fn-node s) (sd name))))
          (let (ftype:ptr (aref (cast ptr:ptr (sd field-types)) idx)
                gep:ptr (new-tmp))
            (fprintf g-body-stream
              "  %s = getelementptr inbounds %%%s, ptr %s, i32 0, i32 %d\n"
              gep (sd name) (p val) idx)
            (let (rt:ptr:Type (cast ptr:Type (make-type TY-PTR)))
              (.set! rt elem ftype)
              ; Interior address into the resource: keep the escape taint
              ; (lifecycle.md §2.2).
              (let (rv:ref:Val (alloc-val (cast ptr rt) gep))
                (.set! rv taint (p taint))
                (return rv)))))))))

; (array T e0 e1 ... | (idx v) ...) -> ptr:T to a stack array of int elements.
(defn emit-array-lit:ref:Val (call:ptr scope:ref:Scope)
  (let (cc:ptr:Node (cast ptr:Node call)
        nargs:i32 (- (node-len cc) 1))
    (when (< nargs 1)
      (die-at (cc line) "array: expects element type and 0+ initializers"))
    (let (etype-node:ptr (node-at cc 1)
          etype:ptr (parse-type-from-node etype-node ((cast ptr:Node etype-node) line))
          ninits:i32 (- nargs 1))
      ; Pass 1: scan inits to compute length and parse designated keys.
      (let (max-idx:i32 -1
            pos-count:i32 0
            keys:ptr (arena-alloc (* (cast i64 ninits) (cast i64 4)))
            i:i32 0)
        (while (< i ninits)
          (let (arg:ptr:Node (cast ptr:Node (node-at cc (+ 2 i)))
                is-designated:i32 0)
            (when (and (= (arg kind) NODE-CELL)
                       (and (= (node-len arg) 2)
                            (= ((cast ptr:Node (node-at arg 0)) kind) NODE-INT)))
              (set! is-designated 1))
            (if (!= is-designated 0)
              (let (k:i64 ((cast ptr:Node (node-at arg 0)) i))
                (when (< k (cast i64 0))
                  (die-at (arg line) "array: designated index must be non-negative"))
                (when (> (cast i32 k) max-idx) (set! max-idx (cast i32 k)))
                (aset! (cast ptr:i32 keys) i (cast i32 k)))
              (do
                (aset! (cast ptr:i32 keys) i (cast i32 -1))
                (inc! pos-count))))
          (inc! i))
        (let (length:i32 pos-count)
          (when (> (+ max-idx 1) length) (set! length (+ max-idx 1)))
          (when (= length 0) (die-at (cc line) "array: at least one initializer required"))
          (let (vals:ptr (arena-alloc (* (cast i64 length) (cast i64 8)))
                seen:ptr (arena-alloc (* (cast i64 length) (cast i64 4)))
                pos-cursor:i32 0
                j:i32 0)
            (while (< j length)
              (aset! (cast ptr:ptr vals) j null)
              (aset! (cast ptr:i32 seen) j (cast i32 0))
              (inc! j))
            ; Place designated inits.
            (set! j 0)
            (while (< j ninits)
              (let (k:i32 (aref (cast ptr:i32 keys) j))
                (when (>= k 0)
                  (when (!= (aref (cast ptr:i32 seen) k) 0)
                    (die-at ((cast ptr:Node (node-at cc (+ 2 j))) line)
                      (fmt-i32 "array: index %d specified twice" k)))
                  (aset! (cast ptr:i32 seen) k (cast i32 1))
                  (let (vexpr:ptr (node-at (cast ptr:Node (node-at cc (+ 2 j))) 1)
                        v:ref:Val (emit-node vexpr scope)
                        coerced:ptr (coerce-int-val v etype (cc line)))
                    (when (= coerced null)
                      (die-at (cc line) "array: type mismatch in designated initializer"))
                    (aset! (cast ptr:ptr vals) k coerced))))
              (inc! j))
            ; Positional inits fill the next unspecified slots.
            (set! j 0)
            (while (< j ninits)
              (let (k:i32 (aref (cast ptr:i32 keys) j))
                (when (< k 0)
                  (while (and (< pos-cursor length)
                              (!= (aref (cast ptr:i32 seen) pos-cursor) 0))
                    (inc! pos-cursor))
                  (when (>= pos-cursor length)
                    (die-at (cc line) "array: positional initializer overflows length"))
                  (let (arg:ptr (node-at cc (+ 2 j))
                        v:ref:Val (emit-node arg scope)
                        coerced:ptr (coerce-int-val v etype (cc line)))
                    (when (= coerced null)
                      (die-at (cc line) "array: type mismatch in positional initializer"))
                    (aset! (cast ptr:i32 seen) pos-cursor (cast i32 1))
                    (aset! (cast ptr:ptr vals) pos-cursor coerced)
                    (inc! pos-cursor))))
              (inc! j))
            ; Emit alloca in entry stream, then fill slots.
            (let (slot:ptr (new-tmp)
                  etype-ir:ptr (type-to-ir etype))
              (fprintf g-entry-stream "  %s = alloca %s, i32 %d\n" slot etype-ir length)
              (let (k:i32 0)
                (while (< k length)
                  (let (gep:ptr (new-tmp))
                    (fprintf g-body-stream
                      "  %s = getelementptr inbounds %s, ptr %s, i64 %d\n"
                      gep etype-ir slot k)
                    (let (vp:ptr (aref (cast ptr:ptr vals) k))
                      (if (= vp null)
                        (emit-zero-store etype gep)
                        (let (cv:ptr:Val (cast ptr:Val vp))
                          (fprintf g-body-stream "  store %s %s, ptr %s\n"
                            etype-ir (cv val) gep)))))
                  (inc! k)))
              (let (pt:ptr:Type (cast ptr:Type (make-type TY-PTR)))
                (.set! pt elem etype)
                (return (alloc-val (cast ptr pt) slot))))))))))

; (S e0 e1 ... | (field v) ...) -> ptr:S compound literal (struct-name head).
(defn emit-struct-lit:ref:Val (call:ptr scope:ref:Scope sd:ptr)
  (let (cc:ptr:Node (cast ptr:Node call)
        sdef:ptr:StructDef (cast ptr:StructDef sd)
        nargs:i32 (- (node-len cc) 1)
        nfields:i32 ((cast ptr:StructDef sd) num-fields))
    (when (> nargs nfields)
      (die-at (cc line) (fmt-s "struct literal: too many initializers for struct '%s'" (sdef name))))
    (let (vals:ptr (arena-alloc (* (cast i64 nfields) (cast i64 8)))
          seen:ptr (arena-alloc (* (cast i64 nfields) (cast i64 4)))
          pos-idx:i32 0
          i:i32 0)
      (while (< i nfields)
        (aset! (cast ptr:ptr vals) i null)
        (aset! (cast ptr:i32 seen) i (cast i32 0))
        (inc! i))
      (set! i 0)
      (while (< i nargs)
        (let (arg:ptr:Node (cast ptr:Node (node-at cc (+ 1 i)))
              is-designated:i32 0)
          (when (= (arg kind) NODE-CELL)
            (when (and (= (node-len arg) 2)
                       (= ((cast ptr:Node (node-at arg 0)) kind) NODE-SYM))
              (set! is-designated 1)))
          (if (!= is-designated 0)
            (let (fname-node:ptr:Node (cast ptr:Node (node-at arg 0))
                  vexpr:ptr (node-at arg 1)
                  fidx:i32 (struct-field-idx sd (fname-node s)))
              (when (< fidx 0)
                (die-at (fname-node line)
                  (fmt-s "struct literal: no field '%s'" (fname-node s))))
              (when (!= (aref (cast ptr:i32 seen) fidx) 0)
                (die-at (fname-node line)
                  (fmt-s "struct literal: field '%s' specified twice" (fname-node s))))
              (aset! (cast ptr:i32 seen) fidx (cast i32 1))
              (let (ftype:ptr (aref (cast ptr:ptr (sdef field-types)) fidx)
                    v:ref:Val (emit-node vexpr scope)
                    coerced:ptr (coerce-int-val v ftype (cc line)))
                (when (= coerced null)
                  (die-at (cc line)
                    (fmt-s "struct literal: type mismatch for field '%s'" (fname-node s))))
                (aset! (cast ptr:ptr vals) fidx coerced)))
            (do
              (while (and (< pos-idx nfields)
                          (!= (aref (cast ptr:i32 seen) pos-idx) 0))
                (inc! pos-idx))
              (when (>= pos-idx nfields)
                (die-at (arg line) "struct literal: too many positional initializers"))
              (let (ftype:ptr (aref (cast ptr:ptr (sdef field-types)) pos-idx)
                    v:ref:Val (emit-node arg scope)
                    coerced:ptr (coerce-int-val v ftype (cc line)))
                (when (= coerced null)
                  (die-at (cc line) "struct literal: type mismatch for positional initializer"))
                (aset! (cast ptr:i32 seen) pos-idx (cast i32 1))
                (aset! (cast ptr:ptr vals) pos-idx coerced)
                (inc! pos-idx)))))
        (inc! i))
      (let (slot:ptr (new-tmp)
            sname:ptr (sdef name))
        (fprintf g-entry-stream "  %s = alloca %%%s\n" slot sname)
        (let (k:i32 0)
          (while (< k nfields)
            (let (ftype:ptr (aref (cast ptr:ptr (sdef field-types)) k)
                  ftype-ir:ptr (type-to-ir ftype)
                  gep:ptr (new-tmp))
              (fprintf g-body-stream
                "  %s = getelementptr inbounds %%%s, ptr %s, i32 0, i32 %d\n"
                gep sname slot k)
              (let (vp:ptr (aref (cast ptr:ptr vals) k))
                (if (= vp null)
                  (emit-zero-store ftype gep)
                  (let (cv:ptr:Val (cast ptr:Val vp))
                    (fprintf g-body-stream "  store %s %s, ptr %s\n"
                      ftype-ir (cv val) gep)))))
            (inc! k)))
        (let (pt:ptr:Type (cast ptr:Type (make-type TY-PTR))
              st:ptr:Type (cast ptr:Type (make-type TY-STRUCT)))
          (.set! st sdef sd)
          (.set! pt elem (cast ptr st))
          (return (alloc-val (cast ptr pt) slot)))))))

; ============================================================
; Macro expansion (calls JIT-compiled macro functions at compiler runtime)
; ============================================================

; Find a macro definition by name, or null.
(defn find-macro:?MacroDef (name:ptr)
  (let (mi:i32 0)
    (while (< mi g-num-macros)
      (let (mdef:ptr:MacroDef (cast ptr:MacroDef (ptr+ (cast ptr:MacroDef g-macros) mi)))
        (when (= (mdef name) name)
          (return (cast ptr mdef))))
      (inc! mi)))
  (return null))

; Run one expansion of a macro call: invoke the JIT-compiled macro function
; and return the resulting (ptr Node). Does not desugar or emit IR.
; Attribute macro-generated nodes to the call site. Nodes synthesized during
; expansion (the cons cells built by the __cons/__append quasiquote helpers)
; carry line 0; spliced user arguments keep their real reader line. Stamping
; only line-0 nodes fills in the macro's own structure with the call-site line
; so downstream errors (e.g. a malformed `cond` from a bad `case`/`if`) point at
; the user's code instead of line 0. A non-zero line means the whole subtree is
; already attributed (a user argument), so we stop there.
(defn stamp-macro-lines:void (node:ptr ln:i32)
  (when (= node null) (return))
  (let (n:ptr:Node (cast ptr:Node node))
    (when (!= (n line) 0) (return))
    (.set! n line ln)
    (when (= (n kind) NODE-CELL)
      (stamp-macro-lines (n car) ln)
      (stamp-macro-lines (n cdr) ln))))

(defn expand-macro-call:ptr (call:ptr macro-def:ptr)
  (let (mdef:ptr:MacroDef (cast ptr:MacroDef macro-def)
        nargs:i32 (- (node-len (cast ptr:Node call)) 1))
    (when (!= (mdef variadic) 0)
      (when (< nargs (- (mdef num-params) 1))
        (die-at ((cast ptr:Node call) line)
                (fmt-s "macro: not enough args" (cast i64 0)))))
    (when (= (mdef variadic) 0)
      (when (!= nargs (mdef num-params))
        (die-at ((cast ptr:Node call) line)
                (fmt-s "macro: wrong number of args" (cast i64 0)))))
    (let (args-arr:ptr (malloc (* (cast i64 (mdef num-params)) (ptr-bytes)))
          regular-params:i32 (mdef num-params)
          i:i32 0)
      (when (!= (mdef variadic) 0)
        (set! regular-params (- (mdef num-params) 1)))
      (while (< i regular-params)
        (aset! (cast ptr:ptr args-arr) i (node-at (cast ptr:Node call) (+ i 1)))
        (inc! i))
      (when (!= (mdef variadic) 0)
        (let (rest-list:ptr null
              rj:i32 nargs)
          (while (> rj regular-params)
            (set! rj (- rj 1))
            (set! rest-list (make-cell (node-at (cast ptr:Node call) (+ rj 1)) rest-list 0)))
          (aset! (cast ptr:ptr args-arr) regular-params rest-list)))
      (let (addr:i64 (cast i64 0)
            err:ptr (LLVMOrcLLJITLookup g-jit (addr-of addr) (mdef jit-name)))
        (when (!= err null)
          (fprintf stderr "%s: macro '%s': JIT lookup failed\n"
                        g-source-path (mdef name))
          (exit 1))
        (when (= (cast ptr addr) null)
          (fprintf stderr "%s: macro '%s': JIT function not found\n"
                        g-source-path (mdef name))
          (exit 1))
        (let (result:ptr (funcall-ptr-1 (cast ptr addr) args-arr))
          (free args-arr)
          (when (= result null)
            (fprintf stderr "%s: macro '%s': returned null\n"
                          g-source-path (mdef name))
            (exit 1))
          ; Attribute the expansion to the macro call site so errors in
          ; macro-generated forms report a real source line, not line 0.
          (stamp-macro-lines result ((cast ptr:Node call) line))
          (return result))))))

; Expand a form by macros. depth=1 expands once; depth<0 expands until the
; head is no longer a macro (fixpoint). Subforms are not recursed into,
; matching Common Lisp macroexpand semantics.
(defn macroexpand-form:ptr (form:ptr depth:i32)
  (let (cur:ptr form
        steps:i32 0
        keep-going:i32 1)
    (while (!= keep-going 0)
      (set! keep-going 0)
      (when (and (!= cur null)
                 (and (= ((cast ptr:Node cur) kind) NODE-CELL)
                      (!= (node-len (cast ptr:Node cur)) 0)))
        (let (head:ptr:Node (cast ptr:Node (node-at (cast ptr:Node cur) 0)))
          (when (= (head kind) NODE-SYM)
            (let (mdef:ptr (find-macro (head s)))
              (when (!= mdef null)
                (when (or (< depth 0) (< steps depth))
                  (set! cur (expand-macro-call cur mdef))
                  (inc! steps)
                  (set! keep-going 1))))))))
    (return cur)))

; Like macroexpand-form but recursively expands subforms after the head
; reaches fixpoint. Quoted/quasiquoted forms are left untouched.
(defn macroexpand-all-form:ptr (form:ptr)
  (let (cur:ptr (macroexpand-form form (cast i32 -1)))
    (when (or (= cur null)
              (!= ((cast ptr:Node cur) kind) NODE-CELL))
      (return cur))
    (when (= (node-len (cast ptr:Node cur)) 0) (return cur))
    (let (head:ptr:Node (cast ptr:Node (node-at (cast ptr:Node cur) 0)))
      (when (and (= (head kind) NODE-SYM)
                 (or (= (head s) "quote")
                     (= (head s) "quasiquote")))
        (return cur)))
    (let (out:ptr null
          tail:ptr null
          it:ptr:Node (cast ptr:Node cur))
      (while (and (!= (cast ptr it) null) (= (it kind) NODE-CELL))
        (let (child:ptr (macroexpand-all-form (it car))
              new:ptr (make-cell child null (it line)))
          (if (= out null)
            (do (set! out new) (set! tail new))
            (do (.set! (cast ptr:Node tail) cdr new)
                (set! tail new))))
        (set! it (cast ptr:Node (it cdr))))
      (return out))))

(defn emit-macro-expand:ref:Val (call:ptr scope:ref:Scope macro-def:ptr)
  (let (result:ptr (expand-macro-call call macro-def))
    (return (emit-node (desugar result) scope))))

; ============================================================
; List dispatch
; ============================================================

; Emit a call to a resolved method `m` of generic `gname`, given the argument
; Vals already emitted into `args`. Coerces each argument to the method's
; parameter type (identity for an exact match, so the IR is unchanged) then
; emits the call to the selected symbol. Shared by ordinary overloaded dispatch
; and the operator user-overload path.
(defn emit-resolved-call:ref:Val (n:ptr scope:ref:Scope gname:ptr m:ref:Method args:ptr nargs:i32 line:i32)
  (let (ss:ref:Sym (new Sym))
    (when (and (!= (m param-types) null) (and (= (m has-rest) 0) (= (m num-params) nargs)))
      (let (ci:i32 0)
        (while (< ci nargs)
          (let (slot:ptr (ptr+ (cast ptr:Val args) ci)
                pt:ptr (aref (cast ptr:ptr (m param-types)) ci)
                na:ptr (coerce-num-val slot pt line))
            (when (and (!= na null) (!= na slot)) (memcpy slot na (sizeof Val))))
          (inc! ci))))
    (.set! ss name gname)
    (.set! ss type (m fn-type))
    (.set! ss ir-name (m ir-name))
    (.set! ss is-local 0)
    (return (emit-call-with-args n scope ss args nargs))))

; Emit a call to an overloaded generic: emit the arguments, resolve the method
; from their concrete types, then emit the call to the selected mangled symbol.
(defn emit-generic-call:ref:Val (n:ptr scope:ref:Scope g:ref:Generic)
  (let (nn:ptr:Node (cast ptr:Node n)
        nargs:i32 (- (node-len nn) 1)
        args:ptr (arena-alloc (* (cast i64 (+ nargs 1)) (sizeof Val)))
        argtypes:ptr (arena-alloc (* (cast i64 (+ nargs 1)) (ptr-bytes)))
        arg-nodes:ptr (arena-alloc (* (cast i64 (+ nargs 1)) (ptr-bytes)))
        i:i32 0)
    (while (< i nargs)
      (let (anode:ptr (node-at nn (+ i 1))
            v:ref:Val (emit-node anode scope))
        (memcpy (ptr+ (cast ptr:Val args) i) v (sizeof Val))
        (aset! (cast ptr:ptr argtypes) i ((cast ptr:Val v) type))
        (aset! (cast ptr:ptr arg-nodes) i anode))
      (inc! i))
    (let (m:ref:Method (generic-resolve g argtypes arg-nodes nargs (nn line)))
      (return (emit-resolved-call n scope (g name) m
                                  args nargs (nn line))))))

; Emit an operator that carries user overloads (§10.3). Emit the operands, then
; resolve a user method on the operator's argument types; if one matches, emit a
; call to it, otherwise fall back to the built-in numeric/pointer inline peephole
; (emit-binop-vals). A pure operator (no user overloads) never reaches here — it
; short-circuits to emit-binop in emit-dispatch, preserving byte-identical IR.
(defn emit-operator-dispatch:ref:Val (n:ptr scope:ref:Scope g:ref:Generic binop:ptr)
  (let (nn:ptr:Node (cast ptr:Node n)
        nargs:i32 (- (node-len nn) 1)
        args:ptr (arena-alloc (* (cast i64 (+ nargs 1)) (sizeof Val)))
        argtypes:ptr (arena-alloc (* (cast i64 (+ nargs 1)) (ptr-bytes)))
        arg-nodes:ptr (arena-alloc (* (cast i64 (+ nargs 1)) (ptr-bytes)))
        i:i32 0)
    (while (< i nargs)
      (let (anode:ptr (node-at nn (+ i 1))
            v:ref:Val (emit-node anode scope))
        (memcpy (ptr+ (cast ptr:Val args) i) v (sizeof Val))
        (aset! (cast ptr:ptr argtypes) i ((cast ptr:Val v) type))
        (aset! (cast ptr:ptr arg-nodes) i anode))
      (inc! i))
    (let (m:?Method (operator-user-resolve g argtypes arg-nodes nargs))
      (when (!= m null)
        (return (emit-resolved-call n scope (g name) m
                                    args nargs (nn line))))
      (when (!= nargs 2)
        (die-at (nn line) (fmt-s "%s expects 2 args" ((cast ptr:BinOp binop) name))))
      (return (emit-binop-vals (ptr+ (cast ptr:Val args) 0) (ptr+ (cast ptr:Val args) 1)
                               (aref (cast ptr:ptr arg-nodes) 0) (aref (cast ptr:ptr arg-nodes) 1)
                               binop (nn line))))))

; Unified dispatch tail for emit-list: the head symbol `h` is neither a macro
; nor a special form. Resolve it through the generic registry — a pure operator
; routes to emit-binop (byte-identical IR); an operator carrying user overloads
; resolves user-method-or-inline; overloaded sets dispatch on argument types;
; solitary names and C/extern functions fall through to the ordinary scope-bound
; call (also byte-identical).
(defn emit-dispatch:ref:Val (n:ptr scope:ref:Scope h:ptr head:ptr)
  ; Stage 10 (lifecycle.md §2.3): manually dropping a with-owned binding
  ; double-frees — the armed cleanup also fires at scope exit.
  (when (and (= h "drop") (= (node-len n) 2))
    (let (tname:ptr (node-binding-name (node-at n 1)))
      (when (!= tname null)
        (when-some (tsym (scope-lookup scope tname))
          (when (!= (tsym owns) 0)
            (die-at ((cast ptr:Node n) line)
              (fmt-2s "double drop: '%s' is dropped at `with` scope exit — use (move %s) to take ownership first" tname tname)))))))
  (let (g:?Generic (generic-lookup h))
    (when (!= g null)
      (let (m:ptr:Method (cast ptr:Method (aref (cast ptr:ptr (g methods)) 0)))
        (when (= (m kind) METHOD-INTRINSIC)
          (if (= (g mangled) 0)
            (return (emit-binop n scope (m binop)))
            (return (emit-operator-dispatch n scope g (m binop)))))
        (when (!= (g mangled) 0)
          (return (emit-generic-call n scope g))))))
  ; A defn/extern symbol (is-local 0, TY-FN) is a direct call. Anything else in
  ; head position is a value: emit it once, then route. A function-pointer value
  ; (a local/global TY-FN variable) folds to an indirect call; a non-function
  ; value routes to get (member access) / invoke (callable-values.md §4.1/§4.2).
  ; (if-some rather than a null guard: the guard body would end in die-at,
  ; which the narrowing engine cannot know is noreturn.)
  (if-some (sym (scope-lookup scope h))
    (do
      (when (and (-> sym (_ type) (cast ptr:Type _) (_ kind) (= _ TY-FN))
                 (= (sym is-local) 0))
        (return (emit-call n scope sym)))
      (return (emit-callable-value n scope (emit-symbol-ref head scope))))
    ; No symbol: struct-name-as-constructor (S init...) -> ptr:S compound
    ; literal, else unknown.
    (do
      (let (sd:?StructDef (lookup-struct h))
        (when (!= sd null)
          (return (emit-struct-lit n scope sd))))
      (die-at ((cast ptr:Node head) line) (fmt-s "unknown: %s" h)))))

(defn emit-list:ref:Val (n:ptr scope:ref:Scope)
  (let (nn:ptr:Node (cast ptr:Node n))
    (when (= (node-len nn) 0) (die-at (nn line) "empty list"))
    (let (head:ptr:Node (cast ptr:Node (node-at nn 0)))
      ; An arbitrary-expression head — `((mk) 3)`, `(@p 3)` — cannot be a macro or
      ; special form (those are symbol-keyed): emit it and route as a callable
      ; value (callable-values.md §4.1). Symbol heads continue below.
      (when (!= (head kind) NODE-SYM)
        (return (emit-callable-value n scope (emit-node (cast ptr head) scope))))
      (let (h:ptr (head s)
            hp:ptr (cast ptr head))
        ; Check macro table before special forms.
        (let (mi:i32 0)
          (while (< mi g-num-macros)
            (let (mdef:ptr:MacroDef (cast ptr:MacroDef (ptr+ (cast ptr:MacroDef g-macros) mi)))
              (when (= (mdef name) h)
                (return (emit-macro-expand n scope (cast ptr mdef)))))
            (inc! mi)))
        (when (and (= hp 'gensym) (= (node-len nn) 1))
          (let (tmp:ptr (new-tmp))
            (fprintf g-body-stream "  %s = call ptr @nucleus_gensym()\n" tmp)
            (return (alloc-val ty-ptr tmp))))
        (when (= hp 'funcall-ptr-1) (return (emit-funcall-ptr-1 n scope)))
        (when (= hp 'funcall-ptr-i32) (return (emit-funcall-ptr-i32 n scope)))
        (when (= hp 'funcall-ptr-i64) (return (emit-funcall-ptr-i64 n scope)))
        (when (= hp 'funcall-ptr-ptr) (return (emit-funcall-ptr-ptr n scope)))
        (when (= hp 'return) (return (emit-return n scope)))
        (when (= hp 'do) (return (emit-do n scope)))
        (when (= hp 'let) (return (emit-let n scope)))
        (when (= hp 'with) (return (emit-with n scope)))
        (when (= hp 'cond) (return (emit-cond n scope)))
        (when (= hp 'quote) (return (emit-quote n)))
        (when (= hp 'quasiquote) (return (emit-quasiquote n scope)))
        (when (= hp 'while) (return (emit-while n scope)))
        (when (= hp 'set!) (return (emit-set n scope)))
        (when (= hp 'inc!) (return (emit-inc n scope)))
        (when (= hp 'dec!) (return (emit-dec n scope)))
        (when (= hp 'label) (return (emit-label n scope)))
        (when (= hp 'goto) (return (emit-goto n scope)))
        (when (= hp 'label-addr) (return (emit-label-addr n scope)))
        (when (= hp 'goto-ptr) (return (emit-goto-ptr n scope)))
        (when (= hp 'array) (return (emit-array-lit n scope)))
        (when (= hp 'not) (return (emit-not n scope)))
        (when (= hp 'and) (return (emit-short-circuit n scope 1)))
        (when (= hp 'or) (return (emit-short-circuit n scope 0)))
        (when (= hp 'cast) (return (emit-cast n scope)))
        (when (= hp 'addr-of) (return (emit-addr-of n scope)))
        (when (= hp 'funcall-void) (return (emit-funcall-void n scope)))
        (when (= hp 'funcall) (return (emit-funcall n scope)))
        (when (= hp 'deref) (return (emit-deref n scope)))
        (when (= hp 'ptr-set!) (return (emit-ptr-set n scope)))
        (when (= hp 'ptr+) (return (emit-ptr-add n scope)))
        (when (= hp '_get) (return (emit-field-get n scope)))
        (when (= hp '.) (return (emit-field-get n scope)))
        (when (= hp '.&) (return (emit-field-addr n scope)))
        (when (= hp '.set!) (return (emit-field-set n scope)))
        (when (= hp 'get) (return (emit-get n scope)))
        (when (= hp 'invoke) (return (emit-invoke n scope)))
        (when (= hp 'sizeof) (return (emit-sizeof n scope)))
        (when (= hp 'alloca) (return (emit-alloca-form n scope)))
        (when (= hp 'char) (return (emit-char n scope)))
        (when (= hp 'aref) (return (emit-aref n scope)))
        (when (= hp 'aset!) (return (emit-aset n scope)))
        ; Stage 10: Maybe transition forms (nullability.md §3)
        (when (= hp 'some) (return (emit-some n scope)))
        (when (= hp 'as-ref) (return (emit-as-ref n scope)))
        (when (= hp 'unwrap) (return (emit-unwrap n scope)))
        (when (= hp 'unwrap-or) (return (emit-unwrap-or n scope)))
        (when (= hp 'if-some) (return (emit-if-some n scope 0)))
        (when (= hp 'when-some) (return (emit-if-some n scope 1)))
        (when (= hp 'defer) (return (emit-defer n scope)))
        (when (= hp 'move) (return (emit-move n scope)))
        (return (emit-dispatch n scope h (cast ptr head)))))))

; ============================================================
; Top-level forms
; ============================================================

; ============================================================
; Name (non-)shadowing — a symbol may name only one kind of thing
; (special form, built-in type, struct type, protocol, macro, function, value).
; Each top-level definer checks its name against every other namespace and errors
; on a cross-kind collision. Same-kind reuse (overloaded defn, struct/value
; redefinition) is allowed. Lookups are by content (strcmp) so they don't depend
; on whether a given table stores interned names.
; ============================================================

(defn special-form-named:i32 (name:ptr)
  (when (or (= name "let") (= name "with")) (return 1))
  (when (or (= name "do") (= name "cond")) (return 1))
  (when (or (= name "return") (= name "while")) (return 1))
  (when (or (= name "set!") (= name "inc!")) (return 1))
  (when (or (= name "dec!") (= name "array")) (return 1))
  (when (or (= name "label") (or (= name "goto") (= name "label-addr"))) (return 1))
  (when (or (= name "goto-ptr") (or (= name ".") (= name ".&"))) (return 1))
  (when (or (= name "quote") (= name "quasiquote")) (return 1))
  (when (or (= name "not") (or (= name "and") (= name "or"))) (return 1))
  (when (or (= name "cast") (= name "addr-of")) (return 1))
  (when (or (= name "deref") (or (= name "ptr-set!") (= name "ptr+"))) (return 1))
  (when (or (= name "_get") (= name ".set!")) (return 1))
  (when (or (= name "sizeof") (or (= name "alloca") (= name "char"))) (return 1))
  (when (or (= name "aref") (or (= name "aset!") (= name "gensym"))) (return 1))
  (when (or (= name "funcall") (= name "funcall-void")) (return 1))
  (when (or (= name "funcall-ptr-1") (= name "funcall-ptr-i32")) (return 1))
  (when (or (= name "funcall-ptr-i64") (= name "funcall-ptr-ptr")) (return 1))
  ; Stage 10 safety forms
  (when (or (= name "some") (or (= name "as-ref") (= name "unwrap"))) (return 1))
  (when (or (= name "unwrap-or") (or (= name "if-some") (= name "when-some"))) (return 1))
  (when (or (= name "move") (= name "defer")) (return 1))
  ; top-level definer / structural keywords are reserved too
  (when (or (= name "defn") (or (= name "defvar") (= name "defconst"))) (return 1))
  (when (or (= name "defenum") (or (= name "defstruct") (= name "defmacro"))) (return 1))
  (when (or (= name "defprotocol") (or (= name "extend") (= name "def-rmacro"))) (return 1))
  (when (or (= name "import") (or (= name "include") (= name "extern"))) (return 1))
  (when (or (= name "declare") (= name "compile-time")) (return 1))
  (return 0))

(defn primitive-type-named:i32 (name:ptr)
  (when (or (= name "int") (= name "bool")) (return 1))
  (when (or (= name "i1") (or (= name "i8") (= name "i16"))) (return 1))
  (when (or (= name "i32") (= name "i64")) (return 1))
  (when (or (= name "ui8") (or (= name "ui16") (= name "ui32"))) (return 1))
  (when (= name "ui64") (return 1))
  (when (or (= name "f32") (or (= name "f64") (= name "float"))) (return 1))
  (when (or (= name "double") (or (= name "ptr") (= name "void"))) (return 1))
  (when (= name "CStr") (return 1))
  (return 0))

; The kind currently associated with `name`, or NK-NONE. Highest-priority kind
; wins; a lower-priority definer will see the higher kind and report the clash.
(defn name-existing-kind:i32 (name:ptr)
  (when (!= (special-form-named name) 0) (return NK-SPECIAL))
  (when (!= (primitive-type-named name) 0) (return NK-BUILTIN))
  (let (i:i32 0)
    (while (< i g-structs-len)
      (let (sd:ptr:StructDef (cast ptr:StructDef (ptr+ (cast ptr:StructDef g-structs) i)))
        (when (= (strcmp (sd name) name) 0) (return NK-TYPE)))
      (inc! i)))
  (let (i:i32 0)
    (while (< i g-num-protocols)
      (let (p:ptr:Protocol (cast ptr:Protocol (ptr+ (cast ptr:Protocol g-protocols) i)))
        (when (= (strcmp (p name) name) 0) (return NK-PROTOCOL)))
      (inc! i)))
  (let (i:i32 0)
    (while (< i g-num-macros)
      (let (m:ptr:MacroDef (cast ptr:MacroDef (ptr+ (cast ptr:MacroDef g-macros) i)))
        (when (= (strcmp (m name) name) 0) (return NK-MACRO)))
      (inc! i)))
  (let (i:i32 0)
    (while (< i g-num-generics)
      (let (g:ptr:Generic (cast ptr:Generic (ptr+ (cast ptr:Generic g-generics) i)))
        (when (= (strcmp (g name) name) 0) (return NK-FUNCTION)))
      (inc! i)))
  (let (sc:ptr:Scope (cast ptr:Scope g-globals)
        i:i32 0)
    (while (< i (sc len))
      (let (sym:ptr:Sym (cast ptr:Sym (ptr+ (cast ptr:Sym (sc syms)) i)))
        (when (= (strcmp (sym name) name) 0)
          (if (and (!= (sym type) null)
                   (= (-> sym (_ type) (cast ptr:Type _) (_ kind)) TY-FN))
            (return NK-FUNCTION)
            (return NK-VALUE))))
      (inc! i)))
  (return NK-NONE))

(defn kind-noun:ptr (k:i32)
  (when (= k NK-SPECIAL)  (return "a special form"))
  (when (= k NK-BUILTIN)  (return "a built-in type"))
  (when (= k NK-TYPE)     (return "a type"))
  (when (= k NK-PROTOCOL) (return "a protocol"))
  (when (= k NK-MACRO)    (return "a macro"))
  (when (= k NK-FUNCTION) (return "a function"))
  (when (= k NK-VALUE)    (return "a value"))
  (return "something"))

; Error if `name` already names a different kind of thing than `newk`.
(defn guard-name-kind:void (name:ptr line:i32 newk:i32)
  (let (existing:i32 (name-existing-kind name))
    (when (and (!= existing NK-NONE) (!= existing newk))
      (die-at line
        (fmt-2s "'%s' already names %s — a symbol may name only one kind of thing"
                name (kind-noun existing))))))

; Record the defining source location on a freshly-defined Sym (used by the
; REPL and for error attribution). Tolerates a null sym.
(defn sym-set-src-loc:void (sym:ptr line:i32)
  (when (= sym null) (return))
  (let (s:ptr:Sym (cast ptr:Sym sym))
    (.set! s src-file g-source-path)
    (.set! s src-line line)))

; Produce the LLVM initializer string for a `defvar` init form at `ty`.
; Accepts int / float / string / null / true / false / defconst-name / (char "x").
(defn defvar-init-ir:ptr (init:ptr ty:ptr)
  (let (nn:ptr:Node (cast ptr:Node init)
        ty-kind:i32 ((cast ptr:Type ty) kind))
    ; Integer literal: any int type (signed or unsigned).
    (when (= (nn kind) NODE-INT)
      (when (= (is-int-type ty) 0)
        (die-at (nn line)
          (fmt-s "defvar: integer literal incompatible with type %s" (type-to-ir ty))))
      (return (fmt-i64 "%ld" (nn i))))
    ; Float literal: f32 or f64. LLVM accepts the same decimal/hex form for both.
    (when (= (nn kind) NODE-FLOAT)
      (when (= (is-float-type ty) 0)
        (die-at (nn line)
          (fmt-s "defvar: float literal incompatible with type %s" (type-to-ir ty))))
      (return (float-literal-ir (nn s))))
    ; String literal: ptr type. Intern into the string table and refer to it
    ; as @.str.N (decays to a byte pointer for printf consumers).
    (when (= (nn kind) NODE-STR)
      (when (!= ty-kind TY-PTR)
        (die-at (nn line) "defvar: string literal requires ptr type"))
      (let (sid:i32 (intern-string (nn s) (cast i32 (strlen (nn s)))))
        (return (fmt-i32 "@.str.%d" sid))))
    ; Symbol literal: null, true, false, or a defconst/defenum name.
    (when (= (nn kind) NODE-SYM)
      (when (= (strcmp (nn s) "null") 0)
        (when (!= ty-kind TY-PTR)
          (die-at (nn line) "defvar: null requires ptr type"))
        (return "null"))
      (when (= (strcmp (nn s) "true") 0)
        (when (!= ty-kind TY-I1)
          (die-at (nn line) "defvar: true requires i1/bool type"))
        (return "true"))
      (when (= (strcmp (nn s) "false") 0)
        (when (!= ty-kind TY-I1)
          (die-at (nn line) "defvar: false requires i1/bool type"))
        (return "false"))
      (let (sym:ptr:Sym (cast ptr:Sym (scope-lookup g-globals (nn s))))
        (when (and (!= (cast ptr sym) null) (!= (sym is-const) 0))
          (when (= (is-int-type ty) 0)
            (die-at (nn line)
              (fmt-s "defvar: constant '%s' incompatible with non-integer type" (nn s))))
          (return (sym const-val))))
      (die-at (nn line) (fmt-s "defvar: unsupported init symbol '%s'" (nn s))))
    ; (char "x") — char literal, one byte stored in an int field.
    (when (and (= (nn kind) NODE-CELL) (= (node-len nn) 2))
      (let (head:ptr:Node (cast ptr:Node (node-at nn 0)))
        (when (and (= (head kind) NODE-SYM) (= (strcmp (head s) "char") 0))
          (let (arg:ptr:Node (cast ptr:Node (node-at nn 1)))
            (when (or (!= (arg kind) NODE-STR)
                      (!= (cast i64 (strlen (arg s))) (cast i64 1)))
              (die-at (arg line) "defvar: (char ...) requires a single-char string"))
            (when (= (is-int-type ty) 0)
              (die-at (nn line) "defvar: char literal requires integer type"))
            (return (fmt-i32 "%d" (char-at (arg s) (cast i64 0))))))))
    (die-at (nn line) "defvar: init must be a literal")
    (return null)))

(defn emit-defvar:void (call:ptr)
  (let (cc:ptr:Node (cast ptr:Node call))
    (when (or (< (node-len cc) 2) (> (node-len cc) 3))
      (die-at (cc line) "defvar: expects name and optional init"))
    (let (name-node:ptr (node-at cc 1))
      (let (name:ptr null
            ty:ptr (extract-name-and-type name-node (cast ptr:ptr (addr-of name))
                                          ((cast ptr:Node name-node) line)))
        (when (= ty null)
          (die-at ((cast ptr:Node name-node) line) (fmt-s "defvar: missing :type on '%s'" name)))
        (guard-name-kind name (cc line) NK-VALUE)
        (let (ir-name:ptr (fmt-s "@%s" name)
              align:i32 (type-size ty)
              init-ir:ptr null)
          (if (= (node-len cc) 3)
            (set! init-ir (defvar-init-ir (node-at cc 2) ty))
            (let (tk:i32 ((cast ptr:Type ty) kind))
              (cond (!= (is-ptr-like ty) 0) (set! init-ir "null")
                    (or (= tk TY-F32) (= tk TY-F64)) (set! init-ir "0.0")
                    (= tk TY-I1) (set! init-ir "false")
                    true (set! init-ir "0"))))
          (fprintf g-out "%s = global %s %s, align %d\n\n"
            ir-name (type-to-ir ty) init-ir align)
          (sym-set-src-loc (scope-define g-globals name ty ir-name 1) (cc line)))))))

(defn emit-defconst:void (call:ptr)
  (let (cc:ptr:Node (cast ptr:Node call))
    (when (!= (node-len cc) 3) (die-at (cc line) "defconst: expects name and value"))
    (let (name:ptr:Node (cast ptr:Node (node-at cc 1))
          val:ptr:Node (cast ptr:Node (node-at cc 2)))
      (when (!= (name kind) NODE-SYM)
        (die-at (name line) "defconst: name must be symbol"))
      (when (!= (val kind) NODE-INT)
        (die-at (val line) "defconst: value must be integer literal"))
      (guard-name-kind (name s) (cc line) NK-VALUE)
      (let (sym:ptr:Sym (cast ptr:Sym (scope-define g-globals (name s) ty-i32 null 0)))
        (.set! sym is-const 1)
        (.set! sym const-val (fmt-i64 "%ld" (val i)))))))

(defn emit-defenum:void (call:ptr)
  (let (cc:ptr:Node (cast ptr:Node call))
    (when (< (node-len cc) 2) (die-at (cc line) "defenum: missing name"))
    (let (i:i32 2)
      (while (< i (node-len cc))
        (let (name:ptr:Node (cast ptr:Node (node-at cc i)))
          (when (!= (name kind) NODE-SYM)
            (die-at (name line) "defenum: value must be symbol"))
          (guard-name-kind (name s) (cc line) NK-VALUE)
          (let (sym:ptr:Sym (cast ptr:Sym (scope-define g-globals (name s) ty-i32 null 0)))
            (.set! sym is-const 1)
            (.set! sym const-val (fmt-i32 "%d" (- i 2)))))
        (inc! i)))))

(defn emit-defstruct:void (call:ptr)
  (let (cc:ptr:Node (cast ptr:Node call))
    (when (< (node-len cc) 2) (die-at (cc line) "defstruct: missing name"))
    (let (name-node:ptr:Node (cast ptr:Node (node-at cc 1)))
      (when (!= (name-node kind) NODE-SYM)
        (die-at (name-node line) "defstruct: name must be symbol"))
      (guard-name-kind (name-node s) (cc line) NK-TYPE)
      ; Reuse a StructDef pre-registered by prescan-struct-names (name only), or
      ; register fresh. Skip if its definition was already written to IR — covers
      ; redefinition (the prelude defines Node and some programs also do).
      (let (existing:?StructDef (lookup-struct (name-node s)))
        (when (and (!= existing null) (!= (existing emitted) 0))
          (return)))
      (let (sd:ref:StructDef (if-some (e (lookup-struct (name-node s)))
                               e
                               (register-struct (name-node s)))
            nfields:i32 (- (node-len cc) 2))
        (.set! sd field-names (arena-alloc (* (cast i64 nfields) (ptr-bytes))))
        (.set! sd field-types (arena-alloc (* (cast i64 nfields) (ptr-bytes))))
        (.set! sd num-fields nfields)
        (let (i:i32 0)
          (while (< i nfields)
            (let (field:ptr (node-at cc (+ i 2))
                  fname:ptr null
                  fty:ptr (extract-name-and-type field (cast ptr:ptr (addr-of fname))
                                                  ((cast ptr:Node field) line)))
              (when (= fty null)
                (die-at ((cast ptr:Node field) line) (fmt-s "defstruct: field '%s' missing :type" fname)))
              (aset! (cast ptr:ptr (sd field-names)) i (intern-str fname))
              (aset! (cast ptr:ptr (sd field-types)) i fty))
            (inc! i)))
        (fprintf g-out "%%%s = type { " (name-node s))
        (let (i:i32 0)
          (while (< i nfields)
            (when (!= i 0) (fprintf g-out ", "))
            (fprintf g-out "%s" (type-to-ir (aref (cast ptr:ptr (sd field-types)) i)))
            (inc! i)))
        (fprintf g-out " }\n\n")
        (.set! sd emitted 1)))))

(defn emit-extern:void (call:ptr)
  (let (cc:ptr:Node (cast ptr:Node call))
    (when (!= (node-len cc) 2)
      (die-at (cc line) "extern: expects name:type"))
    (let (arg1:ptr (node-at cc 1)
          name:ptr null
          ty:ptr null)
      (set! ty (extract-name-and-type arg1 (cast ptr:ptr (addr-of name))
                                      ((cast ptr:Node arg1) line)))
      (when (= ty null)
        (die-at ((cast ptr:Node arg1) line)
          (fmt-s "extern: missing :type on '%s'" name)))
      (guard-name-kind name (cc line) NK-VALUE)
      (let (ir-name:ptr (fmt-s "@%s" name))
        (fprintf g-out "%s = external global %s\n\n" ir-name (type-to-ir ty))
        (scope-define g-globals name ty ir-name 1)))))

; ============================================================
; C header handling — imported from src/cheader.nuc
; ============================================================

(import cheader)
(import repl)

; ============================================================
; defn
; ============================================================

(defn emit-defn:void (call:ptr)
  (let (cc:ptr:Node (cast ptr:Node call))
    (when (< (node-len cc) 4) (die-at (cc line) "defn: bad form"))
    (let (name-node:ptr (node-at cc 1)
          params-node:ptr (node-at cc 2))
      (when (= (node-is-list params-node) 0)
        (die-at ((cast ptr:Node name-node) line) "defn: params must be list"))
      ; A bounded-generic template (carries `&where`) emits no code itself; it is
      ; registered in prescan and monomorphized per call site.
      (when (>= (params-where-index params-node) 0) (return))
      (let (fname:ptr null
            ret:ptr (extract-name-and-type name-node (cast ptr:ptr (addr-of fname))
                                           ((cast ptr:Node name-node) line)))
        (when (= ret null)
          (die-at ((cast ptr:Node name-node) line) (fmt-s "defn: missing :type on '%s'" fname)))
        (guard-name-kind fname (cc line) NK-FUNCTION)
        (let (
              raw-nparams:i32 (node-len params-node)
              has-rest:i32 0
              rest-idx:i32 -1
              opt-idx:i32 -1
              nopt:i32 0)
          ; Scan for &rest and &optional. &rest must be second-to-last so the rest
          ; param itself is the trailing entry. &optional comes after all required
          ; params; everything after it (until end or &rest) is an optional spec.
          (let (si:i32 0)
            (while (< si raw-nparams)
              (let (sp:ptr:Node (cast ptr:Node (node-at params-node si)))
                (when (= (sp kind) NODE-SYM)
                  (when (= (sp s) "&rest")
                    (when (!= si (- raw-nparams 2))
                      (die-at (sp line) "defn: &rest must be second-to-last param"))
                    (when (!= has-rest 0)
                      (die-at (sp line) "defn: multiple &rest in params"))
                    (set! has-rest 1)
                    (set! rest-idx si))
                  (when (= (sp s) "&optional")
                    (when (!= opt-idx -1)
                      (die-at (sp line) "defn: multiple &optional in params"))
                    (set! opt-idx si))))
              (inc! si)))
          (when (and (!= opt-idx -1) (!= has-rest 0))
            (die-at ((cast ptr:Node (node-at params-node opt-idx)) line)
                    "defn: &optional cannot be combined with &rest"))
          (when (!= opt-idx -1)
            (when (= opt-idx (- raw-nparams 1))
              (die-at ((cast ptr:Node (node-at params-node opt-idx)) line)
                      "defn: &optional must be followed by at least one param"))
            (set! nopt (- (- raw-nparams 1) opt-idx)))
          (let (nparams:i32 raw-nparams)
            (when (!= has-rest 0) (set! nparams (- nparams 1)))
            (when (!= opt-idx -1) (set! nparams (- nparams 1)))
            (let (param-types:ptr null
                  param-names:ptr null
                  opt-defaults:ptr null
                  required:i32 (- nparams nopt))
              (when (> nparams 0)
                  (set! param-types (arena-alloc (* (cast i64 nparams) (ptr-bytes))))
                  (set! param-names (arena-alloc (* (cast i64 nparams) (ptr-bytes)))))
              (when (> nopt 0)
                  (set! opt-defaults (arena-alloc (* (cast i64 nopt) (ptr-bytes)))))
              (let (i:i32 0
                    di:i32 0)
                (while (< i raw-nparams)
                  (let (skip:i32 0)
                    (when (and (!= has-rest 0) (= i rest-idx)) (set! skip 1))
                    (when (= i opt-idx) (set! skip 1))
                    (when (= skip 0)
                      (let (p:ptr (node-at params-node i)
                            pname:ptr null
                            is-opt:i32 0
                            spec:ptr (node-at params-node i)
                            default-node:ptr null)
                        (when (and (!= opt-idx -1) (> i opt-idx)) (set! is-opt 1))
                        (when (!= is-opt 0)
                          ; Optional param: a 2-element list (name:type default).
                          (when (or (= (node-is-list p) 0) (!= (node-len p) 2))
                            (die-at ((cast ptr:Node p) line)
                              "defn: &optional param must be (name:type default)"))
                          (set! spec (node-at p 0))
                          (set! default-node (node-at p 1)))
                        (let (pty:ptr (extract-name-and-type spec (cast ptr:ptr (addr-of pname))
                                                             ((cast ptr:Node spec) line)))
                          (when (= pty null)
                            (die-at ((cast ptr:Node p) line) (fmt-s "defn: missing :type on param '%s'" pname)))
                          ; The &rest parameter receives a Node* cons-list head.
                          ; The user's declared type annotates element type only;
                          ; the actual param is always ptr.
                          (when (and (!= has-rest 0) (= di (- nparams 1)))
                            (set! pty ty-ptr))
                          (aset! (cast ptr:ptr param-types) di pty)
                          (aset! (cast ptr:ptr param-names) di pname)
                          (when (!= is-opt 0)
                            (aset! (cast ptr:ptr opt-defaults) (- di required) default-node))))
                      (inc! di)))
                  (inc! i)))
          ; Register function in globals
          (let (ft:ptr:Type (cast ptr:Type (make-type TY-FN)))
            (.set! ft ret ret)
            (.set! ft num-params nparams)
            (.set! ft params param-types)
            (.set! ft variadic 0)
            (.set! ft has-rest has-rest)
            (.set! ft nopt nopt)
            (.set! ft opt-defaults opt-defaults)
            ; Solitary names (and fallback defns with no registered generic) keep
            ; their scope binding under @name. Overloaded methods dispatch through
            ; the generic registry, so no bare-name binding is installed.
            (when (= (defn-is-mangled fname) 0)
              (scope-define g-globals fname (cast ptr ft)
                            (defn-ir-name fname param-types nparams) 0)))
          ; Codegen
          (reset-function-state)
          ; g-cur-fname is the @-less IR symbol of this function (for blockaddress
          ; in label-addr). defn-ir-name returns "@sym"; skip the leading '@'.
          (set! g-cur-fname (ptr+ (cast ptr:i8 (defn-ir-name fname param-types nparams))
                                  (cast i32 1)))
          ; Aggregate return ABI (Stage 8 Phase C): drives the signature, the
          ; sret hidden param, and how `return` lowers a struct value.
          (set! g-fn-ret-abi (abi-classify ret))
          ; Stage 10: declared return type, for the pointer-kind check on
          ; `return` (a (ref T) return requires a ref value).
          (set! g-fn-ret-type ret)
          (when (= ((cast ptr:AbiInfo g-fn-ret-abi) kind) ABI-MEMORY)
            (set! g-fn-sret-name "%.sret"))
          (let (fn-scope:ref:Scope (scope-new g-globals)
                i:i32 0)
            (while (< i nparams)
              (abi-emit-param-prologue fn-scope
                (aref (cast ptr:ptr param-names) i)
                (aref (cast ptr:ptr param-types) i))
              (inc! i))
            (set! i 3)
            ; Pre-scan the body for (label NAME) decls so forward gotos and
            ; last-decl-wins resolution work.
            (let (psi:i32 i)
              (while (< psi (node-len cc))
                (prescan-labels (node-at cc psi))
                (inc! psi)))
            (let (last-val:ptr:Val (alloc-val ty-void null))
              (while (< i (node-len cc))
                (set! last-val (emit-node (node-at cc i) fn-scope))
                (inc! i))
              ; Fire function-scope (defer …) cleanups on the implicit-return
              ; fall-off path (explicit returns walk the scope chain instead).
              (emit-scope-cleanups fn-scope)
              (when (= g-block-term 0)
                ; Stage 10: the implicit return is a return — same escape sink
                ; as the explicit one (the (ref T) kind check runs inside
                ; coerce-int-val below).
                (when (!= ((cast ptr:Val last-val) taint) null)
                  (die-at (cc line)
                    "resource bound by `with` escapes via implicit return — use (move ...) to transfer ownership"))
                (if (!= ((cast ptr:AbiInfo g-fn-ret-abi) kind) ABI-DIRECT)
                  ; Struct return via the aggregate ABI. A void last expression
                  ; (degenerate fall-off) returns a zeroed struct.
                  (emit-struct-ret
                    (if (= ((cast ptr:Type ((cast ptr:Val last-val) type)) kind) TY-VOID)
                      (alloc-val ret "zeroinitializer")
                      last-val))
                (if (= ((cast ptr:Type ret) kind) TY-VOID)
                  (fprintf g-body-stream "  ret void\n")
                  ; Implicit return: if the last expression yielded a value
                  ; matching the declared return type, return it. If the last
                  ; expression was void (e.g., a side-effect or a no-return
                  ; call like die-at the compiler can't recognize), fall back
                  ; to a zero/null return so the function has a well-typed
                  ; terminator.
                  (if (= ((cast ptr:Type ((cast ptr:Val last-val) type)) kind) TY-VOID)
                    (let (zero:ptr "0")
                      (when (!= (is-ptr-like ret) 0) (set! zero "null"))
                      (fprintf g-body-stream "  ret %s %s\n" (type-to-ir ret) zero))
                    (let (coerced:ptr (coerce-int-val last-val ret (cc line)))
                      (when (= coerced null)
                        (die-at (cc line)
                          (fmt-s "%s: implicit return type mismatch — last expression does not match declared return type"
                                 fname)))
                      (let (cv:ptr:Val (cast ptr:Val coerced))
                        (fprintf g-body-stream "  ret %s %s\n"
                          (type-to-ir ret) (cv val)))))))))
            ; Close streams and emit function
            (fclose g-entry-stream)
            (fclose g-body-stream)
            (fprintf g-out "define %s %s("
              (abi-ret-ir g-fn-ret-abi ret) (defn-ir-name fname param-types nparams))
            ; A MEMORY return prepends the hidden sret pointer parameter.
            (let (need-comma:i32 0)
              (when (= ((cast ptr:AbiInfo g-fn-ret-abi) kind) ABI-MEMORY)
                (fprintf g-out "ptr sret(%s) align %d %s"
                  (type-to-ir ret) ((cast ptr:AbiInfo g-fn-ret-abi) align) g-fn-sret-name)
                (set! need-comma 1))
              (set! i 0)
              (while (< i nparams)
                (when (!= need-comma 0) (fprintf g-out ", "))
                (abi-print-param
                  (abi-classify (aref (cast ptr:ptr param-types) i))
                  (aref (cast ptr:ptr param-types) i)
                  (aref (cast ptr:ptr param-names) i))
                (set! need-comma 1)
                (inc! i)))
            (fprintf g-out ") {\n")
            (fprintf g-out "entry:\n")
            (when (and (!= g-entry-bufp null) (!= (char-at g-entry-bufp (cast i64 0)) 0))
              (fputs g-entry-bufp g-out))
            (when (and (!= g-body-bufp null) (!= (char-at g-body-bufp (cast i64 0)) 0))
              (fputs g-body-bufp g-out))
            (fprintf g-out "}\n\n")
            (free g-entry-bufp)
            (free g-body-bufp)
            (set! g-entry-bufp null)
            (set! g-body-bufp null)))))))))

; ============================================================
; Compile-time JIT helpers
; ============================================================

(defn jit-ensure-init:void (line:i32)
  (when (!= g-jit null) (return))
  ; Initialize x86 target (expands LLVMInitializeNativeTarget)
  (LLVMInitializeX86TargetInfo)
  (LLVMInitializeX86Target)
  (LLVMInitializeX86TargetMC)
  (LLVMInitializeX86AsmPrinter)
  ; Create LLJIT
  (let (jit-ref:ptr null
        err:ptr (LLVMOrcCreateLLJIT (addr-of jit-ref) null))
    (when (!= err null)
       (fprintf stderr "%s:%d: JIT error in LLVMOrcCreateLLJIT: %s\n"
                   g-source-path line (LLVMGetErrorMessage err))
          (when (!= g-interactive 0) (repl_throw))
          (exit 1))
    (set! g-jit jit-ref))
  (set! g-jit-dylib (LLVMOrcLLJITGetMainJITDylib g-jit))
  ; Expose host process symbols so CT code can call printf, malloc, etc.
  (let (prefix:i8 (LLVMOrcLLJITGetGlobalPrefix g-jit)
        gen:ptr null
        err:ptr (LLVMOrcCreateDynamicLibrarySearchGeneratorForProcess
                   (addr-of gen) prefix null null))
    (when (!= err null)
       (fprintf stderr "%s:%d: JIT error in CreateDynLibSearchGen: %s\n"
                   g-source-path line (LLVMGetErrorMessage err))
          (when (!= g-interactive 0) (repl_throw))
          (exit 1))
    (LLVMOrcJITDylibAddGenerator g-jit-dylib gen)))

(defn jit-add-module:void (ir:ptr line:i32)
  (jit-add-module-rt ir line null))

; Add a module to the JIT, optionally under a resource tracker. Pass rt=null to
; add to the main JITDylib without a tracker (used by compile-time and macro JIT).
; Pass a tracker to add under it so the module's symbols can be removed later
; via LLVMOrcResourceTrackerRemove (used by the REPL for redefinition).
(defn jit-add-module-rt:void (ir:ptr line:i32 rt:ptr)
  (jit-ensure-init line)
  ; LLVMOrcThreadSafeContextGetContext was removed in LLVM 20+. Create the
  ; parsing context directly. tsctx is only used for ThreadSafeModule locking
  ; which is irrelevant in single-threaded compilation. ctx leaks (fine).
  (let (ctx:ptr (LLVMContextCreate)
        ir-len:i64 (cast i64 (strlen ir))
        mb:ptr (LLVMCreateMemoryBufferWithMemoryRangeCopy ir ir-len "<compile-time>")
        mod:ptr null
        errmsg:ptr null
        parse-err:i32 (LLVMParseIRInContext ctx mb (addr-of mod) (addr-of errmsg)))
    (when (!= parse-err 0)
       (fprintf stderr "%s:%d: compile-time: IR parse error: %s\n"
                   g-source-path line errmsg)
          (when (!= g-interactive 0) (repl_throw))
          (exit 1))
    (let (tsctx:ptr (LLVMOrcCreateNewThreadSafeContext)
          tsmod:ptr (LLVMOrcCreateNewThreadSafeModule mod tsctx)
          err:ptr null)
      (LLVMOrcDisposeThreadSafeContext tsctx)
      (if (= rt null)
        (set! err (LLVMOrcLLJITAddLLVMIRModule g-jit g-jit-dylib tsmod))
        (set! err (LLVMOrcLLJITAddLLVMIRModuleWithRT g-jit rt tsmod)))
      (when (!= err null)
         (fprintf stderr "%s:%d: JIT error in AddLLVMIRModule: %s\n"
                     g-source-path line (LLVMGetErrorMessage err))
            (when (!= g-interactive 0) (repl_throw))
            (exit 1)))))

(defn jit-call-ct-main-sym:void (line:i32 sym:ptr)
  (let (addr:i64 (cast i64 0))
    (let (err:ptr (LLVMOrcLLJITLookup g-jit (cast ptr (addr-of addr)) sym))
      (when (!= err null)
         (LLVMConsumeError err) (return))
      (when (= addr (cast i64 0)) (return))
      ; Redirect stdout -> stderr so CT printf does not corrupt the IR output
      (fflush (cast ptr stdout))
      (let (saved-fd:i32 (dup 1))
        (dup2 2 1)
        (funcall-void (cast ptr addr))
        (fflush (cast ptr stdout))
        (dup2 saved-fd 1)
        (close saved-fd)))))

; ============================================================
; compile-time special form
; ============================================================

(defn emit-compile-time:void (form:ptr)
  ; (compile-time body-form...)
  (let (nforms:i32 (node-len (cast ptr:Node form))
        ff:ptr:Node   (cast ptr:Node form))
    (when (< nforms 2)
      (die-at (ff line) "compile-time: expected at least one body form"))

    ; Flush the main streams so g-type-bufp / g-decl-bufp are current.
    (fflush g-type-stream)
    (fflush g-decl-stream)

    ; Open fresh CT streams.
    (let (ct-type-bufp:ptr null
          ct-type-sizep:i64 (cast i64 0)
          ct-decl-bufp:ptr null
          ct-decl-sizep:i64 (cast i64 0)
          ct-def-bufp:ptr null
          ct-def-sizep:i64 (cast i64 0)
          ct-type:ptr (open_memstream (addr-of ct-type-bufp) (cast ptr (addr-of ct-type-sizep)))
          ct-decl:ptr (open_memstream (addr-of ct-decl-bufp) (cast ptr (addr-of ct-decl-sizep)))
          ct-def:ptr  (open_memstream (addr-of ct-def-bufp)  (cast ptr (addr-of ct-def-sizep))))

      ; Redirect global state to CT streams.
      (let (saved-g-out:ptr g-out
            saved-decl-out:ptr g-decl-out
            saved-qq-used:i32 g-qq-used)
        (set! g-qq-used 0)
        (set! g-decl-out ct-decl)

        ; Pre-scan: register defn signatures from CT body.
        (let (bi:i32 1)
          (while (< bi nforms)
            (let (bf:ptr:Node (cast ptr:Node (node-at ff bi)))
              (when (and (!= (cast ptr bf) null)
                       (and (= (bf kind) NODE-CELL)
                            (and (>= (node-len bf) 4)
                                 (and (-> bf (node-at _ 0) (cast ptr:Node _) (_ kind) (= _ NODE-SYM))
                                      (-> bf (node-at _ 0) (cast ptr:Node _) (_ s) (= _ "defn"))))))
                (let (name-node:ptr (node-at bf 1)
                      params-node:ptr (node-at bf 2))
                  (when (!= (node-is-list params-node) 0)
                    (let (fname:ptr null
                          ret:ptr (extract-name-and-type name-node (cast ptr:ptr (addr-of fname))
                                                          ((cast ptr:Node name-node) line)))
                      (when (!= ret null)
                        (let (nparams:i32 (node-len params-node)
                              ptypes:ptr null)
                          (when (> nparams 0)
                            (set! ptypes (arena-alloc (* (cast i64 nparams) (ptr-bytes)))))
                          (let (j:i32 0)
                            (while (< j nparams)
                              (let (p:ptr (node-at params-node j)
                                    pn:ptr null
                                    pty:ptr (extract-name-and-type p (cast ptr:ptr (addr-of pn))
                                                                    ((cast ptr:Node p) line)))
                                (if (!= pty null)
                                  (aset! (cast ptr:ptr ptypes) j pty)
                                  (aset! (cast ptr:ptr ptypes) j ty-i32)))
                              (inc! j)))
                          (let (ft:ptr:Type (cast ptr:Type (make-type TY-FN)))
                            (.set! ft ret ret)
                            (.set! ft num-params nparams)
                            (.set! ft params ptypes)
                            (scope-define g-globals fname (cast ptr ft)
                                          (fmt-s "@%s" fname) 0)))))))))
            (inc! bi)))

        ; Collect expression forms (non-top-level) for __compile_time_main.
        (let (expr-forms:ptr (arena-alloc (* (cast i64 256) (ptr-bytes)))
              nexpr:i32 0
              bi:i32 1)
          (while (< bi nforms)
            (let (bf:ptr:Node (cast ptr:Node (node-at ff bi))
                  is-tl:i32 0)
              (when (and (!= (cast ptr bf) null)
                       (and (= (bf kind) NODE-CELL)
                            (and (!= (node-len bf) 0)
                                 (-> bf (node-at _ 0) (cast ptr:Node _) (_ kind) (= _ NODE-SYM)))))
                (let (bh:ptr (-> bf (node-at _ 0) (cast ptr:Node _) (_ s)))
                  (when (= bh "defstruct")
                     (set! is-tl 1) (set! g-out ct-type) (emit-defstruct (cast ptr bf)))
                  (when (= bh "defconst")
                     (set! is-tl 1) (emit-defconst (cast ptr bf)))
                  (when (= bh "defenum")
                     (set! is-tl 1) (emit-defenum (cast ptr bf)))
                  (when (= bh "defvar")
                     (set! is-tl 1) (set! g-out ct-decl) (emit-defvar (cast ptr bf)))
                  (when (= bh "include")
                     (set! is-tl 1) (set! g-out ct-decl) (emit-include (cast ptr bf)))
                  (when (= bh "extern")
                     (set! is-tl 1) (set! g-out ct-decl) (emit-extern (cast ptr bf)))
                  (when (= bh "defn")
                     (set! is-tl 1) (set! g-out ct-def) (emit-defn (cast ptr bf)))))
              (when (and (= is-tl 0) (< nexpr 256))
                 (aset! (cast ptr:ptr expr-forms) nexpr (cast ptr bf))
                    (inc! nexpr)))
            (inc! bi))

          ; Emit unique @__compile_time_main_N wrapping the expression forms.
          (let (ct-sym:ptr (fmt-i64 "__compile_time_main_%ld" (cast i64 g-ct-id)))
          (inc! g-ct-id)
          (set! g-out ct-def)
          (reset-function-state)
          (let (fn-scope:ref:Scope (scope-new g-globals)
                ei:i32 0)
            (while (< ei nexpr)
              (emit-node (aref (cast ptr:ptr expr-forms) ei) fn-scope)
              (inc! ei)))
          (when (= g-block-term 0)
            (fprintf g-body-stream "  ret void\n"))
          ; Flush streams so bufp pointers are populated
          (fclose g-entry-stream)
          (fclose g-body-stream)
          (fprintf ct-def "define void @%s() {\n" ct-sym)
          (fprintf ct-def "entry:\n")
          (when (and (!= g-entry-bufp null) (!= (char-at g-entry-bufp (cast i64 0)) 0))
            (fputs g-entry-bufp ct-def))
          (when (and (!= g-body-bufp null) (!= (char-at g-body-bufp (cast i64 0)) 0))
            (fputs g-body-bufp ct-def))
          (fprintf ct-def "}\n\n")
          (free g-entry-bufp)
          (free g-body-bufp)
          (set! g-entry-bufp null)
          (set! g-body-bufp null)

          (let (ct-qq:i32 g-qq-used)
            ; Restore global state.
            (set! g-out saved-g-out)
            (set! g-decl-out saved-decl-out)
            (set! g-qq-used saved-qq-used)

            ; If CT used quasiquote, add private helpers and declare the
            ; host-defined helpers (alloc-node, make-cell, intern-symbol).
            (when (!= ct-qq 0)
               (fprintf ct-decl "declare ptr @malloc(i64)\n")
                  (fprintf ct-decl "declare ptr @alloc-node()\n")
                  (fprintf ct-decl "declare ptr @make-cell(ptr, ptr, i32)\n")
                  (fprintf ct-decl "declare ptr @intern-symbol(ptr)\n")
                  (fprintf ct-def "define private ptr @__cons(ptr %%a, ptr %%b) {\n")
                  (fprintf ct-def "  %%c = call ptr @malloc(i64 40)\n")
                  (fprintf ct-def "  %%p0 = getelementptr inbounds { i32, i32, i64, ptr, ptr, ptr }, ptr %%c, i32 0, i32 0\n")
                  (fprintf ct-def "  store i32 3, ptr %%p0, align 8\n")
                  (fprintf ct-def "  %%p4 = getelementptr inbounds { i32, i32, i64, ptr, ptr, ptr }, ptr %%c, i32 0, i32 4\n")
                  (fprintf ct-def "  store ptr %%a, ptr %%p4, align 8\n")
                  (fprintf ct-def "  %%p5 = getelementptr inbounds { i32, i32, i64, ptr, ptr, ptr }, ptr %%c, i32 0, i32 5\n")
                  (fprintf ct-def "  store ptr %%b, ptr %%p5, align 8\n")
                  (fprintf ct-def "  ret ptr %%c\n")
                  (fprintf ct-def "}\n\n")
                  (fprintf ct-def "define private ptr @__append(ptr %%a, ptr %%b) {\n")
                  (fprintf ct-def "entry:\n")
                  (fprintf ct-def "  %%z = icmp eq ptr %%a, null\n")
                  (fprintf ct-def "  br i1 %%z, label %%nil, label %%rec\n")
                  (fprintf ct-def "nil:\n")
                  (fprintf ct-def "  ret ptr %%b\n")
                  (fprintf ct-def "rec:\n")
                  (fprintf ct-def "  %%p4 = getelementptr inbounds { i32, i32, i64, ptr, ptr, ptr }, ptr %%a, i32 0, i32 4\n")
                  (fprintf ct-def "  %%car = load ptr, ptr %%p4, align 8\n")
                  (fprintf ct-def "  %%p5 = getelementptr inbounds { i32, i32, i64, ptr, ptr, ptr }, ptr %%a, i32 0, i32 5\n")
                  (fprintf ct-def "  %%cdr = load ptr, ptr %%p5, align 8\n")
                  (fprintf ct-def "  %%rest = call ptr @__append(ptr %%cdr, ptr %%b)\n")
                  (fprintf ct-def "  %%c = call ptr @__cons(ptr %%car, ptr %%rest)\n")
                  (fprintf ct-def "  ret ptr %%c\n")
                  (fprintf ct-def "}\n\n"))

            (fclose ct-type)
            (fclose ct-decl)
            (fclose ct-def)

            ; Assemble full CT module IR in a memstream.
            (let (ir-bufp:ptr null  ir-sizep:i64 (cast i64 0)
                  irs:ptr (open_memstream (addr-of ir-bufp) (cast ptr (addr-of ir-sizep))))
              (fprintf irs "; ModuleID = '<compile-time>'\n")
              (fprintf irs "target triple = \"%s\"\n\n" ((cast ptr:Target g-host-target) triple))
              ; In REPL mode, include the accumulated preamble
              (when (!= g-interactive 0)
                 (fflush g-repl-preamble)
                    (when (and (!= g-repl-preamble-bufp null)
                               (!= (char-at g-repl-preamble-bufp (cast i64 0)) 0))
                      (fputs g-repl-preamble-bufp irs)))
              ; Type defs: main-so-far + CT-specific
              (when (and (!= g-type-bufp null) (!= (char-at g-type-bufp (cast i64 0)) 0))
                (fputs g-type-bufp irs))
              (when (and (!= ct-type-bufp null) (!= (char-at ct-type-bufp (cast i64 0)) 0))
                (fputs ct-type-bufp irs))
              ; String constants (shared)
              (emit-string-table irs)
              ; Declarations: main-so-far + CT-specific
              (when (and (!= g-decl-bufp null) (!= (char-at g-decl-bufp (cast i64 0)) 0))
                (fputs g-decl-bufp irs))
              (when (and (!= ct-decl-bufp null) (!= (char-at ct-decl-bufp (cast i64 0)) 0))
                (fputs ct-decl-bufp irs))
              ; Definitions from CT body + @__compile_time_main
              (when (and (!= ct-def-bufp null) (!= (char-at ct-def-bufp (cast i64 0)) 0))
                (fputs ct-def-bufp irs))
              (fclose irs)

              (jit-add-module ir-bufp (ff line))
              (jit-call-ct-main-sym (ff line) ct-sym)

              (free ct-type-bufp)
              (free ct-decl-bufp)
              (free ct-def-bufp)
              (free ir-bufp)))))))))

; ============================================================
; defmacro top-level form
; ============================================================

(defn emit-defmacro:void (form:ptr)
  ; (defmacro name (params...) body...)
  (let (ff:ptr:Node (cast ptr:Node form))
    (when (< (node-len ff) 4)
      (die-at (ff line) "defmacro: expects name, params, and body"))
    (let (name-node:ptr:Node (cast ptr:Node (node-at ff 1))
          params-node:ptr (node-at ff 2))
      (when (!= (name-node kind) NODE-SYM)
        (die-at (name-node line) "defmacro: name must be symbol"))
      (when (= (node-is-list params-node) 0)
        (die-at (name-node line) "defmacro: params must be a list"))
      (guard-name-kind (name-node s) (ff line) NK-MACRO)
      (let (macro-name:ptr (name-node s)
            num-params:i32 (node-len params-node)
            jit-name:ptr (fmt-sd "__macro_%s_%d" (sanitize-for-ir macro-name) g-num-macros))
        ; Detect &rest variadic parameter (must be second-to-last in param list).
        (let (variadic:i32 0
              pcount:i32 num-params)
          (let (vi:i32 0)
            (while (< vi num-params)
              (let (vp:ptr:Node (cast ptr:Node (node-at params-node vi)))
                (when (= (vp s) "&rest")
                    (when (!= vi (- num-params 2))
                      (die-at (vp line) "defmacro: &rest must be second-to-last param"))
                    (set! variadic 1)
                    (set! pcount (- num-params 1))))
              (inc! vi)))
        ; Collect param names, skipping &rest keyword.
        (let (pnames:ptr null
              pi:i32 0
              ai:i32 0)
          (when (> pcount 0)
            (set! pnames (arena-alloc (* (cast i64 pcount) (ptr-bytes)))))
          (while (< pi num-params)
            (let (p:ptr:Node (cast ptr:Node (node-at params-node pi)))
              (when (!= (p kind) NODE-SYM)
                (die-at (p line) "defmacro: param must be a symbol"))
              (when (!= (p s) "&rest")
                  (aset! (cast ptr:ptr pnames) ai (p s))
                  (inc! ai)))
            (inc! pi))
          ; Register in macro table
          (when (>= g-num-macros 256)
            (die-at (ff line) "defmacro: macro table full"))
          (let (mdef:ptr:MacroDef (cast ptr:MacroDef (ptr+ (cast ptr:MacroDef g-macros) g-num-macros)))
            (.set! mdef name macro-name)
            (.set! mdef jit-name jit-name)
            (.set! mdef num-params pcount)
            (.set! mdef variadic variadic)
            (inc! g-num-macros))

          ; Flush main streams
          (fflush g-type-stream)
          (fflush g-decl-stream)

          ; Open fresh CT streams
          (let (ct-decl-bufp:ptr null  ct-decl-sizep:i64 (cast i64 0)
                ct-def-bufp:ptr null   ct-def-sizep:i64  (cast i64 0)
                ct-decl:ptr (open_memstream (addr-of ct-decl-bufp) (cast ptr (addr-of ct-decl-sizep)))
                ct-def:ptr  (open_memstream (addr-of ct-def-bufp)  (cast ptr (addr-of ct-def-sizep))))

            ; Redirect global state
            (let (saved-g-out:ptr g-out
                  saved-decl-out:ptr g-decl-out
                  saved-qq-used:i32 g-qq-used)
              (set! g-qq-used 0)
              (set! g-decl-out ct-decl)
              (set! g-out ct-def)

              ; Set up function codegen state
              (reset-function-state)
              (let (fn-scope:ref:Scope (scope-new g-globals))

                ; Entry prologue: alloca for args pointer, then load each param
                (fprintf g-entry-stream "  %%__args.addr = alloca ptr, align 8\n")
                (fprintf g-entry-stream "  store ptr %%__args.arg, ptr %%__args.addr, align 8\n")
                (let (ei:i32 0)
                  (while (< ei pcount)
                    (let (pname:ptr (aref (cast ptr:ptr pnames) ei))
                      (fprintf g-entry-stream "  %%%s.addr = alloca ptr, align 8\n" pname)
                      (fprintf g-entry-stream "  %%__ap%d = load ptr, ptr %%__args.addr, align 8\n" ei)
                      (fprintf g-entry-stream "  %%__ag%d = getelementptr ptr, ptr %%__ap%d, i32 %d\n" ei ei ei)
                      (fprintf g-entry-stream "  %%__av%d = load ptr, ptr %%__ag%d, align 8\n" ei ei)
                      (fprintf g-entry-stream "  store ptr %%__av%d, ptr %%%s.addr, align 8\n" ei pname)
                      (scope-define fn-scope pname ty-ptr (fmt-s "%%%s.addr" pname) 1))
                    (inc! ei)))

                ; Compile body forms; last result is return value
                (let (last-val:ptr "null"
                      bi:i32 3)
                  (while (< bi (node-len ff))
                    (let (bv:ref:Val (emit-node (node-at ff bi) fn-scope))
                      (when (and (!= (cast ptr bv) null)
                               (and (!= (bv val) null)
                                    (-> bv (_ type) (cast ptr:Type _) (_ kind) (= _ TY-PTR))))
                        (set! last-val (bv val))))
                    (inc! bi))
                  (fprintf g-body-stream "  ret ptr %s\n" last-val))

                (let (macro-qq:i32 g-qq-used)
                  ; Restore global state
                  (set! g-out saved-g-out)
                  (set! g-decl-out saved-decl-out)
                  (set! g-qq-used saved-qq-used)

                  ; Finalize the function
                  (fclose g-entry-stream)
                  (fclose g-body-stream)
                  (fprintf ct-def "define ptr @%s(ptr %%__args.arg) {\n" jit-name)
                  (fprintf ct-def "entry:\n")
                  (when (and (!= g-entry-bufp null) (!= (char-at g-entry-bufp (cast i64 0)) 0))
                    (fputs g-entry-bufp ct-def))
                  (when (and (!= g-body-bufp null) (!= (char-at g-body-bufp (cast i64 0)) 0))
                    (fputs g-body-bufp ct-def))
                  (fprintf ct-def "}\n\n")
                  (free g-entry-bufp)
                  (free g-body-bufp)
                  (set! g-entry-bufp null)
                  (set! g-body-bufp null)

                  ; Add QQ helpers if needed.
                  ; Only emit malloc declaration if it's not already in g-decl-bufp
                  ; (e.g. from an earlier (include stdlib)).
                  (when (!= macro-qq 0)
                     (when (= g-malloc-decl-done 0)
                          (fprintf ct-decl "declare ptr @malloc(i64)\n"))
                        (fprintf ct-decl "declare ptr @alloc-node()\n")
                        (fprintf ct-decl "declare ptr @make-cell(ptr, ptr, i32)\n")
                        (fprintf ct-decl "declare ptr @intern-symbol(ptr)\n")
                        (fprintf ct-def "define private ptr @__cons(ptr %%a, ptr %%b) {\n")
                        (fprintf ct-def "  %%c = call ptr @malloc(i64 40)\n")
                        (fprintf ct-def "  %%p0 = getelementptr inbounds { i32, i32, i64, ptr, ptr, ptr }, ptr %%c, i32 0, i32 0\n")
                        (fprintf ct-def "  store i32 3, ptr %%p0, align 8\n")
                        (fprintf ct-def "  %%p1 = getelementptr inbounds { i32, i32, i64, ptr, ptr, ptr }, ptr %%c, i32 0, i32 1\n")
                        (fprintf ct-def "  store i32 0, ptr %%p1, align 4\n")
                        (fprintf ct-def "  %%p2 = getelementptr inbounds { i32, i32, i64, ptr, ptr, ptr }, ptr %%c, i32 0, i32 2\n")
                        (fprintf ct-def "  store i64 0, ptr %%p2, align 8\n")
                        (fprintf ct-def "  %%p3 = getelementptr inbounds { i32, i32, i64, ptr, ptr, ptr }, ptr %%c, i32 0, i32 3\n")
                        (fprintf ct-def "  store ptr null, ptr %%p3, align 8\n")
                        (fprintf ct-def "  %%p4 = getelementptr inbounds { i32, i32, i64, ptr, ptr, ptr }, ptr %%c, i32 0, i32 4\n")
                        (fprintf ct-def "  store ptr %%a, ptr %%p4, align 8\n")
                        (fprintf ct-def "  %%p5 = getelementptr inbounds { i32, i32, i64, ptr, ptr, ptr }, ptr %%c, i32 0, i32 5\n")
                        (fprintf ct-def "  store ptr %%b, ptr %%p5, align 8\n")
                        (fprintf ct-def "  ret ptr %%c\n")
                        (fprintf ct-def "}\n\n")
                        (fprintf ct-def "define private ptr @__append(ptr %%a, ptr %%b) {\n")
                        (fprintf ct-def "entry:\n")
                        (fprintf ct-def "  %%z = icmp eq ptr %%a, null\n")
                        (fprintf ct-def "  br i1 %%z, label %%nil, label %%rec\n")
                        (fprintf ct-def "nil:\n")
                        (fprintf ct-def "  ret ptr %%b\n")
                        (fprintf ct-def "rec:\n")
                        (fprintf ct-def "  %%p4 = getelementptr inbounds { i32, i32, i64, ptr, ptr, ptr }, ptr %%a, i32 0, i32 4\n")
                        (fprintf ct-def "  %%car = load ptr, ptr %%p4, align 8\n")
                        (fprintf ct-def "  %%p5 = getelementptr inbounds { i32, i32, i64, ptr, ptr, ptr }, ptr %%a, i32 0, i32 5\n")
                        (fprintf ct-def "  %%cdr = load ptr, ptr %%p5, align 8\n")
                        (fprintf ct-def "  %%rest = call ptr @__append(ptr %%cdr, ptr %%b)\n")
                        (fprintf ct-def "  %%c = call ptr @__cons(ptr %%car, ptr %%rest)\n")
                        (fprintf ct-def "  ret ptr %%c\n")
                        (fprintf ct-def "}\n\n"))

                  ; Always declare nucleus_gensym
                  (fprintf ct-decl "declare ptr @nucleus_gensym()\n")

                  (fclose ct-decl)
                  (fclose ct-def)

                  ; Assemble the macro JIT module IR
                  (let (ir-bufp:ptr null  ir-sizep:i64 (cast i64 0)
                        irs:ptr (open_memstream (addr-of ir-bufp) (cast ptr (addr-of ir-sizep))))
                    (fprintf irs "; ModuleID = '<defmacro %s>'\n" macro-name)
                    (fprintf irs "target triple = \"%s\"\n\n" ((cast ptr:Target g-host-target) triple))
                    ; In REPL mode, include the accumulated preamble
                    (when (!= g-interactive 0)
                       (fflush g-repl-preamble)
                          (when (and (!= g-repl-preamble-bufp null)
                                     (!= (char-at g-repl-preamble-bufp (cast i64 0)) 0))
                            (fputs g-repl-preamble-bufp irs)))
                    (when (and (!= g-type-bufp null) (!= (char-at g-type-bufp (cast i64 0)) 0))
                      (fputs g-type-bufp irs))
                    (emit-string-table irs)
                    (when (and (!= g-decl-bufp null) (!= (char-at g-decl-bufp (cast i64 0)) 0))
                      (fputs g-decl-bufp irs))
                    (when (and (!= ct-decl-bufp null) (!= (char-at ct-decl-bufp (cast i64 0)) 0))
                      (fputs ct-decl-bufp irs))
                    (when (and (!= ct-def-bufp null) (!= (char-at ct-def-bufp (cast i64 0)) 0))
                      (fputs ct-def-bufp irs))
                    (fclose irs)
                    (jit-add-module ir-bufp (ff line))
                    (free ct-decl-bufp)
                    (free ct-def-bufp)
                    (free ir-bufp))))))))))))

; ============================================================
; String table emission
; ============================================================

(defn emit-string-table:void (out:ptr)
  (let (i:i32 0)
    (while (< i g-strs-len)
      (let (sl:ptr:StrLit (cast ptr:StrLit (ptr+ (cast ptr:StrLit g-strs) i))
            ir-len:i32 (+ (sl len) 1))
        (fprintf out "@.str.%d = private unnamed_addr constant [%d x i8] c\""
          (sl id) ir-len)
        (let (j:i32 0)
          (while (< j (sl len))
            (let (c:i32 (char-at (sl bytes) (cast i64 j)))
              (if (or (or (= c 92) (= c 34))
                    (or (< c 32) (>= c 127)))
                (fprintf out "\\%02X" c)
                (fputc c out)))
            (inc! j)))
        (fprintf out "\\00\", align 1\n"))
      (inc! i)))
  (when (!= g-strs-len 0) (fputc 10 out)))

; ============================================================
; Driver
; ============================================================

(defn read-file:ptr (path:ptr)
  (let (f:ptr (fopen path "rb"))
    (when (= f null) (perror path) (exit 1))
    (when (!= (fseek f (cast i64 0) 2) 0) (perror "fseek") (exit 1))
    (let (sz:i64 (ftell f))
      (when (< sz (cast i64 0)) (perror "ftell") (exit 1))
      (rewind f)
      (let (buf:ptr (malloc (+ sz (cast i64 1))))
        (when (= buf null) (perror "malloc") (exit 1))
        (let (nr:i64 (fread buf (cast i64 1) sz f))
          (aset! (cast ptr:i8 buf) nr (cast i8 0))
          (fclose f)
          (return buf))))))

; ============================================================
; Desugar pass — split colon-typed symbols into lists
; ============================================================

; Split a symbol string containing : into a list of symbol nodes.
; Split a colon-separated symbol string into a flat list of SYM nodes.
; "ptr:Node" → (ptr Node), "ptr:ptr:Node" → (ptr ptr Node).
(defn split-colon-segments:ptr (s:ptr line:i32)
  (let (result:ptr null
        tail:ptr null
        start:i64 (cast i64 0)
        i:i64 (cast i64 0)
        slen:i64 (cast i64 (strlen s)))
    (while (<= i slen)
      (when (or (= i slen) (= (char-at s i) 58))
         (let (seg-len:i64 (- i start)
                  seg:ptr (arena-strndup (ptr+ (cast ptr:i8 s) start) seg-len)
                  n:ptr (intern-symbol seg))
              (let (cell:ptr (make-cell n null line))
                (when (= tail null) (set! result cell))
                (when (!= tail null) (.set! (cast ptr:Node tail) cdr cell))
                (set! tail cell)))
            (set! start (+ i (cast i64 1))))
      (set! i (+ i (cast i64 1))))
    (return result)))

; Desugar a colon-typed symbol into a binding list:
;   "foo:int"        → (foo int)
;   "node:ptr:Node"  → (node (ptr Node))    ; type tail wrapped
;   "pp:ptr:ptr:Node"→ (pp (ptr ptr Node))
(defn desugar-symbol:ptr (sym:ptr line:i32)
  (let (result:ptr (split-colon-segments ((cast ptr:Node sym) s) line))
    ; If 3+ segments (name + multi-symbol type), wrap the type tail
    ; in a sublist so the binding becomes (name (seg1 seg2 ...)).
    (when (!= result null)
      (let (rest:ptr ((cast ptr:Node result) cdr))
        (when (and (!= rest null) (!= ((cast ptr:Node rest) cdr) null))
          (let (wrap:ptr (make-cell rest null line))
            (.set! (cast ptr:Node result) cdr wrap)))))
    (return result)))

; Desugar a single typed-name node (symbol with :).
; Returns the node unchanged if it has no colon.
(defn desugar-typed:ptr (node:ptr)
  (when (= node null) (return null))
  (let (n:ptr:Node (cast ptr:Node node))
    (when (and (= (n kind) NODE-SYM) (!= (strchr (n s) 58) null))
      (return (desugar-symbol node (n line))))
    (return node)))

; Desugar a parameter list: each element that is a typed symbol gets split.
(defn desugar-params:ptr (params:ptr)
  (when (= params null) (return null))
  (let (n:ptr:Node (cast ptr:Node params))
    (when (!= (n kind) NODE-CELL) (return params))
    (let (new-car:ptr (desugar-typed (n car))
          new-cdr:ptr (desugar-params (n cdr)))
      (when (and (= new-car (n car)) (= new-cdr (n cdr)))
        (return params))
      (let (c:ptr:Node (cast ptr:Node (alloc-node)))
        (.set! c kind NODE-CELL)
        (.set! c line (n line))
        (.set! c car new-car)
        (.set! c cdr new-cdr)
        (return (cast ptr c))))))

; Desugar a let binding list: pairs of (name val) where name may be typed.
(defn desugar-let-bindings:ptr (binds:ptr)
  (when (= binds null) (return null))
  (let (n:ptr:Node (cast ptr:Node binds))
    (when (!= (n kind) NODE-CELL) (return binds))
    ; Even-indexed children are binding names, odd are values — desugar names only.
    (let (result:ptr null
          tail:ptr null
          cur:ptr binds
          idx:i32 0
          changed:i32 0)
      (while (!= cur null)
        (let (cn:ptr:Node (cast ptr:Node cur)
              elem:ptr (cn car)
              new-elem:ptr elem)
          (when (= (% idx 2) 0)
            (set! new-elem (desugar-typed elem)))
          (when (!= new-elem elem) (set! changed 1))
          (let (cell:ptr (make-cell new-elem null (cn line)))
            (when (= tail null) (set! result cell))
            (when (!= tail null) (.set! (cast ptr:Node tail) cdr cell))
            (set! tail cell)))
        (set! cur ((cast ptr:Node cur) cdr))
        (inc! idx))
      (when (= changed 0) (return binds))
      (return result))))

; Desugar a top-level form list.  Recognises defn, defvar, defstruct,
; extern, declare, and let, and desugars only the binding-position symbols.
; Expression bodies are NOT desugared (they may contain typed symbols from
; macro expansion that should stay as symbols for split-typed in value position).
(defn desugar:ptr (forms:ptr)
  (when (= forms null) (return null))
  (let (n:ptr:Node (cast ptr:Node forms))
    (when (!= (n kind) NODE-CELL) (return forms))
    (let (new-car:ptr (desugar-form (n car))
          new-cdr:ptr (desugar (n cdr)))
      (when (and (= new-car (n car)) (= new-cdr (n cdr)))
        (return forms))
      (let (c:ptr:Node (cast ptr:Node (alloc-node)))
        (.set! c kind NODE-CELL)
        (.set! c line (n line))
        (.set! c car new-car)
        (.set! c cdr new-cdr)
        (return (cast ptr c))))))

; Desugar a single form.  Only touches binding positions of known forms.
(defn desugar-form:ptr (form:ptr)
  (when (= form null) (return null))
  (let (f:ptr:Node (cast ptr:Node form))
    (when (!= (f kind) NODE-CELL) (return form))
    (when (= (node-len form) 0) (return form))
    (let (head:ptr:Node (cast ptr:Node (node-at form 0)))
      (when (!= (head kind) NODE-SYM) (return form))
      (let (h:ptr (head s))
        ; (defn name:type (params...) body...)
        (when (= h "defn")
          (when (>= (node-len form) 3)
            (let (new-name:ptr (desugar-typed (node-at form 1))
                  new-params:ptr (desugar-params (node-at form 2)))
              (when (and (= new-name (node-at form 1))
                         (= new-params (node-at form 2)))
                (return form))
              ; Rebuild: (defn new-name new-params body...)
              (return (make-cell (cast ptr head)
                       (make-cell new-name
                         (make-cell new-params
                           ((cast ptr:Node ((cast ptr:Node (f cdr)) cdr)) cdr)
                           (f line))
                         (f line))
                       (f line))))))
        ; (defvar name:type [init])
        (when (= h "defvar")
          (when (>= (node-len form) 2)
            (let (new-name:ptr (desugar-typed (node-at form 1)))
              (when (= new-name (node-at form 1)) (return form))
              (return (make-cell (cast ptr head)
                       (make-cell new-name
                         ((cast ptr:Node (f cdr)) cdr)
                         (f line))
                       (f line))))))
        ; (defstruct name field:type ...)
        (when (= h "defstruct")
          (when (>= (node-len form) 2)
            ; Desugar fields (positions 2+)
            (let (new-rest:ptr (desugar-params ((cast ptr:Node (f cdr)) cdr)))
              (when (= new-rest ((cast ptr:Node (f cdr)) cdr))
                (return form))
              (return (make-cell (cast ptr head)
                       (make-cell (node-at form 1)
                         new-rest
                         (f line))
                       (f line))))))
        ; (extern name:type)
        (when (= h "extern")
          (when (= (node-len form) 2)
            (let (new-name:ptr (desugar-typed (node-at form 1)))
              (when (= new-name (node-at form 1)) (return form))
              (return (make-cell (cast ptr head)
                       (make-cell new-name null (f line))
                       (f line))))))
        ; (declare name:type (params...))
        (when (= h "declare")
          (when (>= (node-len form) 2)
            (let (new-name:ptr (desugar-typed (node-at form 1))
                  new-params:ptr null)
              (when (= (node-len form) 3)
                (set! new-params (desugar-params (node-at form 2))))
              (when (and (= new-name (node-at form 1))
                         (or (= (node-len form) 2) (= new-params (node-at form 2))))
                (return form))
              (when (= (node-len form) 3)
                (return (make-cell (cast ptr head)
                         (make-cell new-name
                           (make-cell new-params null (f line))
                           (f line))
                         (f line))))
              (return (make-cell (cast ptr head)
                       (make-cell new-name null (f line))
                       (f line))))))
        ; (let (bindings...) body...) — desugar binding names
        ; (with (bindings...) body...) — same shape; auto-frees libc-alloc'd bindings
        (when (or (= h "let") (= h "with"))
          (when (>= (node-len form) 2)
            (let (new-binds:ptr (desugar-let-bindings (node-at form 1)))
              (when (= new-binds (node-at form 1)) (return form))
              (return (make-cell (cast ptr head)
                       (make-cell new-binds
                         ((cast ptr:Node (f cdr)) cdr)
                         (f line))
                       (f line))))))
        ; Recurse into body of compile-time and do blocks
        (when (or (= h "compile-time") (= h "do"))
          (let (new-body:ptr (desugar (f cdr)))
            (when (= new-body (f cdr)) (return form))
            (return (make-cell (cast ptr head) new-body (f line)))))
        (return form)))))

; Pre-register the names of all top-level structs so that defn signatures
; mentioning a struct type (e.g. a param typed ptr:Circle) resolve during
; prescan-defn-signatures, which runs before any defstruct is emitted. Only the
; name is registered here; fields and the IR type are filled by emit-defstruct.
(defn prescan-struct-names:void (forms:ptr)
  (let (fc:ptr forms)
    (while (!= fc null)
      (let (f:ptr:Node (cast ptr:Node ((cast ptr:Node fc) car)))
        (when (and (and (!= (cast ptr f) null) (= (f kind) NODE-CELL))
                   (and (>= (node-len (cast ptr f)) 2)
                        (and (-> f (node-at _ 0) (cast ptr:Node _) (_ kind) (= _ NODE-SYM))
                             (-> f (node-at _ 0) (cast ptr:Node _) (_ s)
                                 (= _ "defstruct")))))
          (let (nn:ptr:Node (cast ptr:Node (node-at (cast ptr f) 1)))
            (when (and (= (nn kind) NODE-SYM)
                       (= (cast ptr (lookup-struct (nn s))) null))
              (register-struct (nn s))))))
      (set! fc ((cast ptr:Node fc) cdr)))))

; Pre-scan a form list and forward-declare all defn signatures in g-globals.
(defn prescan-defn-signatures:void (forms:ptr)
  (let (fc:ptr forms)
    (while (!= fc null)
      (let (f:ptr:Node (cast ptr:Node ((cast ptr:Node fc) car)))
        (when (and (and (!= (cast ptr f) null) (= (f kind) NODE-CELL))
                   (and (>= (node-len (cast ptr f)) 4)
                        (and (-> f (node-at _ 0) (cast ptr:Node _) (_ kind) (= _ NODE-SYM))
                             (-> f (node-at _ 0) (cast ptr:Node _) (_ s) (= _ "defn")))))
          (let (name-node:ptr (node-at (cast ptr f) 1)
                params-node:ptr (node-at (cast ptr f) 2))
            (when (!= (node-is-list params-node) 0)
              ; A `&where` clause marks a bounded-generic template: retain it for
              ; on-demand monomorphization rather than parsing its tyvar types.
              (if (>= (params-where-index params-node) 0)
                (register-generic-defn (cast ptr f) 0)
                (let (fname:ptr null
                      ret:ptr (extract-name-and-type name-node (cast ptr:ptr (addr-of fname))
                                                      ((cast ptr:Node name-node) line)))
                  (when (!= ret null)
                    (let (nparams:i32 (defn-params-count params-node)
                          ptypes:ptr (defn-params-to-types params-node)
                          has-rest:i32 (if (< (defn-params-count params-node)
                                              (node-len params-node)) 1 0))
                      (generic-register-method fname ret ptypes nparams has-rest 0
                                               (cast ptr f))))))))))
      (set! fc ((cast ptr:Node fc) cdr)))
    (finalize-generics)))

(defn emit-def-rmacro:void (call:ptr)
  (let (cc:ptr:Node (cast ptr:Node call))
    (when (!= (node-len cc) 3)
      (die-at (cc line) "def-rmacro: expects (def-rmacro \"prefix\" symbol)"))
    (let (prefix-node:ptr:Node (cast ptr:Node (node-at cc 1))
          sym-node:ptr:Node (cast ptr:Node (node-at cc 2)))
      (when (!= (prefix-node kind) NODE-STR)
        (die-at (prefix-node line) "def-rmacro: prefix must be a string"))
      (when (!= (sym-node kind) NODE-SYM)
        (die-at (sym-node line) "def-rmacro: wrap symbol must be a symbol"))
      (register-rmacro (prefix-node s) (sym-node s)))))

; Emit a list of top-level forms (pre-scan + dispatch loop).
; Used by main and by emit-import for recursive processing.
(defn emit-toplevel-forms:void (forms:ptr)
  (set! g-toplevel-depth (+ g-toplevel-depth 1))
  (prescan-struct-names forms)
  (prescan-protocols forms)
  (prescan-defn-signatures forms)
  (let (fc:ptr forms)
    (while (!= fc null)
      (let (f:ptr:Node (cast ptr:Node ((cast ptr:Node fc) car)))
        (when (or (or (= (cast ptr f) null) (!= (f kind) NODE-CELL))
                (or (= (node-len (cast ptr f)) 0)
                    (-> f (node-at _ 0) (cast ptr:Node _) (_ kind) (!= _ NODE-SYM))))
          (die-at (f line)
                  "top-level form must be a list starting with a symbol"))
        (let (h:ptr (-> f (node-at _ 0) (cast ptr:Node _) (_ s))
              hp:ptr (-> f (node-at _ 0)))
          (case hp
            'defconst
              (emit-defconst (cast ptr f))
            'defenum
              (emit-defenum (cast ptr f))
            'defvar
              ; Globals go to the def-stream rather than the decl-stream
              ; so they appear only in the main module IR. CT and macro
              ; JIT modules pull in g-decl-bufp but not g-def-bufp, and
              ; resolve global references back to the host process via
              ; the dylib generator. Otherwise prelude globals (from node
              ; / arena / intern table) would duplicate across modules.
              (do (set! g-out g-def-stream) (emit-defvar (cast ptr f)))
            'defstruct
              (do (set! g-out g-type-stream) (emit-defstruct (cast ptr f)))
            'defcast
              (emit-defcast (cast ptr f))
            'include
              (do (set! g-out g-decl-stream) (emit-include (cast ptr f)))
            'extern
              (do (set! g-out g-decl-stream) (emit-extern (cast ptr f)))
            'defn
              (do (set! g-out g-def-stream) (emit-defn (cast ptr f)))
            'defprotocol
              ; Registered in prescan-protocols; emits no code.
              0
            'extend
              (emit-extend (cast ptr f))
            'compile-time
              (emit-compile-time (cast ptr f))
            'defmacro
              (emit-defmacro (cast ptr f))
            'def-rmacro
              (emit-def-rmacro (cast ptr f))
            'import
              (emit-import (cast ptr f))
            'declare
              (do (set! g-out g-decl-stream) (emit-nuch-declare-import (cast ptr f)))
            (die-at (f line) (fmt-s "unknown top-level form: %s" h)))))
      (set! fc ((cast ptr:Node fc) cdr))))
  ; A2: type-check generic template bodies against their abstract protocol
  ; interface. Only at the outermost level — every import has now registered its
  ; names/protocols/conformances and g-source-path is back to this unit — and
  ; before the worklist drain, so a body error lands at the defn (ahead of any A1
  ; stamp-time error from instantiation).
  (when (= g-toplevel-depth 1)
    (check-generic-templates))
  ; Emit the bodies of any generic instantiations these forms triggered.
  (drain-mono-worklist)
  (set! g-toplevel-depth (- g-toplevel-depth 1)))

; Check if a path is in a Node-based string list.
(defn import-list-has:i32 (list:ptr path:CStr)
  (let (cur:ptr list)
    (while (!= cur null)
      (let (entry:ptr:Node (cast ptr:Node cur))
        (when (= (entry s) path)
          (return 1))
        (set! cur (entry cdr))))
    (return 0)))

; Push a path onto a Node-based string list, return new head.
; (Returns a fresh non-null cell; spelled :ptr because Node is a prelude type
; and the toplevel signature prescan runs before the prelude import — see
; design/stage10/nullability.md N2 friction notes.)
(defn import-list-push:ptr (list:ptr path:ptr)
  (let (n:ref:Node (new Node))
    (.set! n kind NODE-STR)
    (.set! n line 0)
    (.set! n i (cast i64 0))
    (.set! n s path)
    (.set! n car null)
    (.set! n cdr list)
    (return n)))

; Remove the head of a Node-based string list, return new head.
(defn import-list-pop:ptr (list:ptr)
  (when (= list null) (return null))
  (return ((cast ptr:Node list) cdr)))

; Test whether a file exists by attempting to open it.
(defn file-exists:i32 (path:ptr)
  (let (f:ptr (fopen path "r"))
    (when (= f null) (return 0))
    (fclose f)
    (return 1)))

; Try to find a file by name in the import search path.
; Search order: directory of current source file, lib/ relative to cwd.
(defn try-import-path:ptr (filename:ptr)
  ; Try directory of the current source file
  (let (pathlen:i64 (cast i64 (strlen g-source-path))
        last-slash:i64 (cast i64 -1)
        i:i64 (cast i64 0))
    (while (< i pathlen)
      (when (= (char-at g-source-path i) 47)
        (set! last-slash i))
      (set! i (+ i (cast i64 1))))
    (when (>= last-slash (cast i64 0))
      (let (dir:ptr (strndup g-source-path last-slash)
            candidate:ptr (fmt-2s "%s/%s" dir filename))
        (when (!= (file-exists candidate) 0)
          (return candidate)))))
  ; Try lib/ relative to cwd
  (let (candidate:ptr (fmt-s "lib/%s" filename))
    (when (!= (file-exists candidate) 0)
      (return candidate)))
  ; Try -I include paths
  (let (j:i32 0)
    (while (< j g-num-include-paths)
      (let (candidate:ptr (fmt-2s "%s/%s" (aref (cast ptr:ptr g-include-paths) j) filename))
        (when (!= (file-exists candidate) 0)
          (return candidate)))
      (inc! j)))
  (return null))

; Resolve an import name to a .nuc or .nuch file path.
; Tries .nuc first, then .nuch. Returns null if neither found.
(defn resolve-import:ptr (name:ptr line:i32)
  (let (nuc-path:ptr (try-import-path (fmt-s "%s.nuc" name)))
    (when (!= nuc-path null) (return nuc-path)))
  (let (nuch-path:ptr (try-import-path (fmt-s "%s.nuch" name)))
    (when (!= nuch-path null) (return nuch-path)))
  (return null))

; Import a Nucleus source file. Reads, parses, and processes all top-level
; forms from the imported file into the current compilation.
(defn emit-import:void (form:ptr)
  (let (ff:ptr:Node (cast ptr:Node form))
    (when (!= (node-len form) 2)
      (die-at (ff line) "import: expected (import name)"))
    (let (name-node:ptr:Node (cast ptr:Node (node-at form 1)))
      ; Handle string imports: (import "stdio.h") → C header parsing
      (when (= (name-node kind) NODE-STR)
        (set! g-out g-decl-stream)
        (emit-c-include (name-node s) (ff line))
        (return))
      (when (!= (name-node kind) NODE-SYM)
        (die-at (ff line) "import: name must be a symbol"))
      (let (name:ptr (name-node s)
            path:ptr (resolve-import name (ff line)))
        (when (= path null)
          (die-at (ff line) (fmt-s "import: cannot find '%s'" name)))
        ; Duplicate guard
        (when (!= (import-list-has g-imported path) 0)
          (return))
        ; Cycle detection
        (when (!= (import-list-has g-importing path) 0)
          (die-at (ff line) (fmt-s "import: circular import of '%s'" name)))
        ; Save reader state
        (let (save-src:ptr g-src
              save-pos:i64 g-pos
              save-line:i32 g-line
              save-path:ptr g-source-path
              save-peek:ptr g-peek
              save-peek-valid:i32 g-peek-valid)
          ; Push onto importing stack
          (set! g-importing (import-list-push g-importing path))
          ; Read and parse the imported file
          (let (src:ptr (read-file path))
            (set! g-source-path path)
            (set! g-src src)
            (set! g-pos (cast i64 0))
            (set! g-line 1)
            (set! g-peek-valid 0)
            (let (forms:ptr (desugar (read-program))
                  is-nuch:i32 (str-ends-with path ".nuch"))
              ; Process imported forms
              (if (!= is-nuch 0)
                (emit-nuch-import-forms forms)
                (emit-toplevel-forms forms))
              ; Free imported source buffer
              (free src)))
          ; Pop from importing stack, add to imported set
          (set! g-importing (import-list-pop g-importing))
          (set! g-imported (import-list-push g-imported path))
          ; Restore reader state
          (set! g-source-path save-path)
          (set! g-src save-src)
          (set! g-pos save-pos)
          (set! g-line save-line)
          (set! g-peek save-peek)
          (set! g-peek-valid save-peek-valid))))))

; ============================================================
; .nuch header emission
; ============================================================

(defn emit-nuch-list:void (form:ptr)
  (let (i:i32 0
        n:i32 (node-len form))
    (while (< i n)
      (when (!= i 0) (fputc 32 (cast ptr stdout)))
      (print-node (node-at form i))
      (inc! i))))

(defn emit-nuch-defstruct:void (form:ptr)
  (printf "(defstruct ")
  (let (i:i32 1
        n:i32 (node-len form))
    (while (< i n)
      (when (!= i 1) (fputc 32 (cast ptr stdout)))
      (print-node (node-at form i))
      (inc! i)))
  (printf ")\n"))

(defn emit-nuch-declare:void (form:ptr)
  (printf "(declare ")
  ; index 1 is name:rettype, index 2 is param list
  (print-node (node-at form 1))
  (printf " (")
  (let (params:ptr (node-at form 2)
        i:i32 0
        n:i32 (node-len params))
    (while (< i n)
      (when (!= i 0) (fputc 32 (cast ptr stdout)))
      (print-node (node-at params i))
      (inc! i)))
  (printf "))\n"))

(defn emit-nuch-defconst:void (form:ptr)
  (printf "(defconst ")
  (print-node (node-at form 1))
  (printf " ")
  (print-node (node-at form 2))
  (printf ")\n"))

(defn emit-nuch-defenum:void (form:ptr)
  (printf "(defenum")
  (let (i:i32 1
        n:i32 (node-len form))
    (while (< i n)
      (fputc 32 (cast ptr stdout))
      (print-node (node-at form i))
      (inc! i)))
  (printf ")\n"))

(defn emit-nuch-defmacro:void (form:ptr)
  (print-node form)
  (printf "\n"))

; Export one overloaded method, carrying its mangled symbol explicitly so the
; importer can declare it and register it for dispatch:
;   (defmethod "@area.pCircle" area:i32 ((c (ptr Circle))))
(defn emit-nuch-defmethod:void (form:ptr mangled:ptr)
  (printf "(defmethod \"%s\" " mangled)
  (print-node (node-at form 1))
  (printf " (")
  (let (params:ptr (node-at form 2)
        i:i32 0
        n:i32 (node-len params))
    (while (< i n)
      (when (!= i 0) (fputc 32 (cast ptr stdout)))
      (print-node (node-at params i))
      (inc! i)))
  (printf "))\n"))

; A solitary function exports as a plain (declare ...); an overloaded one
; exports a (defmethod ...) per method so each keeps its distinct symbol. A
; bounded-generic template exports verbatim so importers can monomorphize it.
(defn emit-nuch-defn:void (form:ptr)
  (when (>= (params-where-index (node-at form 2)) 0)
    (print-node form)
    (printf "\n")
    (return))
  (let (mangled:ptr (defn-form-mangled-name form))
    (if (!= mangled null)
      (emit-nuch-defmethod form mangled)
      (emit-nuch-declare form))))

; Protocols and conformances export verbatim — the importer re-registers them
; (and trusts the recorded conformance rather than re-checking).
(defn emit-nuch-defprotocol:void (form:ptr)
  (print-node form)
  (printf "\n"))

(defn emit-nuch-extend:void (form:ptr)
  (printf "(extend ")
  (print-node (node-at form 1))
  (printf " ")
  (print-node (node-at form 2))
  (printf ")\n"))

; Cast rules export verbatim (the conv-fn is exported separately as a declare,
; which must precede this form in the header). The importer re-runs emit-defcast.
(defn emit-nuch-defcast:void (form:ptr)
  (print-node form)
  (printf "\n"))

; A module's top-level globals export as `extern` so importers see the symbol
; without its initializer (the producing module owns the definition). Index 1 is
; the desugared name:type node; any initializer is intentionally dropped.
(defn emit-nuch-extern:void (form:ptr)
  (printf "(extern ")
  (print-node (node-at form 1))
  (printf ")\n"))

(defn emit-nuch-header:void (forms:ptr source-file:ptr)
  ; Populate the registries so overloaded names, mangled symbols, and protocols
  ; are known before emitting declarations.
  (prescan-struct-names forms)
  (prescan-protocols forms)
  (prescan-defn-signatures forms)
  (printf "; .nuch header for %s\n" source-file)
  (let (fc:ptr forms)
    (while (!= fc null)
      (let (f:ptr:Node (cast ptr:Node ((cast ptr:Node fc) car)))
        (when (and (and (!= (cast ptr f) null) (= (f kind) NODE-CELL))
                   (and (> (node-len (cast ptr f)) 0)
                        (-> f (node-at _ 0) (cast ptr:Node _) (_ kind) (= _ NODE-SYM))))
          (let (h:ptr (-> f (node-at _ 0) (cast ptr:Node _) (_ s)))
            (case h
              "defstruct"    (emit-nuch-defstruct (cast ptr f))
              "defn"         (emit-nuch-defn (cast ptr f))
              "defprotocol"  (emit-nuch-defprotocol (cast ptr f))
              "extend"       (emit-nuch-extend (cast ptr f))
              "defcast"      (emit-nuch-defcast (cast ptr f))
              "defvar"       (emit-nuch-extern (cast ptr f))
              "defconst"     (emit-nuch-defconst (cast ptr f))
              "defenum"      (emit-nuch-defenum (cast ptr f))
              "defmacro"     (emit-nuch-defmacro (cast ptr f))
              0))))
      (set! fc ((cast ptr:Node fc) cdr)))))

; ============================================================
; .nuch import processing
; ============================================================

(defn str-ends-with:i32 (s:ptr suffix:CStr)
  (let (slen:i64 (cast i64 (strlen s))
        suflen:i64 (cast i64 (strlen suffix)))
    (when (> suflen slen) (return 0))
    (when (= (ptr+ (cast ptr:i8 s) (- slen suflen)) suffix)
      (return 1))
    (return 0)))

(defn emit-nuch-declare-import:void (form:ptr)
  (let (ff:ptr:Node (cast ptr:Node form))
    (when (or (< (node-len form) 2) (> (node-len form) 3))
      (die-at (ff line) "declare: expected (declare name:rettype (params...))"))
    (let (name-node:ptr (node-at form 1)
          params-node:ptr null)
      (when (= (node-len form) 3)
        (set! params-node (node-at form 2)))
      (let (fname:ptr null
            ret:ptr (extract-name-and-type name-node (cast ptr:ptr (addr-of fname))
                                            ((cast ptr:Node name-node) line)))
        (when (= ret null)
          (die-at ((cast ptr:Node name-node) line) (fmt-s "declare: missing :type on '%s'" fname)))
        ; Skip if already defined (e.g. from include or c-include)
        (when (!= (scope-lookup g-globals fname) null) (return))
        (let (nparams:i32 0
              ptypes:ptr null
              j:i32 0)
          (when (!= params-node null)
            (set! nparams (node-len params-node)))
          (when (> nparams 0)
            (set! ptypes (arena-alloc (* (cast i64 nparams) (ptr-bytes)))))
          (while (< j nparams)
            (let (p:ptr (node-at params-node j)
                  pn:ptr null
                  pty:ptr (extract-name-and-type p (cast ptr:ptr (addr-of pn))
                                                  ((cast ptr:Node p) line)))
              (if (!= pty null)
                (aset! (cast ptr:ptr ptypes) j pty)
                (aset! (cast ptr:ptr ptypes) j ty-i32)))
            (inc! j))
          (let (ft:ptr:Type (cast ptr:Type (make-type TY-FN)))
            (.set! ft ret ret)
            (.set! ft num-params nparams)
            (.set! ft params ptypes)
            (.set! ft variadic 0)
            (scope-define g-globals fname (cast ptr ft)
                          (fmt-s "@%s" fname) 0)
            ; Emit LLVM declare, lowering struct-by-value params/return to the
            ; platform C ABI (sret / byval / register coercion) just like a defn.
            (let (ret-info:ptr:AbiInfo (cast ptr:AbiInfo (abi-classify ret)))
              (fprintf g-out "declare %s @%s(" (abi-ret-ir ret-info ret) fname)
              (let (need-comma:i32 0)
                (when (= ((cast ptr:AbiInfo ret-info) kind) ABI-MEMORY)
                  (fprintf g-out "ptr sret(%s) align %d"
                    (type-to-ir ret) ((cast ptr:AbiInfo ret-info) align))
                  (set! need-comma 1))
                (set! j 0)
                (while (< j nparams)
                  (when (!= need-comma 0) (fprintf g-out ", "))
                  (abi-print-param
                    (abi-classify (aref (cast ptr:ptr ptypes) j))
                    (aref (cast ptr:ptr ptypes) j)
                    null)
                  (set! need-comma 1)
                  (inc! j)))
              (fprintf g-out ")\n"))))))))

; Import one exported overloaded method: register it (with its mangled symbol)
; in the generic registry so calls in the importing unit dispatch to it, and
; emit an LLVM declare under the mangled symbol (resolved at link time).
(defn emit-nuch-defmethod-import:void (form:ptr)
  (let (ff:ptr:Node (cast ptr:Node form))
    (when (!= (node-len form) 4)
      (die-at (ff line) "defmethod: expected (defmethod \"@sym\" name:rettype (params...))"))
    (let (sym-node:ptr:Node (cast ptr:Node (node-at form 1))
          name-node:ptr (node-at form 2)
          params-node:ptr (node-at form 3))
      (when (!= (sym-node kind) NODE-STR)
        (die-at (sym-node line) "defmethod: first element must be the mangled symbol string"))
      (let (mangled:ptr (sym-node s)
            fname:ptr null
            ret:ptr (extract-name-and-type name-node (cast ptr:ptr (addr-of fname))
                                            ((cast ptr:Node name-node) line)))
        (when (= ret null)
          (die-at ((cast ptr:Node name-node) line) "defmethod: missing return type"))
        (let (nparams:i32 (defn-params-count params-node)
              ptypes:ptr (defn-params-to-types params-node)
              has-rest:i32 (if (< (defn-params-count params-node)
                                  (node-len params-node)) 1 0)
              m:ptr (generic-register-method fname ret ptypes nparams has-rest 0 null))
          (.set! (cast ptr:Method m) ir-name mangled)
          (let (g:ptr (generic-lookup fname))
            (.set! (cast ptr:Generic g) mangled 1)
            (.set! (cast ptr:Generic g) finalized 1))
          (fprintf g-out "declare %s %s(" (type-to-ir ret) mangled)
          (let (j:i32 0)
            (while (< j nparams)
              (when (!= j 0) (fprintf g-out ", "))
              (fprintf g-out "%s" (type-to-ir (aref (cast ptr:ptr ptypes) j)))
              (inc! j)))
          (fprintf g-out ")\n"))))))

(defn emit-nuch-import-forms:void (forms:ptr)
  (let (fc:ptr forms)
    (while (!= fc null)
      (let (f:ptr:Node (cast ptr:Node ((cast ptr:Node fc) car)))
        (when (and (and (!= (cast ptr f) null) (= (f kind) NODE-CELL))
                   (and (> (node-len (cast ptr f)) 0)
                        (-> f (node-at _ 0) (cast ptr:Node _) (_ kind) (= _ NODE-SYM))))
          (let (h:ptr (-> f (node-at _ 0) (cast ptr:Node _) (_ s)))
            (case h
              "defstruct"
                (do (set! g-out g-type-stream) (emit-defstruct (cast ptr f)))
              "declare"
                (do (set! g-out g-decl-stream) (emit-nuch-declare-import (cast ptr f)))
              "defmethod"
                (do (set! g-out g-decl-stream) (emit-nuch-defmethod-import (cast ptr f)))
              "defn"
                ; Only bounded-generic templates are exported as whole defns;
                ; register (exporter-verified, so trusted) so calls in this
                ; unit can instantiate them.
                (register-generic-defn (cast ptr f) 1)
              "defprotocol"
                (protocol-register-form (cast ptr f))
              "extend"
                (register-imported-conformance (cast ptr f))
              "defcast"
                (emit-defcast (cast ptr f))
              "extern"
                (do (set! g-out g-decl-stream) (emit-extern (cast ptr f)))
              "defconst"
                (emit-defconst (cast ptr f))
              "defenum"
                (emit-defenum (cast ptr f))
              "defmacro"
                (emit-defmacro (cast ptr f))
              "def-rmacro"
                (emit-def-rmacro (cast ptr f))
              0))))
      (set! fc ((cast ptr:Node fc) cdr))))
  ; Finalize any newly-imported generic templates so their names dispatch
  ; through the registry (imported concrete methods finalize themselves).
  (finalize-generics))

; ============================================================
; Compiler initialization — shared by batch and REPL modes
; ============================================================

(defn register-rmacro:void (prefix:ptr wrap-sym:ptr)
  (let (rm:ptr:RMacro (cast ptr:RMacro (ptr+ (cast ptr:RMacro g-rmacros) g-num-rmacros)))
    (.set! rm prefix prefix)
    (.set! rm prefix-len (cast i32 (strlen prefix)))
    (.set! rm wrap-sym wrap-sym))
  (inc! g-num-rmacros))

(defn init-rmacros:void ()
  (set! g-rmacros (arena-alloc (* (cast i64 64) (sizeof RMacro))))
  ; Register longest prefixes first for correct matching.
  (register-rmacro "~@" "unquote-splice")
  (register-rmacro "~" "unquote")
  (register-rmacro "'" "quote")
  (register-rmacro "`" "quasiquote")
  (register-rmacro "@" "deref"))

; Register the built-in blanket protocols (§10.1). Hardcoded for now; a
; user-declarable blanket facility is parked in design/stage999-future.md.
(defn init-blanket:void ()
  (set! g-blanket (arena-alloc (* (cast i64 8) (ptr-bytes))))
  (aset! (cast ptr:ptr g-blanket) 0 "Any")
  (aset! (cast ptr:ptr g-blanket) 1 "Struct")
  (set! g-num-blanket 2))

; Register the LLVM backends the --target matrix can select (X86 + AArch64 +
; ARM, covering Linux/Darwin/Windows variants). Safe to call repeatedly.
(defn targets-init-all:void ()
  (LLVMInitializeX86TargetInfo)
  (LLVMInitializeX86Target)
  (LLVMInitializeX86TargetMC)
  (LLVMInitializeX86AsmPrinter)
  (LLVMInitializeAArch64TargetInfo)
  (LLVMInitializeAArch64Target)
  (LLVMInitializeAArch64TargetMC)
  (LLVMInitializeAArch64AsmPrinter)
  (LLVMInitializeARMTargetInfo)
  (LLVMInitializeARMTarget)
  (LLVMInitializeARMTargetMC)
  (LLVMInitializeARMAsmPrinter))

; Resolve `triple` to a Target descriptor, pulling the datalayout string and
; pointer size from LLVM so emitted IR matches the target ABI.
(defn make-target-for-triple:ref:Target (triple:ptr)
  (let (target:ptr null
        terr:ptr null
        tres:i32 (LLVMGetTargetFromTriple triple (addr-of target) (addr-of terr)))
    (when (!= tres 0)
      (fprintf stderr "nucleusc: target lookup failed for '%s': %s\n" triple terr)
      (LLVMDisposeMessage terr)
      (exit 1))
    (let (tm:ptr (LLVMCreateTargetMachine target triple "" "" 0 2 0))
      (when (= tm null)
        (fprintf stderr "nucleusc: failed to create TargetMachine for '%s'\n" triple)
        (exit 1))
      (let (td:ptr (LLVMCreateTargetDataLayout tm)
            tgt:ptr:Target (cast ptr:Target (arena-alloc (sizeof Target))))
        (let (dl-str:ptr (LLVMCopyStringRepOfTargetData td)
              psize:i32 (LLVMPointerSize td))
          (.set! tgt triple triple)
          (.set! tgt datalayout dl-str)
          (.set! tgt ptr-size psize)
          (.set! tgt ptr-align psize))
        (LLVMDisposeTargetData td)
        (LLVMDisposeTargetMachine tm)
        (return (cast ref:Target tgt))))))

; Populate g-host-target (always native) and g-target (== host unless
; --target=<triple> overrides). Derives g-target-triple / g-target-ptr-bytes so
; the rest of codegen, which predates the Target struct, sees the right values.
(defn target-init:void ()
  (targets-init-all)
  (let (host-triple:ptr (LLVMGetDefaultTargetTriple))
    (set! g-host-target (make-target-for-triple host-triple))
    (if (= g-target-triple-override null)
      (set! g-target g-host-target)
      (set! g-target (make-target-for-triple g-target-triple-override))))
  (let (tg:ptr:Target (cast ptr:Target g-target)
        hg:ptr:Target (cast ptr:Target g-host-target))
    (set! g-target-triple (tg triple))
    (set! g-target-ptr-bytes (tg ptr-size))
    (set! g-host-ptr-bytes (hg ptr-size))))

(defn compiler-init:void ()
  ; Target descriptor (single source of truth for the "pointer is i64"
  ; assumption). target-init below resolves it from LLVM (host, or --target).
  (set! g-target-triple "x86_64-pc-linux-gnu")
  (set! g-target-ptr-bytes 8)
  ; Host pointer size — actual width of a pointer in this running compiler.
  (set! g-host-ptr-bytes (cast i32 (sizeof ptr)))
  (target-init)
  (types-init)
  (init-binops)
  (init-generics)
  (init-blanket)
  (set! g-mono-worklist (make-vec))
  (init-rmacros)
  (set! g-structs (arena-alloc (* (cast i64 MAX-STRUCTS) (sizeof StructDef))))
  (set! g-macros (arena-alloc (* (cast i64 256) (sizeof MacroDef))))
  (set! g-cast-rules (arena-alloc (* (cast i64 MAX-CAST-RULES) (sizeof CastRule))))
  (set! g-cast-rules-len 0)
  (set! g-globals (scope-new null)))

; ============================================================
; Emit quasiquote helpers (__cons / __append) into the given streams
; ============================================================

; NOTE: the __cons/__append IR templates below assume a 64-bit target Node ABI
; (size 40 = 16 + 3*8, pointer fields at 8-byte alignment). To target a platform
; where g-target-ptr-bytes != 8, these literals (malloc size and the `align 8`
; on the ptr stores) must be derived from g-target-ptr-bytes — pointer fields
; would otherwise be misaligned. Tracked as remaining 32-bit work.
(defn emit-qq-helpers:void (decl:ptr def:ptr)
  (when (= g-malloc-decl-done 0)
    (fprintf decl "declare ptr @malloc(i64)\n"))
  (fprintf def "define ptr @__cons(ptr %%a, ptr %%b) {\n")
  (fprintf def "  %%c = call ptr @malloc(i64 40)\n")
  (fprintf def "  %%p0 = getelementptr inbounds { i32, i32, i64, ptr, ptr, ptr }, ptr %%c, i32 0, i32 0\n")
  (fprintf def "  store i32 3, ptr %%p0, align 8\n")
  (fprintf def "  %%p1 = getelementptr inbounds { i32, i32, i64, ptr, ptr, ptr }, ptr %%c, i32 0, i32 1\n")
  (fprintf def "  store i32 0, ptr %%p1, align 4\n")
  (fprintf def "  %%p2 = getelementptr inbounds { i32, i32, i64, ptr, ptr, ptr }, ptr %%c, i32 0, i32 2\n")
  (fprintf def "  store i64 0, ptr %%p2, align 8\n")
  (fprintf def "  %%p3 = getelementptr inbounds { i32, i32, i64, ptr, ptr, ptr }, ptr %%c, i32 0, i32 3\n")
  (fprintf def "  store ptr null, ptr %%p3, align 8\n")
  (fprintf def "  %%p4 = getelementptr inbounds { i32, i32, i64, ptr, ptr, ptr }, ptr %%c, i32 0, i32 4\n")
  (fprintf def "  store ptr %%a, ptr %%p4, align 8\n")
  (fprintf def "  %%p5 = getelementptr inbounds { i32, i32, i64, ptr, ptr, ptr }, ptr %%c, i32 0, i32 5\n")
  (fprintf def "  store ptr %%b, ptr %%p5, align 8\n")
  (fprintf def "  ret ptr %%c\n")
  (fprintf def "}\n\n")
  (fprintf def "define ptr @__append(ptr %%a, ptr %%b) {\n")
  (fprintf def "entry:\n")
  (fprintf def "  %%z = icmp eq ptr %%a, null\n")
  (fprintf def "  br i1 %%z, label %%nil, label %%rec\n")
  (fprintf def "nil:\n")
  (fprintf def "  ret ptr %%b\n")
  (fprintf def "rec:\n")
  (fprintf def "  %%p4 = getelementptr inbounds { i32, i32, i64, ptr, ptr, ptr }, ptr %%a, i32 0, i32 4\n")
  (fprintf def "  %%car = load ptr, ptr %%p4, align 8\n")
  (fprintf def "  %%p5 = getelementptr inbounds { i32, i32, i64, ptr, ptr, ptr }, ptr %%a, i32 0, i32 5\n")
  (fprintf def "  %%cdr = load ptr, ptr %%p5, align 8\n")
  (fprintf def "  %%rest = call ptr @__append(ptr %%cdr, ptr %%b)\n")
  (fprintf def "  %%c = call ptr @__cons(ptr %%car, ptr %%rest)\n")
  (fprintf def "  ret ptr %%c\n")
  (fprintf def "}\n\n"))

; ============================================================
; Open fresh memstreams for a compilation unit
; ============================================================

(defn open-module-streams:void ()
  (set! g-type-stream (open_memstream (addr-of g-type-bufp) (cast ptr (addr-of g-type-sizep))))
  (set! g-decl-stream (open_memstream (addr-of g-decl-bufp) (cast ptr (addr-of g-decl-sizep))))
  (set! g-def-stream  (open_memstream (addr-of g-def-bufp)  (cast ptr (addr-of g-def-sizep))))
  (set! g-decl-out g-decl-stream))

; ============================================================
; Close module streams, output IR to stdout (batch mode)
; ============================================================

; Assemble the full module IR into a heap-allocated buffer. Caller must free
; the returned pointer (g-type-bufp/g-decl-bufp/g-def-bufp are also freed).
; Stores the buffer length through `len-out` (pointer to i64).
(defn assemble-module-ir:ptr (source-file:ptr len-out:ptr)
  (let (ir-bufp:ptr null  ir-sizep:i64 (cast i64 0)
        irs:ptr (open_memstream (addr-of ir-bufp) (cast ptr (addr-of ir-sizep))))
    (fprintf irs "; ModuleID = '%s'\n" source-file)
    (fprintf irs "source_filename = \"%s\"\n" source-file)
    (fprintf irs "target datalayout = \"%s\"\n" ((cast ptr:Target g-target) datalayout))
    (fprintf irs "target triple = \"%s\"\n\n" g-target-triple)
    (when (and (!= g-type-bufp null) (!= (char-at g-type-bufp (cast i64 0)) 0))
      (fputs g-type-bufp irs))
    (emit-string-table irs)
    (when (and (!= g-decl-bufp null) (!= (char-at g-decl-bufp (cast i64 0)) 0))
      (fputs g-decl-bufp irs))
    (when (and (!= g-def-bufp null) (!= (char-at g-def-bufp (cast i64 0)) 0))
      (fputs g-def-bufp irs))
    (fclose irs)
    (free g-type-bufp)
    (free g-decl-bufp)
    (free g-def-bufp)
    (aset! (cast ptr:i64 len-out) 0 ir-sizep)
    (return ir-bufp)))

; Parse the in-memory IR, emit an object file, and (unless -c) invoke clang
; to link a final binary. Exits with a non-zero status on failure.
(defn compile-and-link:void (ir:ptr ir-len:i64 source-file:ptr)
  ; Initialize the x86 target — same set as the JIT path.
  (LLVMInitializeX86TargetInfo)
  (LLVMInitializeX86Target)
  (LLVMInitializeX86TargetMC)
  (LLVMInitializeX86AsmPrinter)

  (let (ctx:ptr (LLVMContextCreate)
        mb:ptr  (LLVMCreateMemoryBufferWithMemoryRangeCopy ir ir-len source-file)
        mod:ptr null
        parse-err:ptr null
        rc:i32 (LLVMParseIRInContext ctx mb (addr-of mod) (addr-of parse-err)))
    (when (!= rc 0)
      (fprintf stderr "nucleusc: failed to parse generated IR: %s\n" parse-err)
      (LLVMDisposeMessage parse-err)
      (exit 1))

    (let (target:ptr null
          terr:ptr null
          tres:i32 (LLVMGetTargetFromTriple g-target-triple (addr-of target) (addr-of terr)))
      (when (!= tres 0)
        (fprintf stderr "nucleusc: target lookup failed: %s\n" terr)
        (LLVMDisposeMessage terr)
        (exit 1))
      ; CodeGenLevel = Default(2), Reloc = PIC(2), CodeModel = Default(0)
      (let (tm:ptr (LLVMCreateTargetMachine target g-target-triple "" "" g-opt-level 2 0))
        (let (out-path:ptr g-output-path
              obj-path:ptr null
              keep-obj:i32 g-emit-obj)
          (when (= out-path null)
            (set! out-path (if (!= g-emit-obj 0) "out.o" "a.out")))
          (if (!= g-emit-obj 0)
            (set! obj-path out-path)
            (set! obj-path (fmt-s "%s.o" out-path)))
          (let (emit-err:ptr null
                eres:i32 (LLVMTargetMachineEmitToFile tm mod obj-path 1 (addr-of emit-err)))
            (when (!= eres 0)
              (fprintf stderr "nucleusc: failed to emit object file '%s': %s\n"
                obj-path emit-err)
              (LLVMDisposeMessage emit-err)
              (exit 1)))
          (LLVMDisposeTargetMachine tm)
          (when (= keep-obj 0)
            ; Build a clang command: clang <obj> -o <out> [link-args...]
            (let (cmd-bufp:ptr null  cmd-sizep:i64 (cast i64 0)
                  cmds:ptr (open_memstream (addr-of cmd-bufp) (cast ptr (addr-of cmd-sizep))))
              (fprintf cmds "clang %s -o %s" obj-path out-path)
              (let (j:i32 0)
                (while (< j g-num-link-args)
                  (fprintf cmds " %s" (aref (cast ptr:ptr g-link-args) j))
                  (inc! j)))
              (fclose cmds)
              (let (rc2:i32 (system cmd-bufp))
                (free cmd-bufp)
                (when (!= rc2 0)
                  (fprintf stderr "nucleusc: link step failed (clang exit %d)\n" rc2)
                  (exit 1))))
            (unlink obj-path)))))))

; Close module streams; emit either textual IR (--emit-llvm) or an object/binary.
(defn flush-module-ir:void (source-file:ptr)
  (when (!= g-qq-used 0)
    (emit-qq-helpers g-decl-stream g-def-stream))
  (fclose g-type-stream)
  (fclose g-decl-stream)
  (fclose g-def-stream)
  (let (ir-len:i64 (cast i64 0)
        ir:ptr (assemble-module-ir source-file (cast ptr (addr-of ir-len))))
    (if (!= g-emit-llvm 0)
      (do
        (fputs ir (cast ptr stdout))
        (free ir))
      (do
        (compile-and-link ir ir-len source-file)
        (free ir)))))


; ============================================================
; Main entry point
; ============================================================

; Detect a leading (exclude-prelude) directive in the parsed form list.
; If present, returns the rest of the forms (with the directive consumed).
; If absent, returns null to signal "auto-prepend prelude".
;
; The directive must be the first form in the file. It takes no arguments;
; presence anywhere else is treated as a normal (and unknown) top-level form.
(defn strip-exclude-prelude:ptr (forms:ptr)
  (when (= forms null) (return null))
  (let (first:ptr ((cast ptr:Node forms) car))
    (when (= first null) (return null))
    (when (!= ((cast ptr:Node first) kind) NODE-CELL) (return null))
    (when (!= (node-len first) 1) (return null))
    (let (head:ptr (node-at first 0))
      (when (= head null) (return null))
      (when (!= ((cast ptr:Node head) kind) NODE-SYM) (return null))
      (when (!= ((cast ptr:Node head) s) "exclude-prelude")
        (return null))
      (return ((cast ptr:Node forms) cdr)))))

; Prepend a synthetic (import prelude) cell onto the given forms list.
(defn prepend-prelude-import:ptr (forms:ptr)
  (let (import-sym:ptr (intern-symbol "import")
        name-sym:ptr   (intern-symbol "prelude")
        name-cell:ptr  (make-cell name-sym null 0)
        import-form:ptr (make-cell import-sym name-cell 0))
    (return (make-cell import-form forms 0))))

(defn add-include-path:void (path:ptr)
  (when (= g-include-paths null)
    (set! g-include-paths (malloc (* (cast i64 64) (ptr-bytes)))))
  (aset! (cast ptr:ptr g-include-paths) g-num-include-paths path)
  (inc! g-num-include-paths))

(defn add-link-arg:void (arg:ptr)
  (when (= g-link-args null)
    (set! g-link-args (malloc (* (cast i64 64) (ptr-bytes)))))
  (aset! (cast ptr:ptr g-link-args) g-num-link-args arg)
  (inc! g-num-link-args))

(defn main:int (argc:i32 argv:ptr)
  (let (source-file:ptr null
        i:i32 1)
    (while (< i argc)
      (let (arg:ptr (aref (cast ptr:ptr argv) i))
        (cond (= arg "--emit-nuch")
                (set! g-emit-nuch 1)
              (= arg "--emit-cheader")
                (set! g-emit-cheader 1)
              (or (= arg "--emit-llvm") (= arg "-S"))
                (set! g-emit-llvm 1)
              (= arg "-c")
                (set! g-emit-obj 1)
              (= arg "-o")
                (do (inc! i)
                    (when (>= i argc)
                      (do (fprintf stderr "-o requires an argument\n") (return 2)))
                    (set! g-output-path (aref (cast ptr:ptr argv) i)))
              (or (= arg "-i") (= arg "--interactive"))
                (set! g-interactive 1)
              (= arg "--repl-format=text")
                (set! g-repl-format 0)
              (= arg "--repl-format=json")
                (set! g-repl-format 1)
              (= arg "-O0")
                (set! g-opt-level 0)
              (= arg "-O1")
                (set! g-opt-level 1)
              (or (= arg "-O") (= arg "-O2"))
                (set! g-opt-level 2)
              (= arg "-O3")
                (set! g-opt-level 3)
              (= (strncmp arg "--target=" (cast i64 9)) 0)
                (set! g-target-triple-override (ptr+ (cast ptr:i8 arg) (cast i64 9)))
              (= (strncmp arg "-I" (cast i64 2)) 0)
                (if (> (cast i64 (strlen arg)) (cast i64 2))
                  ; -I/path/to/dir (no space)
                  (add-include-path (ptr+ (cast ptr:i8 arg) (cast i64 2)))
                  ; -I /path/to/dir (next arg)
                  (do (inc! i)
                      (when (>= i argc)
                        (do (fprintf stderr "-I requires an argument\n") (return 2)))
                      (add-include-path (aref (cast ptr:ptr argv) i))))
              (or (= (strncmp arg "-l" (cast i64 2)) 0)
                  (= (strncmp arg "-L" (cast i64 2)) 0))
                (add-link-arg arg)
              (= (char-at arg (cast i64 0)) 45)
                (do (fprintf stderr "unknown flag: %s\n" arg) (return 2))
              true
                (if (= source-file null)
                  (set! source-file arg)
                  (do (fprintf stderr "unexpected argument: %s\n" arg) (return 2)))))
      (inc! i))

    ; REPL mode
    (when (!= g-interactive 0)
       (repl-main) (return 0))

    ; Batch mode — require source file
    (when (= source-file null)
       (fprintf stderr "usage: nucleusc [--emit-llvm|-S] [-c] [-O0|-O1|-O2|-O3] [-o <path>] [-l<lib>] [-L<dir>] [--emit-nuch] [--emit-cheader] [-i] [--repl-format=text|json] [-I<path>] <file.nuc>\n") (return 2))
    (set! g-source-path source-file)
    (let (src:ptr (read-file source-file))
      (compiler-init)

      ; Lex/parse
      (set! g-src src)
      (set! g-pos (cast i64 0))
      (set! g-line 1)

      (let (forms:ptr (desugar (read-program)))

        ; Apply the standard prelude unless the source begins with
        ; (exclude-prelude). Skipped for header-emit modes, which only need
        ; declarations from the user's source.
        (when (and (= g-emit-nuch 0) (= g-emit-cheader 0))
          (let (after:ptr (strip-exclude-prelude forms))
            (if (!= after null)
              (set! forms after)
              (set! forms (prepend-prelude-import forms)))))

        ; .nuch header mode — emit declarations and exit
        (when (!= g-emit-nuch 0)
           (emit-nuch-header forms source-file)
              (return 0))

        ; C header mode — emit C declarations and exit
        (when (!= g-emit-cheader 0)
           (emit-cheader-header forms source-file)
              (return 0))

        ; Open module streams and compile
        (open-module-streams)
        (emit-toplevel-forms forms)
        (flush-module-ir source-file)))
    (return 0)))
