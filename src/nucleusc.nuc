; Nucleus self-hosted compiler — direct port of nucleusc.c
; Reads a .nuc source file and emits textual LLVM IR to stdout.

(include stdio)
(include string)
(include ctype)
(include unistd)
(import llvm)
(import repl)

(import cparse-ffi)

(extern stderr:ptr)
(extern stdout:ptr)
(extern stdin:ptr)

; ============================================================
; Constants
; ============================================================

(defconst ARENA-SIZE 16777216)
(defconst MAX-STRUCTS 64)

; Token kinds
(defenum TokKind TOK-LPAREN TOK-RPAREN TOK-RMACRO TOK-INT TOK-STRING TOK-SYMBOL TOK-EOF)

; Node kinds
(defenum NodeKind NODE-INT NODE-STR NODE-SYM NODE-CELL)

; Type kinds
(defenum TypeKind TY-VOID TY-I1 TY-I8 TY-I16 TY-I32 TY-I64
                  TY-UI8 TY-UI16 TY-UI32 TY-UI64
                  TY-PTR TY-FN TY-STRUCT)

; ============================================================
; Struct definitions (ordered by dependency)
; ============================================================

(defstruct StructDef
  name:ptr
  field-names:ptr
  field-types:ptr
  num-fields:i32)

(defstruct Type
  kind:i32
  ret:ptr
  params:ptr
  num-params:i32
  variadic:i32
  elem:ptr
  sdef:ptr)

(defstruct Tok
  kind:i32
  line:i32
  i:i64
  s:ptr)

(defstruct Node
  kind:i32
  line:i32
  i:i64
  s:ptr
  car:ptr
  cdr:ptr)

(defstruct Sym
  name:ptr
  type:ptr
  ir-name:ptr
  is-local:i32
  is-const:i32
  const-val:ptr)

(defstruct Scope
  parent:ptr
  syms:ptr
  len:i32
  cap:i32)

(defstruct StrLit
  bytes:ptr
  len:i32
  id:i32)

(defstruct Val
  type:ptr
  val:ptr)

(defstruct BinOp
  name:ptr
  instr:ptr
  instr-u:ptr
  is-cmp:i32)

(defstruct LibcDecl
  module:ptr
  name:ptr
  ret-kind:i32
  p0:i32
  p1:i32
  p2:i32
  p3:i32
  num-params:i32
  variadic:i32)

(defstruct Vec
  data:ptr
  len:i32
  cap:i32)

(defstruct MacroDef
  name:ptr
  jit-name:ptr
  num-params:i32
  variadic:i32)

(defstruct RMacro
  prefix:ptr
  prefix-len:i32
  wrap-sym:ptr)

; ============================================================
; Standard macros — imported from lib/macros.nuc.
;
; This import is placed BEFORE the defvar section intentionally.
; defvar forms emit global-variable definitions to g-decl-stream.  When a
; defmacro is processed, emit-defmacro includes g-decl-bufp in the JIT module.
; If global-variable *definitions* were already in g-decl-bufp they would
; conflict with the running process's own globals.  By placing defmacros
; before any defvar the g-decl-bufp at macro-definition time contains only
; function declarations (from the includes above), which are safe to repeat.
; ============================================================

(import macros)

; ============================================================
; Global variables
; ============================================================

(defvar g-arena:ptr)
(defvar g-arena-used:i64 0)
(defvar g-arena-cap:i64 0)

(defvar g-source-path:ptr)

(defvar g-src:ptr)
(defvar g-pos:i64 0)
(defvar g-line:i32 1)

(defvar g-peek:ptr)
(defvar g-peek-valid:i32 0)

; Singleton types
(defvar ty-void:ptr)
(defvar ty-i1:ptr)
(defvar ty-i8:ptr)
(defvar ty-i16:ptr)
(defvar ty-i32:ptr)
(defvar ty-i64:ptr)
(defvar ty-ptr:ptr)
(defvar ty-ui8:ptr)
(defvar ty-ui16:ptr)
(defvar ty-ui32:ptr)
(defvar ty-ui64:ptr)

; Struct registry
(defvar g-structs:ptr)
(defvar g-structs-len:i32 0)

; Global scope
(defvar g-globals:ptr)

; String literal table
(defvar g-strs:ptr)
(defvar g-strs-len:i32 0)
(defvar g-strs-cap:i32 0)

; Per-function codegen state
(defvar g-tmp:i32 0)
(defvar g-label:i32 0)
(defvar g-entry-stream:ptr)
(defvar g-entry-bufp:ptr)
(defvar g-entry-sizep:i64 0)
(defvar g-body-stream:ptr)
(defvar g-body-bufp:ptr)
(defvar g-body-sizep:i64 0)
(defvar g-block-term:i32 0)

; Current output stream for top-level emission
(defvar g-out:ptr)
(defvar g-decl-out:ptr)
(defvar g-quote-id:i32 0)
(defvar g-qq-used:i32 0)

; Main module streams (global so emit-compile-time can access them mid-compilation)
(defvar g-type-stream:ptr)
(defvar g-decl-stream:ptr)
(defvar g-def-stream:ptr)
(defvar g-type-bufp:ptr)
(defvar g-decl-bufp:ptr)
(defvar g-def-bufp:ptr)
(defvar g-type-sizep:i64 0)
(defvar g-decl-sizep:i64 0)
(defvar g-def-sizep:i64 0)

; JIT state
(defvar g-jit:ptr)
(defvar g-jit-dylib:ptr)
(defvar g-ct-id:i32 0)

; BinOp table
(defvar g-binops:ptr)
(defvar g-num-binops:i32 0)

; LibcDecl table
(defvar g-libc:ptr)
(defvar g-num-libc:i32 0)

; Macro registry
(defvar g-macros:ptr)
(defvar g-num-macros:i32 0)
(defvar g-gensym-id:i32 0)

; Reader macro table
(defvar g-rmacros:ptr)
(defvar g-num-rmacros:i32 0)

; Set to 1 once @malloc has been declared via emit-include (e.g. from (include stdlib)).
; Guards against emitting a duplicate malloc declaration in macro JIT modules.
(defvar g-malloc-decl-done:i32 0)

; Compiler mode flags.
(defvar g-emit-nuch:i32 0)    ; when 1, output .nuch header instead of LLVM IR
(defvar g-emit-cheader:i32 0) ; when 1, output C header instead of LLVM IR
(defvar g-interactive:i32 0)  ; when 1, run in REPL mode (-i / --interactive)

; REPL eval counter (for unique __repl_eval_N symbols).
(defvar g-repl-id:i32 0)

; REPL declarations preamble — accumulated declarations and type defs
; that get prepended to each JIT module.
(defvar g-repl-preamble:ptr)
(defvar g-repl-preamble-bufp:ptr)
(defvar g-repl-preamble-sizep:i64 0)

; Import tracking — duplicate guard and cycle detection.
; Each is a linked list of (path-string . next) pairs using Node cells.
(defvar g-imported:ptr)     ; already-imported resolved paths (null = empty)
(defvar g-importing:ptr)   ; currently-importing stack for cycle detection (null = empty)

; Include path list for -I flag
(defvar g-include-paths:ptr)
(defvar g-num-include-paths:i32 0)

; stdlib (malloc/free/exit) is included here — after defmacro and defvar —
; so that g-decl-bufp is free of malloc when macro JIT modules are assembled.
(include stdlib)

; ============================================================
; Arena allocator — imported from lib/arena.nuc
; ============================================================

(import arena)

; ============================================================
; Formatting helpers — imported from lib/format.nuc
; ============================================================

(import format)

; ============================================================
; Node utilities — imported from lib/node.nuc
; ============================================================

(import node)

; ============================================================
; Allocation helpers
; ============================================================

(defn alloc-tok:ptr ()
  (return (arena-alloc (sizeof Tok))))

(defn nucleus_gensym:ptr ()
  (let (id:i32 g-gensym-id)
    (inc! g-gensym-id)
    (let (buf:ptr (malloc (cast i64 32))
          n:*Node (cast *Node (malloc (cast i64 (sizeof Node)))))
      (snprintf buf (cast i64 32) "__gs_%d" id)
      (memset (cast ptr n) 0 (cast i64 (sizeof Node)))
      (.set! n kind (cast i32 NODE-SYM))
      (.set! n s buf)
      (return (cast ptr n)))))

(defn alloc-type:ptr ()
  (let (t:ptr (arena-alloc (sizeof Type)))
    (return t)))

(defn alloc-val:ptr (ty:ptr v:ptr)
  (let (r:ptr (arena-alloc (sizeof Val)))
    (.set! (cast *Val r) type ty)
    (.set! (cast *Val r) val v)
    (return r)))

; ============================================================
; Growable pointer vector
; ============================================================

(defn make-vec:ptr ()
  (return (arena-alloc (sizeof Vec))))

(defn vec-push:void (v:ptr item:ptr)
  (let (vv:*Vec (cast *Vec v))
    (when (= (. vv len) (. vv cap))
      (let (nc:i32 4)
        (when (!= (. vv cap) 0) (set! nc (* (. vv cap) 2)))
        (let (nd:ptr (arena-alloc (* (i64 nc) (i64 8))))
          (when (!= (. vv len) 0)
            (memcpy nd (. vv data) (* (i64 (. vv len)) (i64 8))))
          (.set! vv data nd)
          (.set! vv cap nc))))
    (aset! (cast *ptr (. vv data)) (. vv len) item)
    (.set! vv len (+ (. vv len) 1))))

; ============================================================
; Reader — imported from lib/reader.nuc
; ============================================================

(import reader)

; ============================================================
; AST printer — inverse of the reader, serializes nodes to stdout
; ============================================================

(defn print-node:void (n:ptr)
  (when (= n null) (do (printf "()") (return)))
  (let (nn:*Node (cast *Node n))
    (when (= (. nn kind) NODE-INT)
      (do (printf "%ld" (. nn i)) (return)))
    (when (= (. nn kind) NODE-SYM)
      (do (fputs (. nn s) (cast ptr stdout)) (return)))
    (when (= (. nn kind) NODE-STR)
      (do
        (fputc 34 (cast ptr stdout))
        (let (s:ptr (. nn s)
              i:i64 (cast i64 0)
              len:i64 (strlen s))
          (while (< i len)
            (let (c:i32 (char-at s i))
              (cond (= c 10) (do (fputc 92 (cast ptr stdout)) (fputc 110 (cast ptr stdout)))
                    (= c 9)  (do (fputc 92 (cast ptr stdout)) (fputc 116 (cast ptr stdout)))
                    (= c 13) (do (fputc 92 (cast ptr stdout)) (fputc 114 (cast ptr stdout)))
                    (= c 92) (do (fputc 92 (cast ptr stdout)) (fputc 92 (cast ptr stdout)))
                    (= c 34) (do (fputc 92 (cast ptr stdout)) (fputc 34 (cast ptr stdout)))
                    (= c 0)  (do (fputc 92 (cast ptr stdout)) (fputc 48 (cast ptr stdout)))
                    true     (fputc c (cast ptr stdout))))
            (set! i (+ i (cast i64 1)))))
        (fputc 34 (cast ptr stdout))
        (return)))
    (when (= (. nn kind) NODE-CELL)
      (do
        (fputc 40 (cast ptr stdout))
        (let (cur:ptr n
              first:i32 1)
          (while (and (!= cur null)
                      (= (. (cast *Node cur) kind) NODE-CELL))
            (when (= first 0) (fputc 32 (cast ptr stdout)))
            (set! first 0)
            (print-node (. (cast *Node cur) car))
            (set! cur (. (cast *Node cur) cdr))))
        (fputc 41 (cast ptr stdout))
        (return)))))

; ============================================================
; Types
; ============================================================

(defn make-type:ptr (k:i32)
  (let (t:*Type (cast *Type (alloc-type)))
    (.set! t kind k)
    (return (cast ptr t))))

(defn types-init:void ()
  (set! ty-void (make-type TY-VOID))
  (set! ty-i1   (make-type TY-I1))
  (set! ty-i8   (make-type TY-I8))
  (set! ty-i16  (make-type TY-I16))
  (set! ty-i32  (make-type TY-I32))
  (set! ty-i64  (make-type TY-I64))
  (set! ty-ui8  (make-type TY-UI8))
  (set! ty-ui16 (make-type TY-UI16))
  (set! ty-ui32 (make-type TY-UI32))
  (set! ty-ui64 (make-type TY-UI64))
  (set! ty-ptr  (make-type TY-PTR)))

(defn type-to-ir:ptr (t:ptr)
  (let (tt:*Type (cast *Type t))
    (when (= (. tt kind) TY-VOID)   (return "void"))
    (when (= (. tt kind) TY-I1)     (return "i1"))
    (when (= (. tt kind) TY-I8)     (return "i8"))
    (when (= (. tt kind) TY-I16)    (return "i16"))
    (when (= (. tt kind) TY-I32)    (return "i32"))
    (when (= (. tt kind) TY-I64)    (return "i64"))
    (when (= (. tt kind) TY-UI8)    (return "i8"))
    (when (= (. tt kind) TY-UI16)   (return "i16"))
    (when (= (. tt kind) TY-UI32)   (return "i32"))
    (when (= (. tt kind) TY-UI64)   (return "i64"))
    (when (= (. tt kind) TY-PTR)    (return "ptr"))
    (when (= (. tt kind) TY-FN)     (return "ptr"))
    (when (= (. tt kind) TY-STRUCT)
      (return (fmt-s "%%%s" (. (cast *StructDef (. tt sdef)) name))))
    (return "?")))

; Map a Nucleus type to its C representation string.
; For function pointer types, returns a simplified "void*" — the full
; C function pointer syntax (with return type and params) is handled
; separately in emit-cheader-declare where we have the param names.
(defn type-to-c:ptr (t:ptr)
  (let (tt:*Type (cast *Type t))
    (when (= (. tt kind) TY-VOID)   (return "void"))
    (when (= (. tt kind) TY-I1)     (return "_Bool"))
    (when (= (. tt kind) TY-I8)     (return "int8_t"))
    (when (= (. tt kind) TY-I16)    (return "int16_t"))
    (when (= (. tt kind) TY-I32)    (return "int32_t"))
    (when (= (. tt kind) TY-I64)    (return "int64_t"))
    (when (= (. tt kind) TY-UI8)    (return "uint8_t"))
    (when (= (. tt kind) TY-UI16)   (return "uint16_t"))
    (when (= (. tt kind) TY-UI32)   (return "uint32_t"))
    (when (= (. tt kind) TY-UI64)   (return "uint64_t"))
    (when (= (. tt kind) TY-PTR)    (return "void*"))
    (when (= (. tt kind) TY-FN)     (return "void*"))
    (when (= (. tt kind) TY-STRUCT)
      (return (fmt-s "struct %s" (. (cast *StructDef (. tt sdef)) name))))
    (return "/* unknown */")))

(defn type-size:i32 (t:ptr)
  (let (tt:*Type (cast *Type t))
    (when (= (. tt kind) TY-I1)   (return 1))
    (when (= (. tt kind) TY-I8)   (return 1))
    (when (= (. tt kind) TY-I16)  (return 2))
    (when (= (. tt kind) TY-I32)  (return 4))
    (when (= (. tt kind) TY-I64)  (return 8))
    (when (= (. tt kind) TY-UI8)  (return 1))
    (when (= (. tt kind) TY-UI16) (return 2))
    (when (= (. tt kind) TY-UI32) (return 4))
    (when (= (. tt kind) TY-UI64) (return 8))
    (when (= (. tt kind) TY-PTR)  (return 8))
    (when (= (. tt kind) TY-STRUCT) (return 8))
    (return 1)))

(defn is-int-type:i32 (t:ptr)
  (let (k:i32 (. (cast *Type t) kind))
    (when (= k TY-I1) (return 1))
    (when (= k TY-I8) (return 1))
    (when (= k TY-I16) (return 1))
    (when (= k TY-I32) (return 1))
    (when (= k TY-I64) (return 1))
    (when (= k TY-UI8) (return 1))
    (when (= k TY-UI16) (return 1))
    (when (= k TY-UI32) (return 1))
    (when (= k TY-UI64) (return 1))
    (return 0)))

(defn int-width:i32 (t:ptr)
  (let (k:i32 (. (cast *Type t) kind))
    (when (= k TY-I1) (return 1))
    (when (= k TY-I8) (return 8))
    (when (= k TY-I16) (return 16))
    (when (= k TY-I32) (return 32))
    (when (= k TY-I64) (return 64))
    (when (= k TY-UI8) (return 8))
    (when (= k TY-UI16) (return 16))
    (when (= k TY-UI32) (return 32))
    (when (= k TY-UI64) (return 64))
    (return 0)))

(defn is-unsigned:i32 (t:ptr)
  (let (k:i32 (. (cast *Type t) kind))
    (when (= k TY-UI8) (return 1))
    (when (= k TY-UI16) (return 1))
    (when (= k TY-UI32) (return 1))
    (when (= k TY-UI64) (return 1))
    (return 0)))

; Try to coerce a value to a target type. Returns a Val* or null on failure.
; Handles: same kind (identity), int-to-int (trunc/sext/zext), same-width sign change.
(defn coerce-int-val:ptr (v:ptr target:ptr line:i32)
  (let (vv:*Val (cast *Val v)
        src:ptr (. vv type)
        sk:i32 (-> src (cast *Type _) (. kind))
        dk:i32 (-> target (cast *Type _) (. kind)))
    ; Same kind — identity
    (when (= sk dk) (return v))
    ; Both integers — emit cast if needed
    (when (and (!= (is-int-type src) 0) (!= (is-int-type target) 0))
      (let (sw:i32 (int-width src) dw:i32 (int-width target))
        (when (= sw dw)
          ; Same width, different signedness — reinterpret (no IR needed)
          (return (alloc-val target (. vv val))))
        (let (tmp:ptr (new-tmp)
              instr:ptr null)
          (if (< dw sw)
            (set! instr "trunc")
            (if (!= (is-unsigned src) 0)
              (set! instr "zext")
              (set! instr "sext")))
          (fprintf g-body-stream "  %s = %s %s %s to %s\n"
            tmp instr (type-to-ir src) (. vv val) (type-to-ir target))
          (return (alloc-val target tmp)))))
    ; Not compatible
    (return null)))

(defn register-struct:ptr (name:ptr)
  (when (>= g-structs-len MAX-STRUCTS)
    (do (fprintf stderr "nucleusc: too many structs\n") (exit 1)))
  (let (sd:*StructDef (cast *StructDef (ptr+ (cast *StructDef g-structs) g-structs-len)))
    (.set! sd name name)
    (inc! g-structs-len)
    (return (cast ptr sd))))

(defn lookup-struct:ptr (name:ptr)
  (let (i:i32 0)
    (while (< i g-structs-len)
      (let (sd:*StructDef (cast *StructDef (ptr+ (cast *StructDef g-structs) i)))
        (when (= (strcmp (. sd name) name) 0)
          (return (cast ptr sd))))
      (inc! i)))
  (return null))

(defn parse-type-name:ptr (name:ptr line:i32)
  (when (= (char-at name (cast i64 0)) 42)
    (let (inner:ptr (parse-type-name (ptr+ (cast *i8 name) (cast i64 1)) line)
          p:*Type (cast *Type (make-type TY-PTR)))
      (.set! p elem inner)
      (return (cast ptr p))))
  (when (= (strcmp name "int")  0) (return ty-i32))
  (when (= (strcmp name "i1")   0) (return ty-i1))
  (when (= (strcmp name "i8")   0) (return ty-i8))
  (when (= (strcmp name "i16")  0) (return ty-i16))
  (when (= (strcmp name "i32")  0) (return ty-i32))
  (when (= (strcmp name "i64")  0) (return ty-i64))
  (when (= (strcmp name "bool") 0) (return ty-i1))
  (when (= (strcmp name "ptr")  0) (return ty-ptr))
  (when (= (strcmp name "void") 0) (return ty-void))
  (when (= (strcmp name "ui8")  0) (return ty-ui8))
  (when (= (strcmp name "ui16") 0) (return ty-ui16))
  (when (= (strcmp name "ui32") 0) (return ty-ui32))
  (when (= (strcmp name "ui64") 0) (return ty-ui64))
  (let (sd:ptr (lookup-struct name))
    (when (!= sd null)
      (let (t:*Type (cast *Type (make-type TY-STRUCT)))
        (.set! t sdef sd)
        (return (cast ptr t)))))
  (die-at line (fmt-s "unknown type: %s" name)))

; Parse a type from an AST node. Handles:
;   - symbol node: delegates to parse-type-name
;   - list node ((fn ret-type) (param-types...)) or (fn ret-type): builds TY-FN
(defn parse-type-from-node:ptr (node:ptr line:i32)
  (let (n:*Node (cast *Node node))
    (when (= (. n kind) NODE-SYM)
      (return (parse-type-name (. n s) line)))
    (when (= (. n kind) NODE-CELL)
      ; Check for function pointer type: ((fn ret) (param-types...))
      (let (head:ptr (. n car))
        (when (!= head null)
         (do
          ; Head is a list (fn ret-type) — function pointer with params
          (when (= (. (cast *Node head) kind) NODE-CELL)
            (let (fn-head:*Node (cast *Node (. (cast *Node head) car)))
              (when (and (!= (cast ptr fn-head) null)
                         (and (= (. fn-head kind) NODE-SYM)
                              (= (strcmp (. fn-head s) "fn") 0)))
                ; Parse return type from (fn ret-type)
                (let (ret-node:ptr (. (cast *Node head) cdr)
                      ret-type:ptr ty-void)
                  (when (and (!= ret-node null)
                             (!= (. (cast *Node ret-node) car) null))
                    (set! ret-type (parse-type-from-node (. (cast *Node ret-node) car) line)))
                  ; Parse parameter types from the second element (param-types...)
                  (let (params-node:ptr (. n cdr)
                        num-p:i32 0
                        param-arr:ptr null
                        is-va:i32 0)
                    (when (!= params-node null)
                      (let (plist:ptr (. (cast *Node params-node) car))
                        (when (!= plist null)
                          ; Count params
                          (let (cur:ptr plist
                                count:i32 0)
                            (while (!= cur null)
                              (inc! count)
                              (set! cur (. (cast *Node cur) cdr)))
                            (set! num-p count)
                            (set! param-arr (arena-alloc (* (cast i64 count) (cast i64 8))))
                            ; Parse each param type
                            (set! cur plist)
                            (let (pi:i32 0)
                              (while (!= cur null)
                                (aset! (cast *ptr param-arr) pi
                                       (parse-type-from-node (. (cast *Node cur) car) line))
                                (inc! pi)
                                (set! cur (. (cast *Node cur) cdr))))))))
                    (let (ft:*Type (cast *Type (make-type TY-FN)))
                      (.set! ft ret ret-type)
                      (.set! ft params param-arr)
                      (.set! ft num-params num-p)
                      (.set! ft variadic is-va)
                      (return (cast ptr ft))))))))
          ; Head is a symbol "fn" — function pointer with no params: (fn ret-type)
          (when (= (. (cast *Node head) kind) NODE-SYM)
            (when (= (strcmp (. (cast *Node head) s) "fn") 0)
              (let (ret-node:ptr (. n cdr)
                    ret-type:ptr ty-void)
                (when (and (!= ret-node null)
                           (!= (. (cast *Node ret-node) car) null))
                  (set! ret-type (parse-type-from-node (. (cast *Node ret-node) car) line)))
                (let (ft:*Type (cast *Type (make-type TY-FN)))
                  (.set! ft ret ret-type)
                  (.set! ft params null)
                  (.set! ft num-params 0)
                  (.set! ft variadic 0)
                  (return (cast ptr ft))))))))))
    (die-at line "unable to parse type expression")))

(defn split-typed:void (sym:ptr out-name:*ptr out-type-name:*ptr)
  (let (colon:ptr (strchr sym 58))
    (if (= colon null)
      (do
        (ptr-set! out-name (arena-strdup sym))
        (ptr-set! out-type-name null))
      (let (name-len:i64 (- (cast i64 colon) (cast i64 sym)))
        (ptr-set! out-name (arena-strndup sym name-len))
        (ptr-set! out-type-name (arena-strdup (ptr+ (cast *i8 colon) (cast i64 1))))))))

; Extract name and type-name from a node that is either:
;   - a symbol node (possibly containing :) — uses split-typed
;   - a list node (name type ...) from desugar — extracts car/cadr strings
; Sets out-name and out-type-name.  out-type-name is null if untyped.
(defn extract-name-type:void (node:ptr out-name:*ptr out-type-name:*ptr)
  (let (n:*Node (cast *Node node))
    (when (= (. n kind) NODE-SYM)
      (do (split-typed (. n s) out-name out-type-name)
          (return)))
    (when (= (. n kind) NODE-CELL)
      (let (car-node:*Node (cast *Node (. n car)))
        (when (and (!= (cast ptr car-node) null) (= (. car-node kind) NODE-SYM))
          (do (ptr-set! out-name (. car-node s))
              (let (rest:ptr (. n cdr))
                (if (!= rest null)
                  (let (type-node:*Node (cast *Node (. (cast *Node rest) car)))
                    (when (and (!= (cast ptr type-node) null) (= (. type-node kind) NODE-SYM))
                      (ptr-set! out-type-name (. type-node s)))
                    (return))
                  (do (ptr-set! out-type-name null)
                      (return))))))))
    ; Fallback: treat as untyped
    (ptr-set! out-name null)
    (ptr-set! out-type-name null)))

; Extract name and parsed Type* from a node. Handles function pointer types.
; Returns the Type* or null if untyped. Sets out-name.
; For simple types: (name type-sym) → parse-type-name
; For function pointer types: (name (fn ret) (param-types)) → parse-type-from-node on rest
(defn extract-name-and-type:ptr (node:ptr out-name:*ptr line:i32)
  (let (n:*Node (cast *Node node))
    ; Simple symbol: name:type — use split-typed then parse-type-name
    (when (= (. n kind) NODE-SYM)
      (let (tname:ptr null)
        (split-typed (. n s) out-name (cast *ptr (addr-of tname)))
        (when (!= tname null)
          (return (parse-type-name tname line)))
        (return null)))
    ; List node from desugar: (name type-info...)
    (when (= (. n kind) NODE-CELL)
      (let (car-node:*Node (cast *Node (. n car)))
        (when (and (!= (cast ptr car-node) null) (= (. car-node kind) NODE-SYM))
         (do
          (ptr-set! out-name (. car-node s))
          (let (rest:ptr (. n cdr))
            (when (= rest null) (return null))
            (let (type-node:ptr (. (cast *Node rest) car))
              (when (= type-node null) (return null))
              ; If type is a symbol, parse simply
              (when (= (. (cast *Node type-node) kind) NODE-SYM)
                (return (parse-type-name (. (cast *Node type-node) s) line)))
              ; If type is a list — could be a function pointer type or nested type
              ; Pass the rest of the binding as the type node: ((fn ret) (params...))
              (when (= (. (cast *Node type-node) kind) NODE-CELL)
                (return (parse-type-from-node rest line)))
              (return null)))))))
    (ptr-set! out-name null)
    (return null)))

; ============================================================
; Symbol table
; ============================================================

(defn scope-new:ptr (parent:ptr)
  (let (s:*Scope (cast *Scope (arena-alloc (sizeof Scope))))
    (.set! s parent parent)
    (return (cast ptr s))))

(defn scope-define:ptr (s:ptr name:ptr type:ptr ir-name:ptr is-local:i32)
  (let (sc:*Scope (cast *Scope s))
    (when (= (. sc len) (. sc cap))
      (let (nc:i32 8)
        (when (!= (. sc cap) 0) (set! nc (* (. sc cap) 2)))
        (let (ns:ptr (arena-alloc (* (i64 nc) (sizeof Sym))))
          (when (!= (. sc len) 0)
            (memcpy ns (. sc syms) (* (i64 (. sc len)) (sizeof Sym))))
          (.set! sc syms ns)
          (.set! sc cap nc))))
    (let (sym:*Sym (cast *Sym (ptr+ (cast *Sym (. sc syms)) (. sc len))))
      (.set! sym name name)
      (.set! sym type type)
      (.set! sym ir-name ir-name)
      (.set! sym is-local is-local)
      (.set! sc len (+ (. sc len) 1))
      (return (cast ptr sym)))))

(defn scope-lookup:ptr (s:ptr name:ptr)
  (let (cur:ptr s)
    (while (!= cur null)
      (let (sc:*Scope (cast *Scope cur)
            i:i32 (- (. sc len) 1))
        (while (>= i 0)
          (let (sym:*Sym (cast *Sym (ptr+ (cast *Sym (. sc syms)) i)))
            (when (= (strcmp (. sym name) name) 0)
              (return (cast ptr sym))))
          (set! i (- i 1)))
        (set! cur (. sc parent)))))
  (return null))

; ============================================================
; String literal table
; ============================================================

(defn intern-string:i32 (bytes:ptr len:i32)
  (let (id:i32 g-strs-len)
    (when (= g-strs-len g-strs-cap)
      (let (nc:i32 8)
        (when (!= g-strs-cap 0) (set! nc (* g-strs-cap 2)))
        (let (ns:ptr (malloc (* (i64 nc) (sizeof StrLit))))
          (when (= ns null) (do (perror "malloc") (exit 1)))
          (when (!= g-strs null)
            (do (memcpy ns g-strs (* (i64 g-strs-len) (sizeof StrLit)))
                (free g-strs)))
          (set! g-strs ns)
          (set! g-strs-cap nc))))
    (let (sl:*StrLit (cast *StrLit (ptr+ (cast *StrLit g-strs) g-strs-len)))
      (.set! sl bytes (arena-strndup bytes (i64 len)))
      (.set! sl len len)
      (.set! sl id id)
      (inc! g-strs-len)
      (return id))))

; ============================================================
; Codegen helpers
; ============================================================

(defn new-tmp:ptr ()
  (let (r:ptr (fmt-i32 "%%t%d" g-tmp))
    (inc! g-tmp)
    (return r)))

(defn new-label-id:i32 ()
  (let (r:i32 g-label)
    (inc! g-label)
    (return r)))

(defn reset-function-state:void ()
  (set! g-tmp 0)
  (set! g-label 0)
  (set! g-block-term 0)
  (set! g-entry-stream (open_memstream (addr-of g-entry-bufp)
                                       (cast ptr (addr-of g-entry-sizep))))
  (set! g-body-stream (open_memstream (addr-of g-body-bufp)
                                      (cast ptr (addr-of g-body-sizep)))))

; ============================================================
; Expression codegen
; ============================================================

(defn emit-node:ptr (n:ptr scope:ptr)
  (let (nn:*Node (cast *Node n))
    (when (= (. nn kind) NODE-INT)  (return (emit-int n)))
    (when (= (. nn kind) NODE-STR)  (return (emit-string n)))
    (when (= (. nn kind) NODE-SYM)  (return (emit-symbol-ref n scope)))
    (when (= (. nn kind) NODE-CELL) (return (emit-list n scope)))
    (return (alloc-val ty-void null))))

(defn emit-int:ptr (n:ptr)
  (return (alloc-val ty-i32 (fmt-i64 "%ld" (. (cast *Node n) i)))))

(defn emit-string:ptr (n:ptr)
  (let (nn:*Node (cast *Node n)
        id:i32 (intern-string (. nn s) (cast i32 (strlen (. nn s))))
        ir-len:i32 (+ (. (cast *StrLit (ptr+ (cast *StrLit g-strs) id)) len) 1)
        tmp:ptr (new-tmp))
    (fprintf g-body-stream
      "  %s = getelementptr inbounds [%d x i8], ptr @.str.%d, i64 0, i64 0\n"
      tmp ir-len id)
    (return (alloc-val ty-ptr tmp))))

(defn emit-quote-tree:ptr (n:ptr)
  (when (= n null) (return "null"))
  (let (nn:*Node (cast *Node n))
    (when (= (. nn kind) NODE-INT)
      (let (id:i32 g-quote-id)
        (inc! g-quote-id)
        (fprintf g-decl-out
          "@.q%d = private unnamed_addr constant { i32, i32, i64, ptr, ptr, ptr } { i32 0, i32 %d, i64 %ld, ptr null, ptr null, ptr null }, align 8\n"
          id (. nn line) (. nn i))
        (return (fmt-i64 "@.q%ld" (cast i64 id)))))
    (when (or (= (. nn kind) NODE-STR) (= (. nn kind) NODE-SYM))
      (let (k:i32 2)
        (when (= (. nn kind) NODE-STR) (set! k 1))
        (let (sid:i32 (intern-string (. nn s) (cast i32 (strlen (. nn s))))
              ir-len:i32 (+ (. (cast *StrLit (ptr+ (cast *StrLit g-strs) sid)) len) 1)
              id:i32 g-quote-id)
          (inc! g-quote-id)
          (fprintf g-decl-out
            "@.q%d = private unnamed_addr constant { i32, i32, i64, ptr, ptr, ptr } { i32 %d, i32 %d, i64 0, ptr getelementptr inbounds ([%d x i8], ptr @.str.%d, i64 0, i64 0), ptr null, ptr null }, align 8\n"
            id k (. nn line) ir-len sid)
          (return (fmt-i64 "@.q%ld" (cast i64 id))))))
    ; NODE-CELL
    (let (car-ref:ptr (emit-quote-tree (. nn car))
          cdr-ref:ptr (emit-quote-tree (. nn cdr))
          id:i32 g-quote-id)
      (inc! g-quote-id)
      (fprintf g-decl-out
        "@.q%d = private unnamed_addr constant { i32, i32, i64, ptr, ptr, ptr } { i32 3, i32 %d, i64 0, ptr null, ptr %s, ptr %s }, align 8\n"
        id (. nn line) car-ref cdr-ref)
      (return (fmt-i64 "@.q%ld" (cast i64 id))))))

(defn emit-quote:ptr (call:ptr)
  (let (cc:*Node (cast *Node call))
    (when (!= (node-len call) 2) (die-at (. cc line) "quote: expects 1 arg"))
    (let (ref:ptr (emit-quote-tree (node-at call 1)))
      (return (alloc-val ty-ptr ref)))))

(defn qq-is-tagged:i32 (n:ptr tag:ptr)
  (when (= n null) (return 0))
  (let (nn:*Node (cast *Node n))
    (when (!= (. nn kind) NODE-CELL) (return 0))
    (when (!= (node-len n) 2) (return 0))
    (let (h:*Node (cast *Node (. nn car)))
      (when (= (cast ptr h) null) (return 0))
      (when (!= (. h kind) NODE-SYM) (return 0))
      (when (= (strcmp (. h s) tag) 0) (return 1))
      (return 0))))

(defn emit-qq-list:ptr (list:ptr scope:ptr)
  (when (= list null) (return (alloc-val ty-ptr "null")))
  (set! g-qq-used 1)
  (let (lc:*Node (cast *Node list)
        elem:ptr (. lc car))
    (when (!= (qq-is-tagged elem "unquote-splice") 0)
      (let (inner:ptr (node-at elem 1)
            a:*Val (cast *Val (emit-node inner scope))
            rest:*Val (cast *Val (emit-qq-list (. lc cdr) scope))
            tmp:ptr (new-tmp))
        (fprintf g-body-stream "  %s = call ptr @__append(ptr %s, ptr %s)\n"
                 tmp (. a val) (. rest val))
        (return (alloc-val ty-ptr tmp))))
    (let (head:*Val (cast *Val (emit-qq-form elem scope))
          tail:*Val (cast *Val (emit-qq-list (. lc cdr) scope))
          tmp:ptr (new-tmp))
      (fprintf g-body-stream "  %s = call ptr @__cons(ptr %s, ptr %s)\n"
               tmp (. head val) (. tail val))
      (return (alloc-val ty-ptr tmp)))))

(defn emit-qq-form:ptr (form:ptr scope:ptr)
  (when (= form null) (return (alloc-val ty-ptr "null")))
  (let (fn:*Node (cast *Node form))
    (when (!= (. fn kind) NODE-CELL)
      (let (ref:ptr (emit-quote-tree form))
        (return (alloc-val ty-ptr ref))))
    (when (!= (qq-is-tagged form "unquote") 0)
      (return (emit-node (node-at form 1) scope)))
    (when (!= (qq-is-tagged form "unquote-splice") 0)
      (die-at (. fn line) "unquote-splice outside list"))
    (return (emit-qq-list form scope))))

(defn emit-quasiquote:ptr (call:ptr scope:ptr)
  (let (cc:*Node (cast *Node call))
    (when (!= (node-len call) 2) (die-at (. cc line) "quasiquote: expects 1 arg"))
    (return (emit-qq-form (node-at call 1) scope))))

(defn emit-symbol-ref:ptr (n:ptr scope:ptr)
  (let (nn:*Node (cast *Node n))
    (when (= (strcmp (. nn s) "null") 0)
      (return (alloc-val ty-ptr "null")))
    (when (= (strcmp (. nn s) "true") 0)
      (return (alloc-val ty-i1 "1")))
    (when (= (strcmp (. nn s) "false") 0)
      (return (alloc-val ty-i1 "0")))
    ; Strip any trailing :type annotation so typed names (e.g. i:i32 from macro
    ; expansion) resolve correctly in value position.
    (let (lookup-name:ptr null
          ignored-type:ptr null)
      (split-typed (. nn s) (cast *ptr (addr-of lookup-name)) (cast *ptr (addr-of ignored-type)))
      (let (sym:*Sym (cast *Sym (scope-lookup scope lookup-name)))
        (when (= (cast ptr sym) null)
          (die-at (. nn line) (fmt-s "undefined: %s" (. nn s))))
        (when (!= (. sym is-const) 0)
          (return (alloc-val (. sym type) (. sym const-val))))
        (when (= (. sym is-local) 0)
         (do
          (when (-> sym (. type) (cast *Type _) (. kind) (= _ TY-FN))
            (return (alloc-val (. sym type) (. sym ir-name))))
          (die-at (. nn line) (fmt-s "cannot use '%s' as value" (. nn s)))))
        (let (tmp:ptr (new-tmp))
          (fprintf g-body-stream "  %s = load %s, ptr %s, align %d\n"
            tmp (type-to-ir (. sym type)) (. sym ir-name) (type-size (. sym type)))
          (return (alloc-val (. sym type) tmp)))))))

; ============================================================
; Binary operations
; ============================================================

(defn add-binop:void (name:ptr instr:ptr instr-u:ptr is-cmp:i32)
  (let (op:*BinOp (cast *BinOp (ptr+ (cast *BinOp g-binops) g-num-binops)))
    (.set! op name name)
    (.set! op instr instr)
    (.set! op instr-u instr-u)
    (.set! op is-cmp is-cmp)
    (inc! g-num-binops)))

(defn init-binops:void ()
  (set! g-binops (arena-alloc (* (cast i64 16) (sizeof BinOp))))
  (add-binop "+"       "add nsw"  "add"      0)
  (add-binop "-"       "sub nsw"  "sub"      0)
  (add-binop "*"       "mul nsw"  "mul"      0)
  (add-binop "/"       "sdiv"     "udiv"     0)
  (add-binop "%"       "srem"     "urem"     0)
  (add-binop "bit-and" "and"      "and"      0)
  (add-binop "bit-or"  "or"       "or"       0)
  (add-binop "bit-xor" "xor"      "xor"      0)
  (add-binop "bit-shl" "shl"      "shl"      0)
  (add-binop "bit-shr" "ashr"     "lshr"     0)
  (add-binop "="       "icmp eq"  "icmp eq"  1)
  (add-binop "!="      "icmp ne"  "icmp ne"  1)
  (add-binop "<"       "icmp slt" "icmp ult" 1)
  (add-binop "<="      "icmp sle" "icmp ule" 1)
  (add-binop ">"       "icmp sgt" "icmp ugt" 1)
  (add-binop ">="      "icmp sge" "icmp uge" 1))

(defn lookup-binop:ptr (name:ptr)
  (let (i:i32 0)
    (while (< i g-num-binops)
      (let (op:*BinOp (cast *BinOp (ptr+ (cast *BinOp g-binops) i)))
        (when (= (strcmp (. op name) name) 0)
          (return (cast ptr op))))
      (inc! i)))
  (return null))

(defn emit-binop:ptr (call:ptr scope:ptr op:ptr)
  (let (cc:*Node (cast *Node call)
        bop:*BinOp (cast *BinOp op))
    (when (!= (node-len cc) 3)
      (die-at (. cc line) (fmt-s "%s expects 2 args" (. bop name))))
    (let (a:*Val (cast *Val (emit-node (node-at cc 1) scope))
          b:*Val (cast *Val (emit-node (node-at cc 2) scope)))
      ; Pointer comparison
      (when (and (-> a (. type) (cast *Type _) (. kind) (= _ TY-PTR))
               (-> b (. type) (cast *Type _) (. kind) (= _ TY-PTR)))
        (when (!= (. bop is-cmp) 0)
          (let (tmp:ptr (new-tmp))
            (fprintf g-body-stream "  %s = %s ptr %s, %s\n"
              tmp (. bop instr) (. a val) (. b val))
            (return (alloc-val ty-i1 tmp)))))
      (when (or (= (is-int-type (. a type)) 0) (= (is-int-type (. b type)) 0))
        (die-at (. cc line) (fmt-s "%s expects integer operands" (. bop name))))
      (when (!= (is-unsigned (. a type)) (is-unsigned (. b type)))
        (die-at (. cc line) (fmt-s "%s: mixed signed/unsigned operands — use explicit cast" (. bop name))))
      (when (!= (-> a (. type) (cast *Type _) (. kind))
               (-> b (. type) (cast *Type _) (. kind)))
        (die-at (. cc line) (fmt-s "%s operand type mismatch" (. bop name))))
      (let (tmp:ptr (new-tmp)
            instr:ptr (. bop instr))
        (when (!= (is-unsigned (. a type)) 0) (set! instr (. bop instr-u)))
        (fprintf g-body-stream "  %s = %s %s %s, %s\n"
          tmp instr (type-to-ir (. a type)) (. a val) (. b val))
        (let (rtype:ptr (. a type))
          (when (!= (. bop is-cmp) 0) (set! rtype ty-i1))
          (return (alloc-val rtype tmp)))))))

; ============================================================
; Cast
; ============================================================

(defn emit-cast:ptr (call:ptr scope:ptr)
  (let (cc:*Node (cast *Node call))
    (when (!= (node-len cc) 3)
      (die-at (. cc line) "cast expects 2 args"))
    (let (type-node:*Node (cast *Node (node-at cc 1)))
      (when (!= (. type-node kind) NODE-SYM)
        (die-at (. type-node line) "cast: target type must be a symbol"))
      (let (dst:ptr (parse-type-name (. type-node s) (. type-node line))
            v:*Val (cast *Val (emit-node (node-at cc 2) scope))
            src:ptr (. v type))
        (when (= (-> src (cast *Type _) (. kind)) (-> dst (cast *Type _) (. kind)))
          (return (alloc-val dst (. v val))))
        (let (instr:ptr null)
          (when (and (!= (is-int-type src) 0) (!= (is-int-type dst) 0))
            (let (sw:i32 (int-width src) dw:i32 (int-width dst))
              (when (= sw dw)
                ; Same width, different signedness — reinterpret (no IR needed)
                (return (alloc-val dst (. v val))))
              (if (< dw sw)
                (set! instr "trunc")
                (if (!= (is-unsigned src) 0)
                  (set! instr "zext")
                  (set! instr "sext")))))
          (when (and (!= (is-int-type src) 0) (-> dst (cast *Type _) (. kind) (= _ TY-PTR)))
            (set! instr "inttoptr"))
          (when (and (-> src (cast *Type _) (. kind) (= _ TY-PTR)) (!= (is-int-type dst) 0))
            (set! instr "ptrtoint"))
          (when (= instr null)
            (die-at (. cc line) "cast: unsupported conversion"))
          (let (tmp:ptr (new-tmp))
            (fprintf g-body-stream "  %s = %s %s %s to %s\n"
              tmp instr (type-to-ir src) (. v val) (type-to-ir dst))
            (return (alloc-val dst tmp))))))))

; ============================================================
; Struct field access
; ============================================================

(defn emit-field-get:ptr (call:ptr scope:ptr)
  (let (cc:*Node (cast *Node call))
    (when (!= (node-len cc) 3)
      (die-at (. cc line) ". expects 2 args"))
    (let (p:*Val (cast *Val (emit-node (node-at cc 1) scope))
          pt:*Type (cast *Type (. p type)))
      (when (or (or (!= (. pt kind) TY-PTR) (= (. pt elem) null))
              (-> pt (. elem) (cast *Type _) (. kind) (!= _ TY-STRUCT)))
        (die-at (. cc line) ".: operand must be pointer to struct"))
      (let (fn-node:*Node (cast *Node (node-at cc 2)))
        (when (!= (. fn-node kind) NODE-SYM)
          (die-at (. fn-node line) ".: field name must be symbol"))
        (let (sd:*StructDef (cast *StructDef (-> pt (. elem) (cast *Type _) (. sdef)))
              idx:i32 -1
              i:i32 0)
          (while (< i (. sd num-fields))
            (when (= (strcmp (aref (cast *ptr (. sd field-names)) i) (. fn-node s)) 0)
              (do (set! idx i) (set! i (. sd num-fields))))
            (inc! i))
          (when (< idx 0)
            (die-at (. fn-node line)
              (fmt-2s ".: no field '%s' on struct '%s'" (. fn-node s) (. sd name))))
          (let (ftype:ptr (aref (cast *ptr (. sd field-types)) idx)
                gep:ptr (new-tmp))
            (fprintf g-body-stream
              "  %s = getelementptr inbounds %%%s, ptr %s, i32 0, i32 %d\n"
              gep (. sd name) (. p val) idx)
            (let (val:ptr (new-tmp))
              (fprintf g-body-stream "  %s = load %s, ptr %s, align %d\n"
                val (type-to-ir ftype) gep (type-size ftype))
              (return (alloc-val ftype val)))))))))

(defn emit-field-set:ptr (call:ptr scope:ptr)
  (let (cc:*Node (cast *Node call))
    (when (!= (node-len cc) 4)
      (die-at (. cc line) ".set! expects 3 args"))
    (let (p:*Val (cast *Val (emit-node (node-at cc 1) scope))
          pt:*Type (cast *Type (. p type)))
      (when (or (or (!= (. pt kind) TY-PTR) (= (. pt elem) null))
              (-> pt (. elem) (cast *Type _) (. kind) (!= _ TY-STRUCT)))
        (die-at (. cc line) ".set!: operand must be pointer to struct"))
      (let (fn-node:*Node (cast *Node (node-at cc 2)))
        (when (!= (. fn-node kind) NODE-SYM)
          (die-at (. fn-node line) ".set!: field name must be symbol"))
        (let (sd:*StructDef (cast *StructDef (-> pt (. elem) (cast *Type _) (. sdef)))
              idx:i32 -1
              i:i32 0)
          (while (< i (. sd num-fields))
            (when (= (strcmp (aref (cast *ptr (. sd field-names)) i) (. fn-node s)) 0)
              (do (set! idx i) (set! i (. sd num-fields))))
            (inc! i))
          (when (< idx 0)
            (die-at (. fn-node line)
              (fmt-2s ".set!: no field '%s' on struct '%s'" (. fn-node s) (. sd name))))
          (let (ftype:ptr (aref (cast *ptr (. sd field-types)) idx)
                v:ptr (emit-node (node-at cc 3) scope)
                coerced:ptr (coerce-int-val v ftype (. cc line)))
            (when (= coerced null)
              (die-at (. cc line) (fmt-s ".set!: type mismatch for field '%s'" (. fn-node s))))
            (let (cv:*Val (cast *Val coerced)
                  gep:ptr (new-tmp))
              (fprintf g-body-stream
                "  %s = getelementptr inbounds %%%s, ptr %s, i32 0, i32 %d\n"
                gep (. sd name) (. p val) idx)
              (fprintf g-body-stream "  store %s %s, ptr %s, align %d\n"
                (type-to-ir ftype) (. cv val) gep (type-size ftype))
              (return (alloc-val ty-void null)))))))))

; ============================================================
; sizeof, alloca, array ops, char, pointer ops
; ============================================================

(defn emit-sizeof:ptr (call:ptr scope:ptr)
  (let (cc:*Node (cast *Node call))
    (when (!= (node-len cc) 2) (die-at (. cc line) "sizeof expects 1 arg"))
    (let (tn:*Node (cast *Node (node-at cc 1)))
      (when (!= (. tn kind) NODE-SYM) (die-at (. tn line) "sizeof: arg must be type name"))
      (let (ty:ptr (parse-type-name (. tn s) (. tn line))
            gep:ptr (new-tmp))
        (fprintf g-body-stream "  %s = getelementptr %s, ptr null, i32 1\n"
          gep (type-to-ir ty))
        (let (sz:ptr (new-tmp))
          (fprintf g-body-stream "  %s = ptrtoint ptr %s to i64\n" sz gep)
          (return (alloc-val ty-i64 sz)))))))

(defn emit-alloca-form:ptr (call:ptr scope:ptr)
  (let (cc:*Node (cast *Node call))
    (when (and (!= (node-len cc) 2) (!= (node-len cc) 3))
      (die-at (. cc line) "alloca expects 1 or 2 args"))
    (let (tn:*Node (cast *Node (node-at cc 1)))
      (when (!= (. tn kind) NODE-SYM)
        (die-at (. tn line) "alloca: first arg must be type name"))
      (let (ty:ptr (parse-type-name (. tn s) (. tn line))
            slot:ptr (new-tmp)
            pt:*Type (cast *Type (make-type TY-PTR)))
        (.set! pt elem ty)
        (if (= (node-len cc) 3)
          (let (nv:*Val (cast *Val (emit-node (node-at cc 2) scope)))
            (fprintf g-body-stream "  %s = alloca %s, i32 %s, align %d\n"
              slot (type-to-ir ty) (. nv val) (type-size ty)))
          (fprintf g-entry-stream "  %s = alloca %s, align %d\n"
            slot (type-to-ir ty) (type-size ty)))
        (return (alloc-val (cast ptr pt) slot))))))

(defn emit-aref:ptr (call:ptr scope:ptr)
  (let (cc:*Node (cast *Node call))
    (when (!= (node-len cc) 3) (die-at (. cc line) "aref expects 2 args"))
    (let (p:*Val (cast *Val (emit-node (node-at cc 1) scope)))
      (when (or (-> p (. type) (cast *Type _) (. kind) (!= _ TY-PTR))
              (-> p (. type) (cast *Type _) (. elem) (= _ null)))
        (die-at (. cc line) "aref: operand must be typed pointer"))
      (let (idx:*Val (cast *Val (emit-node (node-at cc 2) scope)))
        (when (= (is-int-type (. idx type)) 0)
          (die-at (. cc line) "aref: index must be integer"))
        (let (idx64:ptr (. idx val))
          (when (-> idx (. type) (cast *Type _) (. kind) (!= _ TY-I64))
            (let (t:ptr (new-tmp))
              (fprintf g-body-stream "  %s = sext %s %s to i64\n"
                t (type-to-ir (. idx type)) (. idx val))
              (set! idx64 t)))
          (let (elem:ptr (-> p (. type) (cast *Type _) (. elem))
                gep:ptr (new-tmp))
            (fprintf g-body-stream
              "  %s = getelementptr inbounds %s, ptr %s, i64 %s\n"
              gep (type-to-ir elem) (. p val) idx64)
            (let (val:ptr (new-tmp))
              (fprintf g-body-stream "  %s = load %s, ptr %s, align %d\n"
                val (type-to-ir elem) gep (type-size elem))
              (return (alloc-val elem val)))))))))

(defn emit-aset:ptr (call:ptr scope:ptr)
  (let (cc:*Node (cast *Node call))
    (when (!= (node-len cc) 4) (die-at (. cc line) "aset! expects 3 args"))
    (let (p:*Val (cast *Val (emit-node (node-at cc 1) scope)))
      (when (or (-> p (. type) (cast *Type _) (. kind) (!= _ TY-PTR))
              (-> p (. type) (cast *Type _) (. elem) (= _ null)))
        (die-at (. cc line) "aset!: operand must be typed pointer"))
      (let (idx:*Val (cast *Val (emit-node (node-at cc 2) scope)))
        (when (= (is-int-type (. idx type)) 0)
          (die-at (. cc line) "aset!: index must be integer"))
        (let (idx64:ptr (. idx val))
          (when (-> idx (. type) (cast *Type _) (. kind) (!= _ TY-I64))
            (let (t:ptr (new-tmp))
              (fprintf g-body-stream "  %s = sext %s %s to i64\n"
                t (type-to-ir (. idx type)) (. idx val))
              (set! idx64 t)))
          (let (elem:ptr (-> p (. type) (cast *Type _) (. elem))
                v:ptr (emit-node (node-at cc 3) scope)
                coerced:ptr (coerce-int-val v elem (. cc line)))
            (when (= coerced null)
              (die-at (. cc line) "aset!: value type mismatch"))
            (let (cv:*Val (cast *Val coerced)
                  gep:ptr (new-tmp))
              (fprintf g-body-stream
                "  %s = getelementptr inbounds %s, ptr %s, i64 %s\n"
                gep (type-to-ir elem) (. p val) idx64)
              (fprintf g-body-stream "  store %s %s, ptr %s, align %d\n"
                (type-to-ir elem) (. cv val) gep (type-size elem))
              (return (alloc-val ty-void null)))))))))

(defn emit-char:ptr (call:ptr scope:ptr)
  (let (cc:*Node (cast *Node call))
    (when (!= (node-len cc) 2) (die-at (. cc line) "char expects 1 arg"))
    (let (arg:*Node (cast *Node (node-at cc 1)))
      (when (or (!= (. arg kind) NODE-STR) (!= (strlen (. arg s)) (cast i64 1)))
        (die-at (. arg line) "char: arg must be single-char string"))
      (return (alloc-val ty-i8 (fmt-i32 "%d" (char-at (. arg s) (cast i64 0))))))))

(defn emit-addr-of:ptr (call:ptr scope:ptr)
  (let (cc:*Node (cast *Node call))
    (when (!= (node-len cc) 2) (die-at (. cc line) "addr-of expects 1 arg"))
    (let (target:*Node (cast *Node (node-at cc 1)))
      (when (!= (. target kind) NODE-SYM)
        (die-at (. target line) "addr-of: target must be symbol"))
      (let (sym:*Sym (cast *Sym (scope-lookup scope (. target s))))
        (when (= (cast ptr sym) null)
          (die-at (. target line) (fmt-s "addr-of: undefined '%s'" (. target s))))
        (when (-> sym (. type) (cast *Type _) (. kind) (= _ TY-FN))
          (die-at (. target line) (fmt-s "addr-of: cannot take address of function '%s'" (. target s))))
        (let (pt:*Type (cast *Type (make-type TY-PTR)))
          (.set! pt elem (. sym type))
          (return (alloc-val (cast ptr pt) (. sym ir-name))))))))

(defn emit-funcall-void:ptr (call:ptr scope:ptr)
  (let (cc:*Node (cast *Node call))
    (when (!= (node-len cc) 2) (die-at (. cc line) "funcall-void expects 1 arg"))
    (let (fn:*Val (cast *Val (emit-node (node-at cc 1) scope)))
      (when (-> fn (. type) (cast *Type _) (. kind) (!= _ TY-PTR))
        (die-at (. cc line) "funcall-void: arg must be ptr"))
      (fprintf g-body-stream "  call void %s()\n" (. fn val))
      (return (alloc-val ty-void null)))))

; (funcall-ptr-1 fn arg) — call fn(arg) as ptr(ptr) via pointer, return ptr
(defn emit-funcall-ptr-1:ptr (call:ptr scope:ptr)
  (let (cc:*Node (cast *Node call))
    (when (!= (node-len cc) 3) (die-at (. cc line) "funcall-ptr-1 expects 2 args"))
    (let (fn:*Val  (cast *Val (emit-node (node-at cc 1) scope))
          arg:*Val (cast *Val (emit-node (node-at cc 2) scope)))
      (when (-> fn (. type) (cast *Type _) (. kind) (!= _ TY-PTR))
        (die-at (. cc line) "funcall-ptr-1: fn must be ptr"))
      (when (-> arg (. type) (cast *Type _) (. kind) (!= _ TY-PTR))
        (die-at (. cc line) "funcall-ptr-1: arg must be ptr"))
      (let (tmp:ptr (new-tmp))
        (fprintf g-body-stream "  %s = call ptr %s(ptr %s)\n"
          tmp (. fn val) (. arg val))
        (return (alloc-val ty-ptr tmp))))))

; (funcall-ptr-i32 fn) — call fn() as i32() via pointer, return i32
(defn emit-funcall-ptr-i32:ptr (call:ptr scope:ptr)
  (let (cc:*Node (cast *Node call))
    (when (!= (node-len cc) 2) (die-at (. cc line) "funcall-ptr-i32 expects 1 arg"))
    (let (fn:*Val (cast *Val (emit-node (node-at cc 1) scope)))
      (when (-> fn (. type) (cast *Type _) (. kind) (!= _ TY-PTR))
        (die-at (. cc line) "funcall-ptr-i32: arg must be ptr"))
      (let (tmp:ptr (new-tmp))
        (fprintf g-body-stream "  %s = call i32 %s()\n" tmp (. fn val))
        (return (alloc-val ty-i32 tmp))))))

; (funcall-ptr-i64 fn) — call fn() as i64() via pointer, return i64
(defn emit-funcall-ptr-i64:ptr (call:ptr scope:ptr)
  (let (cc:*Node (cast *Node call))
    (when (!= (node-len cc) 2) (die-at (. cc line) "funcall-ptr-i64 expects 1 arg"))
    (let (fn:*Val (cast *Val (emit-node (node-at cc 1) scope)))
      (when (-> fn (. type) (cast *Type _) (. kind) (!= _ TY-PTR))
        (die-at (. cc line) "funcall-ptr-i64: arg must be ptr"))
      (let (tmp:ptr (new-tmp))
        (fprintf g-body-stream "  %s = call i64 %s()\n" tmp (. fn val))
        (return (alloc-val ty-i64 tmp))))))

; (funcall-ptr-ptr fn) — call fn() as ptr() via pointer, return ptr
(defn emit-funcall-ptr-ptr:ptr (call:ptr scope:ptr)
  (let (cc:*Node (cast *Node call))
    (when (!= (node-len cc) 2) (die-at (. cc line) "funcall-ptr-ptr expects 1 arg"))
    (let (fn:*Val (cast *Val (emit-node (node-at cc 1) scope)))
      (when (-> fn (. type) (cast *Type _) (. kind) (!= _ TY-PTR))
        (die-at (. cc line) "funcall-ptr-ptr: arg must be ptr"))
      (let (tmp:ptr (new-tmp))
        (fprintf g-body-stream "  %s = call ptr %s()\n" tmp (. fn val))
        (return (alloc-val ty-ptr tmp))))))

; (funcall fn-ptr args...) — general typed function pointer call
; fn-ptr must have TY-FN type. Emits call with proper LLVM IR signature.
(defn emit-funcall:ptr (call:ptr scope:ptr)
  (let (cc:*Node (cast *Node call))
    (when (< (node-len cc) 2)
      (die-at (. cc line) "funcall expects at least 1 arg"))
    (let (fn-val:*Val (cast *Val (emit-node (node-at cc 1) scope))
          fn-type:*Type (cast *Type (. fn-val type)))
      (when (!= (. fn-type kind) TY-FN)
        (die-at (. cc line) "funcall: first arg must be a function pointer"))
      (let (ret-type:ptr (. fn-type ret)
            np:i32 (. fn-type num-params)
            nargs:i32 (- (node-len cc) 2))
        (when (!= nargs np)
          (die-at (. cc line)
            (fmt-s "funcall: expected %d args, got %d"
              (cast i64 np) (cast i64 nargs))))
        ; Emit arguments
        (let (arg-vals:ptr (arena-alloc (* (cast i64 nargs) (cast i64 8)))
              i:i32 0)
          (while (< i nargs)
            (aset! (cast *ptr arg-vals) i (emit-node (node-at cc (+ i 2)) scope))
            (inc! i))
          ; Build call instruction
          (let (ret-ir:ptr (type-to-ir ret-type))
            (if (= (-> ret-type (cast *Type _) (. kind)) TY-VOID)
              (do
                (fprintf g-body-stream "  call void %s(" (. fn-val val))
                (set! i 0)
                (while (< i nargs)
                  (when (!= i 0) (fprintf g-body-stream ", "))
                  (let (av:*Val (cast *Val (aref (cast *ptr arg-vals) i)))
                    (fprintf g-body-stream "%s %s" (type-to-ir (. av type)) (. av val)))
                  (inc! i))
                (fprintf g-body-stream ")\n")
                (return (alloc-val ty-void null)))
              (let (tmp:ptr (new-tmp))
                (fprintf g-body-stream "  %s = call %s %s(" tmp ret-ir (. fn-val val))
                (set! i 0)
                (while (< i nargs)
                  (when (!= i 0) (fprintf g-body-stream ", "))
                  (let (av:*Val (cast *Val (aref (cast *ptr arg-vals) i)))
                    (fprintf g-body-stream "%s %s" (type-to-ir (. av type)) (. av val)))
                  (inc! i))
                (fprintf g-body-stream ")\n")
                (return (alloc-val ret-type tmp))))))))))

(defn emit-deref:ptr (call:ptr scope:ptr)
  (let (cc:*Node (cast *Node call))
    (when (!= (node-len cc) 2) (die-at (. cc line) "deref expects 1 arg"))
    (let (p:*Val (cast *Val (emit-node (node-at cc 1) scope)))
      (when (or (-> p (. type) (cast *Type _) (. kind) (!= _ TY-PTR))
              (-> p (. type) (cast *Type _) (. elem) (= _ null)))
        (die-at (. cc line) "deref: operand must be typed pointer"))
      (let (elem:ptr (-> p (. type) (cast *Type _) (. elem))
            tmp:ptr (new-tmp))
        (fprintf g-body-stream "  %s = load %s, ptr %s, align %d\n"
          tmp (type-to-ir elem) (. p val) (type-size elem))
        (return (alloc-val elem tmp))))))

(defn emit-ptr-set:ptr (call:ptr scope:ptr)
  (let (cc:*Node (cast *Node call))
    (when (!= (node-len cc) 3) (die-at (. cc line) "ptr-set! expects 2 args"))
    (let (p:*Val (cast *Val (emit-node (node-at cc 1) scope)))
      (when (or (-> p (. type) (cast *Type _) (. kind) (!= _ TY-PTR))
              (-> p (. type) (cast *Type _) (. elem) (= _ null)))
        (die-at (. cc line) "ptr-set!: operand must be typed pointer"))
      (let (elem:ptr (-> p (. type) (cast *Type _) (. elem))
            v:ptr (emit-node (node-at cc 2) scope)
            coerced:ptr (coerce-int-val v elem (. cc line)))
        (when (= coerced null)
          (die-at (. cc line) "ptr-set!: value type mismatch"))
        (let (cv:*Val (cast *Val coerced))
          (fprintf g-body-stream "  store %s %s, ptr %s, align %d\n"
            (type-to-ir elem) (. cv val) (. p val) (type-size elem))
          (return (alloc-val ty-void null)))))))

(defn emit-ptr-add:ptr (call:ptr scope:ptr)
  (let (cc:*Node (cast *Node call))
    (when (!= (node-len cc) 3) (die-at (. cc line) "ptr+ expects 2 args"))
    (let (p:*Val (cast *Val (emit-node (node-at cc 1) scope)))
      (when (or (-> p (. type) (cast *Type _) (. kind) (!= _ TY-PTR))
              (-> p (. type) (cast *Type _) (. elem) (= _ null)))
        (die-at (. cc line) "ptr+: operand must be typed pointer"))
      (let (nv:*Val (cast *Val (emit-node (node-at cc 2) scope)))
        (when (= (is-int-type (. nv type)) 0)
          (die-at (. cc line) "ptr+: offset must be integer"))
        (let (idx:ptr (. nv val))
          (when (-> nv (. type) (cast *Type _) (. kind) (!= _ TY-I64))
            (let (t:ptr (new-tmp))
              (fprintf g-body-stream "  %s = sext %s %s to i64\n"
                t (type-to-ir (. nv type)) (. nv val))
              (set! idx t)))
          (let (elem:ptr (-> p (. type) (cast *Type _) (. elem))
                tmp:ptr (new-tmp))
            (fprintf g-body-stream
              "  %s = getelementptr inbounds %s, ptr %s, i64 %s\n"
              tmp (type-to-ir elem) (. p val) idx)
            (return (alloc-val (. p type) tmp))))))))

(defn emit-not:ptr (call:ptr scope:ptr)
  (let (cc:*Node (cast *Node call))
    (when (!= (node-len cc) 2) (die-at (. cc line) "not expects 1 arg"))
    (let (a:*Val (cast *Val (emit-node (node-at cc 1) scope)))
      (when (-> a (. type) (cast *Type _) (. kind) (!= _ TY-I1))
        (die-at (. cc line) "not expects i1 operand"))
      (let (tmp:ptr (new-tmp))
        (fprintf g-body-stream "  %s = xor i1 %s, 1\n" tmp (. a val))
        (return (alloc-val ty-i1 tmp))))))

(defn emit-short-circuit:ptr (call:ptr scope:ptr is-and:i32)
  (let (cc:*Node (cast *Node call)
        tag:ptr "or")
    (when (!= is-and 0) (set! tag "and"))
    (when (!= (node-len cc) 3)
      (die-at (. cc line) (fmt-s "%s expects 2 args" tag)))
    (let (id:i32 (new-label-id)
          rhs-lbl:ptr (fmt-sd "%s.rhs%d" tag id)
          end-lbl:ptr (fmt-sd "%s.end%d" tag id)
          slot:ptr (fmt-sd "%%%s.val%d" tag id))
      (fprintf g-entry-stream "  %s = alloca i1, align 1\n" slot)
      (let (lhs:*Val (cast *Val (emit-node (node-at cc 1) scope)))
        (when (-> lhs (. type) (cast *Type _) (. kind) (!= _ TY-I1))
          (die-at (. (cast *Node (node-at cc 1)) line)
            (fmt-s "%s expects i1 operands" tag)))
        (fprintf g-body-stream "  store i1 %s, ptr %s, align 1\n"
          (. lhs val) slot)
        (if (!= is-and 0)
          (fprintf g-body-stream "  br i1 %s, label %%%s, label %%%s\n"
            (. lhs val) rhs-lbl end-lbl)
          (fprintf g-body-stream "  br i1 %s, label %%%s, label %%%s\n"
            (. lhs val) end-lbl rhs-lbl))
        (fprintf g-body-stream "%s:\n" rhs-lbl)
        (set! g-block-term 0)
        (let (rhs:*Val (cast *Val (emit-node (node-at cc 2) scope)))
          (when (-> rhs (. type) (cast *Type _) (. kind) (!= _ TY-I1))
            (die-at (. (cast *Node (node-at cc 2)) line)
              (fmt-s "%s expects i1 operands" tag)))
          (fprintf g-body-stream "  store i1 %s, ptr %s, align 1\n"
            (. rhs val) slot)
          (fprintf g-body-stream "  br label %%%s\n" end-lbl)
          (fprintf g-body-stream "%s:\n" end-lbl)
          (set! g-block-term 0)
          (let (tmp:ptr (new-tmp))
            (fprintf g-body-stream "  %s = load i1, ptr %s, align 1\n" tmp slot)
            (return (alloc-val ty-i1 tmp))))))))

; ============================================================
; Function calls
; ============================================================

(defn emit-call:ptr (call:ptr scope:ptr sym:ptr)
  (let (cc:*Node (cast *Node call)
        ss:*Sym (cast *Sym sym)
        nargs:i32 (- (node-len cc) 1)
        args:ptr (arena-alloc (* (i64 nargs) (sizeof Val)))
        i:i32 0)
    (while (< i nargs)
      (let (v:ptr (emit-node (node-at cc (+ i 1)) scope))
        (memcpy (ptr+ (cast *Val args) i) v (sizeof Val)))
      (inc! i))
    (let (arglist:ptr (alloca i8 2048)
          apos:i64 (cast i64 0))
      (aset! (cast *i8 arglist) (cast i64 0) (cast i8 0))
      (set! i 0)
      (while (< i nargs)
        (let (av:*Val (cast *Val (ptr+ (cast *Val args) i))
              sep:ptr "")
          (when (!= i 0) (set! sep ", "))
          (let (w:i32 (snprintf (ptr+ (cast *i8 arglist) apos)
                                (- (cast i64 2048) apos)
                                "%s%s %s" sep
                                (type-to-ir (. av type)) (. av val)))
            (set! apos (+ apos (i64 w)))))
        (inc! i))
      (let (ft:*Type (cast *Type (. ss type)))
        (when (!= (. ft kind) TY-FN)
          (die-at (. cc line) (fmt-s "not a function: %s" (. ss name))))
        (if (!= (. ft variadic) 0)
          (do
            (let (sig:ptr (alloca i8 512)
                  sp:i64 (cast i64 0)
                  w:i32 (snprintf sig (cast i64 512) "%s (" (type-to-ir (. ft ret))))
              (set! sp (i64 w))
              (set! i 0)
              (while (< i (. ft num-params))
                (let (pt:ptr (aref (cast *ptr (. ft params)) i)
                      sep:ptr "")
                  (when (!= i 0) (set! sep ", "))
                  (set! w (snprintf (ptr+ (cast *i8 sig) sp) (- (cast i64 512) sp)
                                    "%s%s" sep (type-to-ir pt)))
                  (set! sp (+ sp (i64 w))))
                (inc! i))
              (let (va-sep:ptr "")
                (when (!= (. ft num-params) 0) (set! va-sep ", "))
                (snprintf (ptr+ (cast *i8 sig) sp) (- (cast i64 512) sp)
                          "%s...)" va-sep))
              (if (-> ft (. ret) (cast *Type _) (. kind) (= _ TY-VOID))
                (fprintf g-body-stream "  call %s %s(%s)\n"
                  sig (. ss ir-name) arglist)
                (let (tmp:ptr (new-tmp))
                  (fprintf g-body-stream "  %s = call %s %s(%s)\n"
                    tmp sig (. ss ir-name) arglist)
                  (return (alloc-val (. ft ret) tmp))))))
          (do
            (if (-> ft (. ret) (cast *Type _) (. kind) (= _ TY-VOID))
              (fprintf g-body-stream "  call %s %s(%s)\n"
                (type-to-ir (. ft ret)) (. ss ir-name) arglist)
              (let (tmp:ptr (new-tmp))
                (fprintf g-body-stream "  %s = call %s %s(%s)\n"
                  tmp (type-to-ir (. ft ret)) (. ss ir-name) arglist)
                (return (alloc-val (. ft ret) tmp))))))
        (return (alloc-val ty-void null))))))

; ============================================================
; Special forms
; ============================================================

(defn emit-return:ptr (call:ptr scope:ptr)
  (let (cc:*Node (cast *Node call))
    (when (= (node-len cc) 1)
      (do
        (fprintf g-body-stream "  ret void\n")
        (set! g-block-term 1)
        (return (alloc-val ty-void null))))
    (when (!= (node-len cc) 2)
      (die-at (. cc line) "return expects 0 or 1 args"))
    (let (v:*Val (cast *Val (emit-node (node-at cc 1) scope)))
      (fprintf g-body-stream "  ret %s %s\n" (type-to-ir (. v type)) (. v val))
      (set! g-block-term 1)
      (return (alloc-val ty-void null)))))

(defn emit-do:ptr (call:ptr scope:ptr)
  (let (cc:*Node (cast *Node call)
        last:ptr (alloc-val ty-void null)
        i:i32 1)
    (while (< i (node-len cc))
      (set! last (emit-node (node-at cc i) scope))
      (inc! i))
    (return last)))

(defn emit-let:ptr (call:ptr scope:ptr)
  (let (cc:*Node (cast *Node call))
    (when (or (< (node-len cc) 2) (-> cc (node-at _ 1) (cast *Node _) (. kind) (!= _ NODE-CELL)))
      (die-at (. cc line) "let: bad form"))
    (let (binds:*Node (cast *Node (node-at cc 1)))
      (when (!= (% (node-len binds) 2) 0)
        (die-at (. binds line) "let: binding list must be even"))
      (let (inner:ptr (scope-new scope)
            i:i32 0)
        (while (< i (node-len binds))
          (let (bname:ptr (node-at binds i)
                bval-node:ptr (node-at binds (+ i 1)))
            (let (name:ptr null
                  ty:ptr (extract-name-and-type bname (cast *ptr (addr-of name))
                                                (. (cast *Node bname) line)))
              (when (= ty null)
                (die-at (. (cast *Node bname) line) (fmt-s "let: missing :type on '%s'" name)))
              (let (slot:ptr (fmt-sd "%%%s.addr.%d" name g-tmp)
                    align:i32 (type-size ty))
                (inc! g-tmp)
                (fprintf g-entry-stream "  %s = alloca %s, align %d\n"
                  slot (type-to-ir ty) align)
                (let (v:*Val (cast *Val (emit-node bval-node inner))
                      coerced:ptr (coerce-int-val v ty (. (cast *Node bval-node) line)))
                  (when (= coerced null)
                    (die-at (. (cast *Node bval-node) line)
                      (fmt-s "let: init type mismatch for '%s'" name)))
                  (let (cv:*Val (cast *Val coerced))
                    (fprintf g-body-stream "  store %s %s, ptr %s, align %d\n"
                      (type-to-ir ty) (. cv val) slot align)
                    (scope-define inner name ty slot 1))))))
          (set! i (+ i 2)))
        (let (last:ptr (alloc-val ty-void null)
              j:i32 2)
          (while (< j (node-len cc))
            (set! last (emit-node (node-at cc j) inner))
            (inc! j))
          (return last))))))

(defn emit-cond:ptr (call:ptr scope:ptr)
  (let (cc:*Node (cast *Node call)
        nargs:i32 (- (node-len cc) 1))
    (when (or (< nargs 2) (!= (% nargs 2) 0))
      (die-at (. cc line) "cond: expects pairs of (test body)"))
    (let (npairs:i32 (/ nargs 2)
          id:i32 (new-label-id)
          end-lbl:ptr (fmt-i32 "cond.end%d" id)
          i:i32 0)
      (while (< i npairs)
        (let (then-lbl:ptr (fmt-i32-i32 "cond.then%d.%d" id i)
              next-lbl:ptr end-lbl)
          (when (< i (- npairs 1))
            (set! next-lbl (fmt-i32-i32 "cond.test%d.%d" id (+ i 1))))
          (let (test:*Val (cast *Val (emit-node (node-at cc (+ 1 (* i 2))) scope)))
            (when (-> test (. type) (cast *Type _) (. kind) (!= _ TY-I1))
              (die-at (. (cast *Node (node-at cc (+ 1 (* i 2)))) line)
                "cond: test must be i1"))
            (fprintf g-body-stream "  br i1 %s, label %%%s, label %%%s\n"
              (. test val) then-lbl next-lbl)
            (fprintf g-body-stream "%s:\n" then-lbl)
            (set! g-block-term 0)
            (emit-node (node-at cc (+ 2 (* i 2))) scope)
            (when (= g-block-term 0)
              (fprintf g-body-stream "  br label %%%s\n" end-lbl))
            (when (< i (- npairs 1))
              (do
                (fprintf g-body-stream "%s:\n" next-lbl)
                (set! g-block-term 0)))))
        (inc! i))
      (fprintf g-body-stream "%s:\n" end-lbl)
      (set! g-block-term 0)
      (return (alloc-val ty-void null)))))

(defn emit-while:ptr (call:ptr scope:ptr)
  (let (cc:*Node (cast *Node call))
    (when (< (node-len cc) 2) (die-at (. cc line) "while: missing condition"))
    (let (id:i32 (new-label-id)
          cond-lbl:ptr (fmt-i32 "while.cond%d" id)
          body-lbl:ptr (fmt-i32 "while.body%d" id)
          end-lbl:ptr (fmt-i32 "while.end%d" id))
      (fprintf g-body-stream "  br label %%%s\n" cond-lbl)
      (fprintf g-body-stream "%s:\n" cond-lbl)
      (set! g-block-term 0)
      (let (cond:*Val (cast *Val (emit-node (node-at cc 1) scope)))
        (when (-> cond (. type) (cast *Type _) (. kind) (!= _ TY-I1))
          (die-at (. (cast *Node (node-at cc 1)) line)
            "while condition must be i1"))
        (fprintf g-body-stream "  br i1 %s, label %%%s, label %%%s\n"
          (. cond val) body-lbl end-lbl))
      (fprintf g-body-stream "%s:\n" body-lbl)
      (set! g-block-term 0)
      (let (i:i32 2)
        (while (< i (node-len cc))
          (emit-node (node-at cc i) scope)
          (inc! i)))
      (when (= g-block-term 0)
        (fprintf g-body-stream "  br label %%%s\n" cond-lbl))
      (fprintf g-body-stream "%s:\n" end-lbl)
      (set! g-block-term 0)
      (return (alloc-val ty-void null)))))

(defn emit-set:ptr (call:ptr scope:ptr)
  (let (cc:*Node (cast *Node call))
    (when (!= (node-len cc) 3) (die-at (. cc line) "set! expects 2 args"))
    (let (target:*Node (cast *Node (node-at cc 1)))
      (when (!= (. target kind) NODE-SYM)
        (die-at (. target line) "set!: target must be symbol"))
      ; Strip any :type annotation so typed names from macro expansions resolve.
      (let (set-name:ptr null
            set-type-ignored:ptr null)
        (split-typed (. target s)
                     (cast *ptr (addr-of set-name))
                     (cast *ptr (addr-of set-type-ignored)))
        (let (sym:*Sym (cast *Sym (scope-lookup scope set-name)))
          (when (or (= (cast ptr sym) null) (= (. sym is-local) 0))
            (die-at (. target line) (fmt-s "set!: undefined local '%s'" (. target s))))
          (let (v:ptr (emit-node (node-at cc 2) scope)
                coerced:ptr (coerce-int-val v (. sym type) (. cc line)))
            (when (= coerced null)
              (die-at (. cc line) (fmt-s "set!: type mismatch for '%s'" (. target s))))
            (let (cv:*Val (cast *Val coerced))
              (fprintf g-body-stream "  store %s %s, ptr %s, align %d\n"
                (type-to-ir (. sym type)) (. cv val) (. sym ir-name) (type-size (. sym type)))
              (return (alloc-val ty-void null)))))))))

(defn emit-inc:ptr (call:ptr scope:ptr)
  (let (cc:*Node (cast *Node call))
    (when (!= (node-len cc) 2) (die-at (. cc line) "inc! expects 1 arg"))
    (let (target:*Node (cast *Node (node-at cc 1)))
      (when (!= (. target kind) NODE-SYM)
        (die-at (. target line) "inc!: target must be symbol"))
      ; Strip any :type annotation so typed names from macro expansions resolve.
      (let (inc-name:ptr null
            inc-type-ignored:ptr null)
        (split-typed (. target s)
                     (cast *ptr (addr-of inc-name))
                     (cast *ptr (addr-of inc-type-ignored)))
        (let (sym:*Sym (cast *Sym (scope-lookup scope inc-name)))
          (when (or (= (cast ptr sym) null) (= (. sym is-local) 0))
            (die-at (. target line) (fmt-s "inc!: undefined local '%s'" (. target s))))
          (when (= (is-int-type (. sym type)) 0)
            (die-at (. cc line) "inc!: must be integer"))
          (let (ir:ptr (type-to-ir (. sym type))
                align:i32 (type-size (. sym type))
                t1:ptr (new-tmp))
            (fprintf g-body-stream "  %s = load %s, ptr %s, align %d\n"
              t1 ir (. sym ir-name) align)
            (let (t2:ptr (new-tmp))
              (fprintf g-body-stream "  %s = add nsw %s %s, 1\n" t2 ir t1)
              (fprintf g-body-stream "  store %s %s, ptr %s, align %d\n"
                ir t2 (. sym ir-name) align)
              (return (alloc-val ty-void null)))))))))

; ============================================================
; Macro expansion (calls JIT-compiled macro functions at compiler runtime)
; ============================================================

(defn emit-macro-expand:ptr (call:ptr scope:ptr macro-def:ptr)
  (let (mdef:*MacroDef (cast *MacroDef macro-def)
        nargs:i32 (- (node-len (cast *Node call)) 1))
    ; Arity check: variadic allows >= (num-params - 1) args; fixed requires exact match.
    (when (!= (. mdef variadic) 0)
      (when (< nargs (- (. mdef num-params) 1))
        (die-at (. (cast *Node call) line)
                (fmt-s "macro: not enough args" (cast i64 0)))))
    (when (= (. mdef variadic) 0)
      (when (!= nargs (. mdef num-params))
        (die-at (. (cast *Node call) line)
                (fmt-s "macro: wrong number of args" (cast i64 0)))))
    ; Build a stack array of Node* args (num-params slots).
    (let (args-arr:ptr (malloc (* (cast i64 (. mdef num-params)) (cast i64 8)))
          regular-params:i32 (. mdef num-params)
          i:i32 0)
      (when (!= (. mdef variadic) 0)
        (set! regular-params (- (. mdef num-params) 1)))
      (while (< i regular-params)
        (aset! (cast *ptr args-arr) i (node-at (cast *Node call) (+ i 1)))
        (inc! i))
      ; Build rest cons list for variadic param, then store in last slot.
      (when (!= (. mdef variadic) 0)
        (let (rest-list:ptr null
              rj:i32 nargs)
          (while (> rj regular-params)
            (set! rj (- rj 1))
            (set! rest-list (make-cell (node-at (cast *Node call) (+ rj 1)) rest-list 0)))
          (aset! (cast *ptr args-arr) regular-params rest-list)))
      ; Look up the JIT function.
      (let (addr:i64 (cast i64 0)
            err:ptr (LLVMOrcLLJITLookup g-jit (addr-of addr) (. mdef jit-name)))
        (when (!= err null)
          (do (fprintf stderr "%s: macro '%s': JIT lookup failed\n"
                       g-source-path (. mdef name))
              (exit 1)))
        (when (= (cast ptr addr) null)
          (do (fprintf stderr "%s: macro '%s': JIT function not found\n"
                       g-source-path (. mdef name))
              (exit 1)))
        ; Call the macro JIT function: ptr fn(ptr args_array)
        (let (result:ptr (funcall-ptr-1 (cast ptr addr) args-arr))
          (free args-arr)
          (when (= result null)
            (do (fprintf stderr "%s: macro '%s': returned null\n"
                         g-source-path (. mdef name))
                (exit 1)))
          (return (emit-node (desugar result) scope)))))))

; ============================================================
; List dispatch
; ============================================================

(defn emit-list:ptr (n:ptr scope:ptr)
  (let (nn:*Node (cast *Node n))
    (when (= (node-len nn) 0) (die-at (. nn line) "empty list"))
    (let (head:*Node (cast *Node (node-at nn 0)))
      (when (!= (. head kind) NODE-SYM)
        (die-at (. head line) "list head must be symbol"))
      (let (h:ptr (. head s))
        ; Check macro table before special forms.
        (let (mi:i32 0)
          (while (< mi g-num-macros)
            (let (mdef:*MacroDef (cast *MacroDef (ptr+ (cast *MacroDef g-macros) mi)))
              (when (= (strcmp (. mdef name) h) 0)
                (return (emit-macro-expand n scope (cast ptr mdef)))))
            (inc! mi)))
        (when (and (= (strcmp h "gensym") 0) (= (node-len nn) 1))
          (let (tmp:ptr (new-tmp))
            (fprintf g-body-stream "  %s = call ptr @nucleus_gensym()\n" tmp)
            (return (alloc-val ty-ptr tmp))))
        (when (= (strcmp h "funcall-ptr-1") 0) (return (emit-funcall-ptr-1 n scope)))
        (when (= (strcmp h "funcall-ptr-i32") 0) (return (emit-funcall-ptr-i32 n scope)))
        (when (= (strcmp h "funcall-ptr-i64") 0) (return (emit-funcall-ptr-i64 n scope)))
        (when (= (strcmp h "funcall-ptr-ptr") 0) (return (emit-funcall-ptr-ptr n scope)))
        (when (= (strcmp h "return") 0) (return (emit-return n scope)))
        (when (= (strcmp h "do") 0) (return (emit-do n scope)))
        (when (= (strcmp h "let") 0) (return (emit-let n scope)))
        (when (= (strcmp h "cond") 0) (return (emit-cond n scope)))
        (when (= (strcmp h "quote") 0) (return (emit-quote n)))
        (when (= (strcmp h "quasiquote") 0) (return (emit-quasiquote n scope)))
        (when (= (strcmp h "while") 0) (return (emit-while n scope)))
        (when (= (strcmp h "set!") 0) (return (emit-set n scope)))
        (when (= (strcmp h "inc!") 0) (return (emit-inc n scope)))
        (when (= (strcmp h "not") 0) (return (emit-not n scope)))
        (when (= (strcmp h "and") 0) (return (emit-short-circuit n scope 1)))
        (when (= (strcmp h "or") 0) (return (emit-short-circuit n scope 0)))
        (when (= (strcmp h "cast") 0) (return (emit-cast n scope)))
        (when (= (strcmp h "addr-of") 0) (return (emit-addr-of n scope)))
        (when (= (strcmp h "funcall-void") 0) (return (emit-funcall-void n scope)))
        (when (= (strcmp h "funcall") 0) (return (emit-funcall n scope)))
        (when (= (strcmp h "deref") 0) (return (emit-deref n scope)))
        (when (= (strcmp h "ptr-set!") 0) (return (emit-ptr-set n scope)))
        (when (= (strcmp h "ptr+") 0) (return (emit-ptr-add n scope)))
        (when (= (strcmp h ".") 0) (return (emit-field-get n scope)))
        (when (= (strcmp h ".set!") 0) (return (emit-field-set n scope)))
        (when (= (strcmp h "sizeof") 0) (return (emit-sizeof n scope)))
        (when (= (strcmp h "alloca") 0) (return (emit-alloca-form n scope)))
        (when (= (strcmp h "char") 0) (return (emit-char n scope)))
        (when (= (strcmp h "aref") 0) (return (emit-aref n scope)))
        (when (= (strcmp h "aset!") 0) (return (emit-aset n scope)))
        (let (op:ptr (lookup-binop h))
          (when (!= op null) (return (emit-binop n scope op)))
          (let (sym:ptr (scope-lookup scope h))
            (when (= sym null)
              (die-at (. head line) (fmt-s "unknown: %s" h)))
            (return (emit-call n scope sym))))))))

; ============================================================
; Top-level forms
; ============================================================

(defn emit-defvar:void (call:ptr)
  (let (cc:*Node (cast *Node call))
    (when (or (< (node-len cc) 2) (> (node-len cc) 3))
      (die-at (. cc line) "defvar: expects name and optional init"))
    (let (name-node:ptr (node-at cc 1))
      (let (name:ptr null
            type-name:ptr null)
        (extract-name-type name-node (cast *ptr (addr-of name))
                                     (cast *ptr (addr-of type-name)))
        (when (= type-name null)
          (die-at (. (cast *Node name-node) line) (fmt-s "defvar: missing :type on '%s'" name)))
        (let (ty:ptr (parse-type-name type-name (. (cast *Node name-node) line))
              ir-name:ptr (fmt-s "@%s" name)
              align:i32 (type-size ty))
          (if (= (node-len cc) 3)
            (let (init:*Node (cast *Node (node-at cc 2)))
              (when (!= (. init kind) NODE-INT)
                (die-at (. init line) "defvar: init must be integer literal"))
              (fprintf g-out "%s = global %s %ld, align %d\n\n"
                ir-name (type-to-ir ty) (. init i) align))
            (let (zero:ptr "0")
              (when (= (. (cast *Type ty) kind) TY-PTR) (set! zero "null"))
              (fprintf g-out "%s = global %s %s, align %d\n\n"
                ir-name (type-to-ir ty) zero align)))
          (scope-define g-globals name ty ir-name 1))))))

(defn emit-defconst:void (call:ptr)
  (let (cc:*Node (cast *Node call))
    (when (!= (node-len cc) 3) (die-at (. cc line) "defconst: expects name and value"))
    (let (name:*Node (cast *Node (node-at cc 1))
          val:*Node (cast *Node (node-at cc 2)))
      (when (!= (. name kind) NODE-SYM)
        (die-at (. name line) "defconst: name must be symbol"))
      (when (!= (. val kind) NODE-INT)
        (die-at (. val line) "defconst: value must be integer literal"))
      (let (sym:*Sym (cast *Sym (scope-define g-globals (. name s) ty-i32 null 0)))
        (.set! sym is-const 1)
        (.set! sym const-val (fmt-i64 "%ld" (. val i)))))))

(defn emit-defenum:void (call:ptr)
  (let (cc:*Node (cast *Node call))
    (when (< (node-len cc) 2) (die-at (. cc line) "defenum: missing name"))
    (let (i:i32 2)
      (while (< i (node-len cc))
        (let (name:*Node (cast *Node (node-at cc i)))
          (when (!= (. name kind) NODE-SYM)
            (die-at (. name line) "defenum: value must be symbol"))
          (let (sym:*Sym (cast *Sym (scope-define g-globals (. name s) ty-i32 null 0)))
            (.set! sym is-const 1)
            (.set! sym const-val (fmt-i32 "%d" (- i 2)))))
        (inc! i)))))

(defn emit-defstruct:void (call:ptr)
  (let (cc:*Node (cast *Node call))
    (when (< (node-len cc) 2) (die-at (. cc line) "defstruct: missing name"))
    (let (name-node:*Node (cast *Node (node-at cc 1)))
      (when (!= (. name-node kind) NODE-SYM)
        (die-at (. name-node line) "defstruct: name must be symbol"))
      (let (sd:*StructDef (cast *StructDef (register-struct (. name-node s)))
            nfields:i32 (- (node-len cc) 2))
        (.set! sd field-names (arena-alloc (* (i64 nfields) (i64 8))))
        (.set! sd field-types (arena-alloc (* (i64 nfields) (i64 8))))
        (.set! sd num-fields nfields)
        (let (i:i32 0)
          (while (< i nfields)
            (let (field:ptr (node-at cc (+ i 2))
                  fname:ptr null
                  fty:ptr (extract-name-and-type field (cast *ptr (addr-of fname))
                                                  (. (cast *Node field) line)))
              (when (= fty null)
                (die-at (. (cast *Node field) line) (fmt-s "defstruct: field '%s' missing :type" fname)))
              (aset! (cast *ptr (. sd field-names)) i fname)
              (aset! (cast *ptr (. sd field-types)) i fty))
            (inc! i)))
        (fprintf g-out "%%%s = type { " (. name-node s))
        (let (i:i32 0)
          (while (< i nfields)
            (when (!= i 0) (fprintf g-out ", "))
            (fprintf g-out "%s" (type-to-ir (aref (cast *ptr (. sd field-types)) i)))
            (inc! i)))
        (fprintf g-out " }\n\n")))))

(defn emit-extern:void (call:ptr)
  (let (cc:*Node (cast *Node call))
    (when (!= (node-len cc) 2)
      (die-at (. cc line) "extern: expects name:type"))
    (let (arg1:ptr (node-at cc 1)
          name:ptr null
          type-name:ptr null)
      (extract-name-type arg1
                   (cast *ptr (addr-of name))
                   (cast *ptr (addr-of type-name)))
      (when (= type-name null)
        (die-at (. (cast *Node arg1) line)
          (fmt-s "extern: missing :type on '%s'" name)))
      (let (ty:ptr (parse-type-name type-name (. (cast *Node arg1) line))
            ir-name:ptr (fmt-s "@%s" name))
        (fprintf g-out "%s = external global %s\n\n" ir-name (type-to-ir ty))
        (scope-define g-globals name ty ir-name 1)))))

; ============================================================
; Libc include
; ============================================================

(defn add-libc:void (module:ptr name:ptr ret:i32 p0:i32 p1:i32 p2:i32 p3:i32 np:i32 va:i32)
  (let (d:*LibcDecl (cast *LibcDecl (ptr+ (cast *LibcDecl g-libc) g-num-libc)))
    (.set! d module module)
    (.set! d name name)
    (.set! d ret-kind ret)
    (.set! d p0 p0)
    (.set! d p1 p1)
    (.set! d p2 p2)
    (.set! d p3 p3)
    (.set! d num-params np)
    (.set! d variadic va)
    (inc! g-num-libc)))

(defn kind-to-type:ptr (k:i32)
  (when (= k TY-VOID) (return ty-void))
  (when (= k TY-I8)   (return ty-i8))
  (when (= k TY-I32)  (return ty-i32))
  (when (= k TY-I64)  (return ty-i64))
  (when (= k TY-PTR)  (return ty-ptr))
  (return ty-void))

(defn libc-param-kind:i32 (d:ptr idx:i32)
  (let (dd:*LibcDecl (cast *LibcDecl d))
    (when (= idx 0) (return (. dd p0)))
    (when (= idx 1) (return (. dd p1)))
    (when (= idx 2) (return (. dd p2)))
    (when (= idx 3) (return (. dd p3)))
    (return TY-VOID)))

(defn init-libc:void ()
  (set! g-libc (arena-alloc (* (cast i64 80) (sizeof LibcDecl))))
  ; stdio
  (add-libc "stdio" "printf"   TY-I32  TY-PTR 0 0 0 1 1)
  (add-libc "stdio" "fprintf"  TY-I32  TY-PTR TY-PTR 0 0 2 1)
  (add-libc "stdio" "snprintf" TY-I32  TY-PTR TY-I64 TY-PTR 0 3 1)
  (add-libc "stdio" "fputc"    TY-I32  TY-I32 TY-PTR 0 0 2 0)
  (add-libc "stdio" "fputs"    TY-I32  TY-PTR TY-PTR 0 0 2 0)
  (add-libc "stdio" "fopen"    TY-PTR  TY-PTR TY-PTR 0 0 2 0)
  (add-libc "stdio" "fclose"   TY-I32  TY-PTR 0 0 0 1 0)
  (add-libc "stdio" "fread"    TY-I64  TY-PTR TY-I64 TY-I64 TY-PTR 4 0)
  (add-libc "stdio" "fwrite"   TY-I64  TY-PTR TY-I64 TY-I64 TY-PTR 4 0)
  (add-libc "stdio" "fseek"    TY-I32  TY-PTR TY-I64 TY-I32 0 3 0)
  (add-libc "stdio" "ftell"    TY-I64  TY-PTR 0 0 0 1 0)
  (add-libc "stdio" "rewind"   TY-VOID TY-PTR 0 0 0 1 0)
  (add-libc "stdio" "perror"   TY-VOID TY-PTR 0 0 0 1 0)
  (add-libc "stdio" "open_memstream" TY-PTR TY-PTR TY-PTR 0 0 2 0)
  (add-libc "stdio" "fflush"        TY-I32 TY-PTR 0 0 0 1 0)
  (add-libc "stdio" "fgets"         TY-PTR TY-PTR TY-I32 TY-PTR 0 3 0)
  ; popen/pclose provided via lib/cparse-ffi.nuch import
  ; stdlib
  (add-libc "stdlib" "malloc"  TY-PTR  TY-I64 0 0 0 1 0)
  (add-libc "stdlib" "realloc" TY-PTR  TY-PTR TY-I64 0 0 2 0)
  (add-libc "stdlib" "free"    TY-VOID TY-PTR 0 0 0 1 0)
  (add-libc "stdlib" "exit"    TY-VOID TY-I32 0 0 0 1 0)
  (add-libc "stdlib" "strtol"  TY-I64  TY-PTR TY-PTR TY-I32 0 3 0)
  ; string
  (add-libc "string" "memcpy"  TY-PTR  TY-PTR TY-PTR TY-I64 0 3 0)
  (add-libc "string" "memset"  TY-PTR  TY-PTR TY-I32 TY-I64 0 3 0)
  (add-libc "string" "memcmp"  TY-I32  TY-PTR TY-PTR TY-I64 0 3 0)
  (add-libc "string" "strlen"  TY-I64  TY-PTR 0 0 0 1 0)
  (add-libc "string" "strcmp"  TY-I32  TY-PTR TY-PTR 0 0 2 0)
  (add-libc "string" "strncmp" TY-I32  TY-PTR TY-PTR TY-I64 0 3 0)
  (add-libc "string" "strchr"  TY-PTR  TY-PTR TY-I32 0 0 2 0)
  (add-libc "string" "strndup" TY-PTR  TY-PTR TY-I64 0 0 2 0)
  ; ctype
  (add-libc "ctype" "isspace" TY-I32  TY-I32 0 0 0 1 0)
  (add-libc "ctype" "isdigit" TY-I32  TY-I32 0 0 0 1 0)
  ; unistd — POSIX fd helpers for CT stdout redirect
  (add-libc "unistd" "dup"   TY-I32 TY-I32 0 0 0 1 0)
  (add-libc "unistd" "dup2"  TY-I32 TY-I32 TY-I32 0 0 2 0)
  (add-libc "unistd" "close" TY-I32 TY-I32 0 0 0 1 0)
  )

(defn emit-include:void (call:ptr)
  (let (cc:*Node (cast *Node call))
    (when (or (!= (node-len cc) 2) (-> cc (node-at _ 1) (cast *Node _) (. kind) (!= _ NODE-SYM)))
      (die-at (. cc line) "include: expects one symbol"))
    (let (mod:ptr (-> cc (node-at _ 1) (cast *Node _) (. s))
          found:i32 0
          i:i32 0)
      (while (< i g-num-libc)
        (let (d:*LibcDecl (cast *LibcDecl (ptr+ (cast *LibcDecl g-libc) i)))
          (when (= (strcmp (. d module) mod) 0)
            (do
              (set! found 1)
              (let (ft:*Type (cast *Type (make-type TY-FN))
                    j:i32 0)
                (.set! ft ret (kind-to-type (. d ret-kind)))
                (.set! ft num-params (. d num-params))
                (.set! ft params (arena-alloc (* (i64 (. d num-params)) (i64 8))))
                (while (< j (. d num-params))
                  (aset! (cast *ptr (. ft params)) j
                         (kind-to-type (libc-param-kind (cast ptr d) j)))
                  (inc! j))
                (.set! ft variadic (. d variadic))
                (scope-define g-globals (. d name) (cast ptr ft)
                              (fmt-s "@%s" (. d name)) 0)
                (when (= (strcmp (. d name) "malloc") 0)
                  (set! g-malloc-decl-done 1))
                (fprintf g-out "declare %s @%s(" (type-to-ir (. ft ret)) (. d name))
                (set! j 0)
                (while (< j (. d num-params))
                  (when (!= j 0) (fprintf g-out ", "))
                  (fprintf g-out "%s"
                    (type-to-ir (aref (cast *ptr (. ft params)) j)))
                  (inc! j))
                (when (!= (. d variadic) 0)
                  (let (sep:ptr "")
                    (when (!= (. d num-params) 0) (set! sep ", "))
                    (fprintf g-out "%s..." sep)))
                (fprintf g-out ")\n")))))
        (inc! i))
      (when (!= found 0) (fprintf g-out "\n"))
      (when (= found 0)
        (die-at (. cc line) (fmt-s "unknown include: %s" mod))))))

; ============================================================
; C header parsing (clang -E)
; ============================================================

; Skip whitespace in buffer, returning new position.
(defn c-skip-ws:i64 (buf:ptr pos:i64 len:i64)
  (while (and (< pos len) (!= (isspace (cast i32 (char-at buf pos))) 0))
    (set! pos (+ pos (cast i64 1))))
  (return pos))

; Read a C identifier or keyword from buffer. Returns the token as a string.
; Sets out-end to the position after the token.
(defn c-read-ident:ptr (buf:ptr pos:i64 len:i64 out-end:*i64)
  (let (start:i64 pos)
    (while (and (< pos len)
                (or (!= (isdigit (cast i32 (char-at buf pos))) 0)
                    (or (and (>= (cast i32 (char-at buf pos)) 65)
                             (<= (cast i32 (char-at buf pos)) 90))
                        (or (and (>= (cast i32 (char-at buf pos)) 97)
                                 (<= (cast i32 (char-at buf pos)) 122))
                            (= (cast i32 (char-at buf pos)) 95)))))
      (set! pos (+ pos (cast i64 1))))
    (ptr-set! out-end pos)
    (return (arena-strndup (ptr+ (cast *i8 buf) start) (- pos start)))))

; Map a C type name to a Nucleus type.
; Returns the Type* or null if unknown/skipped.
(defn c-type-to-nucleus:ptr (name:ptr is-unsigned:i32 is-long:i32 is-short:i32)
  ; Handle base types
  (when (= (strcmp name "void") 0)  (return ty-void))
  (when (= (strcmp name "_Bool") 0) (return ty-i1))
  (when (= (strcmp name "char") 0)
    (if (!= is-unsigned 0) (return ty-ui8) (return ty-i8)))
  (when (= (strcmp name "short") 0)
    (if (!= is-unsigned 0) (return ty-ui16) (return ty-i16)))
  (when (= (strcmp name "int") 0)
    (do
      (when (!= is-short 0)
        (if (!= is-unsigned 0) (return ty-ui16) (return ty-i16)))
      (when (!= is-long 0)
        (if (!= is-unsigned 0) (return ty-ui64) (return ty-i64)))
      (if (!= is-unsigned 0) (return ty-ui32) (return ty-i32))))
  (when (= (strcmp name "long") 0)
    (if (!= is-unsigned 0) (return ty-ui64) (return ty-i64)))
  ; size_t, ssize_t
  (when (= (strcmp name "size_t") 0) (return ty-ui64))
  (when (= (strcmp name "ssize_t") 0) (return ty-i64))
  ; __gnuc_va_list / va_list — treat as ptr
  (when (= (strcmp name "__gnuc_va_list") 0) (return ty-ptr))
  (when (= (strcmp name "va_list") 0) (return ty-ptr))
  ; FILE* — opaque struct, treated as ptr
  (when (= (strcmp name "FILE") 0) (return ty-ptr))
  ; Fallback: if unknown, return ptr
  (return null))

; Skip balanced parentheses in __attribute__((...)) or similar.
; pos should point to the opening '('. Returns position after the matching ')'.
(defn c-skip-parens:i64 (buf:ptr pos:i64 len:i64)
  (let (depth:i32 0)
    (while (< pos len)
      (when (= (char-at buf pos) 40) (inc! depth))
      (when (= (char-at buf pos) 41)
        (do (set! depth (- depth 1))
            (when (= depth 0)
              (return (+ pos (cast i64 1))))))
      (set! pos (+ pos (cast i64 1))))
    (return pos)))

; Parse a C type from the buffer. Handles qualifiers (const, restrict, volatile,
; unsigned, signed, long, short, struct), pointer stars.
; Returns the Nucleus Type*. Sets out-end to position after the type.
(defn c-parse-type:ptr (buf:ptr pos:i64 len:i64 out-end:*i64)
  (let (is-unsigned:i32 0
        is-long:i32 0
        is-short:i32 0
        base-name:ptr null
        ptr-depth:i32 0
        is-struct:i32 0)
    ; Parse type qualifiers and specifiers
    (let (done:i32 0)
      (while (= done 0)
        (set! pos (c-skip-ws buf pos len))
        (when (>= pos len) (set! done 1) (set! pos len))
        (when (= done 0)
          (let (tok-end:i64 (cast i64 0)
                tok:ptr (c-read-ident buf pos len (cast *i64 (addr-of tok-end))))
            (when (= (strlen tok) (cast i64 0)) (set! done 1))
            (when (= done 0)
              (cond
                (= (strcmp tok "const") 0)      (set! pos tok-end)
                (= (strcmp tok "volatile") 0)   (set! pos tok-end)
                (= (strcmp tok "restrict") 0)   (set! pos tok-end)
                (= (strcmp tok "__restrict") 0) (set! pos tok-end)
                (= (strcmp tok "_Atomic") 0)    (set! pos tok-end)
                (= (strcmp tok "extern") 0)     (set! pos tok-end)
                (= (strcmp tok "static") 0)     (set! pos tok-end)
                (= (strcmp tok "inline") 0)     (set! pos tok-end)
                (= (strcmp tok "__inline") 0)   (set! pos tok-end)
                (= (strcmp tok "__inline__") 0) (set! pos tok-end)
                (= (strcmp tok "__extension__") 0) (set! pos tok-end)
                (= (strcmp tok "unsigned") 0)
                  (do (set! is-unsigned 1) (set! pos tok-end))
                (= (strcmp tok "signed") 0)     (set! pos tok-end)
                (= (strcmp tok "long") 0)
                  (do (set! is-long 1)
                      (set! pos tok-end)
                      ; Check if this is the base type itself (no further type follows)
                      ; by peeking at what comes next
                      (let (peek-pos:i64 (c-skip-ws buf tok-end len)
                            peek-end:i64 (cast i64 0)
                            peek-tok:ptr (c-read-ident buf peek-pos len (cast *i64 (addr-of peek-end))))
                        ; If next token is "long", consume it (long long)
                        (when (= (strcmp peek-tok "long") 0)
                          (set! pos peek-end))
                        ; If next token is "int", that will be consumed as base-name
                        ; If next token is something else or a '*', "long" is the base type
                        (when (and (!= (strcmp peek-tok "int") 0)
                                   (and (!= (strcmp peek-tok "long") 0)
                                        (!= (strcmp peek-tok "char") 0)))
                          (do (set! base-name "long") (set! done 1)))))
                (= (strcmp tok "short") 0)
                  (do (set! is-short 1) (set! pos tok-end))
                (= (strcmp tok "struct") 0)
                  (do (set! is-struct 1) (set! pos tok-end))
                (= (strcmp tok "__attribute__") 0)
                  (do (set! pos (c-skip-ws buf tok-end len))
                      (when (and (< pos len) (= (char-at buf pos) 40))
                        (set! pos (c-skip-parens buf pos len))))
                true
                  (do (set! base-name tok) (set! pos tok-end) (set! done 1))))))))
    ; Count pointer stars
    (set! pos (c-skip-ws buf pos len))
    (while (and (< pos len) (= (char-at buf pos) 42))
      (inc! ptr-depth)
      (set! pos (+ pos (cast i64 1)))
      (set! pos (c-skip-ws buf pos len))
      ; Skip const/restrict after *
      (let (check:i32 1)
        (while (!= check 0)
          (set! check 0)
          (let (te:i64 (cast i64 0)
                t:ptr (c-read-ident buf pos len (cast *i64 (addr-of te))))
            (when (or (= (strcmp t "const") 0)
                      (or (= (strcmp t "restrict") 0)
                          (= (strcmp t "__restrict") 0)))
               (set! pos te)
               (set! pos (c-skip-ws buf pos len))
               (set! check 1))))))
    (ptr-set! out-end pos)
    ; If it's a struct, treat as pointer (opaque)
    (when (!= is-struct 0) (return ty-ptr))
    ; Resolve base type
    (when (= base-name null)
        ; bare "unsigned" or "signed" with no base → int
        (when (or (!= is-unsigned 0) (or (!= is-short 0) (!= is-long 0)))
          (set! base-name "int"))
        (when (= base-name null) (return ty-ptr)))
    (let (base-type:ptr (c-type-to-nucleus base-name is-unsigned is-long is-short))
      (when (= base-type null) (set! base-type ty-ptr))
      ; Apply pointer depth
      (when (> ptr-depth 0) (return ty-ptr))
      (return base-type))))

; Parse one C function declaration from the buffer.
; Expects pos to be at the start of a declaration (after leading whitespace).
; Returns 1 if a function declaration was parsed, 0 otherwise.
; On success, registers the function in g-globals and emits LLVM declare.
(defn c-parse-func-decl:i32 (buf:ptr pos:i64 len:i64 out-end:*i64 line:i32)
  ; Parse the return type
  (let (ret-end:i64 (cast i64 0)
        ret-type:ptr (c-parse-type buf pos len (cast *i64 (addr-of ret-end))))
    (set! pos ret-end)
    (set! pos (c-skip-ws buf pos len))
    ; Read the function name
    (let (name-end:i64 (cast i64 0)
          fname:ptr (c-read-ident buf pos len (cast *i64 (addr-of name-end))))
      (when (= (strlen fname) (cast i64 0))
         (ptr-set! out-end pos) (return 0))
      (set! pos name-end)
      (set! pos (c-skip-ws buf pos len))
      ; Expect '('
      (when (or (>= pos len) (!= (char-at buf pos) 40))
         (ptr-set! out-end pos) (return 0))
      (set! pos (+ pos (cast i64 1)))
      ; Parse parameters
      (let (param-types:ptr (arena-alloc (* (cast i64 16) (cast i64 8)))
            num-params:i32 0
            is-variadic:i32 0
            pdone:i32 0)
        (while (= pdone 0)
          (set! pos (c-skip-ws buf pos len))
          (when (>= pos len) (set! pdone 1))
          (when (= pdone 0)
            ; Check for ')'
            (when (= (char-at buf pos) 41)
               (set! pos (+ pos (cast i64 1))) (set! pdone 1))
            (when (= pdone 0)
              ; Check for '...'
              (when (and (< (+ pos (cast i64 2)) len)
                         (and (= (char-at buf pos) 46)
                              (and (= (char-at buf (+ pos (cast i64 1))) 46)
                                   (= (char-at buf (+ pos (cast i64 2))) 46))))
                 (set! is-variadic 1)
                 (set! pos (+ pos (cast i64 3)))
                 (set! pos (c-skip-ws buf pos len))
                 (when (and (< pos len) (= (char-at buf pos) 41))
                   (set! pos (+ pos (cast i64 1))))
                 (set! pdone 1))
              (when (= pdone 0)
                ; Check for void param (no-arg function)
                (let (void-check-end:i64 (cast i64 0)
                      void-check:ptr (c-read-ident buf pos len (cast *i64 (addr-of void-check-end))))
                  (when (= (strcmp void-check "void") 0)
                    (let (after-void:i64 (c-skip-ws buf void-check-end len))
                      (when (and (< after-void len) (= (char-at buf after-void) 41))
                         (set! pos (+ after-void (cast i64 1)))
                         (set! pdone 1)))))
                (when (= pdone 0)
                  ; Parse parameter type
                  (let (ptype-end:i64 (cast i64 0)
                        ptype:ptr (c-parse-type buf pos len (cast *i64 (addr-of ptype-end))))
                    (set! pos ptype-end)
                    (set! pos (c-skip-ws buf pos len))
                    ; Handle function pointer params: void (*name)(args)
                    (when (and (< pos len) (= (char-at buf pos) 40))
                      (set! pos (c-skip-parens buf pos len))
                      (set! pos (c-skip-ws buf pos len))
                      ; Skip second paren group (arg types)
                      (when (and (< pos len) (= (char-at buf pos) 40))
                        (set! pos (c-skip-parens buf pos len)))
                      (set! ptype ty-ptr))
                    ; Skip parameter name (if present)
                    (when (and (< pos len)
                               (or (and (>= (cast i32 (char-at buf pos)) 65)
                                        (<= (cast i32 (char-at buf pos)) 90))
                                   (or (and (>= (cast i32 (char-at buf pos)) 97)
                                            (<= (cast i32 (char-at buf pos)) 122))
                                       (= (cast i32 (char-at buf pos)) 95))))
                      (let (skip-end:i64 (cast i64 0)
                            skip:ptr (c-read-ident buf pos len (cast *i64 (addr-of skip-end))))
                        (set! pos skip-end)))
                    ; Skip array brackets if present: [N]
                    (set! pos (c-skip-ws buf pos len))
                    (while (and (< pos len) (= (char-at buf pos) 91))
                      (while (and (< pos len) (!= (char-at buf pos) 93))
                        (set! pos (+ pos (cast i64 1))))
                      (when (< pos len) (set! pos (+ pos (cast i64 1))))
                      (set! pos (c-skip-ws buf pos len))
                      (set! ptype ty-ptr))
                    ; Store parameter type
                    (when (< num-params 16)
                      (aset! (cast *ptr param-types) num-params ptype))
                    (inc! num-params)
                    (set! pos (c-skip-ws buf pos len))
                    ; Expect ',' or ')'
                    (when (and (< pos len) (= (char-at buf pos) 44))
                      (set! pos (+ pos (cast i64 1))))))))))
        ; Skip any __attribute__ after closing paren
        (set! pos (c-skip-ws buf pos len))
        (let (attr-check:i32 1)
          (while (!= attr-check 0)
            (set! attr-check 0)
            (let (ae:i64 (cast i64 0)
                  at:ptr (c-read-ident buf pos len (cast *i64 (addr-of ae))))
              (when (= (strcmp at "__attribute__") 0)
                 (set! pos (c-skip-ws buf ae len))
                 (when (and (< pos len) (= (char-at buf pos) 40))
                   (set! pos (c-skip-parens buf pos len)))
                 (set! pos (c-skip-ws buf pos len))
                 (set! attr-check 1))
              (when (= (strcmp at "__asm__") 0)
                 (set! pos (c-skip-ws buf ae len))
                 (when (and (< pos len) (= (char-at buf pos) 40))
                   (set! pos (c-skip-parens buf pos len)))
                 (set! pos (c-skip-ws buf pos len))
                 (set! attr-check 1)))))
        ; Skip semicolon
        (when (and (< pos len) (= (char-at buf pos) 59))
          (set! pos (+ pos (cast i64 1))))
        (ptr-set! out-end pos)
        ; Register the function
        (let (ft:*Type (cast *Type (make-type TY-FN)))
          (.set! ft ret ret-type)
          (.set! ft num-params num-params)
          (.set! ft params (arena-alloc (* (i64 num-params) (i64 8))))
          (let (j:i32 0)
            (while (< j num-params)
              (aset! (cast *ptr (. ft params)) j (aref (cast *ptr param-types) j))
              (inc! j)))
          (.set! ft variadic is-variadic)
          ; Only register if not already defined
          (when (= (scope-lookup g-globals fname) null)
              (scope-define g-globals fname (cast ptr ft)
                            (fmt-s "@%s" fname) 0)
              (when (= (strcmp fname "malloc") 0)
                (set! g-malloc-decl-done 1))
              ; Emit LLVM declare

              (fprintf g-out "declare %s @%s(" (type-to-ir ret-type) fname)
              (let (j:i32 0)
              (while (< j num-params)
                (when (!= j 0) (fprintf g-out ", "))
                (fprintf g-out "%s" (type-to-ir (aref (cast *ptr (. ft params)) j)))
                (inc! j)))
              (when (!= is-variadic 0)
                (let (sep:ptr "")
                  (when (!= num-params 0) (set! sep ", "))
                  (fprintf g-out "%s..." sep)))
              (fprintf g-out ")\n")))
        (return 1)))))

; Read all output from a popen'd command into a malloc'd buffer.
; Returns the buffer (null-terminated). Sets out-len to the length.
(defn read-pipe-output:ptr (cmd:ptr out-len:*i64)
  (let (fp:ptr (popen cmd "r"))
    (when (= fp null) (ptr-set! out-len (cast i64 0)) (return null))
    (let (bufsz:i64 (cast i64 65536)
          buf:ptr (malloc bufsz)
          total:i64 (cast i64 0))
      (let (chunk:i64 (fread (ptr+ (cast *i8 buf) total) (cast i64 1) (- (- bufsz total) (cast i64 1)) fp))
        (set! total (+ total chunk))
        (while (> chunk (cast i64 0))
          (when (>= (+ total (cast i64 1)) bufsz)
             (set! bufsz (* bufsz (cast i64 2)))
             (set! buf (realloc buf bufsz)))
          (set! chunk (fread (ptr+ (cast *i8 buf) total) (cast i64 1) (- (- bufsz total) (cast i64 1)) fp))
          (set! total (+ total chunk))))
      (ptr-set! (cast *i8 (ptr+ (cast *i8 buf) total)) 0)
      (pclose fp)
      (ptr-set! out-len total)
      (return buf))))

; Process a C header file: run clang -E, parse function declarations.
; header-path is e.g. "stdio.h" or "/usr/include/mylib.h".
(defn emit-c-include:void (header-path:ptr line:i32)
  (set! g-out g-decl-stream)
  ; Build clang -E command
  (let (cmd:ptr (alloca i8 512))
    (snprintf cmd (cast i64 512) "clang -E -x c -include %s /dev/null 2>/dev/null" header-path)
    (let (buf-len:i64 (cast i64 0)
          buf:ptr (read-pipe-output cmd (cast *i64 (addr-of buf-len))))
      (when (= buf null)
        (die-at line (fmt-s "c-include: failed to preprocess '%s'" header-path)))
      ; Parse declarations
      (let (pos:i64 (cast i64 0)
            prev-pos:i64 (cast i64 -1))
        (while (< pos buf-len)
          (set! prev-pos pos)
          ; Skip whitespace
          (set! pos (c-skip-ws buf pos buf-len))
          (when (< pos buf-len)
            (if (= (char-at buf pos) 35)
              ; Skip # line directives
              (do (while (and (< pos buf-len) (!= (char-at buf pos) 10))
                    (set! pos (+ pos (cast i64 1))))
                  (when (< pos buf-len)
                    (set! pos (+ pos (cast i64 1)))))
              ; Try to read an identifier to check what kind of declaration
              (let (tok-end:i64 (cast i64 0)
                    tok:ptr (c-read-ident buf pos buf-len (cast *i64 (addr-of tok-end))))
                ; Skip typedefs, static inline functions, etc.
                ; Only process extern declarations and top-level type declarations
                (cond
                  (= (strcmp tok "extern") 0)
                    ; Extern declaration — try to parse as function
                    (let (decl-end:i64 (cast i64 0)
                          ok:i32 (c-parse-func-decl buf pos buf-len
                                                    (cast *i64 (addr-of decl-end)) line))
                      (if (!= ok 0)
                        (set! pos decl-end)
                        (do ; Not a function — skip to semicolon
                         (while (and (< pos buf-len) (!= (char-at buf pos) 59))
                           (set! pos (+ pos (cast i64 1))))
                         (when (< pos buf-len)
                              (set! pos (+ pos (cast i64 1))))))))
                  true
                    ; Skip to semicolon or next line
                    (do (while (and (< pos buf-len)
                                    (and (!= (char-at buf pos) 59)
                                         (!= (char-at buf pos) 10)))
                          ; Skip balanced braces (struct/enum bodies)
                          (when (= (char-at buf pos) 123)
                            (let (brace-depth:i32 1)
                              (set! pos (+ pos (cast i64 1)))
                              (while (and (< pos buf-len) (> brace-depth 0))
                                (when (= (char-at buf pos) 123) (inc! brace-depth))
                                (when (= (char-at buf pos) 125)
                                  (set! brace-depth (- brace-depth 1)))
                                (set! pos (+ pos (cast i64 1))))))
                          (when (and (< pos buf-len)
                                     (and (!= (char-at buf pos) 123)
                                          (and (!= (char-at buf pos) 59)
                                               (!= (char-at buf pos) 10))))
                            (set! pos (+ pos (cast i64 1)))))
                        (when (< pos buf-len)
                          (set! pos (+ pos (cast i64 1))))))))
          ; Safety: if pos didn't advance, force it forward to avoid infinite loop
          (when (= pos prev-pos)
            (set! pos (+ pos (cast i64 1))))))  ; closes when, while
      (free buf))                               ; let(pos) close + free in let(buf-len)
    (fprintf g-out "\n")))                      ; let(cmd), defn



; ============================================================
; defn
; ============================================================

(defn emit-defn:void (call:ptr)
  (let (cc:*Node (cast *Node call))
    (when (< (node-len cc) 4) (die-at (. cc line) "defn: bad form"))
    (let (name-node:ptr (node-at cc 1)
          params-node:ptr (node-at cc 2))
      (when (= (node-is-list params-node) 0)
        (die-at (. (cast *Node name-node) line) "defn: params must be list"))
      (let (fname:ptr null
            ret-name:ptr null)
        (extract-name-type name-node (cast *ptr (addr-of fname))
                                     (cast *ptr (addr-of ret-name)))
        (when (= ret-name null)
          (die-at (. (cast *Node name-node) line) (fmt-s "defn: missing :type on '%s'" fname)))
        (let (ret:ptr (parse-type-name ret-name (. (cast *Node name-node) line))
              nparams:i32 (node-len params-node)
              param-types:ptr null
              param-names:ptr null)
          (when (> nparams 0)
              (set! param-types (arena-alloc (* (i64 nparams) (i64 8))))
              (set! param-names (arena-alloc (* (i64 nparams) (i64 8)))))
          (let (i:i32 0)
            (while (< i nparams)
              (let (p:ptr (node-at params-node i)
                    pname:ptr null
                    pty:ptr (extract-name-and-type p (cast *ptr (addr-of pname))
                                                   (. (cast *Node p) line)))
                (when (= pty null)
                  (die-at (. (cast *Node p) line) (fmt-s "defn: missing :type on param '%s'" pname)))
                (aset! (cast *ptr param-types) i pty)
                (aset! (cast *ptr param-names) i pname))
              (inc! i)))
          ; Register function in globals
          (let (ft:*Type (cast *Type (make-type TY-FN)))
            (.set! ft ret ret)
            (.set! ft num-params nparams)
            (.set! ft params param-types)
            (.set! ft variadic 0)
            (scope-define g-globals fname (cast ptr ft)
                          (fmt-s "@%s" fname) 0))
          ; Codegen
          (reset-function-state)
          (let (fn-scope:ptr (scope-new g-globals)
                i:i32 0)
            (while (< i nparams)
              (let (pname:ptr (aref (cast *ptr param-names) i)
                    ptype:ptr (aref (cast *ptr param-types) i)
                    slot:ptr (fmt-s "%%%s.addr" pname)
                    arg:ptr (fmt-s "%%%s.arg" pname)
                    palign:i32 (type-size ptype))
                (fprintf g-entry-stream "  %s = alloca %s, align %d\n"
                  slot (type-to-ir ptype) palign)
                (fprintf g-entry-stream "  store %s %s, ptr %s, align %d\n"
                  (type-to-ir ptype) arg slot palign)
                (scope-define fn-scope pname ptype slot 1))
              (inc! i))
            (set! i 3)
            (while (< i (node-len cc))
              (emit-node (node-at cc i) fn-scope)
              (inc! i))
            (when (= g-block-term 0)
              (if (= (. (cast *Type ret) kind) TY-VOID)
                (fprintf g-body-stream "  ret void\n")
                (let (zero:ptr "0")
                  (when (= (. (cast *Type ret) kind) TY-PTR) (set! zero "null"))
                  (fprintf g-body-stream "  ret %s %s\n" (type-to-ir ret) zero))))
            ; Close streams and emit function
            (fclose g-entry-stream)
            (fclose g-body-stream)
            (fprintf g-out "define %s @%s(" (type-to-ir ret) fname)
            (set! i 0)
            (while (< i nparams)
              (when (!= i 0) (fprintf g-out ", "))
              (fprintf g-out "%s %%%s.arg"
                (type-to-ir (aref (cast *ptr param-types) i))
                (aref (cast *ptr param-names) i))
              (inc! i))
            (fprintf g-out ") {\n")
            (fprintf g-out "entry:\n")
            (when (and (!= g-entry-bufp null) (!= (char-at g-entry-bufp (cast i64 0)) 0))
              (fputs g-entry-bufp g-out))
            (when (and (!= g-body-bufp null) (!= (char-at g-body-bufp (cast i64 0)) 0))
              (fputs g-body-bufp g-out))
            (fprintf g-out "}\n\n")
            (free g-entry-bufp)
            (free g-body-bufp)
            (set! g-entry-bufp null)
            (set! g-body-bufp null)))))))

; ============================================================
; Compile-time JIT helpers
; ============================================================

(defn jit-ensure-init:void (line:i32)
  (when (!= g-jit null) (return))
  ; Initialize x86 target (expands LLVMInitializeNativeTarget)
  (LLVMInitializeX86TargetInfo)
  (LLVMInitializeX86Target)
  (LLVMInitializeX86TargetMC)
  (LLVMInitializeX86AsmPrinter)
  ; Create LLJIT
  (let (jit-ref:ptr null
        err:ptr (LLVMOrcCreateLLJIT (addr-of jit-ref) null))
    (when (!= err null)
       (fprintf stderr "%s:%d: JIT error in LLVMOrcCreateLLJIT: %s\n"
                   g-source-path line (LLVMGetErrorMessage err))
          (when (!= g-interactive 0) (repl_throw))
          (exit 1))
    (set! g-jit jit-ref))
  (set! g-jit-dylib (LLVMOrcLLJITGetMainJITDylib g-jit))
  ; Expose host process symbols so CT code can call printf, malloc, etc.
  (let (prefix:i8 (LLVMOrcLLJITGetGlobalPrefix g-jit)
        gen:ptr null
        err:ptr (LLVMOrcCreateDynamicLibrarySearchGeneratorForProcess
                   (addr-of gen) prefix null null))
    (when (!= err null)
       (fprintf stderr "%s:%d: JIT error in CreateDynLibSearchGen: %s\n"
                   g-source-path line (LLVMGetErrorMessage err))
          (when (!= g-interactive 0) (repl_throw))
          (exit 1))
    (LLVMOrcJITDylibAddGenerator g-jit-dylib gen)))

(defn jit-add-module:void (ir:ptr line:i32)
  (jit-ensure-init line)
  ; LLVMOrcThreadSafeContextGetContext was removed in LLVM 20+. Create the
  ; parsing context directly. tsctx is only used for ThreadSafeModule locking
  ; which is irrelevant in single-threaded compilation. ctx leaks (fine).
  (let (ctx:ptr (LLVMContextCreate)
        ir-len:i64 (strlen ir)
        mb:ptr (LLVMCreateMemoryBufferWithMemoryRangeCopy ir ir-len "<compile-time>")
        mod:ptr null
        errmsg:ptr null
        parse-err:i32 (LLVMParseIRInContext ctx mb (addr-of mod) (addr-of errmsg)))
    (when (!= parse-err 0)
       (fprintf stderr "%s:%d: compile-time: IR parse error: %s\n"
                   g-source-path line errmsg)
          (when (!= g-interactive 0) (repl_throw))
          (exit 1))
    (let (tsctx:ptr (LLVMOrcCreateNewThreadSafeContext)
          tsmod:ptr (LLVMOrcCreateNewThreadSafeModule mod tsctx))
      (LLVMOrcDisposeThreadSafeContext tsctx)
      (let (err:ptr (LLVMOrcLLJITAddLLVMIRModule g-jit g-jit-dylib tsmod))
        (when (!= err null)
           (fprintf stderr "%s:%d: JIT error in AddLLVMIRModule: %s\n"
                       g-source-path line (LLVMGetErrorMessage err))
              (when (!= g-interactive 0) (repl_throw))
              (exit 1))))))

(defn jit-call-ct-main-sym:void (line:i32 sym:ptr)
  (let (addr:i64 (cast i64 0))
    (let (err:ptr (LLVMOrcLLJITLookup g-jit (cast ptr (addr-of addr)) sym))
      (when (!= err null)
         (LLVMConsumeError err) (return))
      (when (= addr (cast i64 0)) (return))
      ; Redirect stdout -> stderr so CT printf does not corrupt the IR output
      (fflush (cast ptr stdout))
      (let (saved-fd:i32 (dup 1))
        (dup2 2 1)
        (funcall-void (cast ptr addr))
        (fflush (cast ptr stdout))
        (dup2 saved-fd 1)
        (close saved-fd)))))

; ============================================================
; compile-time special form
; ============================================================

(defn emit-compile-time:void (form:ptr)
  ; (compile-time body-form...)
  (let (nforms:i32 (node-len (cast *Node form))
        ff:*Node   (cast *Node form))
    (when (< nforms 2)
      (die-at (. ff line) "compile-time: expected at least one body form"))

    ; Flush the main streams so g-type-bufp / g-decl-bufp are current.
    (fflush g-type-stream)
    (fflush g-decl-stream)

    ; Open fresh CT streams.
    (let (ct-type-bufp:ptr null
          ct-type-sizep:i64 (cast i64 0)
          ct-decl-bufp:ptr null
          ct-decl-sizep:i64 (cast i64 0)
          ct-def-bufp:ptr null
          ct-def-sizep:i64 (cast i64 0)
          ct-type:ptr (open_memstream (addr-of ct-type-bufp) (cast ptr (addr-of ct-type-sizep)))
          ct-decl:ptr (open_memstream (addr-of ct-decl-bufp) (cast ptr (addr-of ct-decl-sizep)))
          ct-def:ptr  (open_memstream (addr-of ct-def-bufp)  (cast ptr (addr-of ct-def-sizep))))

      ; Redirect global state to CT streams.
      (let (saved-g-out:ptr g-out
            saved-decl-out:ptr g-decl-out
            saved-qq-used:i32 g-qq-used)
        (set! g-qq-used 0)
        (set! g-decl-out ct-decl)

        ; Pre-scan: register defn signatures from CT body.
        (let (bi:i32 1)
          (while (< bi nforms)
            (let (bf:*Node (cast *Node (node-at ff bi)))
              (when (and (!= (cast ptr bf) null)
                       (and (= (. bf kind) NODE-CELL)
                            (and (>= (node-len bf) 4)
                                 (and (-> bf (node-at _ 0) (cast *Node _) (. kind) (= _ NODE-SYM))
                                      (-> bf (node-at _ 0) (cast *Node _) (. s) (strcmp _ "defn") (= _ 0))))))
                (let (name-node:ptr (node-at bf 1)
                      params-node:ptr (node-at bf 2))
                  (when (!= (node-is-list params-node) 0)
                    (let (fname:ptr null  ret-name:ptr null)
                      (extract-name-type name-node (cast *ptr (addr-of fname))
                                                   (cast *ptr (addr-of ret-name)))
                      (when (!= ret-name null)
                        (let (ret:ptr (parse-type-name ret-name (. (cast *Node name-node) line))
                              nparams:i32 (node-len params-node)
                              ptypes:ptr null)
                          (when (> nparams 0)
                            (set! ptypes (arena-alloc (* (i64 nparams) (i64 8)))))
                          (let (j:i32 0)
                            (while (< j nparams)
                              (let (p:ptr (node-at params-node j)
                                    pn:ptr null  pt-name:ptr null)
                                (extract-name-type p (cast *ptr (addr-of pn))
                                                     (cast *ptr (addr-of pt-name)))
                                (if (!= pt-name null)
                                  (aset! (cast *ptr ptypes) j (parse-type-name pt-name (. (cast *Node p) line)))
                                  (aset! (cast *ptr ptypes) j ty-i32)))
                              (inc! j)))
                          (let (ft:*Type (cast *Type (make-type TY-FN)))
                            (.set! ft ret ret)
                            (.set! ft num-params nparams)
                            (.set! ft params ptypes)
                            (scope-define g-globals fname (cast ptr ft)
                                          (fmt-s "@%s" fname) 0)))))))))
            (inc! bi)))

        ; Collect expression forms (non-top-level) for __compile_time_main.
        (let (expr-forms:ptr (arena-alloc (* (cast i64 256) (cast i64 8)))
              nexpr:i32 0
              bi:i32 1)
          (while (< bi nforms)
            (let (bf:*Node (cast *Node (node-at ff bi))
                  is-tl:i32 0)
              (when (and (!= (cast ptr bf) null)
                       (and (= (. bf kind) NODE-CELL)
                            (and (!= (node-len bf) 0)
                                 (-> bf (node-at _ 0) (cast *Node _) (. kind) (= _ NODE-SYM)))))
                (let (bh:ptr (-> bf (node-at _ 0) (cast *Node _) (. s)))
                  (when (= (strcmp bh "defstruct") 0)
                     (set! is-tl 1) (set! g-out ct-type) (emit-defstruct (cast ptr bf)))
                  (when (= (strcmp bh "defconst") 0)
                     (set! is-tl 1) (emit-defconst (cast ptr bf)))
                  (when (= (strcmp bh "defenum") 0)
                     (set! is-tl 1) (emit-defenum (cast ptr bf)))
                  (when (= (strcmp bh "defvar") 0)
                     (set! is-tl 1) (set! g-out ct-decl) (emit-defvar (cast ptr bf)))
                  (when (= (strcmp bh "include") 0)
                     (set! is-tl 1) (set! g-out ct-decl) (emit-include (cast ptr bf)))
                  (when (= (strcmp bh "extern") 0)
                     (set! is-tl 1) (set! g-out ct-decl) (emit-extern (cast ptr bf)))
                  (when (= (strcmp bh "defn") 0)
                     (set! is-tl 1) (set! g-out ct-def) (emit-defn (cast ptr bf)))))
              (when (and (= is-tl 0) (< nexpr 256))
                 (aset! (cast *ptr expr-forms) nexpr (cast ptr bf))
                    (inc! nexpr)))
            (inc! bi))

          ; Emit unique @__compile_time_main_N wrapping the expression forms.
          (let (ct-sym:ptr (fmt-i64 "__compile_time_main_%ld" (cast i64 g-ct-id)))
          (inc! g-ct-id)
          (set! g-out ct-def)
          (reset-function-state)
          (let (fn-scope:ptr (scope-new g-globals)
                ei:i32 0)
            (while (< ei nexpr)
              (emit-node (aref (cast *ptr expr-forms) ei) fn-scope)
              (inc! ei)))
          (when (= g-block-term 0)
            (fprintf g-body-stream "  ret void\n"))
          ; Flush streams so bufp pointers are populated
          (fclose g-entry-stream)
          (fclose g-body-stream)
          (fprintf ct-def "define void @%s() {\n" ct-sym)
          (fprintf ct-def "entry:\n")
          (when (and (!= g-entry-bufp null) (!= (char-at g-entry-bufp (cast i64 0)) 0))
            (fputs g-entry-bufp ct-def))
          (when (and (!= g-body-bufp null) (!= (char-at g-body-bufp (cast i64 0)) 0))
            (fputs g-body-bufp ct-def))
          (fprintf ct-def "}\n\n")
          (free g-entry-bufp)
          (free g-body-bufp)
          (set! g-entry-bufp null)
          (set! g-body-bufp null)

          (let (ct-qq:i32 g-qq-used)
            ; Restore global state.
            (set! g-out saved-g-out)
            (set! g-decl-out saved-decl-out)
            (set! g-qq-used saved-qq-used)

            ; If CT used quasiquote, add private helpers.
            (when (!= ct-qq 0)
               (fprintf ct-decl "declare ptr @malloc(i64)\n")
                  (fprintf ct-def "define private ptr @__cons(ptr %%a, ptr %%b) {\n")
                  (fprintf ct-def "  %%c = call ptr @malloc(i64 40)\n")
                  (fprintf ct-def "  %%p0 = getelementptr inbounds { i32, i32, i64, ptr, ptr, ptr }, ptr %%c, i32 0, i32 0\n")
                  (fprintf ct-def "  store i32 3, ptr %%p0, align 8\n")
                  (fprintf ct-def "  %%p4 = getelementptr inbounds { i32, i32, i64, ptr, ptr, ptr }, ptr %%c, i32 0, i32 4\n")
                  (fprintf ct-def "  store ptr %%a, ptr %%p4, align 8\n")
                  (fprintf ct-def "  %%p5 = getelementptr inbounds { i32, i32, i64, ptr, ptr, ptr }, ptr %%c, i32 0, i32 5\n")
                  (fprintf ct-def "  store ptr %%b, ptr %%p5, align 8\n")
                  (fprintf ct-def "  ret ptr %%c\n")
                  (fprintf ct-def "}\n\n")
                  (fprintf ct-def "define private ptr @__append(ptr %%a, ptr %%b) {\n")
                  (fprintf ct-def "entry:\n")
                  (fprintf ct-def "  %%z = icmp eq ptr %%a, null\n")
                  (fprintf ct-def "  br i1 %%z, label %%nil, label %%rec\n")
                  (fprintf ct-def "nil:\n")
                  (fprintf ct-def "  ret ptr %%b\n")
                  (fprintf ct-def "rec:\n")
                  (fprintf ct-def "  %%p4 = getelementptr inbounds { i32, i32, i64, ptr, ptr, ptr }, ptr %%a, i32 0, i32 4\n")
                  (fprintf ct-def "  %%car = load ptr, ptr %%p4, align 8\n")
                  (fprintf ct-def "  %%p5 = getelementptr inbounds { i32, i32, i64, ptr, ptr, ptr }, ptr %%a, i32 0, i32 5\n")
                  (fprintf ct-def "  %%cdr = load ptr, ptr %%p5, align 8\n")
                  (fprintf ct-def "  %%rest = call ptr @__append(ptr %%cdr, ptr %%b)\n")
                  (fprintf ct-def "  %%c = call ptr @__cons(ptr %%car, ptr %%rest)\n")
                  (fprintf ct-def "  ret ptr %%c\n")
                  (fprintf ct-def "}\n\n"))

            (fclose ct-type)
            (fclose ct-decl)
            (fclose ct-def)

            ; Assemble full CT module IR in a memstream.
            (let (ir-bufp:ptr null  ir-sizep:i64 (cast i64 0)
                  irs:ptr (open_memstream (addr-of ir-bufp) (cast ptr (addr-of ir-sizep))))
              (fprintf irs "; ModuleID = '<compile-time>'\n")
              (fprintf irs "target triple = \"x86_64-pc-linux-gnu\"\n\n")
              ; In REPL mode, include the accumulated preamble
              (when (!= g-interactive 0)
                 (fflush g-repl-preamble)
                    (when (and (!= g-repl-preamble-bufp null)
                               (!= (char-at g-repl-preamble-bufp (cast i64 0)) 0))
                      (fputs g-repl-preamble-bufp irs)))
              ; Type defs: main-so-far + CT-specific
              (when (and (!= g-type-bufp null) (!= (char-at g-type-bufp (cast i64 0)) 0))
                (fputs g-type-bufp irs))
              (when (and (!= ct-type-bufp null) (!= (char-at ct-type-bufp (cast i64 0)) 0))
                (fputs ct-type-bufp irs))
              ; String constants (shared)
              (emit-string-table irs)
              ; Declarations: main-so-far + CT-specific
              (when (and (!= g-decl-bufp null) (!= (char-at g-decl-bufp (cast i64 0)) 0))
                (fputs g-decl-bufp irs))
              (when (and (!= ct-decl-bufp null) (!= (char-at ct-decl-bufp (cast i64 0)) 0))
                (fputs ct-decl-bufp irs))
              ; Definitions from CT body + @__compile_time_main
              (when (and (!= ct-def-bufp null) (!= (char-at ct-def-bufp (cast i64 0)) 0))
                (fputs ct-def-bufp irs))
              (fclose irs)

              (jit-add-module ir-bufp (. ff line))
              (jit-call-ct-main-sym (. ff line) ct-sym)

              (free ct-type-bufp)
              (free ct-decl-bufp)
              (free ct-def-bufp)
              (free ir-bufp)))))))))

; ============================================================
; defmacro top-level form
; ============================================================

(defn emit-defmacro:void (form:ptr)
  ; (defmacro name (params...) body...)
  (let (ff:*Node (cast *Node form))
    (when (< (node-len ff) 4)
      (die-at (. ff line) "defmacro: expects name, params, and body"))
    (let (name-node:*Node (cast *Node (node-at ff 1))
          params-node:ptr (node-at ff 2))
      (when (!= (. name-node kind) NODE-SYM)
        (die-at (. name-node line) "defmacro: name must be symbol"))
      (when (= (node-is-list params-node) 0)
        (die-at (. name-node line) "defmacro: params must be a list"))
      (let (macro-name:ptr (. name-node s)
            num-params:i32 (node-len params-node)
            jit-name:ptr (fmt-s "__macro_%s" (sanitize-for-ir macro-name)))
        ; Detect &rest variadic parameter (must be second-to-last in param list).
        (let (variadic:i32 0
              pcount:i32 num-params)
          (let (vi:i32 0)
            (while (< vi num-params)
              (let (vp:*Node (cast *Node (node-at params-node vi)))
                (when (= (strcmp (. vp s) "&rest") 0)
                    (when (!= vi (- num-params 2))
                      (die-at (. vp line) "defmacro: &rest must be second-to-last param"))
                    (set! variadic 1)
                    (set! pcount (- num-params 1))))
              (inc! vi)))
        ; Collect param names, skipping &rest keyword.
        (let (pnames:ptr null
              pi:i32 0
              ai:i32 0)
          (when (> pcount 0)
            (set! pnames (arena-alloc (* (i64 pcount) (i64 8)))))
          (while (< pi num-params)
            (let (p:*Node (cast *Node (node-at params-node pi)))
              (when (!= (. p kind) NODE-SYM)
                (die-at (. p line) "defmacro: param must be a symbol"))
              (when (!= (strcmp (. p s) "&rest") 0)
                  (aset! (cast *ptr pnames) ai (. p s))
                  (inc! ai)))
            (inc! pi))
          ; Register in macro table
          (when (>= g-num-macros 256)
            (die-at (. ff line) "defmacro: macro table full"))
          (let (mdef:*MacroDef (cast *MacroDef (ptr+ (cast *MacroDef g-macros) g-num-macros)))
            (.set! mdef name macro-name)
            (.set! mdef jit-name jit-name)
            (.set! mdef num-params pcount)
            (.set! mdef variadic variadic)
            (inc! g-num-macros))

          ; Flush main streams
          (fflush g-type-stream)
          (fflush g-decl-stream)

          ; Open fresh CT streams
          (let (ct-decl-bufp:ptr null  ct-decl-sizep:i64 (cast i64 0)
                ct-def-bufp:ptr null   ct-def-sizep:i64  (cast i64 0)
                ct-decl:ptr (open_memstream (addr-of ct-decl-bufp) (cast ptr (addr-of ct-decl-sizep)))
                ct-def:ptr  (open_memstream (addr-of ct-def-bufp)  (cast ptr (addr-of ct-def-sizep))))

            ; Redirect global state
            (let (saved-g-out:ptr g-out
                  saved-decl-out:ptr g-decl-out
                  saved-qq-used:i32 g-qq-used)
              (set! g-qq-used 0)
              (set! g-decl-out ct-decl)
              (set! g-out ct-def)

              ; Set up function codegen state
              (reset-function-state)
              (let (fn-scope:ptr (scope-new g-globals))

                ; Entry prologue: alloca for args pointer, then load each param
                (fprintf g-entry-stream "  %%__args.addr = alloca ptr, align 8\n")
                (fprintf g-entry-stream "  store ptr %%__args.arg, ptr %%__args.addr, align 8\n")
                (let (ei:i32 0)
                  (while (< ei pcount)
                    (let (pname:ptr (aref (cast *ptr pnames) ei))
                      (fprintf g-entry-stream "  %%%s.addr = alloca ptr, align 8\n" pname)
                      (fprintf g-entry-stream "  %%__ap%d = load ptr, ptr %%__args.addr, align 8\n" ei)
                      (fprintf g-entry-stream "  %%__ag%d = getelementptr ptr, ptr %%__ap%d, i32 %d\n" ei ei ei)
                      (fprintf g-entry-stream "  %%__av%d = load ptr, ptr %%__ag%d, align 8\n" ei ei)
                      (fprintf g-entry-stream "  store ptr %%__av%d, ptr %%%s.addr, align 8\n" ei pname)
                      (scope-define fn-scope pname ty-ptr (fmt-s "%%%s.addr" pname) 1))
                    (inc! ei)))

                ; Compile body forms; last result is return value
                (let (last-val:ptr "null"
                      bi:i32 3)
                  (while (< bi (node-len ff))
                    (let (bv:*Val (cast *Val (emit-node (node-at ff bi) fn-scope)))
                      (when (and (!= (cast ptr bv) null)
                               (and (!= (. bv val) null)
                                    (-> bv (. type) (cast *Type _) (. kind) (= _ TY-PTR))))
                        (set! last-val (. bv val))))
                    (inc! bi))
                  (fprintf g-body-stream "  ret ptr %s\n" last-val))

                (let (macro-qq:i32 g-qq-used)
                  ; Restore global state
                  (set! g-out saved-g-out)
                  (set! g-decl-out saved-decl-out)
                  (set! g-qq-used saved-qq-used)

                  ; Finalize the function
                  (fclose g-entry-stream)
                  (fclose g-body-stream)
                  (fprintf ct-def "define ptr @%s(ptr %%__args.arg) {\n" jit-name)
                  (fprintf ct-def "entry:\n")
                  (when (and (!= g-entry-bufp null) (!= (char-at g-entry-bufp (cast i64 0)) 0))
                    (fputs g-entry-bufp ct-def))
                  (when (and (!= g-body-bufp null) (!= (char-at g-body-bufp (cast i64 0)) 0))
                    (fputs g-body-bufp ct-def))
                  (fprintf ct-def "}\n\n")
                  (free g-entry-bufp)
                  (free g-body-bufp)
                  (set! g-entry-bufp null)
                  (set! g-body-bufp null)

                  ; Add QQ helpers if needed.
                  ; Only emit malloc declaration if it's not already in g-decl-bufp
                  ; (e.g. from an earlier (include stdlib)).
                  (when (!= macro-qq 0)
                     (when (= g-malloc-decl-done 0)
                          (fprintf ct-decl "declare ptr @malloc(i64)\n"))
                        (fprintf ct-def "define private ptr @__cons(ptr %%a, ptr %%b) {\n")
                        (fprintf ct-def "  %%c = call ptr @malloc(i64 40)\n")
                        (fprintf ct-def "  %%p0 = getelementptr inbounds { i32, i32, i64, ptr, ptr, ptr }, ptr %%c, i32 0, i32 0\n")
                        (fprintf ct-def "  store i32 3, ptr %%p0, align 8\n")
                        (fprintf ct-def "  %%p1 = getelementptr inbounds { i32, i32, i64, ptr, ptr, ptr }, ptr %%c, i32 0, i32 1\n")
                        (fprintf ct-def "  store i32 0, ptr %%p1, align 4\n")
                        (fprintf ct-def "  %%p2 = getelementptr inbounds { i32, i32, i64, ptr, ptr, ptr }, ptr %%c, i32 0, i32 2\n")
                        (fprintf ct-def "  store i64 0, ptr %%p2, align 8\n")
                        (fprintf ct-def "  %%p3 = getelementptr inbounds { i32, i32, i64, ptr, ptr, ptr }, ptr %%c, i32 0, i32 3\n")
                        (fprintf ct-def "  store ptr null, ptr %%p3, align 8\n")
                        (fprintf ct-def "  %%p4 = getelementptr inbounds { i32, i32, i64, ptr, ptr, ptr }, ptr %%c, i32 0, i32 4\n")
                        (fprintf ct-def "  store ptr %%a, ptr %%p4, align 8\n")
                        (fprintf ct-def "  %%p5 = getelementptr inbounds { i32, i32, i64, ptr, ptr, ptr }, ptr %%c, i32 0, i32 5\n")
                        (fprintf ct-def "  store ptr %%b, ptr %%p5, align 8\n")
                        (fprintf ct-def "  ret ptr %%c\n")
                        (fprintf ct-def "}\n\n")
                        (fprintf ct-def "define private ptr @__append(ptr %%a, ptr %%b) {\n")
                        (fprintf ct-def "entry:\n")
                        (fprintf ct-def "  %%z = icmp eq ptr %%a, null\n")
                        (fprintf ct-def "  br i1 %%z, label %%nil, label %%rec\n")
                        (fprintf ct-def "nil:\n")
                        (fprintf ct-def "  ret ptr %%b\n")
                        (fprintf ct-def "rec:\n")
                        (fprintf ct-def "  %%p4 = getelementptr inbounds { i32, i32, i64, ptr, ptr, ptr }, ptr %%a, i32 0, i32 4\n")
                        (fprintf ct-def "  %%car = load ptr, ptr %%p4, align 8\n")
                        (fprintf ct-def "  %%p5 = getelementptr inbounds { i32, i32, i64, ptr, ptr, ptr }, ptr %%a, i32 0, i32 5\n")
                        (fprintf ct-def "  %%cdr = load ptr, ptr %%p5, align 8\n")
                        (fprintf ct-def "  %%rest = call ptr @__append(ptr %%cdr, ptr %%b)\n")
                        (fprintf ct-def "  %%c = call ptr @__cons(ptr %%car, ptr %%rest)\n")
                        (fprintf ct-def "  ret ptr %%c\n")
                        (fprintf ct-def "}\n\n"))

                  ; Always declare nucleus_gensym
                  (fprintf ct-decl "declare ptr @nucleus_gensym()\n")

                  (fclose ct-decl)
                  (fclose ct-def)

                  ; Assemble the macro JIT module IR
                  (let (ir-bufp:ptr null  ir-sizep:i64 (cast i64 0)
                        irs:ptr (open_memstream (addr-of ir-bufp) (cast ptr (addr-of ir-sizep))))
                    (fprintf irs "; ModuleID = '<defmacro %s>'\n" macro-name)
                    (fprintf irs "target triple = \"x86_64-pc-linux-gnu\"\n\n")
                    ; In REPL mode, include the accumulated preamble
                    (when (!= g-interactive 0)
                       (fflush g-repl-preamble)
                          (when (and (!= g-repl-preamble-bufp null)
                                     (!= (char-at g-repl-preamble-bufp (cast i64 0)) 0))
                            (fputs g-repl-preamble-bufp irs)))
                    (when (and (!= g-type-bufp null) (!= (char-at g-type-bufp (cast i64 0)) 0))
                      (fputs g-type-bufp irs))
                    (emit-string-table irs)
                    (when (and (!= g-decl-bufp null) (!= (char-at g-decl-bufp (cast i64 0)) 0))
                      (fputs g-decl-bufp irs))
                    (when (and (!= ct-decl-bufp null) (!= (char-at ct-decl-bufp (cast i64 0)) 0))
                      (fputs ct-decl-bufp irs))
                    (when (and (!= ct-def-bufp null) (!= (char-at ct-def-bufp (cast i64 0)) 0))
                      (fputs ct-def-bufp irs))
                    (fclose irs)
                    (jit-add-module ir-bufp (. ff line))
                    (free ct-decl-bufp)
                    (free ct-def-bufp)
                    (free ir-bufp))))))))))))

; ============================================================
; String table emission
; ============================================================

(defn emit-string-table:void (out:ptr)
  (let (i:i32 0)
    (while (< i g-strs-len)
      (let (sl:*StrLit (cast *StrLit (ptr+ (cast *StrLit g-strs) i))
            ir-len:i32 (+ (. sl len) 1))
        (fprintf out "@.str.%d = private unnamed_addr constant [%d x i8] c\""
          (. sl id) ir-len)
        (let (j:i32 0)
          (while (< j (. sl len))
            (let (c:i32 (char-at (. sl bytes) (i64 j)))
              (if (or (or (= c 92) (= c 34))
                    (or (< c 32) (>= c 127)))
                (fprintf out "\\%02X" c)
                (fputc c out)))
            (inc! j)))
        (fprintf out "\\00\", align 1\n"))
      (inc! i)))
  (when (!= g-strs-len 0) (fputc 10 out)))

; ============================================================
; Driver
; ============================================================

(defn read-file:ptr (path:ptr)
  (let (f:ptr (fopen path "rb"))
    (when (= f null) (perror path) (exit 1))
    (when (!= (fseek f (cast i64 0) 2) 0) (perror "fseek") (exit 1))
    (let (sz:i64 (ftell f))
      (when (< sz (cast i64 0)) (perror "ftell") (exit 1))
      (rewind f)
      (let (buf:ptr (malloc (+ sz (cast i64 1))))
        (when (= buf null) (perror "malloc") (exit 1))
        (let (nr:i64 (fread buf (cast i64 1) sz f))
          (aset! (cast *i8 buf) nr (cast i8 0))
          (fclose f)
          (return buf))))))

; ============================================================
; Desugar pass — split colon-typed symbols into lists
; ============================================================

; Split a symbol string containing : into a list of symbol nodes.
; "foo:int" → (foo int),  "bar:ptr:fn:Sym" → (bar ptr fn Sym)
(defn desugar-symbol:ptr (sym:ptr line:i32)
  (let (s:ptr (. (cast *Node sym) s)
        result:ptr null
        tail:ptr null
        start:i64 (cast i64 0)
        i:i64 (cast i64 0)
        slen:i64 (strlen s))
    (while (<= i slen)
      (when (or (= i slen) (= (char-at s i) 58))
         (let (seg-len:i64 (- i start)
                  seg:ptr (arena-strndup (ptr+ (cast *i8 s) start) seg-len)
                  n:*Node (cast *Node (alloc-node)))
              (.set! n kind NODE-SYM)
              (.set! n line line)
              (.set! n s seg)
              (let (cell:ptr (make-cell (cast ptr n) null line))
                (when (= tail null) (set! result cell))
                (when (!= tail null) (.set! (cast *Node tail) cdr cell))
                (set! tail cell)))
            (set! start (+ i (cast i64 1))))
      (set! i (+ i (cast i64 1))))
    (return result)))

; Desugar a single typed-name node (symbol with :).
; Returns the node unchanged if it has no colon.
(defn desugar-typed:ptr (node:ptr)
  (when (= node null) (return null))
  (let (n:*Node (cast *Node node))
    (when (and (= (. n kind) NODE-SYM) (!= (strchr (. n s) 58) null))
      (return (desugar-symbol node (. n line))))
    (return node)))

; Desugar a parameter list: each element that is a typed symbol gets split.
(defn desugar-params:ptr (params:ptr)
  (when (= params null) (return null))
  (let (n:*Node (cast *Node params))
    (when (!= (. n kind) NODE-CELL) (return params))
    (let (new-car:ptr (desugar-typed (. n car))
          new-cdr:ptr (desugar-params (. n cdr)))
      (when (and (= new-car (. n car)) (= new-cdr (. n cdr)))
        (return params))
      (let (c:*Node (cast *Node (alloc-node)))
        (.set! c kind NODE-CELL)
        (.set! c line (. n line))
        (.set! c car new-car)
        (.set! c cdr new-cdr)
        (return (cast ptr c))))))

; Desugar a let binding list: pairs of (name val) where name may be typed.
(defn desugar-let-bindings:ptr (binds:ptr)
  (when (= binds null) (return null))
  (let (n:*Node (cast *Node binds))
    (when (!= (. n kind) NODE-CELL) (return binds))
    ; Even-indexed children are binding names, odd are values — desugar names only.
    (let (result:ptr null
          tail:ptr null
          cur:ptr binds
          idx:i32 0
          changed:i32 0)
      (while (!= cur null)
        (let (cn:*Node (cast *Node cur)
              elem:ptr (. cn car)
              new-elem:ptr elem)
          (when (= (% idx 2) 0)
            (set! new-elem (desugar-typed elem)))
          (when (!= new-elem elem) (set! changed 1))
          (let (cell:ptr (make-cell new-elem null (. cn line)))
            (when (= tail null) (set! result cell))
            (when (!= tail null) (.set! (cast *Node tail) cdr cell))
            (set! tail cell)))
        (set! cur (. (cast *Node cur) cdr))
        (inc! idx))
      (when (= changed 0) (return binds))
      (return result))))

; Desugar a top-level form list.  Recognises defn, defvar, defstruct,
; extern, declare, and let, and desugars only the binding-position symbols.
; Expression bodies are NOT desugared (they may contain typed symbols from
; macro expansion that should stay as symbols for split-typed in value position).
(defn desugar:ptr (forms:ptr)
  (when (= forms null) (return null))
  (let (n:*Node (cast *Node forms))
    (when (!= (. n kind) NODE-CELL) (return forms))
    (let (new-car:ptr (desugar-form (. n car))
          new-cdr:ptr (desugar (. n cdr)))
      (when (and (= new-car (. n car)) (= new-cdr (. n cdr)))
        (return forms))
      (let (c:*Node (cast *Node (alloc-node)))
        (.set! c kind NODE-CELL)
        (.set! c line (. n line))
        (.set! c car new-car)
        (.set! c cdr new-cdr)
        (return (cast ptr c))))))

; Desugar a single form.  Only touches binding positions of known forms.
(defn desugar-form:ptr (form:ptr)
  (when (= form null) (return null))
  (let (f:*Node (cast *Node form))
    (when (!= (. f kind) NODE-CELL) (return form))
    (when (= (node-len form) 0) (return form))
    (let (head:*Node (cast *Node (node-at form 0)))
      (when (!= (. head kind) NODE-SYM) (return form))
      (let (h:ptr (. head s))
        ; (defn name:type (params...) body...)
        (when (= (strcmp h "defn") 0)
          (when (>= (node-len form) 3)
            (let (new-name:ptr (desugar-typed (node-at form 1))
                  new-params:ptr (desugar-params (node-at form 2)))
              (when (and (= new-name (node-at form 1))
                         (= new-params (node-at form 2)))
                (return form))
              ; Rebuild: (defn new-name new-params body...)
              (return (make-cell (cast ptr head)
                       (make-cell new-name
                         (make-cell new-params
                           (. (cast *Node (. (cast *Node (. f cdr)) cdr)) cdr)
                           (. f line))
                         (. f line))
                       (. f line))))))
        ; (defvar name:type [init])
        (when (= (strcmp h "defvar") 0)
          (when (>= (node-len form) 2)
            (let (new-name:ptr (desugar-typed (node-at form 1)))
              (when (= new-name (node-at form 1)) (return form))
              (return (make-cell (cast ptr head)
                       (make-cell new-name
                         (. (cast *Node (. f cdr)) cdr)
                         (. f line))
                       (. f line))))))
        ; (defstruct name field:type ...)
        (when (= (strcmp h "defstruct") 0)
          (when (>= (node-len form) 2)
            ; Desugar fields (positions 2+)
            (let (new-rest:ptr (desugar-params (. (cast *Node (. f cdr)) cdr)))
              (when (= new-rest (. (cast *Node (. f cdr)) cdr))
                (return form))
              (return (make-cell (cast ptr head)
                       (make-cell (node-at form 1)
                         new-rest
                         (. f line))
                       (. f line))))))
        ; (extern name:type)
        (when (= (strcmp h "extern") 0)
          (when (= (node-len form) 2)
            (let (new-name:ptr (desugar-typed (node-at form 1)))
              (when (= new-name (node-at form 1)) (return form))
              (return (make-cell (cast ptr head)
                       (make-cell new-name null (. f line))
                       (. f line))))))
        ; (declare name:type (params...))
        (when (= (strcmp h "declare") 0)
          (when (>= (node-len form) 2)
            (let (new-name:ptr (desugar-typed (node-at form 1))
                  new-params:ptr null)
              (when (= (node-len form) 3)
                (set! new-params (desugar-params (node-at form 2))))
              (when (and (= new-name (node-at form 1))
                         (or (= (node-len form) 2) (= new-params (node-at form 2))))
                (return form))
              (when (= (node-len form) 3)
                (return (make-cell (cast ptr head)
                         (make-cell new-name
                           (make-cell new-params null (. f line))
                           (. f line))
                         (. f line))))
              (return (make-cell (cast ptr head)
                       (make-cell new-name null (. f line))
                       (. f line))))))
        ; (let (bindings...) body...) — desugar binding names
        (when (= (strcmp h "let") 0)
          (when (>= (node-len form) 2)
            (let (new-binds:ptr (desugar-let-bindings (node-at form 1)))
              (when (= new-binds (node-at form 1)) (return form))
              (return (make-cell (cast ptr head)
                       (make-cell new-binds
                         (. (cast *Node (. f cdr)) cdr)
                         (. f line))
                       (. f line))))))
        ; Recurse into body of compile-time and do blocks
        (when (or (= (strcmp h "compile-time") 0) (= (strcmp h "do") 0))
          (let (new-body:ptr (desugar (. f cdr)))
            (when (= new-body (. f cdr)) (return form))
            (return (make-cell (cast ptr head) new-body (. f line)))))
        (return form)))))

; Pre-scan a form list and forward-declare all defn signatures in g-globals.
(defn prescan-defn-signatures:void (forms:ptr)
  (let (fc:ptr forms)
    (while (!= fc null)
      (let (f:*Node (cast *Node (. (cast *Node fc) car)))
        (when (and (and (!= (cast ptr f) null) (= (. f kind) NODE-CELL))
                   (and (>= (node-len (cast ptr f)) 4)
                        (and (-> f (node-at _ 0) (cast *Node _) (. kind) (= _ NODE-SYM))
                             (-> f (node-at _ 0) (cast *Node _) (. s) (strcmp _ "defn") (= _ 0)))))
          (let (name-node:ptr (node-at (cast ptr f) 1)
                params-node:ptr (node-at (cast ptr f) 2))
            (when (!= (node-is-list params-node) 0)
              (let (fname:ptr null
                    ret-name:ptr null)
                (extract-name-type name-node (cast *ptr (addr-of fname))
                                             (cast *ptr (addr-of ret-name)))
                (when (!= ret-name null)
                  (let (ret:ptr (parse-type-name ret-name (. (cast *Node name-node) line))
                        nparams:i32 (node-len params-node)
                        ptypes:ptr null)
                    (when (> nparams 0)
                      (set! ptypes (arena-alloc (* (i64 nparams) (i64 8)))))
                    (let (j:i32 0)
                      (while (< j nparams)
                        (let (p:ptr (node-at params-node j)
                              pn:ptr null
                              pty:ptr (extract-name-and-type p (cast *ptr (addr-of pn))
                                                              (. (cast *Node p) line)))
                          (if (!= pty null)
                            (aset! (cast *ptr ptypes) j pty)
                            (aset! (cast *ptr ptypes) j ty-i32)))
                        (inc! j)))
                    (let (ft:*Type (cast *Type (make-type TY-FN)))
                      (.set! ft ret ret)
                      (.set! ft num-params nparams)
                      (.set! ft params ptypes)
                      (scope-define g-globals fname (cast ptr ft)
                                    (fmt-s "@%s" fname) 0)))))))))
      (set! fc (. (cast *Node fc) cdr)))))

(defn emit-def-rmacro:void (call:ptr)
  (let (cc:*Node (cast *Node call))
    (when (!= (node-len cc) 3)
      (die-at (. cc line) "def-rmacro: expects (def-rmacro \"prefix\" symbol)"))
    (let (prefix-node:*Node (cast *Node (node-at cc 1))
          sym-node:*Node (cast *Node (node-at cc 2)))
      (when (!= (. prefix-node kind) NODE-STR)
        (die-at (. prefix-node line) "def-rmacro: prefix must be a string"))
      (when (!= (. sym-node kind) NODE-SYM)
        (die-at (. sym-node line) "def-rmacro: wrap symbol must be a symbol"))
      (register-rmacro (. prefix-node s) (. sym-node s)))))

; Emit a list of top-level forms (pre-scan + dispatch loop).
; Used by main and by emit-import for recursive processing.
(defn emit-toplevel-forms:void (forms:ptr)
  (prescan-defn-signatures forms)
  (let (fc:ptr forms)
    (while (!= fc null)
      (let (f:*Node (cast *Node (. (cast *Node fc) car)))
        (when (or (or (= (cast ptr f) null) (!= (. f kind) NODE-CELL))
                (or (= (node-len (cast ptr f)) 0)
                    (-> f (node-at _ 0) (cast *Node _) (. kind) (!= _ NODE-SYM))))
          (die-at (. f line)
                  "top-level form must be a list starting with a symbol"))
        (let (h:ptr (-> f (node-at _ 0) (cast *Node _) (. s)))
          (cond (= (strcmp h "defconst") 0)
                  (emit-defconst (cast ptr f))
                (= (strcmp h "defenum") 0)
                  (emit-defenum (cast ptr f))
                (= (strcmp h "defvar") 0)
                  (do (set! g-out g-decl-stream) (emit-defvar (cast ptr f)))
                (= (strcmp h "defstruct") 0)
                  (do (set! g-out g-type-stream) (emit-defstruct (cast ptr f)))
                (= (strcmp h "include") 0)
                  (do (set! g-out g-decl-stream) (emit-include (cast ptr f)))
                (= (strcmp h "extern") 0)
                  (do (set! g-out g-decl-stream) (emit-extern (cast ptr f)))
                (= (strcmp h "defn") 0)
                  (do (set! g-out g-def-stream) (emit-defn (cast ptr f)))
                (= (strcmp h "compile-time") 0)
                  (emit-compile-time (cast ptr f))
                (= (strcmp h "defmacro") 0)
                  (emit-defmacro (cast ptr f))
                (= (strcmp h "def-rmacro") 0)
                  (emit-def-rmacro (cast ptr f))
                (= (strcmp h "import") 0)
                  (emit-import (cast ptr f))
                (= (strcmp h "declare") 0)
                  (do (set! g-out g-decl-stream) (emit-nuch-declare-import (cast ptr f)))
                true
                  (die-at (. f line) (fmt-s "unknown top-level form: %s" h)))))
      (set! fc (. (cast *Node fc) cdr)))))

; Check if a path is in a Node-based string list.
(defn import-list-has:i32 (list:ptr path:ptr)
  (let (cur:ptr list)
    (while (!= cur null)
      (let (entry:*Node (cast *Node cur))
        (when (= (strcmp (. entry s) path) 0)
          (return 1))
        (set! cur (. entry cdr))))
    (return 0)))

; Push a path onto a Node-based string list, return new head.
(defn import-list-push:ptr (list:ptr path:ptr)
  (let (n:*Node (cast *Node (arena-alloc (sizeof Node))))
    (.set! n kind NODE-STR)
    (.set! n line 0)
    (.set! n i (cast i64 0))
    (.set! n s path)
    (.set! n car null)
    (.set! n cdr list)
    (return (cast ptr n))))

; Remove the head of a Node-based string list, return new head.
(defn import-list-pop:ptr (list:ptr)
  (when (= list null) (return null))
  (return (. (cast *Node list) cdr)))

; Test whether a file exists by attempting to open it.
(defn file-exists:i32 (path:ptr)
  (let (f:ptr (fopen path "r"))
    (when (= f null) (return 0))
    (fclose f)
    (return 1)))

; Try to find a file by name in the import search path.
; Search order: directory of current source file, lib/ relative to cwd.
(defn try-import-path:ptr (filename:ptr)
  ; Try directory of the current source file
  (let (pathlen:i64 (strlen g-source-path)
        last-slash:i64 (cast i64 -1)
        i:i64 (cast i64 0))
    (while (< i pathlen)
      (when (= (char-at g-source-path i) 47)
        (set! last-slash i))
      (set! i (+ i (cast i64 1))))
    (when (>= last-slash (cast i64 0))
      (let (dir:ptr (strndup g-source-path last-slash)
            candidate:ptr (fmt-2s "%s/%s" dir filename))
        (when (!= (file-exists candidate) 0)
          (return candidate)))))
  ; Try lib/ relative to cwd
  (let (candidate:ptr (fmt-s "lib/%s" filename))
    (when (!= (file-exists candidate) 0)
      (return candidate)))
  ; Try -I include paths
  (let (j:i32 0)
    (while (< j g-num-include-paths)
      (let (candidate:ptr (fmt-2s "%s/%s" (aref (cast *ptr g-include-paths) j) filename))
        (when (!= (file-exists candidate) 0)
          (return candidate)))
      (inc! j)))
  (return null))

; Resolve an import name to a .nuc or .nuch file path.
; Tries .nuc first, then .nuch. Returns null if neither found.
(defn resolve-import:ptr (name:ptr line:i32)
  (let (nuc-path:ptr (try-import-path (fmt-s "%s.nuc" name)))
    (when (!= nuc-path null) (return nuc-path)))
  (let (nuch-path:ptr (try-import-path (fmt-s "%s.nuch" name)))
    (when (!= nuch-path null) (return nuch-path)))
  (return null))

; Import a Nucleus source file. Reads, parses, and processes all top-level
; forms from the imported file into the current compilation.
(defn emit-import:void (form:ptr)
  (let (ff:*Node (cast *Node form))
    (when (!= (node-len form) 2)
      (die-at (. ff line) "import: expected (import name)"))
    (let (name-node:*Node (cast *Node (node-at form 1)))
      ; Handle string imports: (import "stdio.h") → C header parsing
      (when (= (. name-node kind) NODE-STR)
        (emit-c-include (. name-node s) (. ff line))
        (return))
      (when (!= (. name-node kind) NODE-SYM)
        (die-at (. ff line) "import: name must be a symbol"))
      (let (name:ptr (. name-node s)
            path:ptr (resolve-import name (. ff line)))
        (when (= path null)
          (die-at (. ff line) (fmt-s "import: cannot find '%s'" name)))
        ; Duplicate guard
        (when (!= (import-list-has g-imported path) 0)
          (return))
        ; Cycle detection
        (when (!= (import-list-has g-importing path) 0)
          (die-at (. ff line) (fmt-s "import: circular import of '%s'" name)))
        ; Save reader state
        (let (save-src:ptr g-src
              save-pos:i64 g-pos
              save-line:i32 g-line
              save-path:ptr g-source-path
              save-peek:ptr g-peek
              save-peek-valid:i32 g-peek-valid)
          ; Push onto importing stack
          (set! g-importing (import-list-push g-importing path))
          ; Read and parse the imported file
          (let (src:ptr (read-file path))
            (set! g-source-path path)
            (set! g-src src)
            (set! g-pos (cast i64 0))
            (set! g-line 1)
            (set! g-peek-valid 0)
            (let (forms:ptr (desugar (read-program))
                  is-nuch:i32 (str-ends-with path ".nuch"))
              ; Process imported forms
              (if (!= is-nuch 0)
                (emit-nuch-import-forms forms)
                (emit-toplevel-forms forms))
              ; Free imported source buffer
              (free src)))
          ; Pop from importing stack, add to imported set
          (set! g-importing (import-list-pop g-importing))
          (set! g-imported (import-list-push g-imported path))
          ; Restore reader state
          (set! g-source-path save-path)
          (set! g-src save-src)
          (set! g-pos save-pos)
          (set! g-line save-line)
          (set! g-peek save-peek)
          (set! g-peek-valid save-peek-valid))))))

; ============================================================
; .nuch header emission
; ============================================================

; ============================================================
; C header emission (--emit-cheader)
; ============================================================

(defn type-name-to-c:ptr (name:ptr)
  (when (= (strcmp name "void") 0)  (return "void"))
  (when (= (strcmp name "i1") 0)    (return "_Bool"))
  (when (= (strcmp name "i8") 0)    (return "int8_t"))
  (when (= (strcmp name "i16") 0)   (return "int16_t"))
  (when (= (strcmp name "i32") 0)   (return "int32_t"))
  (when (= (strcmp name "int") 0)   (return "int32_t"))
  (when (= (strcmp name "i64") 0)   (return "int64_t"))
  (when (= (strcmp name "ui8") 0)   (return "uint8_t"))
  (when (= (strcmp name "ui16") 0)  (return "uint16_t"))
  (when (= (strcmp name "ui32") 0)  (return "uint32_t"))
  (when (= (strcmp name "ui64") 0)  (return "uint64_t"))
  (when (= (strcmp name "ptr") 0)   (return "void*"))
  ; Pointer type: *Foo → struct Foo*
  (when (= (char-at name (cast i64 0)) 42)
    (return (fmt-s "%s*" (type-name-to-c (ptr+ (cast *i8 name) (cast i64 1))))))
  ; Assume struct type
  (return (fmt-s "struct %s" name)))

(defn emit-cheader-defstruct:void (form:ptr)
  (let (name:ptr (. (cast *Node (node-at form 1)) s)
        nfields:i32 (- (node-len form) 2))
    (printf "typedef struct {\n")
    (let (i:i32 0)
      (while (< i nfields)
        (let (field:ptr (node-at form (+ i 2))
              fname:ptr null
              tname:ptr null)
          (extract-name-type field (cast *ptr (addr-of fname)) (cast *ptr (addr-of tname)))
          (when (!= tname null)
            (printf "    %s %s;\n" (type-name-to-c tname) fname)))
        (inc! i)))
    (printf "} %s;\n\n" name)))

(defn emit-cheader-declare:void (form:ptr)
  ; (defn name:rettype (params...) ...)
  (let (name-node:ptr (node-at form 1)
        fname:ptr null
        ret-name:ptr null)
    (extract-name-type name-node (cast *ptr (addr-of fname)) (cast *ptr (addr-of ret-name)))
    (when (= ret-name null) (set! ret-name "void"))
    (printf "%s %s(" (type-name-to-c ret-name) fname)
    (let (params:ptr (node-at form 2)
          n:i32 (node-len params)
          i:i32 0)
      (when (= n 0) (printf "void"))
      (while (< i n)
        (when (!= i 0) (printf ", "))
        (let (p:ptr (node-at params i)
              pname:ptr null
              ptname:ptr null)
          (extract-name-type p (cast *ptr (addr-of pname)) (cast *ptr (addr-of ptname)))
          (if (!= ptname null)
            (printf "%s %s" (type-name-to-c ptname) pname)
            ; Complex type (e.g. function pointer) — emit as void*
            (when (!= pname null)
              (printf "void* %s" pname))))
        (inc! i)))
    (printf ");\n")))

(defn emit-cheader-defconst:void (form:ptr)
  (let (name:ptr (. (cast *Node (node-at form 1)) s)
        val-node:*Node (cast *Node (node-at form 2)))
    (when (= (. val-node kind) NODE-INT)
      (printf "#define %s %ld\n" name (. val-node i)))
    (when (= (. val-node kind) NODE-STR)
      (printf "#define %s \"%s\"\n" name (. val-node s)))))

(defn emit-cheader-defenum:void (form:ptr)
  (let (name:ptr (. (cast *Node (node-at form 1)) s)
        n:i32 (- (node-len form) 2))
    (printf "enum %s {\n" name)
    (let (i:i32 0)
      (while (< i n)
        (let (variant:ptr (. (cast *Node (node-at form (+ i 2))) s))
          (printf "    %s_%s = %d" name variant i)
          (when (< i (- n 1)) (printf ","))
          (printf "\n"))
        (inc! i)))
    (printf "};\n\n")))

(defn emit-cheader-header:void (forms:ptr source-file:ptr)
  (printf "#pragma once\n")
  (printf "#include <stdint.h>\n")
  (printf "#include <stdbool.h>\n\n")
  (printf "/* Generated from %s by nucleusc --emit-cheader */\n\n" source-file)
  (let (fc:ptr forms)
    (while (!= fc null)
      (let (f:*Node (cast *Node (. (cast *Node fc) car)))
        (when (and (and (!= (cast ptr f) null) (= (. f kind) NODE-CELL))
                   (and (> (node-len (cast ptr f)) 0)
                        (-> f (node-at _ 0) (cast *Node _) (. kind) (= _ NODE-SYM))))
          (let (h:ptr (-> f (node-at _ 0) (cast *Node _) (. s)))
            (cond (= (strcmp h "defstruct") 0) (emit-cheader-defstruct (cast ptr f))
                  (= (strcmp h "defn") 0)      (emit-cheader-declare (cast ptr f))
                  (= (strcmp h "defconst") 0)  (emit-cheader-defconst (cast ptr f))
                  (= (strcmp h "defenum") 0)   (emit-cheader-defenum (cast ptr f))
                  true                         0))))
      (set! fc (. (cast *Node fc) cdr)))))

(defn emit-nuch-list:void (form:ptr)
  (let (i:i32 0
        n:i32 (node-len form))
    (while (< i n)
      (when (!= i 0) (fputc 32 (cast ptr stdout)))
      (print-node (node-at form i))
      (inc! i))))

(defn emit-nuch-defstruct:void (form:ptr)
  (printf "(defstruct ")
  (let (i:i32 1
        n:i32 (node-len form))
    (while (< i n)
      (when (!= i 1) (fputc 32 (cast ptr stdout)))
      (print-node (node-at form i))
      (inc! i)))
  (printf ")\n"))

(defn emit-nuch-declare:void (form:ptr)
  (printf "(declare ")
  ; index 1 is name:rettype, index 2 is param list
  (print-node (node-at form 1))
  (printf " (")
  (let (params:ptr (node-at form 2)
        i:i32 0
        n:i32 (node-len params))
    (while (< i n)
      (when (!= i 0) (fputc 32 (cast ptr stdout)))
      (print-node (node-at params i))
      (inc! i)))
  (printf "))\n"))

(defn emit-nuch-defconst:void (form:ptr)
  (printf "(defconst ")
  (print-node (node-at form 1))
  (printf " ")
  (print-node (node-at form 2))
  (printf ")\n"))

(defn emit-nuch-defenum:void (form:ptr)
  (printf "(defenum")
  (let (i:i32 1
        n:i32 (node-len form))
    (while (< i n)
      (fputc 32 (cast ptr stdout))
      (print-node (node-at form i))
      (inc! i)))
  (printf ")\n"))

(defn emit-nuch-defmacro:void (form:ptr)
  (print-node form)
  (printf "\n"))

(defn emit-nuch-header:void (forms:ptr source-file:ptr)
  (printf "; .nuch header for %s\n" source-file)
  (let (fc:ptr forms)
    (while (!= fc null)
      (let (f:*Node (cast *Node (. (cast *Node fc) car)))
        (when (and (and (!= (cast ptr f) null) (= (. f kind) NODE-CELL))
                   (and (> (node-len (cast ptr f)) 0)
                        (-> f (node-at _ 0) (cast *Node _) (. kind) (= _ NODE-SYM))))
          (let (h:ptr (-> f (node-at _ 0) (cast *Node _) (. s)))
            (cond (= (strcmp h "defstruct") 0) (emit-nuch-defstruct (cast ptr f))
                  (= (strcmp h "defn") 0)      (emit-nuch-declare (cast ptr f))
                  (= (strcmp h "defconst") 0)  (emit-nuch-defconst (cast ptr f))
                  (= (strcmp h "defenum") 0)   (emit-nuch-defenum (cast ptr f))
                  (= (strcmp h "defmacro") 0)  (emit-nuch-defmacro (cast ptr f))
                  true                         0))))
      (set! fc (. (cast *Node fc) cdr)))))

; ============================================================
; .nuch import processing
; ============================================================

(defn str-ends-with:i32 (s:ptr suffix:ptr)
  (let (slen:i64 (strlen s)
        suflen:i64 (strlen suffix))
    (when (> suflen slen) (return 0))
    (when (= (strcmp (ptr+ (cast *i8 s) (- slen suflen)) suffix) 0)
      (return 1))
    (return 0)))

(defn emit-nuch-declare-import:void (form:ptr)
  (let (ff:*Node (cast *Node form))
    (when (or (< (node-len form) 2) (> (node-len form) 3))
      (die-at (. ff line) "declare: expected (declare name:rettype (params...))"))
    (let (name-node:ptr (node-at form 1)
          params-node:ptr null)
      (when (= (node-len form) 3)
        (set! params-node (node-at form 2)))
      (let (fname:ptr null
            ret-name:ptr null)
        (extract-name-type name-node (cast *ptr (addr-of fname))
                                     (cast *ptr (addr-of ret-name)))
        (when (= ret-name null)
          (die-at (. (cast *Node name-node) line) (fmt-s "declare: missing :type on '%s'" fname)))
        ; Skip if already defined (e.g. from init-libc)
        (when (!= (scope-lookup g-globals fname) null) (return))
        (let (ret:ptr (parse-type-name ret-name (. (cast *Node name-node) line))
              nparams:i32 0
              ptypes:ptr null
              j:i32 0)
          (when (!= params-node null)
            (set! nparams (node-len params-node)))
          (when (> nparams 0)
            (set! ptypes (arena-alloc (* (i64 nparams) (i64 8)))))
          (while (< j nparams)
            (let (p:ptr (node-at params-node j)
                  pn:ptr null
                  pt-name:ptr null)
              (extract-name-type p (cast *ptr (addr-of pn))
                                   (cast *ptr (addr-of pt-name)))
              (if (!= pt-name null)
                (aset! (cast *ptr ptypes) j
                       (parse-type-name pt-name (. (cast *Node p) line)))
                (aset! (cast *ptr ptypes) j ty-i32)))
            (inc! j))
          (let (ft:*Type (cast *Type (make-type TY-FN)))
            (.set! ft ret ret)
            (.set! ft num-params nparams)
            (.set! ft params ptypes)
            (.set! ft variadic 0)
            (scope-define g-globals fname (cast ptr ft)
                          (fmt-s "@%s" fname) 0)
            ; Emit LLVM declare
            (fprintf g-out "declare %s @%s(" (type-to-ir ret) fname)
            (set! j 0)
            (while (< j nparams)
              (when (!= j 0) (fprintf g-out ", "))
              (fprintf g-out "%s"
                (type-to-ir (aref (cast *ptr ptypes) j)))
              (inc! j))
            (fprintf g-out ")\n")))))))

(defn emit-nuch-import-forms:void (forms:ptr)
  (let (fc:ptr forms)
    (while (!= fc null)
      (let (f:*Node (cast *Node (. (cast *Node fc) car)))
        (when (and (and (!= (cast ptr f) null) (= (. f kind) NODE-CELL))
                   (and (> (node-len (cast ptr f)) 0)
                        (-> f (node-at _ 0) (cast *Node _) (. kind) (= _ NODE-SYM))))
          (let (h:ptr (-> f (node-at _ 0) (cast *Node _) (. s)))
            (cond (= (strcmp h "defstruct") 0)
                    (do (set! g-out g-type-stream) (emit-defstruct (cast ptr f)))
                  (= (strcmp h "declare") 0)
                    (do (set! g-out g-decl-stream) (emit-nuch-declare-import (cast ptr f)))
                  (= (strcmp h "defconst") 0)
                    (emit-defconst (cast ptr f))
                  (= (strcmp h "defenum") 0)
                    (emit-defenum (cast ptr f))
                  (= (strcmp h "defmacro") 0)
                    (emit-defmacro (cast ptr f))
                  (= (strcmp h "def-rmacro") 0)
                    (emit-def-rmacro (cast ptr f))
                  true
                    0))))
      (set! fc (. (cast *Node fc) cdr)))))

; ============================================================
; Compiler initialization — shared by batch and REPL modes
; ============================================================

(defn register-rmacro:void (prefix:ptr wrap-sym:ptr)
  (let (rm:*RMacro (cast *RMacro (ptr+ (cast *RMacro g-rmacros) g-num-rmacros)))
    (.set! rm prefix prefix)
    (.set! rm prefix-len (cast i32 (strlen prefix)))
    (.set! rm wrap-sym wrap-sym))
  (inc! g-num-rmacros))

(defn init-rmacros:void ()
  (set! g-rmacros (arena-alloc (* (cast i64 64) (sizeof RMacro))))
  ; Register longest prefixes first for correct matching.
  (register-rmacro "~@" "unquote-splice")
  (register-rmacro "~" "unquote")
  (register-rmacro "'" "quote")
  (register-rmacro "`" "quasiquote")
  (register-rmacro "@" "deref"))

(defn compiler-init:void ()
  (arena-init)
  (types-init)
  (init-binops)
  (init-libc)
  (init-rmacros)
  (set! g-structs (arena-alloc (* (cast i64 MAX-STRUCTS) (sizeof StructDef))))
  (set! g-macros (arena-alloc (* (cast i64 256) (sizeof MacroDef))))
  (set! g-globals (scope-new null)))

; ============================================================
; Emit quasiquote helpers (__cons / __append) into the given streams
; ============================================================

(defn emit-qq-helpers:void (decl:ptr def:ptr)
  (fprintf decl "declare ptr @malloc(i64)\n")
  (fprintf def "define ptr @__cons(ptr %%a, ptr %%b) {\n")
  (fprintf def "  %%c = call ptr @malloc(i64 40)\n")
  (fprintf def "  %%p0 = getelementptr inbounds { i32, i32, i64, ptr, ptr, ptr }, ptr %%c, i32 0, i32 0\n")
  (fprintf def "  store i32 3, ptr %%p0, align 8\n")
  (fprintf def "  %%p1 = getelementptr inbounds { i32, i32, i64, ptr, ptr, ptr }, ptr %%c, i32 0, i32 1\n")
  (fprintf def "  store i32 0, ptr %%p1, align 4\n")
  (fprintf def "  %%p2 = getelementptr inbounds { i32, i32, i64, ptr, ptr, ptr }, ptr %%c, i32 0, i32 2\n")
  (fprintf def "  store i64 0, ptr %%p2, align 8\n")
  (fprintf def "  %%p3 = getelementptr inbounds { i32, i32, i64, ptr, ptr, ptr }, ptr %%c, i32 0, i32 3\n")
  (fprintf def "  store ptr null, ptr %%p3, align 8\n")
  (fprintf def "  %%p4 = getelementptr inbounds { i32, i32, i64, ptr, ptr, ptr }, ptr %%c, i32 0, i32 4\n")
  (fprintf def "  store ptr %%a, ptr %%p4, align 8\n")
  (fprintf def "  %%p5 = getelementptr inbounds { i32, i32, i64, ptr, ptr, ptr }, ptr %%c, i32 0, i32 5\n")
  (fprintf def "  store ptr %%b, ptr %%p5, align 8\n")
  (fprintf def "  ret ptr %%c\n")
  (fprintf def "}\n\n")
  (fprintf def "define ptr @__append(ptr %%a, ptr %%b) {\n")
  (fprintf def "entry:\n")
  (fprintf def "  %%z = icmp eq ptr %%a, null\n")
  (fprintf def "  br i1 %%z, label %%nil, label %%rec\n")
  (fprintf def "nil:\n")
  (fprintf def "  ret ptr %%b\n")
  (fprintf def "rec:\n")
  (fprintf def "  %%p4 = getelementptr inbounds { i32, i32, i64, ptr, ptr, ptr }, ptr %%a, i32 0, i32 4\n")
  (fprintf def "  %%car = load ptr, ptr %%p4, align 8\n")
  (fprintf def "  %%p5 = getelementptr inbounds { i32, i32, i64, ptr, ptr, ptr }, ptr %%a, i32 0, i32 5\n")
  (fprintf def "  %%cdr = load ptr, ptr %%p5, align 8\n")
  (fprintf def "  %%rest = call ptr @__append(ptr %%cdr, ptr %%b)\n")
  (fprintf def "  %%c = call ptr @__cons(ptr %%car, ptr %%rest)\n")
  (fprintf def "  ret ptr %%c\n")
  (fprintf def "}\n\n"))

; ============================================================
; Open fresh memstreams for a compilation unit
; ============================================================

(defn open-module-streams:void ()
  (set! g-type-stream (open_memstream (addr-of g-type-bufp) (cast ptr (addr-of g-type-sizep))))
  (set! g-decl-stream (open_memstream (addr-of g-decl-bufp) (cast ptr (addr-of g-decl-sizep))))
  (set! g-def-stream  (open_memstream (addr-of g-def-bufp)  (cast ptr (addr-of g-def-sizep))))
  (set! g-decl-out g-decl-stream))

; ============================================================
; Close module streams, output IR to stdout (batch mode)
; ============================================================

(defn flush-module-ir:void (source-file:ptr)
  (when (!= g-qq-used 0)
    (emit-qq-helpers g-decl-stream g-def-stream))
  (fclose g-type-stream)
  (fclose g-decl-stream)
  (fclose g-def-stream)
  (printf "; ModuleID = '%s'\n" source-file)
  (printf "source_filename = \"%s\"\n" source-file)
  (printf "target triple = \"x86_64-pc-linux-gnu\"\n\n")
  (when (and (!= g-type-bufp null) (!= (char-at g-type-bufp (cast i64 0)) 0))
    (fputs g-type-bufp (cast ptr stdout)))
  (emit-string-table (cast ptr stdout))
  (when (and (!= g-decl-bufp null) (!= (char-at g-decl-bufp (cast i64 0)) 0))
    (fputs g-decl-bufp (cast ptr stdout)))
  (when (and (!= g-def-bufp null) (!= (char-at g-def-bufp (cast i64 0)) 0))
    (fputs g-def-bufp (cast ptr stdout)))
  (free g-type-bufp)
  (free g-decl-bufp)
  (free g-def-bufp))

; ============================================================
; REPL — interactive Read-Eval-Print Loop
; ============================================================

; Read lines from stdin until parens are balanced, return the accumulated buffer.
; Returns null on EOF.
(defn repl-read-input:ptr ()
  (let (buf:ptr (malloc (cast i64 4096))
        buf-len:i64 (cast i64 0)
        buf-cap:i64 (cast i64 4096)
        depth:i32 0
        got-input:i32 0
        in-string:i32 0
        in-comment:i32 0
        first-line:i32 1)
    (when (= buf null) (perror "malloc") (exit 1))
    (aset! (cast *i8 buf) (cast i64 0) (cast i8 0))
    (let (done:i32 0)
      (while (= done 0)
        ; Print prompt
        (if (!= first-line 0)
          (fprintf stderr "nuc> ")
          (fprintf stderr "...> "))
        (fflush stderr)
        ; Read a line
        (let (line-buf:ptr (malloc (cast i64 4096)))
          (when (= line-buf null) (do (perror "malloc") (exit 1)))
          (when (= (fgets line-buf (cast i32 4096) (cast ptr stdin)) null)
             (free line-buf)
                (if (= got-input 0)
                  (do (free buf) (return null))
                  (set! done 1)))
          (when (= done 0)
            (let (line-len:i64 (strlen line-buf))
              ; Grow buffer if needed
              (when (> (+ buf-len line-len) (- buf-cap (cast i64 1)))
                (let (new-cap:i64 (* buf-cap (cast i64 2)))
                  (while (> (+ buf-len line-len) (- new-cap (cast i64 1)))
                    (set! new-cap (* new-cap (cast i64 2))))
                  (set! buf (realloc buf new-cap))
                  (when (= buf null) (perror "realloc") (exit 1))
                  (set! buf-cap new-cap)))
              (memcpy (ptr+ (cast *i8 buf) buf-len) line-buf line-len)
              (set! buf-len (+ buf-len line-len))
              (aset! (cast *i8 buf) buf-len (cast i8 0))
              (set! got-input 1)
              (set! first-line 0)
              ; Scan the line for paren balance, respecting strings and comments
              (let (li:i64 (cast i64 0))
                (while (< li line-len)
                  (let (c:i32 (bit-and (cast i32 (aref (cast *i8 line-buf) li)) 255))
                    (cond (!= in-comment 0)
                            (when (= c 10) (set! in-comment 0))
                          (!= in-string 0)
                            (cond (= c 92)  ; backslash — skip next char
                                    (set! li (+ li (cast i64 1)))
                                  (= c 34)  ; closing quote
                                    (set! in-string 0)
                                  true (do))
                          (= c 59)  ; semicolon — start comment
                            (set! in-comment 1)
                          (= c 34)  ; opening quote
                            (set! in-string 1)
                          (= c 40)  ; open paren
                            (set! depth (+ depth 1))
                          (= c 41)  ; close paren
                            (set! depth (- depth 1))
                          true (do)))
                  (set! li (+ li (cast i64 1)))))
              (free line-buf)
              ; Done when parens are balanced and we have input
              (when (and (<= depth 0) (!= got-input 0))
                (set! done 1)))))))
    (return buf)))

; Process a single REPL form: parse, compile to IR, JIT, and call.
; Returns the result type kind (TY-VOID, TY-I32, etc.) or -1 on error.
(defn repl-eval-form:void (form:ptr)
  (let (f:*Node (cast *Node form))
    (when (= (cast ptr f) null) (return))
    ; Check if it's a list starting with a known keyword
    (let (h:ptr null
          is-expr:i32 1)
      (when (and (= (. f kind) NODE-CELL)
                 (and (!= (node-len (cast ptr f)) 0)
                      (-> f (node-at _ 0) (cast *Node _) (. kind) (= _ NODE-SYM))))
        (set! h (-> f (node-at _ 0) (cast *Node _) (. s))))
      ; Top-level defining forms
      (cond (and (!= h null) (= (strcmp h "defconst") 0))
              (do (emit-defconst (cast ptr f)) (set! is-expr 0))
            (and (!= h null) (= (strcmp h "defenum") 0))
              (do (emit-defenum (cast ptr f)) (set! is-expr 0))
            (and (!= h null) (= (strcmp h "defvar") 0))
              (do (open-module-streams)
                  (set! g-out g-decl-stream)
                  (emit-defvar (cast ptr f))
                  (repl-jit-module (. f line))
                  ; Add external global reference to preamble AFTER successful JIT
                  (let (var-node:ptr (node-at form 1))
                    (when (!= var-node null)
                      (let (vname:ptr null  vtype-name:ptr null)
                        (extract-name-type var-node (cast *ptr (addr-of vname))
                                                    (cast *ptr (addr-of vtype-name)))
                        (when (!= vtype-name null)
                          (let (vty:ptr (parse-type-name vtype-name (. (cast *Node var-node) line)))
                            (fprintf g-repl-preamble "@%s = external global %s\n"
                              (sanitize-for-ir vname) (type-to-ir vty)))))))
                  (fprintf stderr "  defined\n"))
            (and (!= h null) (= (strcmp h "defstruct") 0))
              (do (open-module-streams)
                  (set! g-out g-type-stream)
                  (emit-defstruct (cast ptr f))
                  ; Append type def to preamble for future modules
                  (fclose g-type-stream) (fclose g-decl-stream) (fclose g-def-stream)
                  (when (and (!= g-type-bufp null) (!= (char-at g-type-bufp (cast i64 0)) 0))
                    (fputs g-type-bufp g-repl-preamble))
                  (free g-type-bufp) (free g-decl-bufp) (free g-def-bufp)
                  (fprintf stderr "  defined\n"))
            (and (!= h null) (= (strcmp h "include") 0))
              (do (open-module-streams)
                  (set! g-out g-decl-stream)
                  (emit-include (cast ptr f))
                  ; Append declarations to preamble for future modules
                  (fclose g-type-stream) (fclose g-decl-stream) (fclose g-def-stream)
                  (when (and (!= g-decl-bufp null) (!= (char-at g-decl-bufp (cast i64 0)) 0))
                    (fputs g-decl-bufp g-repl-preamble))
                  (free g-type-bufp) (free g-decl-bufp) (free g-def-bufp))
            (and (!= h null) (= (strcmp h "extern") 0))
              (do (open-module-streams)
                  (set! g-out g-decl-stream)
                  (emit-extern (cast ptr f))
                  (fclose g-type-stream) (fclose g-decl-stream) (fclose g-def-stream)
                  (when (and (!= g-decl-bufp null) (!= (char-at g-decl-bufp (cast i64 0)) 0))
                    (fputs g-decl-bufp g-repl-preamble))
                  (free g-type-bufp) (free g-decl-bufp) (free g-def-bufp))
            (and (!= h null) (= (strcmp h "defn") 0))
              (do ; Check for redefinition — refuse in REPL (JIT can't redefine symbols)
                  (let (redef:i32 0)
                    (let (name-node:ptr (node-at form 1))
                      (when (!= name-node null)
                        (let (fname:ptr null  ret-name:ptr null)
                          (extract-name-type name-node (cast *ptr (addr-of fname))
                                                       (cast *ptr (addr-of ret-name)))
                          (when (!= (scope-lookup g-globals fname) null)
                            (do (fprintf stderr "  error: cannot redefine '%s' in REPL\n" fname)
                                (set! redef 1))))))
                    (when (= redef 0)
                      (do (open-module-streams)
                          ; Pre-scan for forward declaration
                          (let (one-form:ptr (make-cell form null (. f line)))
                            (prescan-defn-signatures one-form))
                          (set! g-out g-def-stream)
                          (emit-defn (cast ptr f))
                          (when (!= g-qq-used 0)
                            (emit-qq-helpers g-decl-stream g-def-stream))
                          (repl-jit-module (. f line))
                          (set! g-qq-used 0)
                          ; Add function declaration to preamble for future modules
                          (let (name-node2:ptr (node-at form 1))
                            (when (!= name-node2 null)
                              (let (fname2:ptr null  ret-name2:ptr null)
                                (extract-name-type name-node2 (cast *ptr (addr-of fname2))
                                                              (cast *ptr (addr-of ret-name2)))
                                (let (sym:*Sym (cast *Sym (scope-lookup g-globals fname2)))
                                  (when (!= (cast ptr sym) null)
                                    (let (ft:*Type (cast *Type (. sym type)))
                                      (when (= (. ft kind) TY-FN)
                                        (do (fprintf g-repl-preamble "declare %s @%s("
                                              (type-to-ir (. ft ret))
                                              (sanitize-for-ir fname2))
                                            (let (pi:i32 0)
                                              (while (< pi (. ft num-params))
                                                (when (!= pi 0) (fprintf g-repl-preamble ", "))
                                                (fprintf g-repl-preamble "%s"
                                                  (type-to-ir (aref (cast *ptr (. ft params)) pi)))
                                                (inc! pi)))
                                            (when (!= (. ft variadic) 0)
                                              (let (sep:ptr "")
                                                (when (!= (. ft num-params) 0) (set! sep ", "))
                                                (fprintf g-repl-preamble "%s..." sep)))
                                            (fprintf g-repl-preamble ")\n")))))))))
                          (fprintf stderr "  defined\n")))))
            (and (!= h null) (= (strcmp h "compile-time") 0))
              (do (open-module-streams)
                  (emit-compile-time (cast ptr f)))
            (and (!= h null) (= (strcmp h "defmacro") 0))
              (do (emit-defmacro (cast ptr f))
                  (fprintf stderr "  defined\n"))
            (and (!= h null) (= (strcmp h "def-rmacro") 0))
              (do (emit-def-rmacro (cast ptr f))
                  (fprintf stderr "  defined\n"))
            (and (!= h null) (= (strcmp h "import") 0))
              (do (let (pre-len:i32 (. (cast *Scope g-globals) len))
                    (open-module-streams)
                    (emit-import (cast ptr f))
                    ; Append type definitions to preamble before JIT
                    (fflush g-type-stream)
                    (when (and (!= g-type-bufp null) (!= (char-at g-type-bufp (cast i64 0)) 0))
                      (fputs g-type-bufp g-repl-preamble))
                    (repl-jit-module (. f line))
                    ; Add declares for newly imported functions to preamble
                    ; Skip duplicate scope entries (prescan + emit-defn both register)
                    (let (si:i32 pre-len)
                      (while (< si (. (cast *Scope g-globals) len))
                        (let (sym:*Sym (cast *Sym (ptr+ (cast *Sym (. (cast *Scope g-globals) syms)) si))
                              ft:*Type (cast *Type (. sym type)))
                          (when (= (. ft kind) TY-FN)
                            ; Only emit if no later entry has the same name (dedup)
                            (let (is-dup:i32 0
                                  dj:i32 (+ si 1))
                              (while (< dj (. (cast *Scope g-globals) len))
                                (let (nxt:*Sym (cast *Sym (ptr+ (cast *Sym (. (cast *Scope g-globals) syms)) dj)))
                                  (when (= (strcmp (. nxt name) (. sym name)) 0)
                                    (set! is-dup 1)))
                                (inc! dj))
                              (when (= is-dup 0)
                                (do (fprintf g-repl-preamble "declare %s %s("
                                      (type-to-ir (. ft ret))
                                      (. sym ir-name))
                                    (let (pi:i32 0)
                                      (while (< pi (. ft num-params))
                                        (when (!= pi 0) (fprintf g-repl-preamble ", "))
                                        (fprintf g-repl-preamble "%s"
                                          (type-to-ir (aref (cast *ptr (. ft params)) pi)))
                                        (inc! pi)))
                                    (when (!= (. ft variadic) 0)
                                      (let (sep:ptr "")
                                        (when (!= (. ft num-params) 0) (set! sep ", "))
                                        (fprintf g-repl-preamble "%s..." sep)))
                                    (fprintf g-repl-preamble ")\n"))))))
                        (inc! si)))))
            true
              ; Expression — wrap in __repl_eval_N and JIT
              (do (open-module-streams)
                  (let (eval-sym:ptr (fmt-i64 "__repl_eval_%ld" (cast i64 g-repl-id)))
                    (inc! g-repl-id)
                    (set! g-out g-def-stream)
                    (reset-function-state)
                    (let (fn-scope:ptr (scope-new g-globals)
                          result:*Val (cast *Val (emit-node (cast ptr f) fn-scope))
                          result-kind:i32 (. (cast *Type (. result type)) kind))
                      ; Generate the return based on result type
                      (when (= g-block-term 0)
                        (cond (= result-kind TY-VOID)
                                (fprintf g-body-stream "  ret void\n")
                              (or (= result-kind TY-I32) (or (= result-kind TY-I1)
                                  (or (= result-kind TY-I8) (= result-kind TY-I16))))
                                (do (let (ret-val:ptr (. result val))
                                      (when (!= result-kind TY-I32)
                                        (let (ext-tmp:ptr (new-tmp))
                                          (cond (= result-kind TY-I1)
                                                  (fprintf g-body-stream "  %s = zext i1 %s to i32\n"
                                                           ext-tmp (. result val))
                                                (= result-kind TY-I8)
                                                  (fprintf g-body-stream "  %s = sext i8 %s to i32\n"
                                                           ext-tmp (. result val))
                                                (= result-kind TY-I16)
                                                  (fprintf g-body-stream "  %s = sext i16 %s to i32\n"
                                                           ext-tmp (. result val))
                                                true (do))
                                          (set! ret-val ext-tmp)))
                                      (fprintf g-body-stream "  ret i32 %s\n" ret-val)))
                              (= result-kind TY-I64)
                                (fprintf g-body-stream "  ret i64 %s\n" (. result val))
                              (= result-kind TY-PTR)
                                (fprintf g-body-stream "  ret ptr %s\n" (. result val))
                              true
                                (fprintf g-body-stream "  ret void\n")))
                      ; Build function definition
                      (fclose g-entry-stream)
                      (fclose g-body-stream)
                      (let (ret-ir:ptr "void")
                        (when (or (= result-kind TY-I32) (or (= result-kind TY-I1)
                                  (or (= result-kind TY-I8) (= result-kind TY-I16))))
                          (set! ret-ir "i32"))
                        (when (= result-kind TY-I64) (set! ret-ir "i64"))
                        (when (= result-kind TY-PTR) (set! ret-ir "ptr"))
                        (fprintf g-def-stream "define %s @%s() {\n" ret-ir eval-sym)
                        (fprintf g-def-stream "entry:\n")
                        (when (and (!= g-entry-bufp null) (!= (char-at g-entry-bufp (cast i64 0)) 0))
                          (fputs g-entry-bufp g-def-stream))
                        (when (and (!= g-body-bufp null) (!= (char-at g-body-bufp (cast i64 0)) 0))
                          (fputs g-body-bufp g-def-stream))
                        (fprintf g-def-stream "}\n\n")
                        (free g-entry-bufp)
                        (free g-body-bufp)
                        (set! g-entry-bufp null)
                        (set! g-body-bufp null)
                        ; Build and JIT module
                        (when (!= g-qq-used 0)
                          (emit-qq-helpers g-decl-stream g-def-stream))
                        (repl-jit-module (. f line))
                        (set! g-qq-used 0)
                        ; Look up and call the eval function
                        (let (addr:i64 (cast i64 0))
                          (let (err:ptr (LLVMOrcLLJITLookup g-jit (cast ptr (addr-of addr)) eval-sym))
                            (when (!= err null)
                              (do (fprintf stderr "  JIT lookup error: %s\n" (LLVMGetErrorMessage err))
                                  (return)))
                            (when (!= addr (cast i64 0))
                              ; Call and print result based on type
                              (cond (or (= result-kind TY-I32) (or (= result-kind TY-I1)
                                       (or (= result-kind TY-I8) (= result-kind TY-I16))))
                                      (let (fn:ptr (cast ptr addr)
                                            rv:i32 (funcall-ptr-i32 fn))
                                        (fprintf stderr "  %d\n" rv))
                                    (= result-kind TY-I64)
                                      (let (fn:ptr (cast ptr addr)
                                            rv:i64 (funcall-ptr-i64 fn))
                                        (fprintf stderr "  %ld\n" rv))
                                    (= result-kind TY-PTR)
                                      (let (fn:ptr (cast ptr addr)
                                            rv:ptr (funcall-ptr-ptr fn))
                                        (if (!= rv null)
                                          (fprintf stderr "  %p\n" rv)
                                          (fprintf stderr "  null\n")))
                                    (= result-kind TY-VOID)
                                      (do)
                                    true
                                      (do)))))))))))))

; Build a JIT module from the current module streams and add it to the JIT.
; Includes the REPL preamble (accumulated declarations/types) in the module.
(defn repl-jit-module:void (line:i32)
  (fflush g-type-stream)
  (fflush g-decl-stream)
  (fflush g-def-stream)
  (fclose g-type-stream)
  (fclose g-decl-stream)
  (fclose g-def-stream)
  (let (ir-bufp:ptr null  ir-sizep:i64 (cast i64 0)
        irs:ptr (open_memstream (addr-of ir-bufp) (cast ptr (addr-of ir-sizep))))
    (fprintf irs "; ModuleID = '<repl>'\n")
    (fprintf irs "target triple = \"x86_64-pc-linux-gnu\"\n\n")
    ; Preamble (accumulated types + declarations from includes)
    (fflush g-repl-preamble)
    (when (and (!= g-repl-preamble-bufp null) (!= (char-at g-repl-preamble-bufp (cast i64 0)) 0))
      (fputs g-repl-preamble-bufp irs))
    ; This module's types
    (when (and (!= g-type-bufp null) (!= (char-at g-type-bufp (cast i64 0)) 0))
      (fputs g-type-bufp irs))
    (emit-string-table irs)
    ; This module's declarations
    (when (and (!= g-decl-bufp null) (!= (char-at g-decl-bufp (cast i64 0)) 0))
      (fputs g-decl-bufp irs))
    ; This module's definitions
    (when (and (!= g-def-bufp null) (!= (char-at g-def-bufp (cast i64 0)) 0))
      (fputs g-def-bufp irs))
    (fclose irs)
    (when (and (!= ir-bufp null) (!= (char-at ir-bufp (cast i64 0)) 0))
      (jit-add-module ir-bufp line))
    (free g-type-bufp) (free g-decl-bufp) (free g-def-bufp)
    (free ir-bufp)))

; Pre-include all libc modules into the REPL preamble and global scope.
(defn repl-include-all-libc:void ()
  (let (i:i32 0)
    (while (< i g-num-libc)
      (let (d:*LibcDecl (cast *LibcDecl (ptr+ (cast *LibcDecl g-libc) i)))
        (let (ft:*Type (cast *Type (make-type TY-FN))
              j:i32 0)
          (.set! ft ret (kind-to-type (. d ret-kind)))
          (.set! ft num-params (. d num-params))
          (.set! ft params (arena-alloc (* (i64 (. d num-params)) (i64 8))))
          (while (< j (. d num-params))
            (aset! (cast *ptr (. ft params)) j
                   (kind-to-type (libc-param-kind (cast ptr d) j)))
            (inc! j))
          (.set! ft variadic (. d variadic))
          (scope-define g-globals (. d name) (cast ptr ft)
                        (fmt-s "@%s" (. d name)) 0)
          (when (= (strcmp (. d name) "malloc") 0)
            (set! g-malloc-decl-done 1))
          (fprintf g-repl-preamble "declare %s @%s("
            (type-to-ir (. ft ret)) (. d name))
          (set! j 0)
          (while (< j (. d num-params))
            (when (!= j 0) (fprintf g-repl-preamble ", "))
            (fprintf g-repl-preamble "%s"
              (type-to-ir (aref (cast *ptr (. ft params)) j)))
            (inc! j))
          (when (!= (. d variadic) 0)
            (let (sep:ptr "")
              (when (!= (. d num-params) 0) (set! sep ", "))
              (fprintf g-repl-preamble "%s..." sep)))
          (fprintf g-repl-preamble ")\n")))
      (inc! i))
    (fprintf g-repl-preamble "\n")))

; Pre-register the Node struct and NODE-* constants for macros support in REPL.
(defn repl-register-node:void ()
  ; Register Node struct: kind:i32, line:i32, i:i64, s:ptr, car:ptr, cdr:ptr
  (let (sd:*StructDef (cast *StructDef (register-struct "Node")))
    (.set! sd num-fields 6)
    (.set! sd field-names (arena-alloc (* (cast i64 6) (cast i64 8))))
    (.set! sd field-types (arena-alloc (* (cast i64 6) (cast i64 8))))
    (aset! (cast *ptr (. sd field-names)) 0 "kind")
    (aset! (cast *ptr (. sd field-names)) 1 "line")
    (aset! (cast *ptr (. sd field-names)) 2 "i")
    (aset! (cast *ptr (. sd field-names)) 3 "s")
    (aset! (cast *ptr (. sd field-names)) 4 "car")
    (aset! (cast *ptr (. sd field-names)) 5 "cdr")
    (aset! (cast *ptr (. sd field-types)) 0 ty-i32)
    (aset! (cast *ptr (. sd field-types)) 1 ty-i32)
    (aset! (cast *ptr (. sd field-types)) 2 ty-i64)
    (aset! (cast *ptr (. sd field-types)) 3 ty-ptr)
    (aset! (cast *ptr (. sd field-types)) 4 ty-ptr)
    (aset! (cast *ptr (. sd field-types)) 5 ty-ptr))
  ; Add Node IR type to preamble
  (fprintf g-repl-preamble "%%Node = type { i32, i32, i64, ptr, ptr, ptr }\n\n")
  ; Register NODE-* constants
  (let (sym:*Sym (cast *Sym (scope-define g-globals "NODE-INT" (cast ptr ty-i32) null 0)))
    (.set! sym is-const 1) (.set! sym const-val "0"))
  (let (sym:*Sym (cast *Sym (scope-define g-globals "NODE-STR" (cast ptr ty-i32) null 0)))
    (.set! sym is-const 1) (.set! sym const-val "1"))
  (let (sym:*Sym (cast *Sym (scope-define g-globals "NODE-SYM" (cast ptr ty-i32) null 0)))
    (.set! sym is-const 1) (.set! sym const-val "2"))
  (let (sym:*Sym (cast *Sym (scope-define g-globals "NODE-CELL" (cast ptr ty-i32) null 0)))
    (.set! sym is-const 1) (.set! sym const-val "3")))

; REPL main loop
(defn repl-main:void ()
  (fprintf stderr "Nucleus REPL (type Ctrl-D to exit)\n")
  (set! g-source-path "<repl>")
  (compiler-init)
  ; Initialize preamble stream
  (set! g-repl-preamble (open_memstream (addr-of g-repl-preamble-bufp)
                                         (cast ptr (addr-of g-repl-preamble-sizep))))
  ; Pre-include all libc functions (so they're available without explicit include)
  (repl-include-all-libc)
  ; Pre-register Node struct and constants for macro support
  (repl-register-node)
  (let (running:i32 1)
    (while (!= running 0)
      (let (input:ptr (repl-read-input))
        (when (= input null)
          (fprintf stderr "\n") (set! running 0))
        (when (!= input null)
          (when (!= running 0)
              ; Parse the input
              (set! g-src input)
              (set! g-pos (cast i64 0))
              (set! g-line 1)
              (set! g-peek-valid 0)
              (let (forms:ptr (desugar (read-program)))
                ; Process each form
                (let (fc:ptr forms)
                  (while (!= fc null)
                    (let (f:ptr (. (cast *Node fc) car))
                      (when (!= (repl_try) 0)
                        (fprintf stderr "  error (recovered)\n"))
                      (when (= (repl_try) 0)
                        (repl-eval-form f)))
                    (set! fc (. (cast *Node fc) cdr)))))
              (free input)))))))

; ============================================================
; Main entry point
; ============================================================

(defn add-include-path:void (path:ptr)
  (when (= g-include-paths null)
    (set! g-include-paths (malloc (* (cast i64 64) (cast i64 8)))))
  (aset! (cast *ptr g-include-paths) g-num-include-paths path)
  (inc! g-num-include-paths))

(defn main:int (argc:i32 argv:ptr)
  (let (source-file:ptr null
        i:i32 1)
    (while (< i argc)
      (let (arg:ptr (aref (cast *ptr argv) i))
        (cond (= (strcmp arg "--emit-nuch") 0)
                (set! g-emit-nuch 1)
              (= (strcmp arg "--emit-cheader") 0)
                (set! g-emit-cheader 1)
              (or (= (strcmp arg "-i") 0) (= (strcmp arg "--interactive") 0))
                (set! g-interactive 1)
              (= (strncmp arg "-I" (cast i64 2)) 0)
                (if (> (strlen arg) (cast i64 2))
                  ; -I/path/to/dir (no space)
                  (add-include-path (ptr+ (cast *i8 arg) (cast i64 2)))
                  ; -I /path/to/dir (next arg)
                  (do (inc! i)
                      (when (>= i argc)
                        (do (fprintf stderr "-I requires an argument\n") (return 2)))
                      (add-include-path (aref (cast *ptr argv) i))))
              (= (char-at arg (cast i64 0)) 45)
                (do (fprintf stderr "unknown flag: %s\n" arg) (return 2))
              true
                (if (= source-file null)
                  (set! source-file arg)
                  (do (fprintf stderr "unexpected argument: %s\n" arg) (return 2)))))
      (inc! i))

    ; REPL mode
    (when (!= g-interactive 0)
       (repl-main) (return 0))

    ; Batch mode — require source file
    (when (= source-file null)
       (fprintf stderr "usage: nucleusc [--emit-nuch] [--emit-cheader] [-i] [-I<path>] <file.nuc>\n") (return 2))
    (set! g-source-path source-file)
    (let (src:ptr (read-file source-file))
      (compiler-init)

      ; Lex/parse
      (set! g-src src)
      (set! g-pos (cast i64 0))
      (set! g-line 1)

      (let (forms:ptr (desugar (read-program)))

        ; .nuch header mode — emit declarations and exit
        (when (!= g-emit-nuch 0)
           (emit-nuch-header forms source-file)
              (return 0))

        ; C header mode — emit C declarations and exit
        (when (!= g-emit-cheader 0)
           (emit-cheader-header forms source-file)
              (return 0))

        ; Open module streams and compile
        (open-module-streams)
        (emit-toplevel-forms forms)
        (flush-module-ir source-file)))
    (return 0)))
