(include stdio)
(include stdlib)
(include string)

(defn main:int ()
  (let (s:ptr "hello"
        n:i64 (strlen s))
    (printf "len = %lld\n" n)
    (cond (= (strcmp s "hello") 0)
      (printf "match\n")))
  (with (p:ptr:i32 (cast ptr:i32 (malloc (cast i64 16))))
    (ptr-set! p 42)
    (printf "val = %d\n" (deref p)))
  (return 0))
