; Stage 11 M5 — HashSet literal sugar `#{…}`.
;
; `#{"a" "b" "c"}` expands (in the reader) to a let that stack-allocates a
; (HashSet CStr), runs hashset-init with the default allocator, conj-es (==
; insert) each element, and yields the (ref (HashSet CStr)). The outer `with`
; fires Drop at scope exit.

(include stdio)
(import allocator)
(import coll)
(import iterator)
(import hash)
(import hashset)

(defn main:i32 ()
  (with ((s (ref (HashSet CStr))) #{"a" "b" "c"})
    (printf "count=%llu\n" (cast ui64 (count s)))         ; count=3
    (printf "has-a=%d\n" (contains? s "a"))               ; has-a=1
    (printf "has-b=%d\n" (contains? s "b"))               ; has-b=1
    (printf "has-c=%d\n" (contains? s "c"))               ; has-c=1
    (printf "has-z=%d\n" (contains? s "z")))              ; has-z=0

  ; i32 element set literal; duplicate element is deduplicated by insert.
  (with ((n (ref (HashSet i32))) #{10 20 20 30})
    (printf "ncount=%llu\n" (cast ui64 (count n)))        ; ncount=3
    (printf "has-20=%d\n" (contains? n 20))               ; has-20=1
    (printf "has-99=%d\n" (contains? n 99)))              ; has-99=0

  (printf "done\n")
  (return 0))
