; Test importing a library that defines macros.

(include stdio)

; Simple macro library for testing import.
; Separate from lib/macros.nuc because dotimes/-> require the Node struct.
(import testmacros)

(defn main:int ()
  (my-if (= 1 1)
    (printf "if: true branch\n")
    (printf "if: false branch\n"))
  (my-when (= 2 2)
    (printf "when: condition met\n"))
  (my-unless (= 1 2)
    (printf "unless: condition not met\n"))
  (return 0))
