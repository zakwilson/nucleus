; Struct-ABI interop acceptance test (Nucleus caller -> C callee).
; Mirrors tests/abi/clib.c; output must match tests/abi/expected.out, which
; is produced by an all-C reference build. Exercises:
;   - small INTEGER-class struct passed (pair_sum) and returned (pair_make)
;   - small struct with a float field, INTEGER eightbyte (mixed_get)
;   - >16-byte struct passed byval (big_sum) and returned via sret (big_make)
;
; This file is the acceptance gate for Phase C (ABI lowering). Until Phase C
; lands it prints wrong numbers; it is run via `make abi-test`, NOT wired
; into `make test`, so the green build is preserved meanwhile.

(defstruct Pair  a:int b:int)
(defstruct Mixed i:int f:f32)
(defstruct Big   x:i64 y:i64 z:i64)

(include stdio)

(declare pair_make:Pair  (a:int b:int))
(declare pair_sum:int    (p:Pair))
(declare big_make:Big    (x:i64 y:i64 z:i64))
(declare big_sum:i64     (b:Big))
(declare mixed_get:f64   (m:Mixed))

(defn main:int ()
  (let (p:ptr:Pair (alloca Pair))
    (ptr-set! p (pair_make 3 4))
    (printf "pair_make=%d,%d\n" (. p a) (. p b))
    (printf "pair_sum=%d\n" (pair_sum @p)))
  (let (b:ptr:Big (alloca Big))
    (ptr-set! b (big_make 100 200 300))
    (printf "big_make=%lld,%lld,%lld\n" (. b x) (. b y) (. b z))
    (printf "big_sum=%lld\n" (big_sum @b)))
  (let (m:ptr:Mixed (alloca Mixed))
    (.set! m i 7)
    (.set! m f (cast f32 1.5))
    (printf "mixed_get=%.1f\n" (mixed_get @m)))
  (return 0))
